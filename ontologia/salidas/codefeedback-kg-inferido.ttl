    rdfs:label "Polymorphism"@en,
        "Polimorfismo"@es ;
    owl:sameAs cfr:polimorfismo ;
    skos:closeMatch dbr:Polymorphism_\(computer_science\) ;
    skos:definition "Capacidad de tratar de forma uniforme objetos de distintas clases que comparten interfaz."@es ;
    skos:exactMatch wd:Q3240252 ;
    skos:example """for a in animales:
    print(a.hablar())  # cada clase implementa hablar""" ;
    skos:scopeNote "Python lo logra por duck typing: importa el comportamiento, no el tipo exacto."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:esPrerrequisitoDe cfr:duck_typing,
        cfr:singledispatch ;
    cfkg:perteneceATema cfr:T_poo ;
