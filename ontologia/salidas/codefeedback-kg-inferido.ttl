    rdfs:label "functools.lru_cache"@en,
        "functools.lru_cache"@es ;
    owl:sameAs cfr:lru_cache ;
    skos:definition "Decorador que cachea los resultados de una funcion descartando los menos usados (LRU)."@es ;
    skos:example """from functools import lru_cache
@lru_cache(maxsize=None)
def fib(n):
    return n if n < 2 else fib(n-1) + fib(n-2)""" ;
    skos:related cfr:memoizacion ;
    skos:scopeNote "Acelera funciones puras y deterministas; los argumentos deben ser hashables."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
