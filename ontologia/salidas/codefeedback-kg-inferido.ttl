    rdfs:label "reduce"@en,
        "functools.reduce()"@es ;
    owl:sameAs cfr:reduce_func ;
    skos:definition "Funcion functools.reduce que combina los elementos de un iterable en un unico valor."@es ;
    skos:example """from functools import reduce
reduce(lambda a, b: a*b, [1, 2, 3, 4])  # 24""" ;
    skos:related cfr:filter_func ;
    skos:scopeNote "Aplica una funcion binaria acumulando; para sumas o productos hay alternativas mas claras (sum, math.prod)."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:perteneceATema cfr:T_funcional ;
    cfkg:requierePrerrequisito cfr:funcion,
