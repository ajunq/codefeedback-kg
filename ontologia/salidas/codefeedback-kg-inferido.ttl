cfr:arbol_busqueda_binaria a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:EstructuraDeDatos ;
    rdfs:label "Binary search tree"@en,
        "Arbol de busqueda binaria"@es ;
    owl:sameAs cfr:arbol_busqueda_binaria ;
    skos:broader cfr:arbol_binario ;
    skos:broaderTransitive cfr:arbol_binario ;
    skos:closeMatch dbr:Binary_search_tree ;
    skos:definition "Arbol binario donde el subarbol izquierdo solo contiene valores menores y el derecho, mayores."@es ;
    skos:example """def buscar(nodo, x):
    if nodo is None or nodo.v == x:
        return nodo
    return buscar(nodo.izq if x < nodo.v else nodo.der, x)""" ;
    skos:scopeNote "Permite busqueda, insercion y borrado en O(log n) si esta equilibrado; degenera a O(n) si no."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:perteneceATema cfr:T_algoritmos ;
    cfkg:requierePrerrequisito cfr:arbol_binario,
        cfr:arbol_estr,
        cfr:funcion,
        cfr:recursion ;
    cfkg:tieneComplejidadTemporal "O(log n)"^^xsd:string ;
    cfkg:tieneDificultad 4 .

cfr:composicion a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:Paradigma ;
    rdfs:label "Composition"@en,
        "Composición"@es ;
    owl:sameAs cfr:composicion ;
    skos:definition "Diseno en el que un objeto contiene instancias de otras clases para reutilizar su comportamiento."@es ;
    skos:example """class Motor: ...
class Coche:
    def __init__(self):
        self.motor = Motor()  # composicion""" ;
    skos:related cfr:herencia ;
    skos:scopeNote "Suele preferirse a la herencia ('composicion sobre herencia') por su menor acoplamiento."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:contrastaCon cfr:herencia ;
    cfkg:perteneceATema cfr:T_poo ;
    cfkg:relacionadoConceptualmenteCon cfr:herencia ;
    cfkg:requierePrerrequisito cfr:clase,
        cfr:funcion,
        cfr:objeto ;
    cfkg:tieneDificultad 4 .

cfr:dataclass_field a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:Paradigma ;
    rdfs:label "dataclasses.field"@en,
        "dataclasses.field"@es ;
    owl:sameAs cfr:dataclass_field ;
    skos:broader cfr:dataclass ;
    skos:broaderTransitive cfr:dataclass ;
    skos:definition "Funcion que personaliza un campo de una dataclass, por ejemplo con fabricas por defecto."@es ;
    skos:example """from dataclasses import dataclass, field
@dataclass
class C:
    items: list = field(default_factory=list)""" ;
    skos:scopeNote "Usa default_factory=list para valores mutables por defecto y evitar compartirlos entre instancias."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:perteneceATema cfr:T_tipos ;
    cfkg:requierePrerrequisito cfr:anotaciones_tipo,
        cfr:clase,
        cfr:dataclass,
        cfr:funcion ;
    cfkg:tieneDificultad 3 .

cfr:encadenar_excepciones a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:EstructuraDeControl ;
    rdfs:label "Exception chaining"@en,
        "Encadenar excepciones"@es ;
    owl:sameAs cfr:encadenar_excepciones ;
    skos:broader cfr:jerarquia_excepciones ;
    skos:broaderTransitive cfr:jerarquia_excepciones ;
    skos:definition "Mecanismo (raise ... from ...) que vincula una excepcion con la causa original."@es ;
    skos:example """try:
    int('x')
except ValueError as e:
    raise RuntimeError('dato invalido') from e""" ;
    skos:scopeNote "Preserva la traza completa y aclara el origen del error; from None oculta la causa intencionadamente."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:perteneceATema cfr:T_excepciones ;
    cfkg:requierePrerrequisito cfr:condicional,
        cfr:excepcion,
        cfr:raise_excepcion,
        cfr:tipo_bool ;
    cfkg:tieneDificultad 4 .

cfr:finally_clause a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:EstructuraDeControl ;
    rdfs:label "finally clause"@en,
        "Clausula finally"@es ;
    owl:sameAs cfr:finally_clause ;
    skos:broader cfr:try_except_else ;
    skos:broaderTransitive cfr:try_except_else ;
    skos:definition "Bloque finally que se ejecuta siempre tras un try, haya o no excepcion."@es ;
    skos:example """try:
    f = open('d')
finally:
    print('siempre se ejecuta')""" ;
    skos:scopeNote "Ideal para liberar recursos; se ejecuta incluso si hay return dentro del try."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:perteneceATema cfr:T_excepciones ;
    cfkg:requierePrerrequisito cfr:condicional,
        cfr:excepcion,
        cfr:tipo_bool,
        cfr:try_except_else ;
    cfkg:tieneDificultad 2 .

cfr:frozen_dataclass a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:Paradigma ;
    rdfs:label "Frozen dataclass"@en,
        "Dataclass inmutable"@es ;
    owl:sameAs cfr:frozen_dataclass ;
    skos:broader cfr:dataclass ;
    skos:broaderTransitive cfr:dataclass ;
    skos:definition "Dataclass declarada con frozen=True cuyas instancias son inmutables y hashables."@es ;
    skos:example """from dataclasses import dataclass
@dataclass(frozen=True)
class Punto:
    x: int
    y: int""" ;
    skos:scopeNote "Intentar modificar un campo lanza FrozenInstanceError; util para objetos de valor."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:perteneceATema cfr:T_tipos ;
    cfkg:requierePrerrequisito cfr:anotaciones_tipo,
        cfr:clase,
        cfr:dataclass,
        cfr:funcion ;
    cfkg:tieneDificultad 4 .

cfr:gil a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:PrincipioTransversal ;
    rdfs:label "Global Interpreter Lock"@en,
        "GIL"@es ;
    owl:sameAs cfr:gil ;
    skos:closeMatch dbr:Global_interpreter_lock ;
    skos:definition "Bloqueo global del interprete (GIL) de CPython que permite ejecutar un solo hilo de bytecode a la vez."@es ;
    skos:exactMatch wd:Q5570451 ;
    skos:example """# Los hilos no aceleran calculo puro de CPU por el GIL
import threading""" ;
    skos:related cfr:hilos,
        cfr:multiproceso ;
    skos:scopeNote "Limita el paralelismo real con hilos en tareas de CPU; usa multiprocessing para calculo intensivo."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:esPrerrequisitoDe cfr:concurrent_futures,
        cfr:condicion_carrera,
        cfr:hilos,
        cfr:interbloqueo,
        cfr:lock_threading,
        cfr:multiproceso ;
    cfkg:perteneceATema cfr:T_concurrencia ;
    cfkg:relacionadoConceptualmenteCon cfr:concurrent_futures,
        cfr:condicion_carrera,
        cfr:hilos,
        cfr:interbloqueo,
        cfr:lock_threading,
        cfr:multiproceso ;
    cfkg:tieneDificultad 5 .

cfr:herencia_multiple a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
