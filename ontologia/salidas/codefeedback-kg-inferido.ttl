cfr:async_await a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:EstructuraDeControl ;
    rdfs:label "async/await"@en,
        "async/await"@es ;
    owl:sameAs cfr:async_await ;
    skos:definition "Sintaxis async/await para definir y suspender corrutinas en programacion asincrona."@es ;
    skos:example """import asyncio
async def main():
    await asyncio.sleep(1)
    print('listo')""" ;
    skos:narrower cfr:corrutina ;
    skos:scopeNote "await solo puede usarse dentro de una funcion async def; cede el control al bucle de eventos sin bloquear el hilo."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:esPrerrequisitoDe cfr:async_generator,
        cfr:asyncio_mod,
        cfr:corrutina,
        cfr:event_loop ;
    cfkg:introducidoEnVersion "3.5"^^xsd:string ;
    cfkg:perteneceATema cfr:T_concurrencia ;
    cfkg:relacionadoConceptualmenteCon cfr:async_generator,
        cfr:asyncio_mod,
        cfr:corrutina,
        cfr:event_loop ;
    cfkg:requierePrerrequisito cfr:funcion ;
    cfkg:tieneDificultad 5 .

