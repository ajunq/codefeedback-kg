    rdfs:label "File reading"@en,
        "Lectura de ficheros"@es ;
    owl:sameAs cfr:leer_fichero ;
    skos:definition "Lectura del contenido de un fichero con metodos como read(), readline() o iterando lineas."@es ;
    skos:example """with open('d.txt', encoding='utf-8') as f:
    for linea in f:
        print(linea.rstrip())""" ;
    skos:scopeNote "Iterar el objeto de fichero linea a linea es eficiente en memoria para ficheros grandes."@es ;
