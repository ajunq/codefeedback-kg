    rdfs:label "Dunder methods"@en,
        "Métodos especiales (dunder)"@es ;
    owl:sameAs cfr:dunder ;
    skos:definition "Metodos especiales con doble guion bajo (__init__, __len__, __eq__) que integran objetos con el lenguaje."@es ;
    skos:example """class Vec:
    def __init__(self, n): self.n = n
    def __add__(self, o): return Vec(self.n + o.n)""" ;
    skos:scopeNote "Permiten personalizar operadores, iteracion o representacion; tambien llamados metodos magicos."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:esPrerrequisitoDe cfr:sobrecarga_operadores,
        cfr:str_repr ;
    cfkg:perteneceATema cfr:T_poo ;
    cfkg:relacionadoConceptualmenteCon cfr:sobrecarga_operadores,
        cfr:str_repr ;
    cfkg:requierePrerrequisito cfr:clase,
        cfr:funcion,
        cfr:metodo ;
    cfkg:tieneDificultad 4 .

