        cfkg:EntidadEducativa,
        cfkg:FuncionIntegrada ;
    rdfs:label "filter"@en,
        "filter()"@es ;
    owl:sameAs cfr:filter_func ;
    skos:definition "Funcion filter() que selecciona los elementos de un iterable que cumplen un predicado."@es ;
    skos:example "pares = list(filter(lambda x: x % 2 == 0, range(10)))" ;
    skos:related cfr:map_func,
        cfr:reduce_func ;
    skos:scopeNote "Devuelve un iterador perezoso; a menudo una comprension con if resulta mas legible."@es ;
