    owl:sameAs cfr:conjunto ;
    skos:closeMatch dbr:Set_\(abstract_data_type\) ;
    skos:definition "Coleccion no ordenada de elementos unicos e inmutables (set)."@es ;
    skos:exactMatch wd:Q1514741 ;
    skos:example """s = {1, 2, 2, 3}  # {1, 2, 3}
2 in s  # True""" ;
    skos:related cfr:frozenset_tipo,
        cfr:lista ;
    skos:scopeNote "Ofrece pertenencia y operaciones de conjunto (union, interseccion) en tiempo medio O(1); no admite duplicados."@es ;
    cfkg:esPrerrequisitoDe cfr:comprension_sets,
        cfr:frozenset_tipo ;
    cfkg:perteneceATema cfr:T_estructuras ;
    cfkg:relacionadoConceptualmenteCon cfr:comprension_sets,
        cfr:frozenset_tipo ;
    cfkg:tieneComplejidadTemporal "O(1)"^^xsd:string ;
    cfkg:tieneDificultad 3 .

cfr:else_bucle a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:EstructuraDeControl ;
    rdfs:label "loop else"@en,
        "else en bucles"@es ;
    owl:sameAs cfr:else_bucle ;
    skos:definition "Clausula else de un bucle que se ejecuta solo si el bucle termina sin break."@es ;
    skos:example """for x in xs:
    if x == objetivo:
        break
else:
    print('no encontrado')""" ;
    skos:scopeNote "Util para detectar si una busqueda no encontro el elemento; suele confundir a los principiantes."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:perteneceATema cfr:T_control ;
    cfkg:requierePrerrequisito cfr:asignacion,
        cfr:bucle_for ;
    cfkg:tieneDificultad 3 .

cfr:encoding a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:PrincipioTransversal ;
    rdfs:label "Text encoding"@en,
        "Codificación de texto"@es ;
    owl:sameAs cfr:encoding ;
    skos:definition "Esquema que asocia caracteres a secuencias de bytes (UTF-8, Latin-1) al codificar texto."@es ;
    skos:example """datos = 'cana'.encode('utf-8')
texto = datos.decode('utf-8')""" ;
    skos:scopeNote "Especifica siempre encoding al abrir ficheros de texto; errores de codificacion causan UnicodeDecodeError."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:perteneceATema cfr:T_strings ;
    cfkg:requierePrerrequisito cfr:tipo_bytes,
        cfr:tipo_str ;
    cfkg:tieneDificultad 4 .

cfr:entorno_virtual a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:PrincipioTransversal ;
    rdfs:label "Virtual environments"@en,
        "Entornos virtuales (venv)"@es ;
    owl:sameAs cfr:entorno_virtual ;
    skos:definition "Entorno aislado (venv) con su propio interprete y dependencias para un proyecto."@es ;
    skos:example """python -m venv .venv
source .venv/bin/activate""" ;
    skos:scopeNote "Evita conflictos de versiones entre proyectos; se activa antes de instalar paquetes con pip."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:perteneceATema cfr:T_modulos ;
    cfkg:requierePrerrequisito cfr:import_mod,
        cfr:paquete ;
    cfkg:tieneDificultad 3 .

cfr:formato_str a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:PrincipioTransversal ;
    rdfs:label "String formatting"@en,
        "Formateo de cadenas"@es ;
    owl:sameAs cfr:formato_str ;
    skos:definition "Conjunto de tecnicas para insertar valores en cadenas (f-strings, str.format, %)."@es ;
    skos:example """n = 3
f'hay {n} elementos'""" ;
    skos:related cfr:fstring,
        cfr:metodos_str ;
    skos:scopeNote "Las f-strings son la opcion recomendada por su claridad y rendimiento desde Python 3.6."@es ;
    cfkg:aNivelDominio cfr:basico ;
    cfkg:perteneceATema cfr:T_strings ;
    cfkg:requierePrerrequisito cfr:tipo_str ;
    cfkg:tieneDificultad 2 .

cfr:fstring_format_spec a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:PrincipioTransversal ;
    rdfs:label "Format specification"@en,
        "Mini-lenguaje de formato"@es ;
    owl:sameAs cfr:fstring_format_spec ;
    skos:definition "Sintaxis tras los dos puntos en un campo de formato para controlar ancho, precision y alineacion."@es ;
    skos:example """import math
f'{math.pi:.2f}'  # '3.14'
f'{42:05d}'        # '00042'""" ;
    skos:related cfr:fstring ;
    skos:scopeNote "Permite formatear numeros (:.2f), porcentajes (:.0%) o rellenar con ceros (:03d)."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:perteneceATema cfr:T_strings ;
    cfkg:requierePrerrequisito cfr:fstring,
        cfr:tipo_str ;
    cfkg:tieneDificultad 3 .

cfr:future_annotations a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:ConceptoDeTipado,
        cfkg:EntidadEducativa ;
    rdfs:label "Postponed annotations"@en,
        "from __future__ import annotations"@es ;
    owl:sameAs cfr:future_annotations ;
    skos:definition "Directiva que evalua las anotaciones como cadenas, posponiendo su resolucion."@es ;
    skos:example """from __future__ import annotations
class Nodo:
    sig: Nodo | None = None""" ;
    skos:scopeNote "Evita referencias adelantadas y costes de importacion; conviene conocerla al usar tipos recursivos."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:introducidoEnVersion "3.7"^^xsd:string ;
    cfkg:perteneceATema cfr:T_tipos ;
    cfkg:requierePrerrequisito cfr:anotaciones_tipo,
        cfr:funcion ;
    cfkg:tieneDificultad 4 .

cfr:isinstance_func a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:FuncionIntegrada ;
    rdfs:label "isinstance"@en,
        "Funcion isinstance"@es ;
    owl:sameAs cfr:isinstance_func ;
    skos:definition "Funcion que comprueba si un objeto es instancia de una clase o de alguna de varias clases."@es ;
    skos:example "isinstance(3, (int, float))  # True" ;
    skos:related cfr:herencia ;
    skos:scopeNote "Respeta la herencia y es preferible a comparar type(x) directamente; acepta una tupla de tipos."@es ;
    cfkg:aNivelDominio cfr:basico ;
    cfkg:perteneceATema cfr:T_poo ;
    cfkg:requierePrerrequisito cfr:clase,
        cfr:funcion ;
    cfkg:tieneDificultad 2 .

cfr:memoryview_tipo a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:TipoDeDato ;
    rdfs:label "memoryview"@en,
        "memoryview"@es ;
    owl:sameAs cfr:memoryview_tipo ;
    skos:definition "Vista que expone el buffer de memoria de un objeto binario sin copiarlo."@es ;
    skos:example """mv = memoryview(bytearray(b'abcdef'))
bytes(mv[1:4])  # b'bcd'""" ;
    skos:scopeNote "Permite manipular grandes bloques de bytes de forma eficiente, por ejemplo al hacer slicing."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:perteneceATema cfr:T_tipos ;
    cfkg:requierePrerrequisito cfr:tipo_bytes,
        cfr:tipo_str ;
    cfkg:tieneDificultad 4 .

cfr:metaclase a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:Paradigma ;
    rdfs:label "Metaclass"@en,
        "Metaclase"@es ;
    owl:sameAs cfr:metaclase ;
    skos:closeMatch dbr:Metaclass ;
    skos:definition "Clase cuyas instancias son a su vez clases, lo que permite personalizar como se crean."@es ;
    skos:exactMatch wd:Q1924819 ;
    skos:example """class Meta(type):
    def __new__(mcs, n, b, d):
        return super().__new__(mcs, n, b, d)""" ;
    skos:scopeNote "type es la metaclase por defecto; rara vez necesarias, pero potentes para frameworks (ORM, ABC)."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:perteneceATema cfr:T_poo ;
    cfkg:requierePrerrequisito cfr:clase,
        cfr:funcion ;
    cfkg:tieneDificultad 5 .

cfr:metodo_split_join a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:FuncionIntegrada ;
    rdfs:label "split and join"@en,
        "Metodos split y join"@es ;
    owl:sameAs cfr:metodo_split_join ;
    skos:definition "split() divide una cadena en una lista y join() une una lista de cadenas con un separador."@es ;
    skos:example """'a,b,c'.split(',')   # ['a', 'b', 'c']
'-'.join(['a', 'b'])  # 'a-b'""" ;
    skos:scopeNote "Son operaciones inversas habituales al procesar texto y ficheros delimitados."@es ;
    cfkg:aNivelDominio cfr:basico ;
    cfkg:perteneceATema cfr:T_strings ;
    cfkg:requierePrerrequisito cfr:lista,
        cfr:tipo_str ;
    cfkg:tieneDificultad 2 .

cfr:min_max a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:FuncionIntegrada ;
    rdfs:label "min and max"@en,
        "Funciones min y max"@es ;
    owl:sameAs cfr:min_max ;
    skos:definition "Funciones que devuelven el menor o mayor elemento de un iterable o de varios argumentos."@es ;
    skos:example """max([3, 1, 2])             # 3
max(palabras, key=len)""" ;
    skos:scopeNote "Aceptan key para definir el criterio y default para iterables vacios."@es ;
    cfkg:aNivelDominio cfr:basico ;
    cfkg:perteneceATema cfr:T_algoritmos ;
    cfkg:requierePrerrequisito cfr:iterables,
