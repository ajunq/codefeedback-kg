    rdfs:label "Dict comprehension"@en,
        "Comprensión de diccionarios"@es ;
    owl:sameAs cfr:comprension_dicts ;
    skos:broader cfr:comprension_listas ;
    skos:broaderTransitive cfr:comprension_listas ;
    skos:definition "Sintaxis concisa para construir diccionarios a partir de un iterable en una sola expresion."@es ;
    skos:example "cuadrados = {n: n*n for n in range(5)}" ;
    skos:scopeNote "Sigue el patron {clave: valor for ...}; mas legible que un bucle con asignaciones cuando es simple."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:perteneceATema cfr:T_estructuras ;
    cfkg:requierePrerrequisito cfr:asignacion,
