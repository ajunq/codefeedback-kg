    cfkg:tieneDificultad 3 .

cfr:typing_callable a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:ConceptoDeTipado,
        cfkg:EntidadEducativa ;
    rdfs:label "typing.Callable"@en,
        "typing.Callable"@es ;
    owl:sameAs cfr:typing_callable ;
    skos:definition "Anotacion que describe el tipo de un objeto invocable indicando sus argumentos y retorno."@es ;
    skos:example """from typing import Callable
def aplica(f: Callable[[int], int], x: int) -> int:
    return f(x)""" ;
    skos:scopeNote "Util para anotar callbacks y funciones de orden superior; Callable[[int], str] toma un int y devuelve str."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:perteneceATema cfr:T_tipos ;
    cfkg:requierePrerrequisito cfr:anotaciones_tipo,
        cfr:funcion,
        cfr:funcion_orden_superior ;
    cfkg:tieneDificultad 3 .

cfr:typing_generics a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:Paradigma ;
    rdfs:label "Generics"@en,
        "Genéricos (TypeVar)"@es ;
    owl:sameAs cfr:typing_generics ;
    skos:definition "Tipos genericos parametrizados (TypeVar, Generic) que abstraen el tipo de los elementos."@es ;
    skos:example """from typing import TypeVar
T = TypeVar('T')
def primero(xs: list[T]) -> T:
    return xs[0]""" ;
    skos:scopeNote "Permiten contenedores con seguridad de tipos reutilizables; el chequeo lo hace el verificador estatico."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:introducidoEnVersion "3.5"^^xsd:string ;
    cfkg:perteneceATema cfr:T_tipos ;
    cfkg:requierePrerrequisito cfr:anotaciones_tipo,
        cfr:clase,
        cfr:funcion ;
    cfkg:tieneDificultad 4 .

cfr:typing_optional a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:PrincipioTransversal ;
    rdfs:label "Optional"@en,
        "typing.Optional"@es ;
    owl:sameAs cfr:typing_optional ;
    skos:definition "Anotacion Optional[X] que indica un valor de tipo X o None."@es ;
    skos:example """from typing import Optional
def buscar(k) -> Optional[int]:
    return None""" ;
    skos:scopeNote "Equivale a Union[X, None]; documenta funciones que pueden no devolver un valor."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:introducidoEnVersion "3.5"^^xsd:string ;
    cfkg:perteneceATema cfr:T_tipos ;
    cfkg:requierePrerrequisito cfr:anotaciones_tipo,
        cfr:funcion,
        cfr:tipo_none ;
    cfkg:tieneDificultad 3 .

cfr:typing_typeddict a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:ConceptoDeTipado,
        cfkg:EntidadEducativa ;
    rdfs:label "TypedDict"@en,
        "typing.TypedDict"@es ;
    owl:sameAs cfr:typing_typeddict ;
    skos:definition "Tipo que especifica las claves esperadas de un diccionario y el tipo de cada valor."@es ;
    skos:example """from typing import TypedDict
class Usuario(TypedDict):
    nombre: str
    edad: int""" ;
    skos:scopeNote "Aporta seguridad de tipos a los diccionarios tipo registro sin crear una clase."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:introducidoEnVersion "3.8"^^xsd:string ;
    cfkg:perteneceATema cfr:T_tipos ;
    cfkg:requierePrerrequisito cfr:anotaciones_tipo,
        cfr:diccionario,
        cfr:funcion ;
    cfkg:tieneDificultad 4 .

"3.8"^^xsd:string a xsd:string ;
