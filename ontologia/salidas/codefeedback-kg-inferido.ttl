cfr:typing_union a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:PrincipioTransversal ;
    rdfs:label "Union"@en,
        "typing.Union"@es ;
    owl:sameAs cfr:typing_union ;
    skos:definition "Anotacion Union[A, B] que indica que un valor puede ser de varios tipos."@es ;
    skos:example """from typing import Union
def f(x: Union[int, str]) -> str:
    return str(x)""" ;
    skos:scopeNote "Desde Python 3.10 se escribe A | B; usala con moderacion para no diluir el tipado."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
