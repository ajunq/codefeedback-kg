    skos:definition "Arbol en el que cada nodo tiene como maximo dos hijos, izquierdo y derecho."@es ;
    skos:exactMatch wd:Q380172 ;
    skos:example """class NodoB:
    def __init__(self, v):
        self.v = v
        self.izq = self.der = None""" ;
    skos:narrower cfr:arbol_busqueda_binaria ;
    skos:scopeNote "Base de los arboles de busqueda y los montículos; se recorre en preorden, inorden o postorden."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:esPrerrequisitoDe cfr:arbol_busqueda_binaria ;
