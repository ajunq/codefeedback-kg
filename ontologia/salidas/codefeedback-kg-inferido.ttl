        cfkg:PrincipioTransversal ;
    rdfs:label "Triple-quoted strings"@en,
        "Cadenas multilinea"@es ;
    owl:sameAs cfr:multilinea_str ;
    skos:definition "Cadena delimitada por triples comillas que puede abarcar varias lineas."@es ;
    skos:example """texto = \"\"\"linea 1
linea 2\"\"\"""" ;
    skos:scopeNote "Tambien se usan como docstrings; conservan los saltos de linea y la sangria literal."@es ;
    cfkg:aNivelDominio cfr:basico ;
    cfkg:perteneceATema cfr:T_strings ;
    cfkg:requierePrerrequisito cfr:tipo_str ;
