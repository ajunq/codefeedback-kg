    rdfs:label "logging"@en,
        "Modulo logging"@es ;
    owl:sameAs cfr:logging_mod ;
    skos:definition "Modulo estandar para registrar mensajes con distintos niveles de severidad."@es ;
    skos:example """import logging
logging.basicConfig(level=logging.INFO)
logging.info('iniciado')""" ;
    skos:related cfr:pep8 ;
    skos:scopeNote "Preferible a print en programas reales: permite niveles, formato y destinos configurables."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:perteneceATema cfr:T_testing ;
    cfkg:requierePrerrequisito cfr:import_mod ;
