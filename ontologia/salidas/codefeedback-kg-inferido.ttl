    rdfs:label "Abstract base class"@en,
        "Clase abstracta (ABC)"@es ;
    owl:sameAs cfr:abstract_class ;
    skos:definition "Clase base abstracta (ABC) que define una interfaz comun y no puede instanciarse directamente."@es ;
    skos:example """from abc import ABC, abstractmethod
class Figura(ABC):
    @abstractmethod
    def area(self): ...""" ;
    skos:scopeNote "Se declara heredando de abc.ABC y marcando metodos con @abstractmethod; obliga a las subclases a implementarlos."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:perteneceATema cfr:T_poo ;
