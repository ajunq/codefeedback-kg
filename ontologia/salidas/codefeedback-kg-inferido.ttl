    owl:sameAs cfr:getattr_setattr ;
    skos:definition "Funciones que leen y escriben atributos de un objeto a partir de su nombre como cadena."@es ;
    skos:example """getattr(obj, 'x', 0)
setattr(obj, 'x', 10)""" ;
    skos:related cfr:atributo ;
    skos:scopeNote "Permiten acceso dinamico a atributos; getattr admite un valor por defecto para evitar AttributeError."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
