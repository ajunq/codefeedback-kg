    skos:exactMatch wd:Q110938941 ;
    skos:example """def log(f):
    def envoltura(*a, **k):
        print('llamando', f.__name__)
        return f(*a, **k)
    return envoltura""" ;
    skos:narrower cfr:metodo_clase,
        cfr:propiedad ;
    skos:scopeNote "Conserva metadatos con functools.wraps; util para logging, cache, control de acceso o tiempos."@es ;
