cfr:with_multiple a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:EstructuraDeControl ;
    rdfs:label "Multiple context managers"@en,
        "with multiple"@es ;
    owl:sameAs cfr:with_multiple ;
    skos:definition "Sintaxis que gestiona varios recursos en una sola sentencia with separados por comas."@es ;
    skos:example """with open('a') as a, open('b') as b:
    b.write(a.read())""" ;
    skos:related cfr:with_context ;
    skos:scopeNote "Desde Python 3.10 admite parentesis para repartirlos en varias lineas de forma legible."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:perteneceATema cfr:T_control ;
    cfkg:requierePrerrequisito cfr:condicional,
        cfr:excepcion,
        cfr:tipo_bool,
        cfr:with_context ;
    cfkg:tieneDificultad 4 .

cfr:zip_f a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
