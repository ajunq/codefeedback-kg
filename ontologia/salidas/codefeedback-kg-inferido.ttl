    rdfs:label "Closure"@en,
        "Clausura (closure)"@es ;
    owl:sameAs cfr:closure ;
    skos:closeMatch dbr:Closure_\(computer_programming\) ;
    skos:definition "Funcion interna que recuerda y captura variables del ambito envolvente donde fue creada."@es ;
    skos:exactMatch wd:Q535335 ;
    skos:example """def multiplicador(n):
    def f(x):
        return x * n
    return f
doble = multiplicador(2)""" ;
    skos:scopeNote "Permite fabricas de funciones; las variables capturadas se evaluan en el momento de la llamada (cuidado con el late binding)."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:esPrerrequisitoDe cfr:cached_property_mod,
        cfr:decorador,
        cfr:descriptor,
        cfr:functools_wraps,
        cfr:lru_cache,
        cfr:metodo_clase,
        cfr:metodo_estatico,
        cfr:nonlocal_kw,
        cfr:propiedad ;
    cfkg:perteneceATema cfr:T_funcional ;
    cfkg:relacionadoConceptualmenteCon cfr:cached_property_mod,
        cfr:decorador,
