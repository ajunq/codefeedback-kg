    rdfs:label "Mutable vs immutable"@en,
        "Mutable vs inmutable"@es ;
    owl:sameAs cfr:mutable_inmutable ;
    skos:definition "Distincion entre objetos modificables (mutables) y no modificables (inmutables)."@es ;
    skos:example """t = (1, 2)   # inmutable
l = [1, 2]   # mutable""" ;
    skos:scopeNote "Los inmutables son hashables y seguros como claves; evita usar mutables como valores por defecto."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:contrastaCon cfr:tupla ;
