    skos:broaderTransitive cfr:async_await ;
    skos:definition "Funcion que puede suspender y reanudar su ejecucion, cooperando con un planificador."@es ;
    skos:exactMatch wd:Q1339231 ;
    skos:example """async def contador():
    for i in range(3):
        await asyncio.sleep(0)
        yield i""" ;
    skos:scopeNote "En Python moderno se definen con async def; las clasicas usaban generadores con yield."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
