    rdfs:label "Default arguments"@en,
        "Argumentos por defecto"@es ;
    owl:sameAs cfr:valor_por_defecto ;
    skos:definition "Valor asignado a un parametro cuando la llamada no proporciona ese argumento."@es ;
    skos:example """def f(xs=None):
    if xs is None:
        xs = []""" ;
    skos:scopeNote "Nunca uses objetos mutables como valor por defecto: se comparten entre llamadas. Usa None y crealo dentro."@es ;
