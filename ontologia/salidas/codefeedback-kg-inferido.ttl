    rdfs:label "pathlib"@en,
        "pathlib"@es ;
    owl:sameAs cfr:pathlib ;
    skos:definition "Modulo pathlib con una API orientada a objetos para rutas del sistema de ficheros."@es ;
    skos:example """from pathlib import Path
p = Path('datos') / 'fichero.txt'
p.exists()""" ;
    skos:scopeNote "Sustituye a os.path con codigo mas legible y portable; el operador / compone rutas."@es ;
