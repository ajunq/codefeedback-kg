cfr:partial a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:ModuloLibreria ;
    rdfs:label "partial"@en,
        "functools.partial"@es ;
    owl:sameAs cfr:partial ;
    skos:definition "Funcion functools.partial que fija algunos argumentos de otra y devuelve una nueva."@es ;
    skos:example """from functools import partial
cubo = partial(pow, exp=3)""" ;
    skos:scopeNote "Util para especializar funciones genericas y pasarlas como callbacks."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:perteneceATema cfr:T_funcional ;
    cfkg:requierePrerrequisito cfr:funcion,
