        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:PrincipioTransversal ;
    rdfs:label "Mutability"@en,
        "Mutabilidad"@es ;
    rdfs:comment "Propiedad de los objetos cuyo estado puede cambiar tras su creación."@es ;
    owl:sameAs cfr:mutabilidad ;
    skos:closeMatch dbr:Immutable_object ;
    skos:definition "Propiedad de los objetos cuyo estado puede modificarse tras su creacion."@es ;
    skos:example """xs = [1]
xs.append(2)  # mutado en sitio""" ;
    skos:scopeNote "Listas, dicts y sets son mutables; numeros, cadenas y tuplas son inmutables. Afecta a alias y copias."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:contrastaCon cfr:tupla ;
    cfkg:esPrerrequisitoDe cfr:copia_profunda,
        cfr:copia_superficial,
        cfr:identidad_objetos,
        cfr:mutable_inmutable,
        cfr:operador_identidad ;
    cfkg:perteneceATema cfr:T_estructuras ;
