    skos:definition "Conjunto de metodos del tipo str para manipular texto (upper, strip, replace, find)."@es ;
    skos:example "'  Hola  '.strip().lower()  # 'hola'" ;
    skos:related cfr:formato_str ;
    skos:scopeNote "Las cadenas son inmutables: estos metodos devuelven una cadena nueva, no modifican la original."@es ;
