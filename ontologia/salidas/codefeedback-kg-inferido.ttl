        cfr:herencia ;
    cfkg:tieneDificultad 4 .

cfr:yield_from a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:EstructuraDeControl ;
    rdfs:label "yield from"@en,
        "yield from"@es ;
    owl:sameAs cfr:yield_from ;
    skos:definition "Expresion yield from que delega la produccion de valores a otro generador o iterable."@es ;
    skos:example """def aplanar(listas):
    for l in listas:
        yield from l""" ;
    skos:scopeNote "Simplifica la composicion de generadores y transmite valores enviados y excepciones."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:introducidoEnVersion "3.3"^^xsd:string ;
