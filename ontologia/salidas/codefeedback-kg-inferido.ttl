cfr:async_generator a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:EstructuraDeControl ;
    rdfs:label "Async generator"@en,
        "Generador asincrono"@es ;
    owl:sameAs cfr:async_generator ;
    skos:definition "Funcion async def que produce valores con yield y se recorre con async for."@es ;
    skos:example """async def numeros():
    for i in range(3):
        await asyncio.sleep(0)
        yield i""" ;
    skos:scopeNote "Combina produccion perezosa y espera asincrona; util para flujos de datos de red por lotes."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:introducidoEnVersion "3.6"^^xsd:string ;
    cfkg:perteneceATema cfr:T_concurrencia ;
    cfkg:requierePrerrequisito cfr:async_await,
        cfr:funcion,
        cfr:generador,
        cfr:iterables,
        cfr:iterador,
        cfr:lista ;
    cfkg:tieneDificultad 5 .

cfr:bfs a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:PrincipioTransversal ;
    rdfs:label "Breadth-first search"@en,
        "Recorrido en anchura (BFS)"@es ;
    owl:sameAs cfr:bfs ;
    skos:broader cfr:grafo_estr ;
    skos:broaderTransitive cfr:grafo_estr ;
    skos:closeMatch dbr:Breadth-first_search ;
    skos:definition "Recorrido en anchura de un grafo que visita los nodos por niveles desde el origen usando una cola."@es ;
    skos:exactMatch wd:Q325904 ;
    skos:example """from collections import deque
def bfs(g, inicio):
    visto, cola = {inicio}, deque([inicio])
    while cola:
        n = cola.popleft()
        for v in g[n]:
            if v not in visto:
                visto.add(v); cola.append(v)""" ;
    skos:related cfr:dfs ;
    skos:scopeNote "Encuentra el camino mas corto en grafos no ponderados; contrasta con DFS que usa pila/recursion."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:contrastaCon cfr:dfs ;
    cfkg:perteneceATema cfr:T_algoritmos ;
    cfkg:relacionadoConceptualmenteCon cfr:dfs ;
    cfkg:requierePrerrequisito cfr:cola,
        cfr:diccionario,
        cfr:grafo_estr,
        cfr:lista ;
    cfkg:tieneComplejidadTemporal "O(V + E)"^^xsd:string ;
    cfkg:tieneDificultad 5 .

cfr:dfs a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:PrincipioTransversal ;
    rdfs:label "Depth-first search"@en,
        "Recorrido en profundidad (DFS)"@es ;
    owl:sameAs cfr:dfs ;
    skos:broader cfr:grafo_estr ;
    skos:broaderTransitive cfr:grafo_estr ;
    skos:closeMatch dbr:Depth-first_search ;
    skos:definition "Recorrido en profundidad de un grafo que explora un camino al maximo antes de retroceder."@es ;
    skos:exactMatch wd:Q816319 ;
    skos:example """def dfs(g, n, visto=None):
    visto = visto or set()
    visto.add(n)
    for v in g[n]:
        if v not in visto:
            dfs(g, v, visto)""" ;
    skos:related cfr:bfs ;
    skos:scopeNote "Se implementa con recursion o pila explicita; util para deteccion de ciclos y ordenacion topologica."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:contrastaCon cfr:bfs ;
    cfkg:perteneceATema cfr:T_algoritmos ;
    cfkg:relacionadoConceptualmenteCon cfr:bfs ;
    cfkg:requierePrerrequisito cfr:diccionario,
        cfr:funcion,
        cfr:grafo_estr,
        cfr:recursion ;
    cfkg:tieneComplejidadTemporal "O(V + E)"^^xsd:string ;
    cfkg:tieneDificultad 5 .

cfr:hilos a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
