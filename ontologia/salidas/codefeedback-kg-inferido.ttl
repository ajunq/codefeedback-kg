    skos:broader cfr:lista ;
    skos:broaderTransitive cfr:lista ;
    skos:closeMatch dbr:Stack_\(abstract_data_type\) ;
    skos:definition "Estructura LIFO (ultimo en entrar, primero en salir) que apila y desapila por un mismo extremo."@es ;
    skos:exactMatch wd:Q177929 ;
    skos:example """pila = []
pila.append(1)
pila.pop()  # 1""" ;
    skos:related cfr:cola ;
