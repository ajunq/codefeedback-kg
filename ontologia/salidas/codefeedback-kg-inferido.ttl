cfr:functools_wraps a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:ModuloLibreria ;
    rdfs:label "functools.wraps"@en,
        "functools.wraps"@es ;
    owl:sameAs cfr:functools_wraps ;
    skos:definition "Decorador functools.wraps que copia los metadatos de la funcion original a la envoltura."@es ;
    skos:example """import functools
def d(f):
    @functools.wraps(f)
    def w(*a, **k): return f(*a, **k)
    return w""" ;
    skos:scopeNote "Conserva __name__ y __doc__ al crear decoradores; sin el se pierde la introspeccion."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:perteneceATema cfr:T_funcional ;
    cfkg:requierePrerrequisito cfr:ambito,
        cfr:closure,
        cfr:decorador,
        cfr:funcion,
        cfr:funcion_orden_superior ;
    cfkg:tieneDificultad 4 .

cfr:itertools_mod a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:ModuloLibreria ;
    rdfs:label "itertools"@en,
        "itertools"@es ;
    owl:sameAs cfr:itertools_mod ;
    skos:definition "Modulo itertools con utilidades para construir iteradores eficientes y combinatorios."@es ;
    skos:example """import itertools
list(itertools.islice(itertools.count(), 3))  # [0, 1, 2]""" ;
    skos:narrower cfr:itertools_chain,
        cfr:itertools_product ;
    skos:scopeNote "Incluye count, cycle, chain, product o combinations; opera de forma perezosa."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:esPrerrequisitoDe cfr:itertools_chain,
        cfr:itertools_product ;
    cfkg:perteneceATema cfr:T_funcional ;
