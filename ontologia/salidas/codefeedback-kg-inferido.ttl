cfr:typing_any a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:ConceptoDeTipado,
        cfkg:EntidadEducativa ;
    rdfs:label "typing.Any"@en,
        "typing.Any"@es ;
    owl:sameAs cfr:typing_any ;
    skos:definition "Tipo comodin compatible con cualquier otro, que desactiva la comprobacion estatica."@es ;
    skos:example """from typing import Any
def registrar(valor: Any) -> None:
    print(valor)""" ;
    skos:scopeNote "Usalo con moderacion: cada Any es un agujero en el tipado; prefiere tipos concretos o genericos."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:perteneceATema cfr:T_tipos ;
    cfkg:requierePrerrequisito cfr:anotaciones_tipo,
        cfr:funcion ;
    cfkg:tieneDificultad 2 .

cfr:typing_final a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
