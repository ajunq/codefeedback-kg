cfr:tipo_int a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:TipoDeDato ;
    rdfs:label "Integer (int)"@en,
        "Entero (int)"@es ;
    owl:sameAs cfr:tipo_int ;
    skos:definition "Tipo numerico entero de precision arbitraria en Python."@es ;
    skos:example "10 ** 100  # entero enorme sin desbordamiento" ;
    skos:scopeNote "No desborda como en otros lenguajes; admite bases y separadores de miles con guion bajo."@es ;
    cfkg:contrastaCon cfr:tipo_float ;
    cfkg:esPrerrequisitoDe cfr:conversion_tipos,
        cfr:operador_bitwise ;
    cfkg:perteneceATema cfr:T_fundamentos ;
    cfkg:relacionadoConceptualmenteCon cfr:conversion_tipos,
        cfr:operador_bitwise,
