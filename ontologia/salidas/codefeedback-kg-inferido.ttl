        cfkg:Recurso ;
    rdfs:label "Keuning, Jeuring & Heeren (2019), A systematic literature review of automated feedback generation for programming exercises"@en,
        "Keuning et al. (2019): revisión sistemática de generación automática de feedback"@es ;
