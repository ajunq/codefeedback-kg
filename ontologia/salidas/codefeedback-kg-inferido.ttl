    rdfs:label "Multiple inheritance"@en,
        "Herencia múltiple"@es ;
    owl:sameAs cfr:herencia_multiple ;
    skos:broader cfr:herencia ;
    skos:broaderTransitive cfr:herencia ;
    skos:closeMatch dbr:Multiple_inheritance ;
    skos:definition "Capacidad de una clase de heredar de varias clases base a la vez."@es ;
    skos:example """class A: ...
class B: ...
class C(A, B): ...""" ;
    skos:scopeNote "Util con mixins; el orden de resolucion de metodos (MRO) determina que implementacion se usa."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:esPrerrequisitoDe cfr:mixin,
