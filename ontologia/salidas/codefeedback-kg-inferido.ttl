    rdfs:label "NoneType"@en,
        "NoneType (None)"@es ;
    owl:sameAs cfr:tipo_none ;
    skos:definition "Tipo con un unico valor, None, que representa la ausencia de valor."@es ;
    skos:example """def f():
    pass
f() is None  # True""" ;
    skos:scopeNote "Es el retorno por defecto de las funciones; comparalo con is None, no con ==."@es ;
    cfkg:aNivelDominio cfr:basico ;
    cfkg:esPrerrequisitoDe cfr:typing_optional ;
    cfkg:perteneceATema cfr:T_tipos ;
    cfkg:relacionadoConceptualmenteCon cfr:typing_optional ;
    cfkg:tieneDificultad 1 .

