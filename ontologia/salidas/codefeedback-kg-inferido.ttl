    rdfs:label "PEP 8"@en,
        "PEP 8 (estilo)"@es ;
    owl:sameAs cfr:pep8 ;
    skos:definition "Guia de estilo oficial PEP 8 con convenciones de formato del codigo Python."@es ;
    skos:example """# correcto
def calcular_total(precio, cantidad):
    return precio * cantidad""" ;
    skos:scopeNote "Recomienda sangria de 4 espacios, snake_case y lineas de hasta 79 caracteres; herramientas como flake8 la verifican."@es ;
