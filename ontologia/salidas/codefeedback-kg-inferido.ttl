        cfr:lock_threading ;
    cfkg:perteneceATema cfr:T_concurrencia ;
    cfkg:relacionadoConceptualmenteCon cfr:concurrent_futures,
        cfr:condicion_carrera,
        cfr:interbloqueo,
        cfr:lock_threading,
        cfr:multiproceso ;
    cfkg:requierePrerrequisito cfr:gil ;
    cfkg:tieneDificultad 5 .

