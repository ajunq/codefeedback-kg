cfr:protocolo_typing a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:ConceptoDeTipado,
        cfkg:EntidadEducativa ;
    rdfs:label "Protocol (structural typing)"@en,
        "typing.Protocol"@es ;
    owl:sameAs cfr:protocolo_typing ;
    skos:definition "Tipo que describe una interfaz por su estructura (metodos y atributos), no por herencia explicita."@es ;
    skos:example """from typing import Protocol
class Dibujable(Protocol):
    def dibujar(self) -> None: ...""" ;
    skos:scopeNote "Formaliza el duck typing para los verificadores estaticos; una clase la satisface si tiene los miembros."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:introducidoEnVersion "3.8"^^xsd:string ;
    cfkg:perteneceATema cfr:T_tipos ;
    cfkg:requierePrerrequisito cfr:anotaciones_tipo,
        cfr:funcion ;
    cfkg:tieneDificultad 4 .

cfr:range_f a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:FuncionIntegrada ;
    rdfs:label "range"@en,
        "range()"@es ;
    owl:sameAs cfr:range_f ;
    skos:definition "Funcion range() que genera una secuencia perezosa de enteros equiespaciados."@es ;
    skos:example "list(range(2, 10, 2))  # [2, 4, 6, 8]" ;
    skos:scopeNote "Define inicio, fin (excluido) y paso; no crea una lista, ahorra memoria."@es ;
    cfkg:aNivelDominio cfr:basico ;
    cfkg:perteneceATema cfr:T_control ;
    cfkg:requierePrerrequisito cfr:asignacion,
        cfr:bucle_for ;
    cfkg:tieneDificultad 1 .

cfr:retorno_multiple a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:PrincipioTransversal ;
    rdfs:label "Multiple return"@en,
        "Retorno múltiple"@es ;
    owl:sameAs cfr:retorno_multiple ;
    skos:definition "Devolucion de varios valores desde una funcion empaquetandolos en una tupla."@es ;
    skos:example """def divmod2(a, b):
    return a // b, a % b
c, r = divmod2(7, 2)""" ;
    skos:scopeNote "El receptor los desempaqueta en variables separadas; mejora la claridad frente a parametros de salida."@es ;
    cfkg:aNivelDominio cfr:basico ;
    cfkg:perteneceATema cfr:T_funciones ;
    cfkg:requierePrerrequisito cfr:funcion,
        cfr:tupla ;
    cfkg:tieneDificultad 2 .

cfr:sum_func a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
