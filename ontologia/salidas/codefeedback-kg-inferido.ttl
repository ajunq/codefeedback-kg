    owl:sameAs cfr:cola ;
    skos:broader cfr:lista ;
    skos:broaderTransitive cfr:lista ;
    skos:closeMatch dbr:Queue_\(abstract_data_type\) ;
    skos:definition "Estructura FIFO (primero en entrar, primero en salir) que anade por un extremo y extrae por el otro."@es ;
    skos:exactMatch wd:Q220543 ;
    skos:example """from collections import deque
q = deque()
q.append(1); q.popleft()""" ;
    skos:narrower cfr:deque ;
    skos:related cfr:pila ;
    skos:scopeNote "Usa collections.deque para operaciones O(1) en ambos extremos en lugar de list.pop(0)."@es ;
