cfr:try_except_else a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:EstructuraDeControl ;
    rdfs:label "try/except/else/finally"@en,
        "try/except/else/finally"@es ;
    owl:sameAs cfr:try_except_else ;
    skos:definition "Estructura try/except/else/finally para capturar y gestionar excepciones."@es ;
    skos:example """try:
    x = int(s)
except ValueError:
    x = 0
else:
    print('ok')
finally:
    print('fin')""" ;
    skos:narrower cfr:finally_clause ;
    skos:scopeNote "else se ejecuta si no hubo excepcion y finally siempre; mantenes el try lo mas pequeno posible."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:esPrerrequisitoDe cfr:finally_clause,
        cfr:suppress_context ;
    cfkg:perteneceATema cfr:T_excepciones ;
    cfkg:relacionadoConceptualmenteCon cfr:finally_clause,
        cfr:suppress_context ;
    cfkg:requierePrerrequisito cfr:condicional,
        cfr:excepcion,
        cfr:tipo_bool ;
    cfkg:tieneDificultad 3 .

