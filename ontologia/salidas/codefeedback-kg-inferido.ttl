    rdfs:label "Constructor"@en,
        "Constructor __init__"@es ;
    owl:sameAs cfr:init_method ;
    skos:broader cfr:metodo ;
    skos:broaderTransitive cfr:metodo ;
    skos:definition "Metodo especial __init__ que inicializa el estado de una instancia recien creada."@es ;
    skos:example """class Punto:
    def __init__(self, x, y):
        self.x, self.y = x, y""" ;
    skos:scopeNote "Recibe self y los argumentos del constructor; no devuelve valor (debe retornar None)."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
