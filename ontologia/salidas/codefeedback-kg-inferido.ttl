    skos:definition "Sintaxis concisa para construir conjuntos eliminando duplicados a partir de un iterable."@es ;
    skos:example "iniciales = {p[0] for p in ['ana', 'alba', 'bea']}" ;
    skos:scopeNote "Sigue el patron {expr for ...}; util para obtener elementos unicos transformados."@es ;
