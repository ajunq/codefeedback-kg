cfr:python a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:PrincipioTransversal ;
    rdfs:label "Python"@en,
        "Python"@es ;
    owl:sameAs cfr:python ;
    skos:closeMatch dbr:Python_\(programming_language\) ;
    skos:definition "Lenguaje de programacion interpretado, de alto nivel y tipado dinamico, con enfasis en la legibilidad."@es ;
    skos:exactMatch wd:Q28865 ;
    skos:example "print('Hola, mundo')" ;
    skos:prefLabel "Python"@es ;
    skos:scopeNote "Multiparadigma (imperativo, orientado a objetos y funcional); su filosofia se resume en el Zen de Python."@es ;
    cfkg:perteneceATema cfr:T_fundamentos .

cfr:stmt_offbyone a rdf:Statement ;
    rdfs:label "Provenance (reification): off-by-one on indexing per Keuning et al."@en,
        "Procedencia (reificación): off-by-one sobre indexación según Keuning et al."@es ;
    dcterms:source cfr:ref_keuning2019 ;
    rdf:object cfr:indexacion ;
    rdf:predicate cfkg:errorSobreConcepto ;
    rdf:subject cfr:err_off_by_one ;
    rdfs:comment "Procedencia del enunciado (patrón de reificación del material docente)."@es ;
    owl:sameAs cfr:stmt_offbyone .

cfkg: a owl:Ontology ;
    cc:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:created "2026-06-18"^^xsd:date ;
    dcterms:creator "Adrián Bueno Junquero" ;
    dcterms:description "Ontología y grafo de conocimiento del dominio de la programación en Python, diseñado para anclar la generación de retroalimentación formativa automática (arquitectura EKG + RAG + LLM). Modela conceptos, sus prerrequisitos y contrastes, temas, ejercicios, errores conceptuales (misconceptions), recursos y perfiles de estudiante."@es ;
    dcterms:issued "2026-06-21"^^xsd:date ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:modified "2026-06-21"^^xsd:date ;
    dcterms:title "CodeFeedback-KG: A Semantic Knowledge Graph of Python Concepts for Pedagogical Code Feedback"@en,
        "Grafo de Conocimiento Educativo de Programación en Python (CodeFeedback-KG)"@es ;
    vann:preferredNamespacePrefix "cfkg" ;
    vann:preferredNamespaceUri "https://w3id.org/codefeedback-kg/schema#" ;
    rdfs:seeAlso <https://w3id.org/codefeedback-kg/> ;
    owl:sameAs cfkg: ;
    owl:versionIRI <https://w3id.org/codefeedback-kg/schema/2.0.0> ;
    owl:versionInfo "2.0.0" .

