    owl:sameAs cfr:raw_string ;
    skos:definition "Cadena con prefijo r en la que la barra invertida no se interpreta como secuencia de escape."@es ;
    skos:example """ruta = r'C:\\nuevo\\datos'
patron = r'\\d+'""" ;
    skos:related cfr:regex ;
