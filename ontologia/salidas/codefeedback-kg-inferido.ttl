cfr:asyncio_mod a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:ModuloLibreria ;
    rdfs:label "asyncio"@en,
        "asyncio"@es ;
    owl:sameAs cfr:asyncio_mod ;
    skos:definition "Modulo estandar asyncio para escribir codigo concurrente con corrutinas y un bucle de eventos."@es ;
    skos:example """import asyncio
async def tarea():
    return 42
asyncio.run(tarea())""" ;
    skos:scopeNote "Adecuado para E/S concurrente (red, ficheros); no acelera calculo intensivo de CPU."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:esPrerrequisitoDe cfr:event_loop ;
    cfkg:perteneceATema cfr:T_concurrencia ;
    cfkg:relacionadoConceptualmenteCon cfr:event_loop ;
    cfkg:requierePrerrequisito cfr:async_await,
        cfr:funcion ;
    cfkg:tieneDificultad 5 ;
    cfkg:tieneURLDocumentacion "https://docs.python.org/3/library/asyncio.html"^^xsd:anyURI .

cfr:bucle_while a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:EstructuraDeControl ;
    rdfs:label "While loop"@en,
        "Bucle while"@es ;
    owl:sameAs cfr:bucle_while ;
    skos:definition "Bucle que repite un bloque mientras una condicion sea verdadera."@es ;
    skos:example """i = 0
while i < 3:
    print(i)
    i += 1""" ;
    skos:scopeNote "Adecuado cuando no se conoce de antemano el numero de iteraciones; cuida la condicion de parada para evitar bucles infinitos."@es ;
    cfkg:cubiertoPorEjercicio cfr:ej_busqueda ;
    cfkg:esPrerrequisitoDe cfr:busqueda_binaria ;
    cfkg:perteneceATema cfr:T_control ;
    cfkg:relacionadoConceptualmenteCon cfr:busqueda_binaria ;
    cfkg:requierePrerrequisito cfr:condicional,
        cfr:tipo_bool ;
    cfkg:tieneDificultad 2 .

cfr:cola_prioridad a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:EstructuraDeDatos ;
    rdfs:label "Priority queue"@en,
        "Cola de prioridad"@es ;
    owl:sameAs cfr:cola_prioridad ;
    skos:closeMatch dbr:Priority_queue ;
    skos:definition "Cola en la que cada elemento tiene una prioridad y se extrae siempre el de mayor prioridad."@es ;
    skos:exactMatch wd:Q629283 ;
    skos:example """import heapq
pq = []
heapq.heappush(pq, (2, 'tarea B'))
heapq.heappush(pq, (1, 'tarea A'))
heapq.heappop(pq)  # (1, 'tarea A')""" ;
    skos:related cfr:cola,
        cfr:heap ;
    skos:scopeNote "Se implementa eficientemente con un monticulo (heapq); base de algoritmos como Dijkstra."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:perteneceATema cfr:T_estructuras ;
    cfkg:requierePrerrequisito cfr:complejidad,
        cfr:heap,
        cfr:lista ;
    cfkg:tieneComplejidadTemporal "O(log n)"^^xsd:string ;
    cfkg:tieneDificultad 4 .

