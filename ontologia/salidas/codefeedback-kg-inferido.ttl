    rdfs:label "Mixin"@en,
        "Mixin"@es ;
    owl:sameAs cfr:mixin ;
    skos:closeMatch dbr:Mixin ;
    skos:definition "Clase pequena que aporta funcionalidad concreta para combinarse por herencia multiple."@es ;
    skos:example """class SerializableMixin:
    def to_dict(self):
        return self.__dict__""" ;
    skos:scopeNote "No se instancia por si sola; anade un comportamiento transversal a varias clases."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:perteneceATema cfr:T_poo ;
