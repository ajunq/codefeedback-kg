cfr:encapsulacion a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:Paradigma ;
    rdfs:label "Encapsulation"@en,
        "Encapsulación"@es ;
    owl:sameAs cfr:encapsulacion ;
    skos:closeMatch dbr:Encapsulation_\(computer_programming\) ;
    skos:definition "Principio de ocultar el estado interno de un objeto exponiendo solo una interfaz controlada."@es ;
    skos:example """class Cuenta:
    def __init__(self):
        self.__saldo = 0  # 'privado'""" ;
    skos:scopeNote "Python usa convenciones (_protegido, __privado con name mangling) en lugar de modificadores estrictos."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:esPrerrequisitoDe cfr:cached_property_mod,
        cfr:descriptor,
        cfr:propiedad ;
    cfkg:perteneceATema cfr:T_poo ;
    cfkg:relacionadoConceptualmenteCon cfr:cached_property_mod,
        cfr:descriptor,
        cfr:propiedad ;
