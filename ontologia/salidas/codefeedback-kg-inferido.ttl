cfr:suppress_context a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:EstructuraDeControl ;
    rdfs:label "contextlib.suppress"@en,
        "contextlib.suppress"@es ;
    owl:sameAs cfr:suppress_context ;
    skos:definition "Gestor de contexto que ignora silenciosamente las excepciones indicadas dentro del bloque."@es ;
    skos:example """from contextlib import suppress
with suppress(FileNotFoundError):
    open('quiza.txt')""" ;
    skos:related cfr:try_except_else ;
    skos:scopeNote "Alternativa concisa a un try/except con pass; usalo solo cuando ignorar el error sea intencionado."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:perteneceATema cfr:T_excepciones ;
    cfkg:requierePrerrequisito cfr:condicional,
