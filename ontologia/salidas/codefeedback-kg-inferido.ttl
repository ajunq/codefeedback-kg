        cfkg:ModuloLibreria ;
    rdfs:label "pytest"@en,
        "pytest"@es ;
    owl:sameAs cfr:pytest_mod ;
    skos:definition "Marco de pruebas pytest que descubre y ejecuta tests con asserts simples."@es ;
    skos:example """def test_suma():
    assert 1 + 1 == 2""" ;
    skos:scopeNote "Ofrece fixtures, parametrizacion y mensajes de fallo detallados; estandar de facto en Python."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:perteneceATema cfr:T_testing ;
    cfkg:requierePrerrequisito cfr:funcion ;
    cfkg:tieneDificultad 4 .

cfr:raw_string a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
