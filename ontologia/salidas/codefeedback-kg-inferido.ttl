cfr:counter a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:EstructuraDeDatos ;
    rdfs:label "Counter"@en,
        "collections.Counter"@es ;
    owl:sameAs cfr:counter ;
    skos:broader cfr:diccionario ;
    skos:broaderTransitive cfr:diccionario ;
    skos:definition "Subclase de diccionario (collections.Counter) que cuenta apariciones de elementos hashables."@es ;
    skos:example """from collections import Counter
c = Counter('banana')
c.most_common(1)  # [('a', 3)]""" ;
    skos:scopeNote "Ofrece most_common() y aritmetica de multiconjuntos; ideal para frecuencias."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:perteneceATema cfr:T_estructuras ;
    cfkg:requierePrerrequisito cfr:diccionario ;
    cfkg:tieneDificultad 3 .

cfr:defaultdict a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:EstructuraDeDatos ;
    rdfs:label "defaultdict"@en,
        "collections.defaultdict"@es ;
    owl:sameAs cfr:defaultdict ;
    skos:broader cfr:diccionario ;
    skos:broaderTransitive cfr:diccionario ;
    skos:definition "Diccionario (collections.defaultdict) que crea un valor por defecto al acceder a una clave inexistente."@es ;
    skos:example """from collections import defaultdict
d = defaultdict(list)
d['a'].append(1)""" ;
    skos:scopeNote "Evita comprobar la existencia de la clave; se inicializa con una fabrica (list, int, set)."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:perteneceATema cfr:T_estructuras ;
    cfkg:requierePrerrequisito cfr:diccionario ;
    cfkg:tieneDificultad 3 .

cfr:deque a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:EstructuraDeDatos ;
    rdfs:label "deque"@en,
        "collections.deque"@es ;
    owl:sameAs cfr:deque ;
    skos:broader cfr:cola ;
    skos:broaderTransitive cfr:cola ;
    skos:definition "Cola doblemente terminada (collections.deque) con insercion y extraccion O(1) por ambos extremos."@es ;
    skos:example """from collections import deque
d = deque([1, 2])
d.appendleft(0); d.pop()""" ;
    skos:scopeNote "Preferible a list para colas y pilas; permite limitar su tamano con maxlen."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:perteneceATema cfr:T_estructuras ;
    cfkg:requierePrerrequisito cfr:lista ;
    cfkg:tieneDificultad 3 .

cfr:frozenset_tipo a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:EstructuraDeDatos ;
    rdfs:label "frozenset"@en,
        "Conjunto inmutable (frozenset)"@es ;
    owl:sameAs cfr:frozenset_tipo ;
    skos:definition "Version inmutable y hashable del conjunto, que no admite anadir ni quitar elementos."@es ;
    skos:example """fs = frozenset({1, 2, 3})
{fs: 'valor'}  # valido como clave""" ;
    skos:related cfr:conjunto ;
    skos:scopeNote "Al ser hashable puede usarse como clave de diccionario o elemento de otro conjunto."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:perteneceATema cfr:T_estructuras ;
    cfkg:requierePrerrequisito cfr:conjunto ;
    cfkg:tieneDificultad 3 .

cfr:funcion_lambda a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
