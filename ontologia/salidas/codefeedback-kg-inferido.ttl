cfr:unittest_mod a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:ModuloLibreria ;
    rdfs:label "unittest"@en,
        "unittest"@es ;
    owl:sameAs cfr:unittest_mod ;
    skos:definition "Marco de pruebas unittest de la biblioteca estandar, basado en clases TestCase."@es ;
    skos:example """import unittest
class T(unittest.TestCase):
    def test_ok(self):
        self.assertEqual(1 + 1, 2)""" ;
    skos:scopeNote "Inspirado en xUnit; ofrece metodos assert y setUp/tearDown para preparar cada prueba."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:perteneceATema cfr:T_testing ;
    cfkg:requierePrerrequisito cfr:clase,
        cfr:funcion ;
    cfkg:tieneDificultad 4 ;
    cfkg:tieneURLDocumentacion "https://docs.python.org/3/library/unittest.html"^^xsd:anyURI .

