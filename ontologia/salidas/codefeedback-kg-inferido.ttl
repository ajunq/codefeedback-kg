    rdfs:label "typing.Literal"@en,
        "typing.Literal"@es ;
    owl:sameAs cfr:typing_literal ;
    skos:definition "Anotacion que restringe un valor a un conjunto concreto de constantes literales."@es ;
    skos:example """from typing import Literal
def mover(d: Literal['n', 's', 'e', 'o']) -> None: ...""" ;
    skos:scopeNote "Documenta parametros que solo admiten ciertos valores; el verificador rechaza los demas."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:introducidoEnVersion "3.8"^^xsd:string ;
