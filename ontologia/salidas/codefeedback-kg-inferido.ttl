cfr:prog_dinamica a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:PrincipioTransversal ;
    rdfs:label "Dynamic programming"@en,
        "Programación dinámica"@es ;
    owl:sameAs cfr:prog_dinamica ;
    skos:closeMatch dbr:Dynamic_programming ;
    skos:definition "Tecnica que resuelve un problema combinando soluciones de subproblemas solapados, guardandolas."@es ;
    skos:example """def fib(n, memo={}):
    if n < 2: return n
    if n not in memo:
        memo[n] = fib(n-1) + fib(n-2)
    return memo[n]""" ;
    skos:scopeNote "Combina recursion con memoizacion o tablas; evita recalcular (p. ej. Fibonacci, mochila)."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:perteneceATema cfr:T_algoritmos ;
    cfkg:requierePrerrequisito cfr:diccionario,
        cfr:funcion,
        cfr:memoizacion,
        cfr:recursion ;
    cfkg:tieneDificultad 5 .

cfr:recoleccion_basura a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:PrincipioTransversal ;
    rdfs:label "Garbage collection"@en,
        "Recoleccion de basura"@es ;
    owl:sameAs cfr:recoleccion_basura ;
    skos:closeMatch dbr:Garbage_collection_\(computer_science\) ;
    skos:definition "Gestion automatica de la memoria que libera los objetos que ya no son alcanzables."@es ;
    skos:exactMatch wd:Q322202 ;
    skos:example """import gc
gc.collect()  # fuerza una recoleccion""" ;
    skos:scopeNote "CPython usa conteo de referencias mas un recolector ciclico (modulo gc) para los ciclos de referencias."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:esPrerrequisitoDe cfr:conteo_referencias ;
    cfkg:perteneceATema cfr:T_fundamentos ;
    cfkg:relacionadoConceptualmenteCon cfr:conteo_referencias ;
    cfkg:requierePrerrequisito cfr:clase,
        cfr:funcion,
        cfr:objeto ;
    cfkg:tieneDificultad 4 .

cfr:singledispatch a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:ModuloLibreria ;
    rdfs:label "functools.singledispatch"@en,
        "functools.singledispatch"@es ;
    owl:sameAs cfr:singledispatch ;
    skos:definition "Decorador que crea una funcion generica cuya implementacion se elige segun el tipo del primer argumento."@es ;
    skos:example """from functools import singledispatch
@singledispatch
def mostrar(x): print(x)
@mostrar.register
def _(x: list): print('lista', x)""" ;
    skos:related cfr:polimorfismo ;
    skos:scopeNote "Aporta despacho multiple basico al estilo funcional, sin recurrir a una jerarquia de clases."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:perteneceATema cfr:T_funcional ;
    cfkg:requierePrerrequisito cfr:clase,
        cfr:funcion,
        cfr:herencia,
        cfr:polimorfismo ;
    cfkg:tieneDificultad 4 .

cfr:slicing a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:PrincipioTransversal ;
    rdfs:label "Slicing"@en,
        "Slicing (rebanado)"@es ;
    owl:sameAs cfr:slicing ;
    skos:broader cfr:indexacion ;
    skos:broaderTransitive cfr:indexacion ;
    skos:definition "Extraccion de subsecuencias mediante la notacion [inicio:fin:paso]."@es ;
    skos:example """xs = [0, 1, 2, 3, 4]
xs[1:4]  # [1, 2, 3]""" ;
    skos:narrower cfr:slicing_str ;
    skos:scopeNote "El fin se excluye; admite indices negativos y omitir extremos. xs[:] copia la secuencia."@es ;
    cfkg:esPrerrequisitoDe cfr:slicing_str ;
    cfkg:perteneceATema cfr:T_estructuras ;
    cfkg:relacionadoConceptualmenteCon cfr:slicing_str ;
    cfkg:requierePrerrequisito cfr:indexacion,
        cfr:lista ;
    cfkg:tieneDificultad 3 .

cfr:slots a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:Paradigma ;
    rdfs:label "__slots__"@en,
        "__slots__"@es ;
    owl:sameAs cfr:slots ;
    skos:definition "Declaracion que fija los atributos permitidos de una clase y evita el __dict__ por instancia."@es ;
    skos:example """class Punto:
    __slots__ = ('x', 'y')
    def __init__(self, x, y):
        self.x, self.y = x, y""" ;
    skos:scopeNote "Reduce el consumo de memoria con muchas instancias, a costa de perder atributos dinamicos."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:perteneceATema cfr:T_poo ;
    cfkg:requierePrerrequisito cfr:atributo,
        cfr:clase,
        cfr:funcion,
        cfr:objeto ;
    cfkg:tieneDificultad 4 .

cfr:sobrecarga_operadores a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:Paradigma ;
    rdfs:label "Operator overloading"@en,
        "Sobrecarga de operadores"@es ;
    owl:sameAs cfr:sobrecarga_operadores ;
    skos:definition "Definicion del comportamiento de los operadores (+, ==, []) para objetos propios."@es ;
    skos:example """class V:
    def __init__(self, n): self.n = n
    def __add__(self, o): return V(self.n + o.n)""" ;
    skos:scopeNote "Se implementa con metodos dunder (__add__, __eq__); usala cuando aporte semantica natural."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:perteneceATema cfr:T_poo ;
    cfkg:requierePrerrequisito cfr:clase,
        cfr:dunder,
        cfr:funcion,
        cfr:metodo ;
    cfkg:tieneDificultad 5 .

cfr:str_repr a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:Paradigma ;
    rdfs:label "str and repr"@en,
        "__str__ y __repr__"@es ;
    owl:sameAs cfr:str_repr ;
    skos:definition "Metodos __str__ (representacion legible) y __repr__ (representacion no ambigua) de un objeto."@es ;
    skos:example """class P:
    def __repr__(self):
        return f'P({self.x!r})'""" ;
    skos:scopeNote "__str__ se usa en print y __repr__ en la consola/depuracion; define __repr__ al menos."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
