    skos:definition "Sintaxis concisa para construir listas a partir de un iterable, con filtros opcionales."@es ;
    skos:exactMatch wd:Q795065 ;
    skos:example "ys = [x*x for x in range(10) if x % 2 == 0]" ;
    skos:narrower cfr:comprension_dicts,
        cfr:comprension_sets,
        cfr:expresion_generadora ;
    skos:scopeNote "Mas legible y rapida que un bucle con append para transformaciones simples; evita anidar demasiado."@es ;
