cfr:type_checking a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:PrincipioTransversal ;
    rdfs:label "Type checking"@en,
        "Comprobación de tipos (mypy)"@es ;
    owl:sameAs cfr:type_checking ;
    skos:definition "Comprobacion estatica de tipos a partir de las anotaciones, sin ejecutar el programa."@es ;
    skos:example """# def f(x: int) -> int: return x + 1
# mypy avisa si se llama f('a')""" ;
    skos:scopeNote "Herramientas como mypy detectan incoherencias antes de la ejecucion; no afecta al rendimiento."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:perteneceATema cfr:T_testing ;
    cfkg:requierePrerrequisito cfr:anotaciones_tipo,
