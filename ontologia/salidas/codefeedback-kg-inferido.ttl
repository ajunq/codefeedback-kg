cfr:iterador a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:PrincipioTransversal ;
    rdfs:label "Iterator"@en,
        "Iterador (iter, next)"@es ;
    owl:sameAs cfr:iterador ;
    skos:closeMatch dbr:Iterator ;
    skos:definition "Objeto que produce los elementos de un iterable de uno en uno mediante next()."@es ;
    skos:exactMatch wd:Q1326388 ;
    skos:example """it = iter([1, 2])
next(it)  # 1""" ;
    skos:scopeNote "Implementa __iter__ y __next__; lanza StopIteration al agotarse."@es ;
