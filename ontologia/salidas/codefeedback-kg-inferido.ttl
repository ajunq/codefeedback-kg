cfr:pip_mod a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:PrincipioTransversal ;
    rdfs:label "pip"@en,
        "Gestor de paquetes (pip)"@es ;
    owl:sameAs cfr:pip_mod ;
    skos:definition "Gestor de paquetes pip para instalar bibliotecas desde el indice PyPI."@es ;
    skos:example """pip install requests
pip freeze > requirements.txt""" ;
    skos:scopeNote "Trabaja con requirements.txt e idealmente dentro de un entorno virtual."@es ;
    cfkg:aNivelDominio cfr:basico ;
    cfkg:perteneceATema cfr:T_modulos ;
    cfkg:requierePrerrequisito cfr:import_mod,
