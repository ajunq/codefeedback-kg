cfr:memoizacion a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:PrincipioTransversal ;
    rdfs:label "Memoization"@en,
        "Memoización (lru_cache)"@es ;
    owl:sameAs cfr:memoizacion ;
    skos:closeMatch dbr:Memoization ;
    skos:definition "Tecnica que almacena en cache los resultados de una funcion para reutilizarlos."@es ;
    skos:example """import functools
@functools.lru_cache
def fib(n):
    return n if n < 2 else fib(n-1) + fib(n-2)""" ;
    skos:scopeNote "functools.lru_cache la implementa con un decorador; acelera funciones puras y recursivas."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:esPrerrequisitoDe cfr:lru_cache,
        cfr:prog_dinamica ;
    cfkg:perteneceATema cfr:T_recursion ;
    cfkg:relacionadoConceptualmenteCon cfr:lru_cache,
        cfr:prog_dinamica ;
    cfkg:requierePrerrequisito cfr:diccionario,
        cfr:funcion,
        cfr:recursion ;
    cfkg:tieneDificultad 4 .

cfr:notacion_o a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:PrincipioTransversal ;
    rdfs:label "Big-O notation"@en,
        "Notación O grande"@es ;
    owl:sameAs cfr:notacion_o ;
    skos:closeMatch dbr:Big_O_notation ;
    skos:definition "Notacion O grande que describe el crecimiento asintotico del coste de un algoritmo."@es ;
    skos:exactMatch wd:Q269878 ;
    skos:example """# Busqueda binaria: O(log n)
# Ordenacion por mezcla: O(n log n)""" ;
    skos:narrower cfr:ordenacion_burbuja,
        cfr:ordenacion_mezcla,
        cfr:ordenacion_rapida ;
    skos:scopeNote "Ignora constantes y terminos menores; O(1) < O(log n) < O(n) < O(n log n) < O(n^2)."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:esPrerrequisitoDe cfr:ordenacion_mezcla ;
    cfkg:perteneceATema cfr:T_algoritmos ;
    cfkg:relacionadoConceptualmenteCon cfr:ordenacion_mezcla ;
    cfkg:requierePrerrequisito cfr:complejidad ;
    cfkg:tieneDificultad 4 .

cfr:ordenacion_mezcla a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:PrincipioTransversal ;
    rdfs:label "Merge sort"@en,
        "Ordenación por mezcla"@es ;
    owl:sameAs cfr:ordenacion_mezcla ;
    skos:broader cfr:notacion_o ;
    skos:broaderTransitive cfr:notacion_o ;
    skos:closeMatch dbr:Merge_sort ;
    skos:definition "Algoritmo de ordenacion por division y conquista que fusiona sublistas ordenadas."@es ;
    skos:exactMatch wd:Q189057 ;
    skos:example """def mezcla(xs):
    if len(xs) <= 1: return xs
    m = len(xs)//2
    return fusion(mezcla(xs[:m]), mezcla(xs[m:]))""" ;
    skos:scopeNote "Estable y O(n log n) en el peor caso, pero usa memoria adicional O(n)."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:perteneceATema cfr:T_algoritmos ;
    cfkg:requierePrerrequisito cfr:complejidad,
        cfr:funcion,
        cfr:notacion_o,
        cfr:recursion ;
    cfkg:tieneComplejidadTemporal "O(n log n)"^^xsd:string ;
    cfkg:tieneDificultad 5 .

