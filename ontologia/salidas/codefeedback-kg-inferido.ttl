        cfkg:EntidadEducativa,
        cfkg:FuncionIntegrada ;
    rdfs:label "zip"@en,
        "zip()"@es ;
    owl:sameAs cfr:zip_f ;
    skos:definition "Funcion zip() que combina varios iterables en tuplas de elementos correspondientes."@es ;
    skos:example "list(zip([1, 2], ['a', 'b']))  # [(1, 'a'), (2, 'b')]" ;
    skos:scopeNote "Se detiene en el iterable mas corto; zip(*m) permite transponer; para rellenar usa itertools.zip_longest."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:perteneceATema cfr:T_control ;
