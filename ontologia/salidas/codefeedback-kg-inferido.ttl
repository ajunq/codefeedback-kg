    rdfs:label "Method resolution order"@en,
        "Orden de resolución (MRO)"@es ;
    owl:sameAs cfr:mro ;
    skos:definition "Orden de resolucion de metodos (MRO) que determina como Python busca atributos en herencia multiple."@es ;
    skos:example """class C(A, B): ...
C.mro()""" ;
    skos:scopeNote "Se calcula con el algoritmo C3 y es consultable con NombreClase.mro()."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:perteneceATema cfr:T_poo ;
    cfkg:requierePrerrequisito cfr:clase,
