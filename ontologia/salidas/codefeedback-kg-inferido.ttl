    rdfs:label "json module"@en,
        "Módulo json"@es ;
    owl:sameAs cfr:json_mod ;
    skos:closeMatch dbr:JSON ;
    skos:definition "Modulo json para serializar objetos Python a texto JSON y deserializarlos."@es ;
    skos:exactMatch wd:Q2063 ;
    skos:example """import json
json.dumps({'a': 1})  # '{"a": 1}'""" ;
    skos:scopeNote "dumps/loads trabajan con cadenas; dump/load con ficheros. No todos los tipos son serializables."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:perteneceATema cfr:T_ficheros ;
    cfkg:requierePrerrequisito cfr:diccionario ;
    cfkg:tieneDificultad 3 ;
    cfkg:tieneURLDocumentacion "https://docs.python.org/3/library/json.html"^^xsd:anyURI .

cfr:logging_mod a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
