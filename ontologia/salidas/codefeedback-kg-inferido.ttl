cfr:regex a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:ModuloLibreria ;
    rdfs:label "Regular expressions"@en,
        "Expresiones regulares (re)"@es ;
    owl:sameAs cfr:regex ;
    skos:closeMatch dbr:Regular_expression ;
    skos:definition "Expresiones regulares (modulo re) para buscar y manipular texto segun patrones."@es ;
    skos:exactMatch wd:Q185612 ;
    skos:example """import re
re.findall(r'\\d+', 'a12b3')  # ['12', '3']""" ;
    skos:scopeNote "Compila patrones con re.compile; usa cadenas raw (r'...') para las barras invertidas."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:perteneceATema cfr:T_strings ;
    cfkg:requierePrerrequisito cfr:tipo_str ;
    cfkg:tieneDificultad 5 ;
    cfkg:tieneURLDocumentacion "https://docs.python.org/3/library/re.html"^^xsd:anyURI .

cfr:tabla_hash a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:EstructuraDeDatos ;
    rdfs:label "Hash table"@en,
        "Tabla hash"@es ;
    owl:sameAs cfr:tabla_hash ;
    skos:broader cfr:diccionario ;
    skos:broaderTransitive cfr:diccionario ;
    skos:closeMatch dbr:Hash_table ;
    skos:definition "Estructura que asocia claves a valores usando una funcion hash para acceso medio O(1)."@es ;
    skos:exactMatch wd:Q207440 ;
    skos:example """d = {}
d['clave'] = 'valor'  # respaldado por una tabla hash""" ;
    skos:scopeNote "Es la base interna de dict y set; las colisiones se resuelven internamente."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:perteneceATema cfr:T_algoritmos ;
    cfkg:requierePrerrequisito cfr:diccionario ;
    cfkg:tieneComplejidadTemporal "O(1)"^^xsd:string ;
    cfkg:tieneDificultad 4 .

cfr:truthiness a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
