        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:FuncionIntegrada ;
    rdfs:label "sum"@en,
        "Funcion sum"@es ;
    owl:sameAs cfr:sum_func ;
    skos:definition "Funcion que suma los elementos de un iterable numerico, con un valor inicial opcional."@es ;
    skos:example """sum([1, 2, 3])      # 6
sum([1, 2], 10)     # 13""" ;
    skos:scopeNote "No la uses para concatenar cadenas (usa join); admite un segundo argumento como punto de partida."@es ;
    cfkg:aNivelDominio cfr:basico ;
    cfkg:perteneceATema cfr:T_control ;
    cfkg:requierePrerrequisito cfr:iterables,
        cfr:lista ;
    cfkg:tieneDificultad 1 .

cfr:ternario a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:EstructuraDeControl ;
    rdfs:label "Ternary operator"@en,
        "Operador ternario"@es ;
    owl:sameAs cfr:ternario ;
    skos:definition "Expresion condicional en una linea: valor_si_verdadero if condicion else valor_si_falso."@es ;
    skos:example "signo = 'par' if n % 2 == 0 else 'impar'" ;
    skos:scopeNote "Util para asignaciones breves; si la logica crece, un if/else completo es mas claro."@es ;
    cfkg:aNivelDominio cfr:basico ;
    cfkg:perteneceATema cfr:T_control ;
    cfkg:requierePrerrequisito cfr:condicional,
        cfr:tipo_bool ;
    cfkg:tieneDificultad 2 .

cfr:tipo_float a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:TipoDeDato ;
    rdfs:label "Float"@en,
        "Flotante (float)"@es ;
    owl:sameAs cfr:tipo_float ;
    skos:definition "Tipo numerico de coma flotante de doble precision (IEEE 754)."@es ;
    skos:example "0.1 + 0.2  # 0.30000000000000004" ;
    skos:scopeNote "Tiene precision limitada: evita comparar floats con == y usa math.isclose."@es ;
    cfkg:aNivelDominio cfr:basico ;
    cfkg:contrastaCon cfr:tipo_int ;
    cfkg:esPrerrequisitoDe cfr:tipo_complex ;
    cfkg:perteneceATema cfr:T_tipos ;
    cfkg:relacionadoConceptualmenteCon cfr:tipo_complex,
        cfr:tipo_int ;
