        cfr:functools_wraps,
        cfr:lru_cache,
        cfr:metodo_clase,
        cfr:metodo_estatico,
        cfr:nonlocal_kw,
        cfr:propiedad ;
    cfkg:requierePrerrequisito cfr:ambito,
        cfr:funcion ;
    cfkg:tieneDificultad 4 .

