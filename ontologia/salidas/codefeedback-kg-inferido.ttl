        cfr:itertools_product ;
    cfkg:requierePrerrequisito cfr:iterables,
        cfr:lista ;
    cfkg:tieneDificultad 4 ;
    cfkg:tieneURLDocumentacion "https://docs.python.org/3/library/itertools.html"^^xsd:anyURI .

