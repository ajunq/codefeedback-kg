cfr:busqueda_lineal a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:PrincipioTransversal ;
    rdfs:label "Linear search"@en,
        "Búsqueda lineal"@es ;
    owl:sameAs cfr:busqueda_lineal ;
    skos:closeMatch dbr:Linear_search ;
    skos:definition "Algoritmo que recorre una secuencia elemento a elemento hasta encontrar el buscado."@es ;
    skos:exactMatch wd:Q787903 ;
    skos:example """def lineal(xs, x):
    for i, v in enumerate(xs):
        if v == x:
            return i
    return -1""" ;
    skos:related cfr:busqueda_binaria ;
    skos:scopeNote "Simple y sin requisitos de orden, pero ineficiente (O(n)) para colecciones grandes."@es ;
    cfkg:aNivelDominio cfr:basico ;
    cfkg:contrastaCon cfr:busqueda_binaria ;
    cfkg:perteneceATema cfr:T_algoritmos ;
    cfkg:relacionadoConceptualmenteCon cfr:busqueda_binaria ;
    cfkg:requierePrerrequisito cfr:asignacion,
        cfr:bucle_for ;
    cfkg:tieneComplejidadTemporal "O(n)"^^xsd:string ;
    cfkg:tieneDificultad 2 .

cfr:copia_profunda a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:PrincipioTransversal ;
    rdfs:label "Deep copy"@en,
        "Copia profunda"@es ;
    owl:sameAs cfr:copia_profunda ;
    skos:definition "Copia que duplica recursivamente un objeto y todos los objetos anidados que contiene."@es ;
    skos:example """import copy
b = copy.deepcopy(a)""" ;
    skos:scopeNote "Usa copy.deepcopy cuando modificar la copia no debe afectar al original anidado; es mas costosa que la superficial."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:contrastaCon cfr:copia_superficial ;
    cfkg:perteneceATema cfr:T_tipos ;
    cfkg:relacionadoConceptualmenteCon cfr:copia_superficial ;
    cfkg:requierePrerrequisito cfr:copia_superficial,
        cfr:lista,
        cfr:mutabilidad ;
    cfkg:tieneDificultad 4 .

cfr:ej_suma_lista a _:n36bd77e927a0451a9b86ac2c9f81b30db7,
        owl:Thing,
        cfkg:Ejercicio,
        cfkg:EntidadEducativa ;
    rdfs:label "Sum the elements of a list"@en,
        "Suma de los elementos de una lista"@es ;
    owl:sameAs cfr:ej_suma_lista ;
    cfkg:cubreConcepto cfr:bucle_for,
        cfr:funcion,
