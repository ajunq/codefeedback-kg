    rdfs:label "Heap"@en,
        "Montículo (heapq)"@es ;
    owl:sameAs cfr:heap ;
    skos:closeMatch dbr:Heap_\(data_structure\) ;
    skos:definition "Arbol binario parcialmente ordenado que da acceso O(1) al minimo o maximo (modulo heapq)."@es ;
    skos:example """import heapq
h = [3, 1, 2]
heapq.heapify(h)
heapq.heappop(h)  # 1""" ;
    skos:scopeNote "heapq implementa un min-heap sobre una lista; util para colas de prioridad y los k mayores."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:esPrerrequisitoDe cfr:cola_prioridad ;
