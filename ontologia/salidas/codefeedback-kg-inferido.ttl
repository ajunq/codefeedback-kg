        cfkg:EntidadEducativa,
        cfkg:Paradigma ;
    rdfs:label "Context manager"@en,
        "Gestor de contexto"@es ;
    owl:sameAs cfr:context_manager ;
    skos:definition "Objeto que define la entrada (__enter__) y salida (__exit__) de un bloque with para gestionar recursos."@es ;
    skos:example """class Recurso:
    def __enter__(self): return self
    def __exit__(self, *a): print('cerrado')""" ;
    skos:scopeNote "Garantiza la liberacion del recurso incluso si ocurre una excepcion; contextlib facilita crearlos."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:esPrerrequisitoDe cfr:contextlib_mod ;
    cfkg:perteneceATema cfr:T_control ;
    cfkg:relacionadoConceptualmenteCon cfr:contextlib_mod ;
