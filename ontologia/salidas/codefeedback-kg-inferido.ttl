    owl:sameAs cfr:interbloqueo ;
    skos:closeMatch dbr:Deadlock ;
    skos:definition "Situacion en la que dos o mas hilos se bloquean mutuamente esperando recursos que el otro retiene."@es ;
    skos:exactMatch wd:Q623276 ;
    skos:example """# Hilo 1: lock_a luego lock_b
# Hilo 2: lock_b luego lock_a  -> interbloqueo""" ;
    skos:related cfr:lock_threading ;
    skos:scopeNote "Se previene adquiriendo los cerrojos siempre en el mismo orden o con tiempos de espera."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:perteneceATema cfr:T_concurrencia ;
    cfkg:requierePrerrequisito cfr:gil,
