    skos:scopeNote "Adecuados para E/S concurrente; por el GIL no paralelizan calculo de CPU. Cuidado con las condiciones de carrera."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:contrastaCon cfr:multiproceso ;
    cfkg:esPrerrequisitoDe cfr:concurrent_futures,
        cfr:condicion_carrera,
