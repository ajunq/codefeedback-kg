    owl:sameAs cfr:modulo_random ;
    skos:definition "Modulo random para generar numeros pseudoaleatorios y muestreos."@es ;
    skos:example """import random
random.randint(1, 6)""" ;
    skos:scopeNote "No es criptograficamente seguro; usa el modulo secrets para contrasenas o tokens."@es ;
