cfr:modulo_sys a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:ModuloLibreria ;
    rdfs:label "sys module"@en,
        "Módulo sys"@es ;
    owl:sameAs cfr:modulo_sys ;
    skos:definition "Modulo sys con acceso a parametros y funciones del interprete (argv, path, exit)."@es ;
    skos:example """import sys
print(sys.argv)""" ;
    skos:scopeNote "sys.argv recibe los argumentos de linea de comandos; sys.exit termina el programa."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:esPrerrequisitoDe cfr:argparse_mod ;
    cfkg:perteneceATema cfr:T_modulos ;
    cfkg:relacionadoConceptualmenteCon cfr:argparse_mod ;
    cfkg:requierePrerrequisito cfr:import_mod ;
    cfkg:tieneDificultad 3 .

cfr:namedtuple a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:EstructuraDeDatos ;
    rdfs:label "Named tuple"@en,
        "namedtuple"@es ;
    owl:sameAs cfr:namedtuple ;
    skos:broader cfr:tupla ;
    skos:broaderTransitive cfr:tupla ;
    skos:definition "Tupla con campos nombrados (collections.namedtuple) accesibles por atributo."@es ;
    skos:example """from collections import namedtuple
Punto = namedtuple('Punto', 'x y')
Punto(1, 2).x""" ;
    skos:related cfr:dataclass ;
    skos:scopeNote "Ligera e inmutable; mejora la legibilidad frente a tuplas posicionales. Para datos mutables usa dataclass."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:perteneceATema cfr:T_tipos ;
    cfkg:requierePrerrequisito cfr:tupla ;
    cfkg:tieneDificultad 3 .

cfr:paquete a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
