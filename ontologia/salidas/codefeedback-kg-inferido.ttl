cfr:map_func a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:FuncionIntegrada ;
    rdfs:label "map"@en,
        "map()"@es ;
    owl:sameAs cfr:map_func ;
    skos:definition "Funcion map() que aplica una funcion a cada elemento de uno o varios iterables."@es ;
    skos:example "dobles = list(map(lambda x: x*2, [1, 2, 3]))" ;
    skos:related cfr:filter_func ;
    skos:scopeNote "Devuelve un iterador perezoso; una comprension suele ser mas legible."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:perteneceATema cfr:T_funcional ;
    cfkg:requierePrerrequisito cfr:funcion,
        cfr:funcion_orden_superior,
        cfr:iterables,
        cfr:lista ;
