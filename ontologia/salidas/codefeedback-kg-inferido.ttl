    skos:definition "Metodo (@staticmethod) que no recibe ni instancia ni clase, agrupado por afinidad logica."@es ;
    skos:example """class Mat:
    @staticmethod
    def suma(a, b):
        return a + b""" ;
    skos:scopeNote "Se comporta como una funcion normal dentro del espacio de nombres de la clase."@es ;
