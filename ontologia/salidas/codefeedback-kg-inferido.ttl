cfr:generador a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:EstructuraDeControl ;
    rdfs:label "Generator"@en,
        "Generador (yield)"@es ;
    owl:sameAs cfr:generador ;
    skos:closeMatch dbr:Generator_\(computer_programming\) ;
    skos:definition "Funcion que produce una secuencia de valores de forma perezosa usando yield."@es ;
    skos:exactMatch wd:Q2565187 ;
    skos:example """def cuenta(n):
    i = 0
    while i < n:
        yield i
        i += 1""" ;
    skos:scopeNote "Mantiene su estado entre llamadas y ahorra memoria; se agota tras recorrerse una vez."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:esPrerrequisitoDe cfr:async_generator,
