cfr:operador_aritmetico a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:OperadorDelLenguaje ;
    rdfs:label "Arithmetic operators"@en,
        "Operadores aritmeticos"@es ;
    owl:sameAs cfr:operador_aritmetico ;
    skos:definition "Operadores que realizan calculos numericos: +, -, *, /, //, % y **."@es ;
    skos:example """7 // 2   # 3
7 % 2    # 1
2 ** 10  # 1024""" ;
    skos:scopeNote "// es la division entera y / siempre devuelve float; ** eleva a una potencia."@es ;
    cfkg:aNivelDominio cfr:basico ;
    cfkg:perteneceATema cfr:T_fundamentos ;
    cfkg:requierePrerrequisito cfr:variable ;
    cfkg:tieneDificultad 1 .

cfr:operador_asignacion_aumentada a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:OperadorDelLenguaje ;
    rdfs:label "Augmented assignment"@en,
        "Asignacion aumentada"@es ;
    owl:sameAs cfr:operador_asignacion_aumentada ;
    skos:definition "Operadores como +=, -= o *= que combinan una operacion con la asignacion."@es ;
    skos:example """total = 0
total += 5  # total == 5""" ;
    skos:scopeNote "En objetos mutables (listas) modifican en sitio; en inmutables crean un objeto nuevo."@es ;
    cfkg:aNivelDominio cfr:basico ;
    cfkg:perteneceATema cfr:T_fundamentos ;
    cfkg:requierePrerrequisito cfr:asignacion ;
    cfkg:tieneDificultad 1 .

cfr:operador_bitwise a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:OperadorDelLenguaje ;
    rdfs:label "Bitwise operators"@en,
        "Operadores a nivel de bits"@es ;
    owl:sameAs cfr:operador_bitwise ;
    skos:definition "Operadores que manipulan los bits individuales de los enteros: &, |, ^, ~, << y >>."@es ;
    skos:example """0b1100 & 0b1010  # 0b1000 (8)
1 << 4           # 16""" ;
    skos:scopeNote "Utiles para mascaras, banderas y optimizaciones; no confundir & con and."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:perteneceATema cfr:T_fundamentos ;
    cfkg:requierePrerrequisito cfr:tipo_int ;
    cfkg:tieneDificultad 3 .

cfr:operador_comparacion a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:OperadorDelLenguaje ;
    rdfs:label "Comparison operators"@en,
        "Operadores de comparacion"@es ;
    owl:sameAs cfr:operador_comparacion ;
    skos:definition "Operadores que comparan valores y devuelven un booleano: ==, !=, <, <=, >, >=."@es ;
    skos:example "1 < 2 <= 2  # True" ;
    skos:scopeNote "Pueden encadenarse (1 < x < 10); == compara valor mientras que is compara identidad."@es ;
    cfkg:aNivelDominio cfr:basico ;
    cfkg:perteneceATema cfr:T_fundamentos ;
    cfkg:requierePrerrequisito cfr:variable ;
    cfkg:tieneDificultad 1 .

cfr:operador_logico a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:OperadorDelLenguaje ;
    rdfs:label "Logical operators"@en,
        "Operadores logicos"@es ;
    owl:sameAs cfr:operador_logico ;
    skos:definition "Operadores and, or y not que combinan o niegan expresiones booleanas."@es ;
    skos:example """(x > 0) and (x < 10)
nombre or 'anonimo'""" ;
    skos:scopeNote "and/or evaluan de forma perezosa (cortocircuito) y devuelven uno de los operandos, no solo True/False."@es ;
    cfkg:aNivelDominio cfr:basico ;
    cfkg:perteneceATema cfr:T_fundamentos ;
    cfkg:requierePrerrequisito cfr:tipo_bool ;
    cfkg:tieneDificultad 1 .

cfr:operador_pertenencia a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:OperadorDelLenguaje ;
    rdfs:label "Membership operators"@en,
        "Operadores de pertenencia (in)"@es ;
    owl:sameAs cfr:operador_pertenencia ;
    skos:definition "Operadores in y not in que comprueban si un valor esta contenido en una coleccion."@es ;
    skos:example """3 in [1, 2, 3]   # True
'a' in 'casa'    # True""" ;
    skos:scopeNote "En sets y dicts es O(1); en listas es O(n). Tambien busca subcadenas en strings."@es ;
    cfkg:aNivelDominio cfr:basico ;
    cfkg:perteneceATema cfr:T_estructuras ;
    cfkg:requierePrerrequisito cfr:lista ;
    cfkg:tieneDificultad 1 .

cfr:ordered_dict a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:EstructuraDeDatos ;
    rdfs:label "OrderedDict"@en,
        "collections.OrderedDict"@es ;
    owl:sameAs cfr:ordered_dict ;
    skos:definition "Diccionario que recuerda el orden de insercion y ofrece operaciones de reordenacion."@es ;
    skos:example """from collections import OrderedDict
d = OrderedDict(a=1, b=2)
d.move_to_end('a')""" ;
    skos:related cfr:diccionario ;
    skos:scopeNote "Desde Python 3.7 dict ya conserva el orden, pero OrderedDict aporta move_to_end e igualdad sensible al orden."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:perteneceATema cfr:T_estructuras ;
    cfkg:requierePrerrequisito cfr:diccionario ;
    cfkg:tieneDificultad 3 .

cfr:pytest_mod a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
