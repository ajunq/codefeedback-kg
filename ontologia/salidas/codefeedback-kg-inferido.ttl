        cfkg:EntidadEducativa,
        cfkg:ModuloLibreria ;
    rdfs:label "Package"@en,
        "Paquete"@es ;
    owl:sameAs cfr:paquete ;
    skos:definition "Directorio que agrupa modulos relacionados y se importa como una unidad."@es ;
    skos:example "from paquete.subpaquete import modulo" ;
    skos:scopeNote "Tradicionalmente contiene __init__.py; permite organizar proyectos en jerarquias de espacios de nombres."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
