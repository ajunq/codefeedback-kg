    skos:example "'Python'[0:3]  # 'Pyt'" ;
    skos:scopeNote "Las cadenas son inmutables: el slicing devuelve una nueva cadena. xs[::-1] la invierte."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
