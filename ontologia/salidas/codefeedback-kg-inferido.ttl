        cfr:iterables,
        cfr:iterador,
        cfr:lista ;
    cfkg:tieneDificultad 4 .

cfr:context_manager a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
