        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:PrincipioTransversal ;
    rdfs:label "Binary search"@en,
        "Búsqueda binaria"@es ;
    owl:sameAs cfr:busqueda_binaria ;
    skos:closeMatch dbr:Binary_search_algorithm ;
    skos:definition "Algoritmo que localiza un elemento en una lista ordenada dividiendo a la mitad el espacio de busqueda."@es ;
    skos:exactMatch wd:Q243754 ;
    skos:example """def binaria(xs, x):
    lo, hi = 0, len(xs) - 1
    while lo <= hi:
        m = (lo + hi) // 2
        if xs[m] == x: return m
        if xs[m] < x: lo = m + 1
        else: hi = m - 1
    return -1""" ;
    skos:prefLabel "Búsqueda binaria"@es ;
    skos:related cfr:busqueda_lineal ;
    skos:scopeNote "Requiere que la secuencia este ordenada; su coste es O(log n) frente a O(n) de la busqueda lineal."@es ;
    cfkg:contrastaCon cfr:busqueda_lineal ;
    cfkg:cubiertoPorEjercicio cfr:ej_busqueda ;
    cfkg:perteneceATema cfr:T_complejidad ;
    cfkg:relacionadoConceptualmenteCon cfr:busqueda_lineal,
        cfr:lista ;
    cfkg:requierePrerrequisito cfr:bucle_while,
        cfr:condicional,
        cfr:indexacion,
        cfr:lista,
        cfr:tipo_bool ;
    cfkg:seAplicaA cfr:lista ;
    cfkg:tieneComplejidadTemporal "O(log n)"^^xsd:string ;
    cfkg:tieneDificultad 4 .

cfr:closure a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
