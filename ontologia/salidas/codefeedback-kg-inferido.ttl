    skos:exactMatch wd:Q567612 ;
    skos:example "ordenar = sorted(pares, key=lambda p: p[1])" ;
    skos:scopeNote "Util como argumento breve (key de sorted); si crece, mejor una funcion con def."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:perteneceATema cfr:T_funcional ;
    cfkg:requierePrerrequisito cfr:funcion ;
