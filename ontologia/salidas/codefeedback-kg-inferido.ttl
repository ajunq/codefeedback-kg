    skos:example """nombre = 'Ana'
f'Hola {nombre}, {2+2=}'""" ;
    skos:related cfr:formato_str ;
    skos:scopeNote "Disponible desde Python 3.6; admite formato y, desde 3.8, la sintaxis de depuracion {x=}."@es ;
