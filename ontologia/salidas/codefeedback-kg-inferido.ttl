    owl:sameAs cfr:arbol_estr ;
    skos:closeMatch dbr:Tree_\(data_structure\) ;
    skos:definition "Estructura de datos jerarquica formada por nodos con un nodo raiz y subarboles hijos."@es ;
    skos:exactMatch wd:Q223655 ;
    skos:example "nodo = {'valor': 1, 'hijos': [{'valor': 2, 'hijos': []}]}" ;
    skos:narrower cfr:arbol_binario ;
