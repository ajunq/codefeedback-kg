    rdfs:label "Walrus operator"@en,
        "Operador morsa (:=)"@es ;
    owl:sameAs cfr:walrus ;
    skos:definition "Operador de asignacion en expresion := que asigna y devuelve un valor a la vez."@es ;
    skos:example """if (n := len(datos)) > 10:
    print(f'{n} elementos')""" ;
    skos:scopeNote "Disponible desde Python 3.8; util para reutilizar un calculo dentro de una condicion sin repetirlo."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:introducidoEnVersion "3.8"^^xsd:string ;
    cfkg:perteneceATema cfr:T_control ;
    cfkg:requierePrerrequisito cfr:condicional,
        cfr:tipo_bool ;
    cfkg:tieneDificultad 3 .

