cfr:any_all a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:FuncionIntegrada ;
    rdfs:label "any and all"@en,
        "Funciones any y all"@es ;
    owl:sameAs cfr:any_all ;
    skos:definition "any() devuelve True si algun elemento es verdadero; all() si todos lo son."@es ;
    skos:example """all(x > 0 for x in [1, 2, 3])  # True
any(x < 0 for x in [1, 2, 3])  # False""" ;
    skos:related cfr:truthiness ;
    skos:scopeNote "Operan de forma perezosa con cortocircuito; sobre un iterable vacio, all es True y any es False."@es ;
    cfkg:aNivelDominio cfr:basico ;
    cfkg:perteneceATema cfr:T_control ;
    cfkg:requierePrerrequisito cfr:iterables,
        cfr:lista ;
    cfkg:tieneDificultad 2 .

cfr:conversion_tipos a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:PrincipioTransversal ;
    rdfs:label "Type casting"@en,
        "Conversión de tipos"@es ;
    owl:sameAs cfr:conversion_tipos ;
    skos:definition "Cambio explicito del tipo de un valor mediante constructores como int(), str() o float()."@es ;
    skos:example """edad = int('42')
texto = str(3.14)""" ;
    skos:scopeNote "Evita errores de TypeError al combinar tipos incompatibles; puede lanzar ValueError si el formato no es valido."@es ;
    cfkg:aNivelDominio cfr:basico ;
    cfkg:perteneceATema cfr:T_tipos ;
    cfkg:requierePrerrequisito cfr:tipo_int,
        cfr:tipo_str ;
    cfkg:tieneDificultad 2 .

cfr:enum_tipo a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:Paradigma ;
    rdfs:label "Enum"@en,
        "Enumeración (Enum)"@es ;
    owl:sameAs cfr:enum_tipo ;
    skos:definition "Tipo enumerado (enum.Enum) que define un conjunto de constantes simbolicas con nombre."@es ;
    skos:exactMatch wd:Q760170 ;
    skos:example """from enum import Enum
class Color(Enum):
    ROJO = 1
    VERDE = 2""" ;
    skos:related cfr:clase ;
    skos:scopeNote "Mejora la legibilidad frente a constantes sueltas; los miembros son unicos y comparables por identidad."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:perteneceATema cfr:T_tipos ;
    cfkg:requierePrerrequisito cfr:clase,
        cfr:funcion ;
    cfkg:tieneDificultad 3 .

cfr:global_kw a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:PrincipioTransversal ;
    rdfs:label "global"@en,
        "Palabra clave global"@es ;
    owl:sameAs cfr:global_kw ;
    skos:definition "Declaracion que permite a una funcion reasignar una variable del ambito global."@es ;
    skos:example """contador = 0
def inc():
    global contador
    contador += 1""" ;
    skos:related cfr:ambito,
        cfr:nonlocal_kw ;
    skos:scopeNote "Su uso suele indicar un diseno mejorable; prefiere devolver valores o encapsular el estado."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:perteneceATema cfr:T_funciones ;
    cfkg:requierePrerrequisito cfr:ambito,
        cfr:funcion ;
    cfkg:tieneDificultad 3 .

cfr:identidad_objetos a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:PrincipioTransversal ;
    rdfs:label "Object identity"@en,
        "Identidad de objetos (is)"@es ;
    owl:sameAs cfr:identidad_objetos ;
    skos:definition "Comprobacion (is) de si dos nombres referencian exactamente el mismo objeto en memoria."@es ;
    skos:example """a = [1]
b = a
a is b  # True
a is [1]  # False""" ;
    skos:scopeNote "is compara identidad y == compara valor; reserva is para None y centinelas."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:esPrerrequisitoDe cfr:operador_identidad ;
    cfkg:perteneceATema cfr:T_tipos ;
    cfkg:relacionadoConceptualmenteCon cfr:operador_identidad ;
    cfkg:requierePrerrequisito cfr:mutabilidad,
        cfr:mutable_inmutable ;
    cfkg:tieneDificultad 3 .

cfr:indexacion_negativa a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:PrincipioTransversal ;
    rdfs:label "Negative indexing"@en,
        "Indexación negativa"@es ;
    owl:sameAs cfr:indexacion_negativa ;
    skos:broader cfr:indexacion ;
    skos:broaderTransitive cfr:indexacion ;
    skos:definition "Acceso a elementos contando desde el final con indices negativos (-1 es el ultimo)."@es ;
    skos:example """xs = [1, 2, 3]
xs[-1]  # 3""" ;
    skos:scopeNote "Evita calcular len(x)-1; tambien aplica al slicing."@es ;
    cfkg:aNivelDominio cfr:basico ;
    cfkg:perteneceATema cfr:T_estructuras ;
    cfkg:requierePrerrequisito cfr:indexacion,
        cfr:lista ;
    cfkg:tieneDificultad 2 .

cfr:ordenacion_burbuja a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:PrincipioTransversal ;
    rdfs:label "Bubble sort"@en,
        "Ordenación de burbuja"@es ;
    owl:sameAs cfr:ordenacion_burbuja ;
    skos:broader cfr:notacion_o ;
    skos:broaderTransitive cfr:notacion_o ;
    skos:closeMatch dbr:Bubble_sort ;
    skos:definition "Algoritmo de ordenacion que intercambia repetidamente elementos adyacentes desordenados."@es ;
    skos:exactMatch wd:Q60864 ;
    skos:example """def burbuja(xs):
    for i in range(len(xs)):
        for j in range(len(xs)-1-i):
            if xs[j] > xs[j+1]:
                xs[j], xs[j+1] = xs[j+1], xs[j]""" ;
    skos:scopeNote "Didactico pero ineficiente (O(n^2)); en la practica usa sorted() (Timsort)."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:perteneceATema cfr:T_algoritmos ;
    cfkg:requierePrerrequisito cfr:asignacion,
        cfr:bucle_for ;
    cfkg:tieneComplejidadTemporal "O(n^2)"^^xsd:string ;
    cfkg:tieneDificultad 3 .

cfr:ordenacion_rapida a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:PrincipioTransversal ;
    rdfs:label "Quicksort"@en,
        "Ordenación rápida"@es ;
    owl:sameAs cfr:ordenacion_rapida ;
    skos:broader cfr:notacion_o ;
    skos:broaderTransitive cfr:notacion_o ;
    skos:closeMatch dbr:Quicksort ;
    skos:definition "Algoritmo de ordenacion por division y conquista que particiona en torno a un pivote."@es ;
    skos:exactMatch wd:Q486598 ;
    skos:example """def rapida(xs):
    if len(xs) <= 1: return xs
    p = xs[0]
    return rapida([x for x in xs[1:] if x < p]) + [p] + rapida([x for x in xs[1:] if x >= p])""" ;
    skos:scopeNote "O(n log n) en promedio y O(n^2) en el peor caso; la eleccion del pivote es clave."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:perteneceATema cfr:T_algoritmos ;
    cfkg:requierePrerrequisito cfr:funcion,
        cfr:recursion ;
    cfkg:tieneComplejidadTemporal "O(n log n)"^^xsd:string ;
    cfkg:tieneDificultad 5 .

cfr:parametros a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:PrincipioTransversal ;
    rdfs:label "Parameters"@en,
        "Parámetros y argumentos"@es ;
    owl:sameAs cfr:parametros ;
    skos:definition "Variables declaradas en la definicion de una funcion que reciben los argumentos al llamarla."@es ;
    skos:example """def f(a, b=0):  # a y b son parametros
    return a + b""" ;
    skos:scopeNote "Distingue parametro (en la definicion) de argumento (en la llamada); admiten valores por defecto."@es ;
    cfkg:aNivelDominio cfr:basico ;
    cfkg:esPrerrequisitoDe cfr:args_kwargs,
        cfr:argumentos_nombrados,
        cfr:valor_por_defecto ;
    cfkg:perteneceATema cfr:T_funciones ;
    cfkg:relacionadoConceptualmenteCon cfr:args_kwargs,
        cfr:argumentos_nombrados,
        cfr:valor_por_defecto ;
    cfkg:requierePrerrequisito cfr:funcion ;
    cfkg:tieneDificultad 2 .

cfr:recursion_cola a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
        _:n36bd77e927a0451a9b86ac2c9f81b30db12,
        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:PrincipioTransversal ;
    rdfs:label "Tail recursion"@en,
        "Recursión de cola"@es ;
    owl:sameAs cfr:recursion_cola ;
    skos:broader cfr:recursion ;
    skos:broaderTransitive cfr:recursion ;
    skos:closeMatch dbr:Tail_call ;
    skos:definition "Recursion en la que la llamada recursiva es la ultima operacion de la funcion."@es ;
    skos:exactMatch wd:Q1340959 ;
    skos:example """def suma(xs, acc=0):
    if not xs: return acc
    return suma(xs[1:], acc + xs[0])""" ;
    skos:scopeNote "Otros lenguajes la optimizan, pero CPython no elimina la recursion de cola: puede desbordar la pila."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:perteneceATema cfr:T_recursion ;
    cfkg:requierePrerrequisito cfr:funcion,
        cfr:recursion ;
    cfkg:tieneDificultad 5 .

cfr:reduce_func a _:n36bd77e927a0451a9b86ac2c9f81b30db11,
