        owl:Thing,
        skos:Concept,
        cfkg:Concepto,
        cfkg:EntidadEducativa,
        cfkg:OperadorDelLenguaje ;
    rdfs:label "Identity operators"@en,
        "Operadores de identidad (is)"@es ;
    owl:sameAs cfr:operador_identidad ;
    skos:definition "Operadores is e is not que comprueban si dos nombres referencian el mismo objeto."@es ;
    skos:example """x = None
x is None  # True""" ;
    skos:scopeNote "Reservalos para comparar con None; para igualdad de valor usa ==."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:perteneceATema cfr:T_tipos ;
    cfkg:requierePrerrequisito cfr:identidad_objetos,
