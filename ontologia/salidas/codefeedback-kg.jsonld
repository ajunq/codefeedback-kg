  {
    "@id": "https://w3id.org/codefeedback-kg/id/funcion",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Function"
      },
      {
        "@language": "es",
        "@value": "Función"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Bloque de codigo reutilizable con nombre que recibe parametros y puede devolver un valor."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "def cuadrado(x):\n    return x * x"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#narrower": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/funcion_lambda"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "es",
        "@value": "Función"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Se define con def; favorece la modularidad y evita la repeticion de codigo."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#esPrerrequisitoDe": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/recursion"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_funciones"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 2
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneEjemploCodigo": [
      {
        "@value": "def f(x):\n    return x + 1"
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/fstring_format_spec",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Format specification"
      },
      {
        "@language": "es",
        "@value": "Mini-lenguaje de formato"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Sintaxis tras los dos puntos en un campo de formato para controlar ancho, precision y alineacion."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "import math\nf'{math.pi:.2f}'  # '3.14'\nf'{42:05d}'        # '00042'"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#related": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/fstring"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Permite formatear numeros (:.2f), porcentajes (:.0%) o rellenar con ceros (:03d)."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/intermedio"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_strings"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/fstring"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 3
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/stmt_offbyone",
    "@type": [
      "http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"
    ],
    "http://purl.org/dc/terms/source": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/ref_keuning2019"
      }
    ],
    "http://www.w3.org/1999/02/22-rdf-syntax-ns#object": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/indexacion"
      }
    ],
    "http://www.w3.org/1999/02/22-rdf-syntax-ns#predicate": [
      {
        "@id": "https://w3id.org/codefeedback-kg/schema#errorSobreConcepto"
      }
    ],
    "http://www.w3.org/1999/02/22-rdf-syntax-ns#subject": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/err_off_by_one"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "es",
        "@value": "Procedencia del enunciado (patrón de reificación del material docente)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Provenance (reification): off-by-one on indexing per Keuning et al."
      },
      {
        "@language": "es",
        "@value": "Procedencia (reificación): off-by-one sobre indexación según Keuning et al."
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/ej_busqueda",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#Ejercicio"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
