      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Tipo con un unico valor, None, que representa la ausencia de valor."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "def f():\n    pass\nf() is None  # True"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Es el retorno por defecto de las funciones; comparalo con is None, no con ==."
      }
    ],
