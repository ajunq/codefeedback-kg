      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Modulo datetime para representar y operar con fechas, horas y duraciones."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "from datetime import date\ndate.today().isoformat()"
      }
