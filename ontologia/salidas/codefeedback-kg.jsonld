[
  {
    "@id": "https://w3id.org/codefeedback-kg/id/async_await",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#EstructuraDeControl"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "async/await"
      },
      {
        "@language": "es",
        "@value": "async/await"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Sintaxis async/await para definir y suspender corrutinas en programacion asincrona."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "import asyncio\nasync def main():\n    await asyncio.sleep(1)\n    print('listo')"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#narrower": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/corrutina"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "await solo puede usarse dentro de una funcion async def; cede el control al bucle de eventos sin bloquear el hilo."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#introducidoEnVersion": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "3.5"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_concurrencia"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/funcion"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 5
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/dfs",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Depth-first search"
      },
      {
        "@language": "es",
        "@value": "Recorrido en profundidad (DFS)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/grafo_estr"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "http://dbpedia.org/resource/Depth-first_search"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Recorrido en profundidad de un grafo que explora un camino al maximo antes de retroceder."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#exactMatch": [
      {
        "@id": "http://www.wikidata.org/entity/Q816319"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "def dfs(g, n, visto=None):\n    visto = visto or set()\n    visto.add(n)\n    for v in g[n]:\n        if v not in visto:\n            dfs(g, v, visto)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#related": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/bfs"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Se implementa con recursion o pila explicita; util para deteccion de ciclos y ordenacion topologica."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#contrastaCon": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/bfs"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_algoritmos"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/grafo_estr"
      },
      {
        "@id": "https://w3id.org/codefeedback-kg/id/recursion"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneComplejidadTemporal": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "O(V + E)"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 5
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/regex",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#ModuloLibreria"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Regular expressions"
      },
      {
        "@language": "es",
        "@value": "Expresiones regulares (re)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "http://dbpedia.org/resource/Regular_expression"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Expresiones regulares (modulo re) para buscar y manipular texto segun patrones."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#exactMatch": [
      {
        "@id": "http://www.wikidata.org/entity/Q185612"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "import re\nre.findall(r'\\d+', 'a12b3')  # ['12', '3']"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Compila patrones con re.compile; usa cadenas raw (r'...') para las barras invertidas."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_strings"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/tipo_str"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 5
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneURLDocumentacion": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI",
        "@value": "https://docs.python.org/3/library/re.html"
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/enumerate_f",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#FuncionIntegrada"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "enumerate"
      },
      {
        "@language": "es",
        "@value": "enumerate()"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Funcion enumerate() que produce pares (indice, elemento) al iterar un iterable."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "for i, v in enumerate(['a', 'b'], start=1):\n    print(i, v)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Evita gestionar manualmente un contador; admite un indice inicial con start."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/basico"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_control"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/bucle_for"
      },
      {
        "@id": "https://w3id.org/codefeedback-kg/id/indexacion"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 2
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/future_annotations",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#ConceptoDeTipado"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Postponed annotations"
      },
      {
        "@language": "es",
        "@value": "from __future__ import annotations"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Directiva que evalua las anotaciones como cadenas, posponiendo su resolucion."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "from __future__ import annotations\nclass Nodo:\n    sig: Nodo | None = None"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Evita referencias adelantadas y costes de importacion; conviene conocerla al usar tipos recursivos."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#introducidoEnVersion": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "3.7"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_tipos"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/anotaciones_tipo"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 4
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/T_complejidad",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#Tema"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Algorithmic complexity"
      },
      {
        "@language": "es",
        "@value": "Complejidad algorítmica"
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/err_late_binding",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#ErrorConceptual"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Loop closure late binding"
      },
      {
        "@language": "es",
        "@value": "Late binding en clausuras de bucle"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#errorSobreConcepto": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/closure"
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/interbloqueo",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#ConceptoDeConcurrencia"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Deadlock"
      },
      {
        "@language": "es",
        "@value": "Interbloqueo"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "http://dbpedia.org/resource/Deadlock"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Situacion en la que dos o mas hilos se bloquean mutuamente esperando recursos que el otro retiene."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#exactMatch": [
      {
        "@id": "http://www.wikidata.org/entity/Q623276"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "# Hilo 1: lock_a luego lock_b\n# Hilo 2: lock_b luego lock_a  -> interbloqueo"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#related": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/lock_threading"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Se previene adquiriendo los cerrojos siempre en el mismo orden o con tiempos de espera."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_concurrencia"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/lock_threading"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 5
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/err_paso_referencia",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#ErrorConceptual"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Value vs reference confusion"
      },
      {
        "@language": "es",
        "@value": "Confusión paso por valor / por referencia"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#errorSobreConcepto": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/mutabilidad"
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/schema#OperadorDelLenguaje",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "es",
        "@value": "Simbolo que representa una operacion sobre uno o varios operandos."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Language operator"
      },
      {
        "@language": "es",
        "@value": "Operador del lenguaje"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://w3id.org/codefeedback-kg/schema#Concepto"
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/unittest_mod",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#ModuloLibreria"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "unittest"
      },
      {
        "@language": "es",
        "@value": "unittest"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Marco de pruebas unittest de la biblioteca estandar, basado en clases TestCase."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "import unittest\nclass T(unittest.TestCase):\n    def test_ok(self):\n        self.assertEqual(1 + 1, 2)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Inspirado en xUnit; ofrece metodos assert y setUp/tearDown para preparar cada prueba."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_testing"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/clase"
      },
      {
        "@id": "https://w3id.org/codefeedback-kg/id/funcion"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 4
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneURLDocumentacion": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI",
        "@value": "https://docs.python.org/3/library/unittest.html"
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/encadenar_excepciones",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#EstructuraDeControl"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Exception chaining"
      },
      {
        "@language": "es",
        "@value": "Encadenar excepciones"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/jerarquia_excepciones"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Mecanismo (raise ... from ...) que vincula una excepcion con la causa original."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "try:\n    int('x')\nexcept ValueError as e:\n    raise RuntimeError('dato invalido') from e"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Preserva la traza completa y aclara el origen del error; from None oculta la causa intencionadamente."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_excepciones"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/raise_excepcion"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 4
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/typing_union",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Union"
      },
      {
        "@language": "es",
        "@value": "typing.Union"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Anotacion Union[A, B] que indica que un valor puede ser de varios tipos."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "from typing import Union\ndef f(x: Union[int, str]) -> str:\n    return str(x)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Desde Python 3.10 se escribe A | B; usala con moderacion para no diluir el tipado."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/intermedio"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#introducidoEnVersion": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "3.5"
      }
    ],
