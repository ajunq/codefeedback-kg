      "https://w3id.org/codefeedback-kg/schema#EstructuraDeDatos"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Graph"
      },
      {
        "@language": "es",
        "@value": "Grafo (estructura)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "http://dbpedia.org/resource/Graph_(abstract_data_type)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Estructura de datos formada por nodos (vertices) y conexiones (aristas) entre ellos."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#exactMatch": [
      {
        "@id": "http://www.wikidata.org/entity/Q2479726"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "g = {'a': ['b', 'c'], 'b': ['c'], 'c': []}"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#narrower": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/bfs"
      },
      {
        "@id": "https://w3id.org/codefeedback-kg/id/dfs"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Se representa habitualmente con listas o diccionarios de adyacencia; base de BFS y DFS."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
