      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 2
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/ej_suma_lista",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#Ejercicio"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Sum the elements of a list"
      },
      {
        "@language": "es",
        "@value": "Suma de los elementos de una lista"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#cubreConcepto": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/bucle_for"
      },
