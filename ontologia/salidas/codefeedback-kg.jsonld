        "@language": "en",
        "@value": "pip"
      },
      {
        "@language": "es",
        "@value": "Gestor de paquetes (pip)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Gestor de paquetes pip para instalar bibliotecas desde el indice PyPI."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "pip install requests\npip freeze > requirements.txt"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Trabaja con requirements.txt e idealmente dentro de un entorno virtual."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
