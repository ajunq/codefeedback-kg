      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Funcion zip() que combina varios iterables en tuplas de elementos correspondientes."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "list(zip([1, 2], ['a', 'b']))  # [(1, 'a'), (2, 'b')]"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Se detiene en el iterable mas corto; zip(*m) permite transponer; para rellenar usa itertools.zip_longest."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
