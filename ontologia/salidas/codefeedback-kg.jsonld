      {
        "@id": "https://w3id.org/codefeedback-kg/id/decorador"
      },
      {
        "@id": "https://w3id.org/codefeedback-kg/id/memoizacion"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 4
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/tupla",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#EstructuraDeDatos"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Tuple"
      },
      {
        "@language": "es",
        "@value": "Tupla"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "http://dbpedia.org/resource/Tuple"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Secuencia ordenada e inmutable de elementos, posiblemente de distintos tipos."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#exactMatch": [
      {
        "@id": "http://www.wikidata.org/entity/Q2879072"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "punto = (3, 4)\nx, y = punto"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#narrower": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/namedtuple"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#related": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/lista"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Util para datos heterogeneos fijos y como claves de diccionario; es hashable si sus elementos lo son."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#contrastaCon": [
      {
