  {
    "@id": "https://w3id.org/codefeedback-kg/id/metodos_str",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#FuncionIntegrada"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "String methods"
      },
      {
        "@language": "es",
        "@value": "Métodos de cadena"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Conjunto de metodos del tipo str para manipular texto (upper, strip, replace, find)."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "'  Hola  '.strip().lower()  # 'hola'"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#related": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/formato_str"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Las cadenas son inmutables: estos metodos devuelven una cadena nueva, no modifican la original."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/basico"
      }
    ],
