  {
    "@id": "https://w3id.org/codefeedback-kg/id/conteo_referencias",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Reference counting"
      },
      {
        "@language": "es",
        "@value": "Conteo de referencias"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "http://dbpedia.org/resource/Reference_counting"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Tecnica que libera un objeto cuando el numero de referencias que lo apuntan llega a cero."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "import sys\nx = []\nsys.getrefcount(x)  # numero de referencias"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#related": [
      {
