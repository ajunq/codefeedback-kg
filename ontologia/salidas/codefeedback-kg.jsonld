  {
    "@id": "https://w3id.org/codefeedback-kg/id/retorno_multiple",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Multiple return"
      },
      {
        "@language": "es",
        "@value": "Retorno múltiple"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Devolucion de varios valores desde una funcion empaquetandolos en una tupla."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "def divmod2(a, b):\n    return a // b, a % b\nc, r = divmod2(7, 2)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "El receptor los desempaqueta en variables separadas; mejora la claridad frente a parametros de salida."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/basico"
      }
    ],
