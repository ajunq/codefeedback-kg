  {
    "@id": "https://w3id.org/codefeedback-kg/id/context_manager",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#Paradigma"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Context manager"
      },
      {
        "@language": "es",
        "@value": "Gestor de contexto"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Objeto que define la entrada (__enter__) y salida (__exit__) de un bloque with para gestionar recursos."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "class Recurso:\n    def __enter__(self): return self\n    def __exit__(self, *a): print('cerrado')"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Garantiza la liberacion del recurso incluso si ocurre una excepcion; contextlib facilita crearlos."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
