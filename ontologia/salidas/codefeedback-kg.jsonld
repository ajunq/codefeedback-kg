  {
    "@id": "https://w3id.org/codefeedback-kg/id/pep8",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "PEP 8"
      },
      {
        "@language": "es",
        "@value": "PEP 8 (estilo)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Guia de estilo oficial PEP 8 con convenciones de formato del codigo Python."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "# correcto\ndef calcular_total(precio, cantidad):\n    return precio * cantidad"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Recomienda sangria de 4 espacios, snake_case y lineas de hasta 79 caracteres; herramientas como flake8 la verifican."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/basico"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_testing"
      }
    ],
