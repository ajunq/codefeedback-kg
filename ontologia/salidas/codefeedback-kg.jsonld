  {
    "@id": "https://w3id.org/codefeedback-kg/id/frozen_dataclass",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#Paradigma"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Frozen dataclass"
      },
      {
        "@language": "es",
        "@value": "Dataclass inmutable"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/dataclass"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Dataclass declarada con frozen=True cuyas instancias son inmutables y hashables."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "from dataclasses import dataclass\n@dataclass(frozen=True)\nclass Punto:\n    x: int\n    y: int"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Intentar modificar un campo lanza FrozenInstanceError; util para objetos de valor."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
