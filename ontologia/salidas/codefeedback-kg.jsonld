    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Operator overloading"
      },
      {
        "@language": "es",
        "@value": "Sobrecarga de operadores"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Definicion del comportamiento de los operadores (+, ==, []) para objetos propios."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "class V:\n    def __init__(self, n): self.n = n\n    def __add__(self, o): return V(self.n + o.n)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Se implementa con metodos dunder (__add__, __eq__); usala cuando aporte semantica natural."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
