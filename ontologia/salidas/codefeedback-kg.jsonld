    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Static method"
      },
      {
        "@language": "es",
        "@value": "Método estático"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/metodo"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Metodo (@staticmethod) que no recibe ni instancia ni clase, agrupado por afinidad logica."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "class Mat:\n    @staticmethod\n    def suma(a, b):\n        return a + b"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Se comporta como una funcion normal dentro del espacio de nombres de la clase."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
