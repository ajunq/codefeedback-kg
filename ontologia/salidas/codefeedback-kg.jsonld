  {
    "@id": "https://w3id.org/codefeedback-kg/id/gil",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Global Interpreter Lock"
      },
      {
        "@language": "es",
        "@value": "GIL"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "http://dbpedia.org/resource/Global_interpreter_lock"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Bloqueo global del interprete (GIL) de CPython que permite ejecutar un solo hilo de bytecode a la vez."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#exactMatch": [
      {
        "@id": "http://www.wikidata.org/entity/Q5570451"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "# Los hilos no aceleran calculo puro de CPU por el GIL\nimport threading"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#related": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/hilos"
      },
      {
        "@id": "https://w3id.org/codefeedback-kg/id/multiproceso"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Limita el paralelismo real con hilos en tareas de CPU; usa multiprocessing para calculo intensivo."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
