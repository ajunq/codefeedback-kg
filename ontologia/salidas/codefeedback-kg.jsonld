  {
    "@id": "https://w3id.org/codefeedback-kg/id/identidad_objetos",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Object identity"
      },
      {
        "@language": "es",
        "@value": "Identidad de objetos (is)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Comprobacion (is) de si dos nombres referencian exactamente el mismo objeto en memoria."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "a = [1]\nb = a\na is b  # True\na is [1]  # False"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "is compara identidad y == compara valor; reserva is para None y centinelas."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/intermedio"
      }
