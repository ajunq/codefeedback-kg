      },
      {
        "@language": "es",
        "@value": "Árbol"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "http://dbpedia.org/resource/Tree_(data_structure)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Estructura de datos jerarquica formada por nodos con un nodo raiz y subarboles hijos."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#exactMatch": [
      {
        "@id": "http://www.wikidata.org/entity/Q223655"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "nodo = {'valor': 1, 'hijos': [{'valor': 2, 'hijos': []}]}"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#narrower": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/arbol_binario"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Es la base de arboles binarios, de busqueda y montículos; se recorre habitualmente de forma recursiva."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
