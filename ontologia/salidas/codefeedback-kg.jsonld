  {
    "@id": "https://w3id.org/codefeedback-kg/id/concurrent_futures",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#ConceptoDeConcurrencia"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "concurrent.futures"
      },
      {
        "@language": "es",
        "@value": "concurrent.futures"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Interfaz de alto nivel para ejecutar tareas en grupos de hilos o procesos mediante Executors."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "from concurrent.futures import ThreadPoolExecutor\nwith ThreadPoolExecutor() as ex:\n    list(ex.map(str, range(3)))"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#related": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/hilos"
      },
      {
        "@id": "https://w3id.org/codefeedback-kg/id/multiproceso"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "ThreadPoolExecutor para E/S y ProcessPoolExecutor para CPU; map() y submit() devuelven futuros."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_concurrencia"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/hilos"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 4
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/descriptor",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#Paradigma"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Descriptor"
      },
      {
        "@language": "es",
        "@value": "Descriptor"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Objeto que define __get__, __set__ o __delete__ para controlar el acceso a un atributo."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "class SoloLectura:\n    def __get__(self, obj, tipo=None):\n        return 42"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Es el mecanismo subyacente de property, los metodos y classmethod; protocolo avanzado de POO."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_poo"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/propiedad"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 5
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/memoryview_tipo",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#TipoDeDato"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "memoryview"
      },
      {
        "@language": "es",
        "@value": "memoryview"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Vista que expone el buffer de memoria de un objeto binario sin copiarlo."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "mv = memoryview(bytearray(b'abcdef'))\nbytes(mv[1:4])  # b'bcd'"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Permite manipular grandes bloques de bytes de forma eficiente, por ejemplo al hacer slicing."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_tipos"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/tipo_bytes"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 4
      }
    ]
  },
