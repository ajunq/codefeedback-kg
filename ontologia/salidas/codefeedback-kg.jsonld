    "@id": "https://w3id.org/codefeedback-kg/id/clase",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#Paradigma"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Class"
      },
      {
        "@language": "es",
        "@value": "Clase"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "http://dbpedia.org/resource/Class_(computer_programming)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Plantilla que define atributos y metodos para crear objetos de un mismo tipo."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#exactMatch": [
      {
        "@id": "http://www.wikidata.org/entity/Q4479242"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "class Coche:\n    def __init__(self, marca):\n        self.marca = marca"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#related": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/enum_tipo"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Convencion: el nombre va en CamelCase; instanciar la clase llama a __init__."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
