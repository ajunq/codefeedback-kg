      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "http://dbpedia.org/resource/Big_O_notation"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Notacion O grande que describe el crecimiento asintotico del coste de un algoritmo."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#exactMatch": [
      {
        "@id": "http://www.wikidata.org/entity/Q269878"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "# Busqueda binaria: O(log n)\n# Ordenacion por mezcla: O(n log n)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#narrower": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/ordenacion_burbuja"
      },
      {
        "@id": "https://w3id.org/codefeedback-kg/id/ordenacion_mezcla"
      },
      {
        "@id": "https://w3id.org/codefeedback-kg/id/ordenacion_rapida"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Ignora constantes y terminos menores; O(1) < O(log n) < O(n) < O(n log n) < O(n^2)."
      }
    ],
