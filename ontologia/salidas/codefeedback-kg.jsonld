        "@language": "es",
        "@value": "Módulo math"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Modulo math con funciones y constantes matematicas para numeros reales."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "import math\nmath.sqrt(2)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Incluye sqrt, sin, factorial, pi y e; para vectores grandes considera numpy."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
