    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Arbol de clases de excepcion donde las mas especificas heredan de las generales."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "try:\n    ...\nexcept FileNotFoundError:\n    ...\nexcept OSError:\n    ..."
      }
