      {
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI",
        "@value": "https://docs.python.org/3/library/pathlib.html"
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/desempaquetado",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Unpacking"
      },
      {
        "@language": "es",
        "@value": "Desempaquetado"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Asignacion simultanea de los elementos de un iterable a varias variables."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "a, b, *resto = [1, 2, 3, 4]"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Admite el comodin * para capturar el resto; util para intercambios y retorno multiple."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/basico"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_estructuras"
      }
    ],
