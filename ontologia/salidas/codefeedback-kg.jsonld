      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Sintaxis (PEP 526) para anotar el tipo de una variable, con o sin asignacion."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "conteo: int = 0\nnombres: list[str]"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Las anotaciones se guardan en __annotations__; documentan la intencion sin afectar a la ejecucion."
      }
    ],
