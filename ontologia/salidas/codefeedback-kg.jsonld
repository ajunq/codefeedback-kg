        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/bucle_for",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#EstructuraDeControl"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "For loop"
      },
      {
        "@language": "es",
        "@value": "Bucle for"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Bucle que itera sobre los elementos de un iterable ejecutando un bloque por cada uno."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "for x in [1, 2, 3]:\n    print(x)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#narrower": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/comprension_listas"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "es",
        "@value": "Bucle for"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#related": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/recursion"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Es el bucle idiomatico en Python; con range() permite repetir un numero fijo de veces."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
