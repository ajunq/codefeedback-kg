  {
    "@id": "https://w3id.org/codefeedback-kg/id/bucle_while",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#EstructuraDeControl"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "While loop"
      },
      {
        "@language": "es",
        "@value": "Bucle while"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Bucle que repite un bloque mientras una condicion sea verdadera."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "i = 0\nwhile i < 3:\n    print(i)\n    i += 1"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Adecuado cuando no se conoce de antemano el numero de iteraciones; cuida la condicion de parada para evitar bucles infinitos."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_control"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/condicional"
      }
    ],
