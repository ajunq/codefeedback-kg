  {
    "@id": "https://w3id.org/codefeedback-kg/id/operador_pertenencia",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#OperadorDelLenguaje"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Membership operators"
      },
      {
        "@language": "es",
        "@value": "Operadores de pertenencia (in)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Operadores in y not in que comprueban si un valor esta contenido en una coleccion."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "3 in [1, 2, 3]   # True\n'a' in 'casa'    # True"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "En sets y dicts es O(1); en listas es O(n). Tambien busca subcadenas en strings."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/basico"
      }
    ],
