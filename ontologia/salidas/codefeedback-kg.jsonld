      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/herencia"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "http://dbpedia.org/resource/Multiple_inheritance"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Capacidad de una clase de heredar de varias clases base a la vez."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "class A: ...\nclass B: ...\nclass C(A, B): ..."
      }
