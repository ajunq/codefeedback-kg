      {
        "@language": "en",
        "@value": "is covered by exercise"
      },
      {
        "@language": "es",
        "@value": "es cubierto por el ejercicio"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "https://w3id.org/codefeedback-kg/schema#Ejercicio"
      }
    ],
    "http://www.w3.org/2002/07/owl#inverseOf": [
      {
        "@id": "https://w3id.org/codefeedback-kg/schema#cubreConcepto"
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/conversion_tipos",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Type casting"
      },
      {
        "@language": "es",
        "@value": "Conversión de tipos"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Cambio explicito del tipo de un valor mediante constructores como int(), str() o float()."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "edad = int('42')\ntexto = str(3.14)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Evita errores de TypeError al combinar tipos incompatibles; puede lanzar ValueError si el formato no es valido."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/basico"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_tipos"
      }
    ],
