  {
    "@id": "https://w3id.org/codefeedback-kg/id/ordenacion_rapida",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Quicksort"
      },
      {
        "@language": "es",
        "@value": "Ordenación rápida"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/notacion_o"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "http://dbpedia.org/resource/Quicksort"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Algoritmo de ordenacion por division y conquista que particiona en torno a un pivote."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#exactMatch": [
      {
        "@id": "http://www.wikidata.org/entity/Q486598"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "def rapida(xs):\n    if len(xs) <= 1: return xs\n    p = xs[0]\n    return rapida([x for x in xs[1:] if x < p]) + [p] + rapida([x for x in xs[1:] if x >= p])"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "O(n log n) en promedio y O(n^2) en el peor caso; la eleccion del pivote es clave."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_algoritmos"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/recursion"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneComplejidadTemporal": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "O(n log n)"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 5
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/assert_stmt",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#EstructuraDeControl"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "assert"
      },
      {
        "@language": "es",
        "@value": "assert"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Sentencia assert que verifica una condicion y lanza AssertionError si es falsa."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "def media(xs):\n    assert len(xs) > 0, 'lista vacia'\n    return sum(xs) / len(xs)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Util para comprobaciones internas y pruebas; se desactiva al ejecutar Python con la opcion -O."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/intermedio"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_testing"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/condicional"
      }
    ],
