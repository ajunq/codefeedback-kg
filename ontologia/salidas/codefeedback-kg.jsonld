        "@value": "Dict comprehension"
      },
      {
        "@language": "es",
        "@value": "Comprensión de diccionarios"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/comprension_listas"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Sintaxis concisa para construir diccionarios a partir de un iterable en una sola expresion."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "cuadrados = {n: n*n for n in range(5)}"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Sigue el patron {clave: valor for ...}; mas legible que un bucle con asignaciones cuando es simple."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
      }
