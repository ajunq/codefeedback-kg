    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Diccionario (collections.defaultdict) que crea un valor por defecto al acceder a una clave inexistente."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "from collections import defaultdict\nd = defaultdict(list)\nd['a'].append(1)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Evita comprobar la existencia de la clave; se inicializa con una fabrica (list, int, set)."
      }
    ],
