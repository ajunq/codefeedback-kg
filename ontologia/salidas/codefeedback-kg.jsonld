    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Functions"
      },
      {
        "@language": "es",
        "@value": "Funciones"
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/formato_str",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "String formatting"
      },
      {
        "@language": "es",
        "@value": "Formateo de cadenas"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Conjunto de tecnicas para insertar valores en cadenas (f-strings, str.format, %)."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "n = 3\nf'hay {n} elementos'"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#related": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/fstring"
      },
      {
        "@id": "https://w3id.org/codefeedback-kg/id/metodos_str"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Las f-strings son la opcion recomendada por su claridad y rendimiento desde Python 3.6."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/basico"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_strings"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/tipo_str"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 2
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/tipo_int",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#TipoDeDato"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Integer (int)"
      },
      {
        "@language": "es",
        "@value": "Entero (int)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Tipo numerico entero de precision arbitraria en Python."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "10 ** 100  # entero enorme sin desbordamiento"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "No desborda como en otros lenguajes; admite bases y separadores de miles con guion bajo."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_fundamentos"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/deque",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#EstructuraDeDatos"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "deque"
      },
      {
        "@language": "es",
        "@value": "collections.deque"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/cola"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Cola doblemente terminada (collections.deque) con insercion y extraccion O(1) por ambos extremos."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "from collections import deque\nd = deque([1, 2])\nd.appendleft(0); d.pop()"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Preferible a list para colas y pilas; permite limitar su tamano con maxlen."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/intermedio"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_estructuras"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/lista"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 3
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/heap",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#EstructuraDeDatos"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Heap"
      },
      {
        "@language": "es",
        "@value": "Montículo (heapq)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "http://dbpedia.org/resource/Heap_(data_structure)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Arbol binario parcialmente ordenado que da acceso O(1) al minimo o maximo (modulo heapq)."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "import heapq\nh = [3, 1, 2]\nheapq.heapify(h)\nheapq.heappop(h)  # 1"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "heapq implementa un min-heap sobre una lista; util para colas de prioridad y los k mayores."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_estructuras"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/complejidad"
      },
      {
        "@id": "https://w3id.org/codefeedback-kg/id/lista"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneComplejidadTemporal": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "O(log n)"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 4
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/mro",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#Paradigma"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Method resolution order"
      },
      {
        "@language": "es",
        "@value": "Orden de resolución (MRO)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Orden de resolucion de metodos (MRO) que determina como Python busca atributos en herencia multiple."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "class C(A, B): ...\nC.mro()"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Se calcula con el algoritmo C3 y es consultable con NombreClase.mro()."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_poo"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/herencia_multiple"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 5
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/funcion_lambda",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Lambda"
      },
      {
        "@language": "es",
        "@value": "Función lambda"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/funcion"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "http://dbpedia.org/resource/Anonymous_function"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Funcion anonima de una sola expresion definida con la palabra clave lambda."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#exactMatch": [
      {
        "@id": "http://www.wikidata.org/entity/Q567612"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "ordenar = sorted(pares, key=lambda p: p[1])"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Util como argumento breve (key de sorted); si crece, mejor una funcion con def."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/intermedio"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_funcional"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/funcion"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 3
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/memoizacion",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Memoization"
      },
      {
        "@language": "es",
        "@value": "Memoización (lru_cache)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "http://dbpedia.org/resource/Memoization"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Tecnica que almacena en cache los resultados de una funcion para reutilizarlos."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "import functools\n@functools.lru_cache\ndef fib(n):\n    return n if n < 2 else fib(n-1) + fib(n-2)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "functools.lru_cache la implementa con un decorador; acelera funciones puras y recursivas."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_recursion"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/diccionario"
      },
      {
        "@id": "https://w3id.org/codefeedback-kg/id/recursion"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 4
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/metodo_clase",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#Paradigma"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Class method"
      },
      {
        "@language": "es",
        "@value": "Método de clase"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/decorador"
      },
      {
        "@id": "https://w3id.org/codefeedback-kg/id/metodo"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Metodo (@classmethod) que recibe la clase (cls) en lugar de la instancia."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "class Fecha:\n    @classmethod\n    def hoy(cls):\n        return cls()"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Util para constructores alternativos (fabricas) que devuelven instancias configuradas."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_poo"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/decorador"
      },
      {
        "@id": "https://w3id.org/codefeedback-kg/id/metodo"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 4
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/atributo_clase",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#Paradigma"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Class attribute"
      },
      {
        "@language": "es",
        "@value": "Atributo de clase"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Atributo definido en la clase y compartido por todas sus instancias."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "class Contador:\n    total = 0  # atributo de clase compartido"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#related": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/atributo"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Cuidado al usar valores mutables: se comparten entre instancias; las asignaciones via self crean copias locales."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/intermedio"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_poo"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/atributo"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 3
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/logging_mod",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#ModuloLibreria"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "logging"
      },
      {
        "@language": "es",
        "@value": "Modulo logging"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Modulo estandar para registrar mensajes con distintos niveles de severidad."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "import logging\nlogging.basicConfig(level=logging.INFO)\nlogging.info('iniciado')"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#related": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/pep8"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Preferible a print en programas reales: permite niveles, formato y destinos configurables."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/intermedio"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_testing"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/import_mod"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 3
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/tipo_float",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#TipoDeDato"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Float"
      },
      {
        "@language": "es",
        "@value": "Flotante (float)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Tipo numerico de coma flotante de doble precision (IEEE 754)."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "0.1 + 0.2  # 0.30000000000000004"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Tiene precision limitada: evita comparar floats con == y usa math.isclose."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/basico"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#contrastaCon": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/tipo_int"
      }
    ],
