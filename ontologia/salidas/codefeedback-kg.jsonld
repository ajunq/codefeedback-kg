      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 4
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/csv_mod",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#ModuloLibreria"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "csv module"
      },
      {
        "@language": "es",
        "@value": "Módulo csv"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "http://dbpedia.org/resource/Comma-separated_values"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Modulo estandar csv para leer y escribir ficheros de valores separados por comas."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "import csv\nwith open('d.csv', newline='') as f:\n    for fila in csv.reader(f):\n        print(fila)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Maneja correctamente comillas y delimitadores; usa newline='' al abrir el fichero."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
