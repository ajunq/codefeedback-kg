  {
    "@id": "https://w3id.org/codefeedback-kg/id/complejidad",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Time complexity"
      },
      {
        "@language": "es",
        "@value": "Complejidad temporal"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "http://dbpedia.org/resource/Time_complexity"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Estimacion del crecimiento del tiempo o memoria de un algoritmo segun el tamano de la entrada."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#exactMatch": [
      {
        "@id": "http://www.wikidata.org/entity/Q2393193"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "# Recorrer una lista es O(n)\nfor x in xs:\n    procesar(x)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Se expresa con notacion O grande; guia la eleccion de algoritmos y estructuras de datos."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
