  {
    "@id": "https://w3id.org/codefeedback-kg/id/cached_property_mod",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#ModuloLibreria"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "functools.cached_property"
      },
      {
        "@language": "es",
        "@value": "functools.cached_property"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Decorador que convierte un metodo en una propiedad cuyo valor se calcula una vez y se cachea."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "from functools import cached_property\nclass D:\n    @cached_property\n    def media(self):\n        return sum(self.xs) / len(self.xs)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#related": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/propiedad"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Ideal para calculos costosos que no cambian; el resultado se guarda en el __dict__ de la instancia."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#introducidoEnVersion": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "3.8"
      }
