  {
    "@id": "https://w3id.org/codefeedback-kg/id/contextlib_mod",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#ModuloLibreria"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "contextlib"
      },
      {
        "@language": "es",
        "@value": "Modulo contextlib"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Modulo con utilidades para crear gestores de contexto, como el decorador @contextmanager."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "from contextlib import contextmanager\n@contextmanager\ndef abierto(p):\n    f = open(p)\n    try:\n        yield f\n    finally:\n        f.close()"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#related": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/context_manager"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "@contextmanager convierte un generador con un unico yield en un gestor de contexto."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_control"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/context_manager"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 4
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/mixin",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#Paradigma"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Mixin"
      },
      {
        "@language": "es",
        "@value": "Mixin"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "http://dbpedia.org/resource/Mixin"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Clase pequena que aporta funcionalidad concreta para combinarse por herencia multiple."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "class SerializableMixin:\n    def to_dict(self):\n        return self.__dict__"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "No se instancia por si sola; anade un comportamiento transversal a varias clases."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_poo"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/herencia_multiple"
      }
    ],
