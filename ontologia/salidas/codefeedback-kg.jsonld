      {
        "@language": "es",
        "@value": "Multiproceso"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "http://dbpedia.org/resource/Process_(computing)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Ejecucion paralela mediante varios procesos (multiprocessing) con memoria independiente."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "from multiprocessing import Pool\nwith Pool() as p:\n    p.map(cuadrado, range(10))"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#related": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/gil"
      },
      {
        "@id": "https://w3id.org/codefeedback-kg/id/hilos"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Esquiva el GIL y aprovecha varios nucleos para calculo de CPU; comunicar procesos tiene coste."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#contrastaCon": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/hilos"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_concurrencia"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/gil"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 5
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/raise_excepcion",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#EstructuraDeControl"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "raise"
      },
      {
        "@language": "es",
        "@value": "raise"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Sentencia raise que lanza una excepcion de forma explicita."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "if x < 0:\n    raise ValueError('x debe ser positivo')"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Permite senalar errores del dominio; puede relanzar la actual con raise a secas dentro de un except."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/intermedio"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_excepciones"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/excepcion"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 3
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/asignacion",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Assignment"
      },
      {
        "@language": "es",
        "@value": "Asignación"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Operacion que vincula un nombre a un objeto en memoria mediante el operador =."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "x = [1, 2, 3]\ny = x  # y referencia la misma lista"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "En Python la asignacion no copia el objeto: asocia una referencia; varios nombres pueden apuntar al mismo objeto."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#esPrerrequisitoDe": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/bucle_for"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_fundamentos"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ]
  },
  {
    "@id": "http://www.w3.org/2004/02/skos/core#broader",
