  {
    "@id": "https://w3id.org/codefeedback-kg/id/abstract_class",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#Paradigma"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Abstract base class"
      },
      {
        "@language": "es",
        "@value": "Clase abstracta (ABC)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Clase base abstracta (ABC) que define una interfaz comun y no puede instanciarse directamente."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "from abc import ABC, abstractmethod\nclass Figura(ABC):\n    @abstractmethod\n    def area(self): ..."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Se declara heredando de abc.ABC y marcando metodos con @abstractmethod; obliga a las subclases a implementarlos."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
