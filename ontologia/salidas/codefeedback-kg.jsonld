      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Sintaxis *args y **kwargs para aceptar un numero variable de argumentos posicionales y por nombre."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "def f(*args, **kwargs):\n    print(args, kwargs)\nf(1, 2, a=3)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "*args agrupa posicionales en una tupla y **kwargs los nombrados en un diccionario."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
