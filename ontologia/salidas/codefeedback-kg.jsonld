    "@type": [
      "https://w3id.org/codefeedback-kg/schema#ErrorConceptual"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Expecting threads to parallelize"
      },
      {
        "@language": "es",
        "@value": "Esperar paralelismo real con hilos (GIL)"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#errorSobreConcepto": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/gil"
