  {
    "@id": "https://w3id.org/codefeedback-kg/id/nonlocal_kw",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "nonlocal"
      },
      {
        "@language": "es",
        "@value": "Palabra clave nonlocal"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Declaracion que permite a una funcion anidada reasignar una variable del ambito envolvente."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "def contador():\n    n = 0\n    def inc():\n        nonlocal n\n        n += 1\n        return n\n    return inc"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#related": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/ambito"
      },
      {
        "@id": "https://w3id.org/codefeedback-kg/id/closure"
      },
      {
        "@id": "https://w3id.org/codefeedback-kg/id/global_kw"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Sin ella, una asignacion crearia una variable local; clave en clausuras que mantienen estado."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
      }
    ],
