      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Acceso a un elemento de una secuencia mediante su posicion entre corchetes."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "xs = [10, 20, 30]\nxs[0]  # 10"
      }
