        "@id": "https://w3id.org/codefeedback-kg/id/T_ficheros"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/abrir_fichero"
      }
    ],
