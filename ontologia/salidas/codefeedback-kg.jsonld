  {
    "@id": "https://w3id.org/codefeedback-kg/id/operador_aritmetico",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#OperadorDelLenguaje"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Arithmetic operators"
      },
      {
        "@language": "es",
        "@value": "Operadores aritmeticos"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Operadores que realizan calculos numericos: +, -, *, /, //, % y **."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "7 // 2   # 3\n7 % 2    # 1\n2 ** 10  # 1024"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "// es la division entera y / siempre devuelve float; ** eleva a una potencia."
      }
    ],
