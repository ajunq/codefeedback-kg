      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "'Hola' + ' ' + 'mundo'\n''.join(['a', 'b', 'c'])"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Para unir muchas cadenas en un bucle, str.join es mas eficiente que la concatenacion repetida."
      }
    ],
