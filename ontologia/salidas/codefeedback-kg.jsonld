  {
    "@id": "https://w3id.org/codefeedback-kg/id/callable_func",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#FuncionIntegrada"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "callable"
      },
      {
        "@language": "es",
        "@value": "Funcion callable"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Funcion que indica si un objeto puede invocarse como una funcion."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "callable(len)   # True\ncallable(42)    # False"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#related": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/funcion_orden_superior"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Son invocables las funciones, clases y objetos con __call__; util al recibir callbacks."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/intermedio"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_funcional"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/funcion"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 3
