      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Anotacion Optional[X] que indica un valor de tipo X o None."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "from typing import Optional\ndef buscar(k) -> Optional[int]:\n    return None"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Equivale a Union[X, None]; documenta funciones que pueden no devolver un valor."
      }
    ],
