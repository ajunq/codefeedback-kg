      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "def f(a, b, c): ...\nargs = [1, 2, 3]\nf(*args)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "* expande secuencias y ** diccionarios; permiten reenviar argumentos entre funciones."
      }
