    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Augmented assignment"
      },
      {
        "@language": "es",
        "@value": "Asignacion aumentada"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Operadores como +=, -= o *= que combinan una operacion con la asignacion."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "total = 0\ntotal += 5  # total == 5"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "En objetos mutables (listas) modifican en sitio; en inmutables crean un objeto nuevo."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
