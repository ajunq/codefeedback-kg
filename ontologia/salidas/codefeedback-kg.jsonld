        "@value": "Complejo (complex)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Tipo numerico para numeros complejos con parte real e imaginaria (sufijo j)."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "z = 2 + 3j\nz.real  # 2.0"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Soporta aritmetica compleja nativa; accede a .real y .imag."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
