  {
    "@id": "https://w3id.org/codefeedback-kg/id/dunder",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#Paradigma"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Dunder methods"
      },
      {
        "@language": "es",
        "@value": "Métodos especiales (dunder)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Metodos especiales con doble guion bajo (__init__, __len__, __eq__) que integran objetos con el lenguaje."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "class Vec:\n    def __init__(self, n): self.n = n\n    def __add__(self, o): return Vec(self.n + o.n)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Permiten personalizar operadores, iteracion o representacion; tambien llamados metodos magicos."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
