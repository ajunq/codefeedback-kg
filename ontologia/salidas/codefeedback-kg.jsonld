  {
    "@id": "https://w3id.org/codefeedback-kg/id/sorted_f",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#FuncionIntegrada"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "sorted/sort"
      },
      {
        "@language": "es",
        "@value": "sorted() y sort()"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Funcion sorted() que devuelve una lista ordenada y metodo list.sort() que ordena en sitio."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "sorted([3, 1, 2])  # [1, 2, 3]\nsorted(palabras, key=len)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Admiten key para criterio y reverse; el algoritmo Timsort es estable y O(n log n)."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/basico"
