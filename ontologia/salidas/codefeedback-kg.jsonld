      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Tipo que describe una interfaz por su estructura (metodos y atributos), no por herencia explicita."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "from typing import Protocol\nclass Dibujable(Protocol):\n    def dibujar(self) -> None: ..."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Formaliza el duck typing para los verificadores estaticos; una clase la satisface si tiene los miembros."
      }
    ],
