        "@language": "en",
        "@value": "Set"
      },
      {
        "@language": "es",
        "@value": "Conjunto (set)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "http://dbpedia.org/resource/Set_(abstract_data_type)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Coleccion no ordenada de elementos unicos e inmutables (set)."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#exactMatch": [
      {
        "@id": "http://www.wikidata.org/entity/Q1514741"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "s = {1, 2, 2, 3}  # {1, 2, 3}\n2 in s  # True"
