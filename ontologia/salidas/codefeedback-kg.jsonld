      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 2
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/fstring",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "f-strings"
      },
      {
        "@language": "es",
        "@value": "f-strings"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Cadena literal con prefijo f que permite interpolar expresiones entre llaves."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "nombre = 'Ana'\nf'Hola {nombre}, {2+2=}'"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#related": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/formato_str"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Disponible desde Python 3.6; admite formato y, desde 3.8, la sintaxis de depuracion {x=}."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
