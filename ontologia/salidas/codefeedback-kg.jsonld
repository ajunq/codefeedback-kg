  {
    "@id": "https://w3id.org/codefeedback-kg/id/ordenacion_mezcla",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Merge sort"
      },
      {
        "@language": "es",
        "@value": "Ordenación por mezcla"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/notacion_o"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "http://dbpedia.org/resource/Merge_sort"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Algoritmo de ordenacion por division y conquista que fusiona sublistas ordenadas."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#exactMatch": [
      {
        "@id": "http://www.wikidata.org/entity/Q189057"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "def mezcla(xs):\n    if len(xs) <= 1: return xs\n    m = len(xs)//2\n    return fusion(mezcla(xs[:m]), mezcla(xs[m:]))"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Estable y O(n log n) en el peor caso, pero usa memoria adicional O(n)."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_algoritmos"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/notacion_o"
      },
      {
        "@id": "https://w3id.org/codefeedback-kg/id/recursion"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneComplejidadTemporal": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "O(n log n)"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 5
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/schema#",
    "@type": [
      "http://www.w3.org/2002/07/owl#Ontology"
    ],
    "http://creativecommons.org/ns#license": [
      {
        "@id": "https://creativecommons.org/licenses/by/4.0/"
      }
    ],
    "http://purl.org/dc/terms/created": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#date",
        "@value": "2026-06-18"
      }
    ],
    "http://purl.org/dc/terms/creator": [
      {
        "@value": "Adrián Bueno Junquero"
      }
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@language": "es",
        "@value": "Ontología y grafo de conocimiento del dominio de la programación en Python, diseñado para anclar la generación de retroalimentación formativa automática (arquitectura EKG + RAG + LLM). Modela conceptos, sus prerrequisitos y contrastes, temas, ejercicios, errores conceptuales (misconceptions), recursos y perfiles de estudiante."
      }
    ],
    "http://purl.org/dc/terms/issued": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#date",
        "@value": "2026-06-21"
      }
    ],
    "http://purl.org/dc/terms/license": [
      {
        "@id": "https://creativecommons.org/licenses/by/4.0/"
      }
    ],
    "http://purl.org/dc/terms/modified": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#date",
        "@value": "2026-06-21"
      }
    ],
    "http://purl.org/dc/terms/title": [
      {
        "@language": "en",
        "@value": "CodeFeedback-KG: A Semantic Knowledge Graph of Python Concepts for Pedagogical Code Feedback"
      },
      {
        "@language": "es",
        "@value": "Grafo de Conocimiento Educativo de Programación en Python (CodeFeedback-KG)"
      }
    ],
    "http://purl.org/vocab/vann/preferredNamespacePrefix": [
      {
        "@value": "cfkg"
      }
    ],
    "http://purl.org/vocab/vann/preferredNamespaceUri": [
      {
        "@value": "https://w3id.org/codefeedback-kg/schema#"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#seeAlso": [
      {
        "@id": "https://w3id.org/codefeedback-kg/"
      }
    ],
    "http://www.w3.org/2002/07/owl#versionIRI": [
      {
        "@id": "https://w3id.org/codefeedback-kg/schema/2.0.0"
      }
    ],
    "http://www.w3.org/2002/07/owl#versionInfo": [
      {
        "@value": "2.0.0"
      }
    ]
  },
