  {
    "@id": "https://w3id.org/codefeedback-kg/id/typing_callable",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#ConceptoDeTipado"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "typing.Callable"
      },
      {
        "@language": "es",
        "@value": "typing.Callable"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Anotacion que describe el tipo de un objeto invocable indicando sus argumentos y retorno."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "from typing import Callable\ndef aplica(f: Callable[[int], int], x: int) -> int:\n    return f(x)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Util para anotar callbacks y funciones de orden superior; Callable[[int], str] toma un int y devuelve str."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/intermedio"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_tipos"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/anotaciones_tipo"
      },
      {
        "@id": "https://w3id.org/codefeedback-kg/id/funcion_orden_superior"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 3
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/global_kw",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "global"
      },
      {
        "@language": "es",
        "@value": "Palabra clave global"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Declaracion que permite a una funcion reasignar una variable del ambito global."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "contador = 0\ndef inc():\n    global contador\n    contador += 1"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#related": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/ambito"
      },
      {
        "@id": "https://w3id.org/codefeedback-kg/id/nonlocal_kw"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Su uso suele indicar un diseno mejorable; prefiere devolver valores o encapsular el estado."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/intermedio"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_funciones"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/ambito"
      }
    ],
