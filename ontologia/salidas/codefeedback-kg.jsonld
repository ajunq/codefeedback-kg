      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Modulo sys con acceso a parametros y funciones del interprete (argv, path, exit)."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "import sys\nprint(sys.argv)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "sys.argv recibe los argumentos de linea de comandos; sys.exit termina el programa."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
