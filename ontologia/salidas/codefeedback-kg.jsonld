  {
    "@id": "https://w3id.org/codefeedback-kg/id/ambito",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Variable scope"
      },
      {
        "@language": "es",
        "@value": "Ámbito de variables (scope)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "http://dbpedia.org/resource/Scope_(computer_science)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Region del programa donde un nombre de variable es visible y accesible (regla LEGB)."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "x = 1\ndef f():\n    x = 2  # variable local, no afecta a la global\n    return x"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Distingue ambito local, envolvente, global e incorporado; una asignacion crea una variable local salvo global/nonlocal."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_funciones"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/funcion"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 3
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/truthiness",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Truthiness"
      },
      {
        "@language": "es",
        "@value": "Valores de verdad"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Evaluacion de un objeto como verdadero o falso en un contexto booleano."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "if not lista:\n    print('vacia')"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#related": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/any_all"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Colecciones vacias, 0, None y '' son falsy; el resto es truthy. Aprovechalo en condiciones idiomaticas."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/basico"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
