  {
    "@id": "https://w3id.org/codefeedback-kg/id/copia_profunda",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Deep copy"
      },
      {
        "@language": "es",
        "@value": "Copia profunda"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Copia que duplica recursivamente un objeto y todos los objetos anidados que contiene."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "import copy\nb = copy.deepcopy(a)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Usa copy.deepcopy cuando modificar la copia no debe afectar al original anidado; es mas costosa que la superficial."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#contrastaCon": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/copia_superficial"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_tipos"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/copia_superficial"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 4
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/copia_superficial",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Shallow copy"
      },
      {
        "@language": "es",
        "@value": "Copia superficial"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Copia que duplica el contenedor externo pero comparte las referencias a los objetos internos."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "import copy\nb = copy.copy(a)  # superficial"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "list(x), x[:] o copy.copy crean copias superficiales; modificar elementos anidados afecta a ambas copias."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_tipos"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/lista"
      },
      {
        "@id": "https://w3id.org/codefeedback-kg/id/mutabilidad"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 4
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/objeto",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#Paradigma"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Object"
      },
      {
        "@language": "es",
        "@value": "Objeto / instancia"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "http://dbpedia.org/resource/Object_(computer_science)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Instancia concreta de una clase con su propio estado y comportamiento."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "p = Punto(1, 2)  # p es un objeto"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Todo en Python es un objeto; se crea llamando a la clase y vive mientras haya referencias a el."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/intermedio"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_poo"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/clase"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 3
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/T_recursion",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#Tema"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Recursion"
      },
      {
        "@language": "es",
        "@value": "Recursión"
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/generador",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#EstructuraDeControl"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Generator"
      },
      {
        "@language": "es",
        "@value": "Generador (yield)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "http://dbpedia.org/resource/Generator_(computer_programming)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Funcion que produce una secuencia de valores de forma perezosa usando yield."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#exactMatch": [
      {
        "@id": "http://www.wikidata.org/entity/Q2565187"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "def cuenta(n):\n    i = 0\n    while i < n:\n        yield i\n        i += 1"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Mantiene su estado entre llamadas y ahorra memoria; se agota tras recorrerse una vez."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_funcional"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/funcion"
      },
      {
        "@id": "https://w3id.org/codefeedback-kg/id/iterador"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 4
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/schema#esVarianteDe",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty",
      "http://www.w3.org/2002/07/owl#SymmetricProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "es",
        "@value": "Relacion simetrica entre variantes sintacticas o conceptuales de una misma idea."
