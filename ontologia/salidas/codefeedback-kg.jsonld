  {
    "@id": "https://w3id.org/codefeedback-kg/id/match_case",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#EstructuraDeControl"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Structural pattern matching"
      },
      {
        "@language": "es",
        "@value": "match-case"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Coincidencia estructural de patrones (match/case) que compara un valor con varias formas."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "match punto:\n    case (0, 0):\n        print('origen')\n    case (x, y):\n        print(x, y)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#narrower": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/patron_captura"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Disponible desde Python 3.10; permite desestructurar y usar guardas, mas potente que una cadena de if."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
