    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "split and join"
      },
      {
        "@language": "es",
        "@value": "Metodos split y join"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "split() divide una cadena en una lista y join() une una lista de cadenas con un separador."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "'a,b,c'.split(',')   # ['a', 'b', 'c']\n'-'.join(['a', 'b'])  # 'a-b'"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Son operaciones inversas habituales al procesar texto y ficheros delimitados."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
