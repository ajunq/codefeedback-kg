  {
    "@id": "https://w3id.org/codefeedback-kg/id/itertools_mod",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#ModuloLibreria"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "itertools"
      },
      {
        "@language": "es",
        "@value": "itertools"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Modulo itertools con utilidades para construir iteradores eficientes y combinatorios."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "import itertools\nlist(itertools.islice(itertools.count(), 3))  # [0, 1, 2]"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#narrower": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/itertools_chain"
      },
      {
        "@id": "https://w3id.org/codefeedback-kg/id/itertools_product"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Incluye count, cycle, chain, product o combinations; opera de forma perezosa."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_funcional"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
