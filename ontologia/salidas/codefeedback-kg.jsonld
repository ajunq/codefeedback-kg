      {
        "@language": "en",
        "@value": "Attribute"
      },
      {
        "@language": "es",
        "@value": "Atributo de instancia"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Variable asociada a una instancia que almacena parte de su estado."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "class Punto:\n    def __init__(self, x):\n        self.x = x  # atributo de instancia"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Se define normalmente en __init__ usando self; no confundir con atributos de clase compartidos."
      }
    ],
