        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 4
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/ternario",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#EstructuraDeControl"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Ternary operator"
      },
      {
        "@language": "es",
        "@value": "Operador ternario"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Expresion condicional en una linea: valor_si_verdadero if condicion else valor_si_falso."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "signo = 'par' if n % 2 == 0 else 'impar'"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Util para asignaciones breves; si la logica crece, un if/else completo es mas claro."
      }
    ],
