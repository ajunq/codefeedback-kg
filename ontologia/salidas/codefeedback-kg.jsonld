    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Funcion que personaliza un campo de una dataclass, por ejemplo con fabricas por defecto."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "from dataclasses import dataclass, field\n@dataclass\nclass C:\n    items: list = field(default_factory=list)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Usa default_factory=list para valores mutables por defecto y evitar compartirlos entre instancias."
      }
    ],
