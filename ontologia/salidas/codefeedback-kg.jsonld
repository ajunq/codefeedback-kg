    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Type checking"
      },
      {
        "@language": "es",
        "@value": "Comprobación de tipos (mypy)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Comprobacion estatica de tipos a partir de las anotaciones, sin ejecutar el programa."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "# def f(x: int) -> int: return x + 1\n# mypy avisa si se llama f('a')"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Herramientas como mypy detectan incoherencias antes de la ejecucion; no afecta al rendimiento."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
