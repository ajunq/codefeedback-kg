      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 4
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/err_mod_durante_iteracion",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#ErrorConceptual"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Mutating list while iterating"
      },
      {
        "@language": "es",
        "@value": "Modificar una lista mientras se itera"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#errorSobreConcepto": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/bucle_for"
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/typing_final",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#ConceptoDeTipado"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "typing.Final"
      },
      {
        "@language": "es",
        "@value": "typing.Final"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Anotacion que marca un nombre como constante que no debe reasignarse ni redefinirse."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "from typing import Final\nMAX: Final = 100"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "El verificador estatico avisa si se intenta modificar; no impide el cambio en tiempo de ejecucion."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/intermedio"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#introducidoEnVersion": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "3.8"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_tipos"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/anotaciones_tipo"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 3
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/basico",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#NivelDominio"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "basic"
      },
      {
        "@language": "es",
        "@value": "básico"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#notation": [
      {
        "@value": "1"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
