  {
    "@id": "https://w3id.org/codefeedback-kg/id/singledispatch",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#ModuloLibreria"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "functools.singledispatch"
      },
      {
        "@language": "es",
        "@value": "functools.singledispatch"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Decorador que crea una funcion generica cuya implementacion se elige segun el tipo del primer argumento."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "from functools import singledispatch\n@singledispatch\ndef mostrar(x): print(x)\n@mostrar.register\ndef _(x: list): print('lista', x)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#related": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/polimorfismo"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Aporta despacho multiple basico al estilo funcional, sin recurrir a una jerarquia de clases."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
