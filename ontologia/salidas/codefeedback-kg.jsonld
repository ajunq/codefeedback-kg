        "@value": "Extraccion de subsecuencias mediante la notacion [inicio:fin:paso]."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "xs = [0, 1, 2, 3, 4]\nxs[1:4]  # [1, 2, 3]"
