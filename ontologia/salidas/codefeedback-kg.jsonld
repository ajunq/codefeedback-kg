    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Capacidad de tratar de forma uniforme objetos de distintas clases que comparten interfaz."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#exactMatch": [
      {
        "@id": "http://www.wikidata.org/entity/Q3240252"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "for a in animales:\n    print(a.hablar())  # cada clase implementa hablar"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Python lo logra por duck typing: importa el comportamiento, no el tipo exacto."
      }
