  {
    "@id": "https://w3id.org/codefeedback-kg/id/metodo",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#Paradigma"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Method"
      },
      {
        "@language": "es",
        "@value": "Método"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Funcion definida dentro de una clase que opera sobre sus instancias."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "class Saludo:\n    def hola(self):\n        return 'hola'"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#narrower": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/init_method"
      },
      {
        "@id": "https://w3id.org/codefeedback-kg/id/metodo_clase"
      },
      {
        "@id": "https://w3id.org/codefeedback-kg/id/metodo_estatico"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Recibe la instancia como primer parametro (self); se invoca con la notacion objeto.metodo()."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/intermedio"
