    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Text encoding"
      },
      {
        "@language": "es",
        "@value": "Codificación de texto"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Esquema que asocia caracteres a secuencias de bytes (UTF-8, Latin-1) al codificar texto."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "datos = 'cana'.encode('utf-8')\ntexto = datos.decode('utf-8')"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Especifica siempre encoding al abrir ficheros de texto; errores de codificacion causan UnicodeDecodeError."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
