    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Docstring"
      },
      {
        "@language": "es",
        "@value": "Docstring"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Cadena de documentacion situada al inicio de un modulo, clase o funcion."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "def suma(a, b):\n    \"\"\"Devuelve la suma de a y b.\"\"\"\n    return a + b"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Accesible mediante help() y __doc__; conviene seguir convenciones como PEP 257."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/basico"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_testing"
      }
    ],
