    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "typing.Literal"
      },
      {
        "@language": "es",
        "@value": "typing.Literal"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Anotacion que restringe un valor a un conjunto concreto de constantes literales."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "from typing import Literal\ndef mover(d: Literal['n', 's', 'e', 'o']) -> None: ..."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Documenta parametros que solo admiten ciertos valores; el verificador rechaza los demas."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/intermedio"
