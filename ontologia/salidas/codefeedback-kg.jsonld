  {
    "@id": "https://w3id.org/codefeedback-kg/id/cola_prioridad",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#EstructuraDeDatos"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Priority queue"
      },
      {
        "@language": "es",
        "@value": "Cola de prioridad"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "http://dbpedia.org/resource/Priority_queue"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Cola en la que cada elemento tiene una prioridad y se extrae siempre el de mayor prioridad."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#exactMatch": [
      {
        "@id": "http://www.wikidata.org/entity/Q629283"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "import heapq\npq = []\nheapq.heappush(pq, (2, 'tarea B'))\nheapq.heappush(pq, (1, 'tarea A'))\nheapq.heappop(pq)  # (1, 'tarea A')"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#related": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/cola"
      },
      {
        "@id": "https://w3id.org/codefeedback-kg/id/heap"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Se implementa eficientemente con un monticulo (heapq); base de algoritmos como Dijkstra."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_estructuras"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/heap"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneComplejidadTemporal": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "O(log n)"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 4
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/T_funcional",
    "@type": [
