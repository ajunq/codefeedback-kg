  {
    "@id": "https://w3id.org/codefeedback-kg/id/busqueda_binaria",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Binary search"
      },
      {
        "@language": "es",
        "@value": "Búsqueda binaria"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "http://dbpedia.org/resource/Binary_search_algorithm"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Algoritmo que localiza un elemento en una lista ordenada dividiendo a la mitad el espacio de busqueda."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#exactMatch": [
      {
        "@id": "http://www.wikidata.org/entity/Q243754"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "def binaria(xs, x):\n    lo, hi = 0, len(xs) - 1\n    while lo <= hi:\n        m = (lo + hi) // 2\n        if xs[m] == x: return m\n        if xs[m] < x: lo = m + 1\n        else: hi = m - 1\n    return -1"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "es",
        "@value": "Búsqueda binaria"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#related": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/busqueda_lineal"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Requiere que la secuencia este ordenada; su coste es O(log n) frente a O(n) de la busqueda lineal."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_complejidad"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/bucle_while"
      },
      {
        "@id": "https://w3id.org/codefeedback-kg/id/indexacion"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#seAplicaA": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/lista"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneComplejidadTemporal": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "O(log n)"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 4
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/schema#tieneComplejidadTemporal",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "es",
        "@value": "Complejidad temporal en notacion O grande (p. ej. 'O(log n)')."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://w3id.org/codefeedback-kg/schema#Concepto"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
