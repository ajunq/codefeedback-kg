  {
    "@id": "https://w3id.org/codefeedback-kg/id/herencia",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#Paradigma"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Inheritance"
      },
      {
        "@language": "es",
        "@value": "Herencia"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "http://dbpedia.org/resource/Inheritance_(object-oriented_programming)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Mecanismo por el que una clase deriva atributos y metodos de otra clase base."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#exactMatch": [
      {
        "@id": "http://www.wikidata.org/entity/Q212542"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "class Animal:\n    def hablar(self): ...\nclass Perro(Animal):\n    def hablar(self): return 'guau'"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#narrower": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/herencia_multiple"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#related": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/composicion"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Modela relaciones 'es-un'; usa super() para extender el comportamiento heredado sin duplicarlo."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_poo"
      }
    ],
