  {
    "@id": "https://w3id.org/codefeedback-kg/id/lista",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#EstructuraDeDatos"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "List"
      },
      {
        "@language": "es",
        "@value": "Lista"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "http://dbpedia.org/resource/List_(abstract_data_type)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Secuencia mutable y ordenada que admite elementos de cualquier tipo."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#exactMatch": [
      {
        "@id": "http://www.wikidata.org/entity/Q27948"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "xs = [1, 'a', True]\nxs.append(2)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#narrower": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/cola"
      },
      {
        "@id": "https://w3id.org/codefeedback-kg/id/pila"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "es",
        "@value": "Lista"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#related": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/conjunto"
      },
      {
        "@id": "https://w3id.org/codefeedback-kg/id/tupla"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Crece dinamicamente; el acceso por indice es O(1) y la insercion al final amortizada O(1)."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/basico"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_estructuras"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneComplejidadTemporal": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "O(n)"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 2
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneEjemploCodigo": [
      {
        "@value": "xs = [1, 2, 3]"
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/argparse_mod",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#ModuloLibreria"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "argparse"
      },
      {
        "@language": "es",
        "@value": "Modulo argparse"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Modulo estandar para definir y analizar argumentos de la linea de comandos."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "import argparse\np = argparse.ArgumentParser()\np.add_argument('nombre')\np.parse_args()"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#related": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/modulo_sys"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Genera ayuda automatica y valida tipos; mas robusto que leer sys.argv manualmente."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/intermedio"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_modulos"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/modulo_sys"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 3
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/yield_from",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#EstructuraDeControl"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "yield from"
      },
      {
        "@language": "es",
        "@value": "yield from"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Expresion yield from que delega la produccion de valores a otro generador o iterable."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "def aplanar(listas):\n    for l in listas:\n        yield from l"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Simplifica la composicion de generadores y transmite valores enviados y excepciones."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#introducidoEnVersion": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "3.3"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_funcional"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/generador"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 5
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/arbol_busqueda_binaria",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#EstructuraDeDatos"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Binary search tree"
      },
      {
        "@language": "es",
        "@value": "Arbol de busqueda binaria"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/arbol_binario"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "http://dbpedia.org/resource/Binary_search_tree"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Arbol binario donde el subarbol izquierdo solo contiene valores menores y el derecho, mayores."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "def buscar(nodo, x):\n    if nodo is None or nodo.v == x:\n        return nodo\n    return buscar(nodo.izq if x < nodo.v else nodo.der, x)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Permite busqueda, insercion y borrado en O(log n) si esta equilibrado; degenera a O(n) si no."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_algoritmos"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/arbol_binario"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneComplejidadTemporal": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "O(log n)"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 4
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/schema#cubiertoPorEjercicio",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "es",
        "@value": "Inversa de cubreConcepto."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://w3id.org/codefeedback-kg/schema#Concepto"
