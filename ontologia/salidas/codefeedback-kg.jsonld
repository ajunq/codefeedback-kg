  {
    "@id": "https://w3id.org/codefeedback-kg/id/closure",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Closure"
      },
      {
        "@language": "es",
        "@value": "Clausura (closure)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "http://dbpedia.org/resource/Closure_(computer_programming)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Funcion interna que recuerda y captura variables del ambito envolvente donde fue creada."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#exactMatch": [
      {
        "@id": "http://www.wikidata.org/entity/Q535335"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "def multiplicador(n):\n    def f(x):\n        return x * n\n    return f\ndoble = multiplicador(2)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Permite fabricas de funciones; las variables capturadas se evaluan en el momento de la llamada (cuidado con el late binding)."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_funcional"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/ambito"
      },
      {
        "@id": "https://w3id.org/codefeedback-kg/id/funcion"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 4
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/metaclase",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#Paradigma"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Metaclass"
      },
      {
        "@language": "es",
        "@value": "Metaclase"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "http://dbpedia.org/resource/Metaclass"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Clase cuyas instancias son a su vez clases, lo que permite personalizar como se crean."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#exactMatch": [
      {
        "@id": "http://www.wikidata.org/entity/Q1924819"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "class Meta(type):\n    def __new__(mcs, n, b, d):\n        return super().__new__(mcs, n, b, d)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "type es la metaclase por defecto; rara vez necesarias, pero potentes para frameworks (ORM, ABC)."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_poo"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
