    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "str and repr"
      },
      {
        "@language": "es",
        "@value": "__str__ y __repr__"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Metodos __str__ (representacion legible) y __repr__ (representacion no ambigua) de un objeto."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "class P:\n    def __repr__(self):\n        return f'P({self.x!r})'"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "__str__ se usa en print y __repr__ en la consola/depuracion; define __repr__ al menos."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
