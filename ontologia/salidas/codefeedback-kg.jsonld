      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 5
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/operador_comparacion",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#OperadorDelLenguaje"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Comparison operators"
      },
      {
        "@language": "es",
        "@value": "Operadores de comparacion"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Operadores que comparan valores y devuelven un booleano: ==, !=, <, <=, >, >=."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "1 < 2 <= 2  # True"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Pueden encadenarse (1 < x < 10); == compara valor mientras que is compara identidad."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/basico"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_fundamentos"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/variable"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/comprension_sets",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#EstructuraDeControl"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Set comprehension"
      },
      {
        "@language": "es",
        "@value": "Comprensión de conjuntos"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/comprension_listas"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Sintaxis concisa para construir conjuntos eliminando duplicados a partir de un iterable."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "iniciales = {p[0] for p in ['ana', 'alba', 'bea']}"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Sigue el patron {expr for ...}; util para obtener elementos unicos transformados."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_estructuras"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/comprension_listas"
      },
      {
        "@id": "https://w3id.org/codefeedback-kg/id/conjunto"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 4
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/condicional",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#EstructuraDeControl"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Conditional (if)"
      },
      {
        "@language": "es",
        "@value": "Condicional (if)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Sentencia if/elif/else que ejecuta bloques distintos segun condiciones booleanas."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "if x > 0:\n    print('positivo')\nelif x == 0:\n    print('cero')\nelse:\n    print('negativo')"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "La sangria delimita el bloque; las condiciones se evaluan en orden hasta la primera verdadera."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_control"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/tipo_bool"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/propiedad",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#Paradigma"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Property"
      },
      {
        "@language": "es",
        "@value": "Propiedad (@property)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/decorador"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Atributo gestionado (@property) que ejecuta metodos al leer o escribir un valor."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "class C:\n    @property\n    def area(self):\n        return self.lado ** 2"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Permite anadir validacion o calculo sin cambiar la interfaz publica del atributo."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_poo"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/decorador"
      },
      {
        "@id": "https://w3id.org/codefeedback-kg/id/encapsulacion"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 4
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/ordenacion_burbuja",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Bubble sort"
      },
      {
        "@language": "es",
        "@value": "Ordenación de burbuja"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/notacion_o"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "http://dbpedia.org/resource/Bubble_sort"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Algoritmo de ordenacion que intercambia repetidamente elementos adyacentes desordenados."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#exactMatch": [
      {
        "@id": "http://www.wikidata.org/entity/Q60864"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "def burbuja(xs):\n    for i in range(len(xs)):\n        for j in range(len(xs)-1-i):\n            if xs[j] > xs[j+1]:\n                xs[j], xs[j+1] = xs[j+1], xs[j]"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Didactico pero ineficiente (O(n^2)); en la practica usa sorted() (Timsort)."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/intermedio"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_algoritmos"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/bucle_for"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneComplejidadTemporal": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "O(n^2)"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 3
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/tipo_bytes",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#TipoDeDato"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Bytes"
      },
      {
        "@language": "es",
        "@value": "Bytes"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Secuencia inmutable de bytes (0-255) para datos binarios."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "b'abc'\n'cana'.encode('utf-8')"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Se obtiene codificando texto; no confundas bytes con str. Para datos mutables usa bytearray."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/intermedio"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_tipos"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/tipo_str"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 3
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/reduce_func",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#FuncionIntegrada"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "reduce"
      },
      {
        "@language": "es",
        "@value": "functools.reduce()"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Funcion functools.reduce que combina los elementos de un iterable en un unico valor."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "from functools import reduce\nreduce(lambda a, b: a*b, [1, 2, 3, 4])  # 24"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#related": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/filter_func"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Aplica una funcion binaria acumulando; para sumas o productos hay alternativas mas claras (sum, math.prod)."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
