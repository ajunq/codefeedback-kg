      {
        "@language": "en",
        "@value": "import"
      },
      {
        "@language": "es",
        "@value": "import"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Sentencia import que carga un modulo y lo pone a disposicion del programa."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "import math\nmath.pi"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "El interprete cachea los modulos importados; situa los imports al inicio del fichero (PEP 8)."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
