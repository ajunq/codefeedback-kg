      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 3
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/T_excepciones",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#Tema"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Exceptions"
      },
      {
        "@language": "es",
        "@value": "Excepciones"
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/modulo_os",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#ModuloLibreria"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "os module"
      },
      {
        "@language": "es",
        "@value": "Módulo os"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Modulo os con utilidades para interactuar con el sistema operativo y los ficheros."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "import os\nos.getcwd()"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Para rutas, os.path o, preferiblemente, pathlib; os.environ accede a las variables de entorno."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/intermedio"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_modulos"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/import_mod"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 3
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/patron_captura",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#EstructuraDeControl"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Capture patterns"
      },
      {
        "@language": "es",
        "@value": "Patrones de captura"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/match_case"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Patrones de match que extraen partes de una estructura y las vinculan a variables."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "match punto:\n    case (x, y) if x == y:\n        print('diagonal')\n    case (x, y):\n        print(x, y)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Permiten desestructurar secuencias y objetos; combinados con guardas (if) afinan la coincidencia."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#introducidoEnVersion": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "3.10"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_control"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/match_case"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 4
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/recursion_cola",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Tail recursion"
      },
      {
        "@language": "es",
        "@value": "Recursión de cola"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/recursion"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "http://dbpedia.org/resource/Tail_call"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Recursion en la que la llamada recursiva es la ultima operacion de la funcion."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#exactMatch": [
      {
        "@id": "http://www.wikidata.org/entity/Q1340959"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "def suma(xs, acc=0):\n    if not xs: return acc\n    return suma(xs[1:], acc + xs[0])"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Otros lenguajes la optimizan, pero CPython no elimina la recursion de cola: puede desbordar la pila."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_recursion"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/recursion"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 5
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/arbol_binario",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#EstructuraDeDatos"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Binary tree"
      },
      {
        "@language": "es",
        "@value": "Arbol binario"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/arbol_estr"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "http://dbpedia.org/resource/Binary_tree"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Arbol en el que cada nodo tiene como maximo dos hijos, izquierdo y derecho."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#exactMatch": [
      {
        "@id": "http://www.wikidata.org/entity/Q380172"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "class NodoB:\n    def __init__(self, v):\n        self.v = v\n        self.izq = self.der = None"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#narrower": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/arbol_busqueda_binaria"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Base de los arboles de busqueda y los montículos; se recorre en preorden, inorden o postorden."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_algoritmos"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/arbol_estr"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 4
      }
    ]
  }
