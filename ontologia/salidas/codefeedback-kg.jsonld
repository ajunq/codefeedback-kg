      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_funciones"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/closure"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 4
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/escribir_fichero",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#FuncionIntegrada"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "File writing"
      },
      {
        "@language": "es",
        "@value": "Escritura de ficheros"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Escritura de datos en un fichero mediante metodos como write() o writelines()."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "with open('s.txt', 'w', encoding='utf-8') as f:\n    f.write('hola')"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Abre en modo 'w' (sobrescribe) o 'a' (anade); usa with para cerrar y volcar el buffer."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/intermedio"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
