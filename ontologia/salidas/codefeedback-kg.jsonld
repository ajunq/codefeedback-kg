  {
    "@id": "https://w3id.org/codefeedback-kg/id/pytest_mod",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#ModuloLibreria"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "pytest"
      },
      {
        "@language": "es",
        "@value": "pytest"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Marco de pruebas pytest que descubre y ejecuta tests con asserts simples."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "def test_suma():\n    assert 1 + 1 == 2"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Ofrece fixtures, parametrizacion y mensajes de fallo detallados; estandar de facto en Python."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_testing"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/funcion"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 4
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/tipo_str",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#TipoDeDato"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "String (str)"
      },
      {
        "@language": "es",
        "@value": "Cadena (str)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Secuencia inmutable de caracteres Unicode para representar texto."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "s = 'Python'\ns[0]  # 'P'"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Admite indexacion, slicing y muchos metodos; al ser inmutable, cada operacion crea una cadena nueva."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_fundamentos"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/grafo_estr",
