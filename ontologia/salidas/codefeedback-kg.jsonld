      },
      {
        "@language": "es",
        "@value": "Sentencia with"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Sentencia with que delega en un gestor de contexto la apertura y cierre de un recurso."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "with open('f.txt') as f:\n    datos = f.read()"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Garantiza la liberacion del recurso aunque ocurra una excepcion; reduce el codigo repetitivo de try/finally."
      }
    ],
