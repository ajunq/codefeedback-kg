      {
        "@language": "en",
        "@value": "Coroutine"
      },
      {
        "@language": "es",
        "@value": "Corrutina"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/async_await"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Funcion que puede suspender y reanudar su ejecucion, cooperando con un planificador."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#exactMatch": [
      {
        "@id": "http://www.wikidata.org/entity/Q1339231"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "async def contador():\n    for i in range(3):\n        await asyncio.sleep(0)\n        yield i"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "En Python moderno se definen con async def; las clasicas usaban generadores con yield."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
