    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Stack"
      },
      {
        "@language": "es",
        "@value": "Pila (stack)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/lista"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "http://dbpedia.org/resource/Stack_(abstract_data_type)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Estructura LIFO (ultimo en entrar, primero en salir) que apila y desapila por un mismo extremo."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#exactMatch": [
      {
        "@id": "http://www.wikidata.org/entity/Q177929"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "pila = []\npila.append(1)\npila.pop()  # 1"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#related": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/cola"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Una lista funciona como pila con append y pop; base de la recursion, el deshacer y la evaluacion de expresiones."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
