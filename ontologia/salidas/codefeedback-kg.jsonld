  {
    "@id": "https://w3id.org/codefeedback-kg/id/else_bucle",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#EstructuraDeControl"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "loop else"
      },
      {
        "@language": "es",
        "@value": "else en bucles"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Clausula else de un bucle que se ejecuta solo si el bucle termina sin break."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "for x in xs:\n    if x == objetivo:\n        break\nelse:\n    print('no encontrado')"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Util para detectar si una busqueda no encontro el elemento; suele confundir a los principiantes."
      }
    ],
