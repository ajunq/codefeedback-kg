  {
    "@id": "https://w3id.org/codefeedback-kg/id/min_max",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#FuncionIntegrada"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "min and max"
      },
      {
        "@language": "es",
        "@value": "Funciones min y max"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Funciones que devuelven el menor o mayor elemento de un iterable o de varios argumentos."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "max([3, 1, 2])             # 3\nmax(palabras, key=len)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Aceptan key para definir el criterio y default para iterables vacios."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/basico"
      }
