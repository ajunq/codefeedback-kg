  {
    "@id": "https://w3id.org/codefeedback-kg/id/from_import",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "from import"
      },
      {
        "@language": "es",
        "@value": "from ... import"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Variante del import que trae nombres concretos de un modulo al espacio de nombres actual."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "from math import sqrt\nsqrt(16)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Evita el prefijo del modulo pero puede provocar colisiones; no abuses de from modulo import *."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/basico"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_modulos"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/import_mod"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 2
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/encapsulacion",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#Paradigma"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Encapsulation"
      },
      {
        "@language": "es",
        "@value": "Encapsulación"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "http://dbpedia.org/resource/Encapsulation_(computer_programming)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Principio de ocultar el estado interno de un objeto exponiendo solo una interfaz controlada."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "class Cuenta:\n    def __init__(self):\n        self.__saldo = 0  # 'privado'"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Python usa convenciones (_protegido, __privado con name mangling) en lugar de modificadores estrictos."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/avanzado"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#perteneceATema": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/T_poo"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#requierePrerrequisito": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/atributo"
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#tieneDificultad": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 4
      }
    ]
  },
  {
    "@id": "https://w3id.org/codefeedback-kg/id/typing_typeddict",
    "@type": [
      "https://w3id.org/codefeedback-kg/schema#ConceptoDeTipado"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "TypedDict"
      },
      {
        "@language": "es",
        "@value": "typing.TypedDict"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Tipo que especifica las claves esperadas de un diccionario y el tipo de cada valor."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "from typing import TypedDict\nclass Usuario(TypedDict):\n    nombre: str\n    edad: int"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "es",
        "@value": "Aporta seguridad de tipos a los diccionarios tipo registro sin crear una clase."
      }
    ],
    "https://w3id.org/codefeedback-kg/schema#aNivelDominio": [
