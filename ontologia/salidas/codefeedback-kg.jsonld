      {
        "@language": "en",
        "@value": "Dataclass"
      },
      {
        "@language": "es",
        "@value": "Dataclass"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "es",
        "@value": "Decorador @dataclass que genera automaticamente __init__, __repr__ y __eq__ a partir de anotaciones."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#example": [
      {
        "@value": "from dataclasses import dataclass\n@dataclass\nclass Punto:\n    x: int\n    y: int = 0"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#narrower": [
      {
        "@id": "https://w3id.org/codefeedback-kg/id/dataclass_field"
