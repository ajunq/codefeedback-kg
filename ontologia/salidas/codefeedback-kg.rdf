  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/argumentos_nombrados">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Keyword arguments</rdfs:label>
    <rdfs:label xml:lang="es">Argumentos por nombre</rdfs:label>
    <skos:definition xml:lang="es">Argumentos que se pasan a una funcion indicando el nombre del parametro (clave=valor).</skos:definition>
    <skos:example>def conecta(host, puerto=80):
    ...
conecta('localhost', puerto=8080)</skos:example>
    <skos:scopeNote xml:lang="es">Mejoran la legibilidad y permiten omitir el orden; deben ir despues de los posicionales.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_funciones"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/parametros"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</cfkg:tieneDificultad>
  </rdf:Description>
