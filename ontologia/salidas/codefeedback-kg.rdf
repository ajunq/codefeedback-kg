<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:cc="http://creativecommons.org/ns#"
   xmlns:cfkg="https://w3id.org/codefeedback-kg/schema#"
   xmlns:dcterms="http://purl.org/dc/terms/"
   xmlns:foaf="http://xmlns.com/foaf/0.1/"
   xmlns:owl="http://www.w3.org/2002/07/owl#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
   xmlns:schema1="http://schema.org/"
   xmlns:skos="http://www.w3.org/2004/02/skos/core#"
   xmlns:vann="http://purl.org/vocab/vann/"
>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/finally_clause">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeControl"/>
    <rdfs:label xml:lang="en">finally clause</rdfs:label>
    <rdfs:label xml:lang="es">Clausula finally</rdfs:label>
    <skos:broader rdf:resource="https://w3id.org/codefeedback-kg/id/try_except_else"/>
    <skos:definition xml:lang="es">Bloque finally que se ejecuta siempre tras un try, haya o no excepcion.</skos:definition>
    <skos:example>try:
    f = open('d')
finally:
    print('siempre se ejecuta')</skos:example>
    <skos:scopeNote xml:lang="es">Ideal para liberar recursos; se ejecuta incluso si hay return dentro del try.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_excepciones"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/try_except_else"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/herencia">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Paradigma"/>
    <rdfs:label xml:lang="en">Inheritance</rdfs:label>
    <rdfs:label xml:lang="es">Herencia</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Inheritance_(object-oriented_programming)"/>
    <skos:definition xml:lang="es">Mecanismo por el que una clase deriva atributos y metodos de otra clase base.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q212542"/>
    <skos:example>class Animal:
    def hablar(self): ...
class Perro(Animal):
    def hablar(self): return 'guau'</skos:example>
    <skos:narrower rdf:resource="https://w3id.org/codefeedback-kg/id/herencia_multiple"/>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/composicion"/>
    <skos:scopeNote xml:lang="es">Modela relaciones 'es-un'; usa super() para extender el comportamiento heredado sin duplicarlo.</skos:scopeNote>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_poo"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/clase"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/sobrecarga_operadores">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Paradigma"/>
    <rdfs:label xml:lang="en">Operator overloading</rdfs:label>
    <rdfs:label xml:lang="es">Sobrecarga de operadores</rdfs:label>
    <skos:definition xml:lang="es">Definicion del comportamiento de los operadores (+, ==, []) para objetos propios.</skos:definition>
    <skos:example>class V:
    def __init__(self, n): self.n = n
    def __add__(self, o): return V(self.n + o.n)</skos:example>
    <skos:scopeNote xml:lang="es">Se implementa con metodos dunder (__add__, __eq__); usala cuando aporte semantica natural.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_poo"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/dunder"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/slots">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Paradigma"/>
    <rdfs:label xml:lang="en">__slots__</rdfs:label>
    <rdfs:label xml:lang="es">__slots__</rdfs:label>
    <skos:definition xml:lang="es">Declaracion que fija los atributos permitidos de una clase y evita el __dict__ por instancia.</skos:definition>
    <skos:example>class Punto:
    __slots__ = ('x', 'y')
    def __init__(self, x, y):
        self.x, self.y = x, y</skos:example>
    <skos:scopeNote xml:lang="es">Reduce el consumo de memoria con muchas instancias, a costa de perder atributos dinamicos.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_poo"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/atributo"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/typing_callable">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ConceptoDeTipado"/>
    <rdfs:label xml:lang="en">typing.Callable</rdfs:label>
    <rdfs:label xml:lang="es">typing.Callable</rdfs:label>
    <skos:definition xml:lang="es">Anotacion que describe el tipo de un objeto invocable indicando sus argumentos y retorno.</skos:definition>
    <skos:example>from typing import Callable
def aplica(f: Callable[[int], int], x: int) -&gt; int:
    return f(x)</skos:example>
    <skos:scopeNote xml:lang="es">Util para anotar callbacks y funciones de orden superior; Callable[[int], str] toma un int y devuelve str.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_tipos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/anotaciones_tipo"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/funcion_orden_superior"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/asyncio_mod">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ModuloLibreria"/>
    <rdfs:label xml:lang="en">asyncio</rdfs:label>
    <rdfs:label xml:lang="es">asyncio</rdfs:label>
    <skos:definition xml:lang="es">Modulo estandar asyncio para escribir codigo concurrente con corrutinas y un bucle de eventos.</skos:definition>
    <skos:example>import asyncio
async def tarea():
    return 42
asyncio.run(tarea())</skos:example>
    <skos:scopeNote xml:lang="es">Adecuado para E/S concurrente (red, ficheros); no acelera calculo intensivo de CPU.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_concurrencia"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/async_await"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</cfkg:tieneDificultad>
    <cfkg:tieneURLDocumentacion rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://docs.python.org/3/library/asyncio.html</cfkg:tieneURLDocumentacion>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/metodo_split_join">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#FuncionIntegrada"/>
    <rdfs:label xml:lang="en">split and join</rdfs:label>
    <rdfs:label xml:lang="es">Metodos split y join</rdfs:label>
    <skos:definition xml:lang="es">split() divide una cadena en una lista y join() une una lista de cadenas con un separador.</skos:definition>
    <skos:example>'a,b,c'.split(',')   # ['a', 'b', 'c']
'-'.join(['a', 'b'])  # 'a-b'</skos:example>
    <skos:scopeNote xml:lang="es">Son operaciones inversas habituales al procesar texto y ficheros delimitados.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_strings"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/lista"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/tipo_str"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nd262beec0bf6424083a51343e94e0bcfb21">
    <rdf:first rdf:resource="https://w3id.org/codefeedback-kg/schema#Estudiante"/>
    <rdf:rest rdf:nodeID="nd262beec0bf6424083a51343e94e0bcfb22"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/comprension_dicts">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeControl"/>
    <rdfs:label xml:lang="en">Dict comprehension</rdfs:label>
    <rdfs:label xml:lang="es">Comprensión de diccionarios</rdfs:label>
    <skos:broader rdf:resource="https://w3id.org/codefeedback-kg/id/comprension_listas"/>
    <skos:definition xml:lang="es">Sintaxis concisa para construir diccionarios a partir de un iterable en una sola expresion.</skos:definition>
    <skos:example>cuadrados = {n: n*n for n in range(5)}</skos:example>
    <skos:scopeNote xml:lang="es">Sigue el patron {clave: valor for ...}; mas legible que un bucle con asignaciones cuando es simple.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_estructuras"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/comprension_listas"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/diccionario"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/jerarquia_excepciones">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeControl"/>
    <rdfs:label xml:lang="en">Exception hierarchy</rdfs:label>
    <rdfs:label xml:lang="es">Jerarquía de excepciones</rdfs:label>
    <skos:definition xml:lang="es">Arbol de clases de excepcion donde las mas especificas heredan de las generales.</skos:definition>
    <skos:example>try:
    ...
except FileNotFoundError:
    ...
except OSError:
    ...</skos:example>
    <skos:narrower rdf:resource="https://w3id.org/codefeedback-kg/id/encadenar_excepciones"/>
    <skos:narrower rdf:resource="https://w3id.org/codefeedback-kg/id/excepcion_personalizada"/>
    <skos:scopeNote xml:lang="es">Captura primero las especificas; except Exception captura casi todo y puede ocultar errores.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_excepciones"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/excepcion"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/herencia"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/metodo">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Paradigma"/>
    <rdfs:label xml:lang="en">Method</rdfs:label>
    <rdfs:label xml:lang="es">Método</rdfs:label>
    <skos:definition xml:lang="es">Funcion definida dentro de una clase que opera sobre sus instancias.</skos:definition>
    <skos:example>class Saludo:
    def hola(self):
        return 'hola'</skos:example>
    <skos:narrower rdf:resource="https://w3id.org/codefeedback-kg/id/init_method"/>
    <skos:narrower rdf:resource="https://w3id.org/codefeedback-kg/id/metodo_clase"/>
    <skos:narrower rdf:resource="https://w3id.org/codefeedback-kg/id/metodo_estatico"/>
    <skos:scopeNote xml:lang="es">Recibe la instancia como primer parametro (self); se invoca con la notacion objeto.metodo().</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_poo"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/clase"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/funcion"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/hilos">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Paradigma"/>
    <rdfs:label xml:lang="en">Threads</rdfs:label>
    <rdfs:label xml:lang="es">Hilos (threading)</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Thread_(computing)"/>
    <skos:definition xml:lang="es">Hilos de ejecucion (threading) que comparten memoria dentro de un mismo proceso.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q213092"/>
    <skos:example>import threading
t = threading.Thread(target=tarea)
t.start(); t.join()</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/gil"/>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/multiproceso"/>
    <skos:scopeNote xml:lang="es">Adecuados para E/S concurrente; por el GIL no paralelizan calculo de CPU. Cuidado con las condiciones de carrera.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:contrastaCon rdf:resource="https://w3id.org/codefeedback-kg/id/multiproceso"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_concurrencia"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/gil"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/unittest_mod">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ModuloLibreria"/>
    <rdfs:label xml:lang="en">unittest</rdfs:label>
    <rdfs:label xml:lang="es">unittest</rdfs:label>
    <skos:definition xml:lang="es">Marco de pruebas unittest de la biblioteca estandar, basado en clases TestCase.</skos:definition>
    <skos:example>import unittest
class T(unittest.TestCase):
    def test_ok(self):
        self.assertEqual(1 + 1, 2)</skos:example>
    <skos:scopeNote xml:lang="es">Inspirado en xUnit; ofrece metodos assert y setUp/tearDown para preparar cada prueba.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_testing"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/clase"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/funcion"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
    <cfkg:tieneURLDocumentacion rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://docs.python.org/3/library/unittest.html</cfkg:tieneURLDocumentacion>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/else_bucle">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeControl"/>
    <rdfs:label xml:lang="en">loop else</rdfs:label>
    <rdfs:label xml:lang="es">else en bucles</rdfs:label>
    <skos:definition xml:lang="es">Clausula else de un bucle que se ejecuta solo si el bucle termina sin break.</skos:definition>
    <skos:example>for x in xs:
    if x == objetivo:
        break
else:
    print('no encontrado')</skos:example>
    <skos:scopeNote xml:lang="es">Util para detectar si una busqueda no encontro el elemento; suele confundir a los principiantes.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_control"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/bucle_for"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/metodo_estatico">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Paradigma"/>
    <rdfs:label xml:lang="en">Static method</rdfs:label>
    <rdfs:label xml:lang="es">Método estático</rdfs:label>
    <skos:broader rdf:resource="https://w3id.org/codefeedback-kg/id/metodo"/>
    <skos:definition xml:lang="es">Metodo (@staticmethod) que no recibe ni instancia ni clase, agrupado por afinidad logica.</skos:definition>
    <skos:example>class Mat:
    @staticmethod
    def suma(a, b):
        return a + b</skos:example>
    <skos:scopeNote xml:lang="es">Se comporta como una funcion normal dentro del espacio de nombres de la clase.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_poo"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/decorador"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/metodo"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/entorno_virtual">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Virtual environments</rdfs:label>
    <rdfs:label xml:lang="es">Entornos virtuales (venv)</rdfs:label>
    <skos:definition xml:lang="es">Entorno aislado (venv) con su propio interprete y dependencias para un proyecto.</skos:definition>
    <skos:example>python -m venv .venv
source .venv/bin/activate</skos:example>
    <skos:scopeNote xml:lang="es">Evita conflictos de versiones entre proyectos; se activa antes de instalar paquetes con pip.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_modulos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/paquete"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/tabla_hash">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeDatos"/>
    <rdfs:label xml:lang="en">Hash table</rdfs:label>
    <rdfs:label xml:lang="es">Tabla hash</rdfs:label>
    <skos:broader rdf:resource="https://w3id.org/codefeedback-kg/id/diccionario"/>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Hash_table"/>
    <skos:definition xml:lang="es">Estructura que asocia claves a valores usando una funcion hash para acceso medio O(1).</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q207440"/>
    <skos:example>d = {}
d['clave'] = 'valor'  # respaldado por una tabla hash</skos:example>
    <skos:scopeNote xml:lang="es">Es la base interna de dict y set; las colisiones se resuelven internamente.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_algoritmos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/diccionario"/>
    <cfkg:tieneComplejidadTemporal rdf:datatype="http://www.w3.org/2001/XMLSchema#string">O(1)</cfkg:tieneComplejidadTemporal>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/pathlib">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ModuloLibreria"/>
    <rdfs:label xml:lang="en">pathlib</rdfs:label>
    <rdfs:label xml:lang="es">pathlib</rdfs:label>
    <skos:definition xml:lang="es">Modulo pathlib con una API orientada a objetos para rutas del sistema de ficheros.</skos:definition>
    <skos:example>from pathlib import Path
p = Path('datos') / 'fichero.txt'
p.exists()</skos:example>
    <skos:scopeNote xml:lang="es">Sustituye a os.path con codigo mas legible y portable; el operador / compone rutas.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_ficheros"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/abrir_fichero"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
    <cfkg:tieneURLDocumentacion rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://docs.python.org/3/library/pathlib.html</cfkg:tieneURLDocumentacion>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/operador_aritmetico">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#OperadorDelLenguaje"/>
    <rdfs:label xml:lang="en">Arithmetic operators</rdfs:label>
    <rdfs:label xml:lang="es">Operadores aritmeticos</rdfs:label>
    <skos:definition xml:lang="es">Operadores que realizan calculos numericos: +, -, *, /, //, % y **.</skos:definition>
    <skos:example>7 // 2   # 3
7 % 2    # 1
2 ** 10  # 1024</skos:example>
    <skos:scopeNote xml:lang="es">// es la division entera y / siempre devuelve float; ** eleva a una potencia.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_fundamentos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/variable"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/walrus">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Walrus operator</rdfs:label>
    <rdfs:label xml:lang="es">Operador morsa (:=)</rdfs:label>
    <skos:definition xml:lang="es">Operador de asignacion en expresion := que asigna y devuelve un valor a la vez.</skos:definition>
    <skos:example>if (n := len(datos)) &gt; 10:
    print(f'{n} elementos')</skos:example>
    <skos:scopeNote xml:lang="es">Disponible desde Python 3.8; util para reutilizar un calculo dentro de una condicion sin repetirlo.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:introducidoEnVersion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">3.8</cfkg:introducidoEnVersion>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_control"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/condicional"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/mixin">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Paradigma"/>
    <rdfs:label xml:lang="en">Mixin</rdfs:label>
    <rdfs:label xml:lang="es">Mixin</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Mixin"/>
    <skos:definition xml:lang="es">Clase pequena que aporta funcionalidad concreta para combinarse por herencia multiple.</skos:definition>
    <skos:example>class SerializableMixin:
    def to_dict(self):
        return self.__dict__</skos:example>
    <skos:scopeNote xml:lang="es">No se instancia por si sola; anade un comportamiento transversal a varias clases.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_poo"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/herencia_multiple"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/filter_func">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#FuncionIntegrada"/>
    <rdfs:label xml:lang="en">filter</rdfs:label>
    <rdfs:label xml:lang="es">filter()</rdfs:label>
    <skos:definition xml:lang="es">Funcion filter() que selecciona los elementos de un iterable que cumplen un predicado.</skos:definition>
    <skos:example>pares = list(filter(lambda x: x % 2 == 0, range(10)))</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/map_func"/>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/reduce_func"/>
    <skos:scopeNote xml:lang="es">Devuelve un iterador perezoso; a menudo una comprension con if resulta mas legible.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_funcional"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/funcion_orden_superior"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/iterables"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/multiproceso">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Paradigma"/>
    <rdfs:label xml:lang="en">Multiprocessing</rdfs:label>
    <rdfs:label xml:lang="es">Multiproceso</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Process_(computing)"/>
    <skos:definition xml:lang="es">Ejecucion paralela mediante varios procesos (multiprocessing) con memoria independiente.</skos:definition>
    <skos:example>from multiprocessing import Pool
with Pool() as p:
    p.map(cuadrado, range(10))</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/gil"/>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/hilos"/>
    <skos:scopeNote xml:lang="es">Esquiva el GIL y aprovecha varios nucleos para calculo de CPU; comunicar procesos tiene coste.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:contrastaCon rdf:resource="https://w3id.org/codefeedback-kg/id/hilos"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_concurrencia"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/gil"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/ordenacion_mezcla">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Merge sort</rdfs:label>
    <rdfs:label xml:lang="es">Ordenación por mezcla</rdfs:label>
    <skos:broader rdf:resource="https://w3id.org/codefeedback-kg/id/notacion_o"/>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Merge_sort"/>
    <skos:definition xml:lang="es">Algoritmo de ordenacion por division y conquista que fusiona sublistas ordenadas.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q189057"/>
    <skos:example>def mezcla(xs):
    if len(xs) &lt;= 1: return xs
    m = len(xs)//2
    return fusion(mezcla(xs[:m]), mezcla(xs[m:]))</skos:example>
    <skos:scopeNote xml:lang="es">Estable y O(n log n) en el peor caso, pero usa memoria adicional O(n).</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_algoritmos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/notacion_o"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/recursion"/>
    <cfkg:tieneComplejidadTemporal rdf:datatype="http://www.w3.org/2001/XMLSchema#string">O(n log n)</cfkg:tieneComplejidadTemporal>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#NivelDominio">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Mastery level</rdfs:label>
    <rdfs:label xml:lang="es">Nivel de dominio</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/comprension_listas">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeControl"/>
    <rdfs:label xml:lang="en">List comprehension</rdfs:label>
    <rdfs:label xml:lang="es">Comprensión de listas</rdfs:label>
    <skos:broader rdf:resource="https://w3id.org/codefeedback-kg/id/bucle_for"/>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/List_comprehension"/>
    <skos:definition xml:lang="es">Sintaxis concisa para construir listas a partir de un iterable, con filtros opcionales.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q795065"/>
    <skos:example>ys = [x*x for x in range(10) if x % 2 == 0]</skos:example>
    <skos:narrower rdf:resource="https://w3id.org/codefeedback-kg/id/comprension_dicts"/>
    <skos:narrower rdf:resource="https://w3id.org/codefeedback-kg/id/comprension_sets"/>
    <skos:narrower rdf:resource="https://w3id.org/codefeedback-kg/id/expresion_generadora"/>
    <skos:scopeNote xml:lang="es">Mas legible y rapida que un bucle con append para transformaciones simples; evita anidar demasiado.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_control"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/lista"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
    <cfkg:tieneEjemploCodigo>ys = [x*x for x in xs if x &gt; 0]</cfkg:tieneEjemploCodigo>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/concurrent_futures">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ConceptoDeConcurrencia"/>
    <rdfs:label xml:lang="en">concurrent.futures</rdfs:label>
    <rdfs:label xml:lang="es">concurrent.futures</rdfs:label>
    <skos:definition xml:lang="es">Interfaz de alto nivel para ejecutar tareas en grupos de hilos o procesos mediante Executors.</skos:definition>
    <skos:example>from concurrent.futures import ThreadPoolExecutor
with ThreadPoolExecutor() as ex:
    list(ex.map(str, range(3)))</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/hilos"/>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/multiproceso"/>
    <skos:scopeNote xml:lang="es">ThreadPoolExecutor para E/S y ProcessPoolExecutor para CPU; map() y submit() devuelven futuros.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_concurrencia"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/hilos"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/conjunto">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeDatos"/>
    <rdfs:label xml:lang="en">Set</rdfs:label>
    <rdfs:label xml:lang="es">Conjunto (set)</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Set_(abstract_data_type)"/>
    <skos:definition xml:lang="es">Coleccion no ordenada de elementos unicos e inmutables (set).</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q1514741"/>
    <skos:example>s = {1, 2, 2, 3}  # {1, 2, 3}
2 in s  # True</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/frozenset_tipo"/>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/lista"/>
    <skos:scopeNote xml:lang="es">Ofrece pertenencia y operaciones de conjunto (union, interseccion) en tiempo medio O(1); no admite duplicados.</skos:scopeNote>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_estructuras"/>
    <cfkg:tieneComplejidadTemporal rdf:datatype="http://www.w3.org/2001/XMLSchema#string">O(1)</cfkg:tieneComplejidadTemporal>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/modulo_os">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ModuloLibreria"/>
    <rdfs:label xml:lang="en">os module</rdfs:label>
    <rdfs:label xml:lang="es">Módulo os</rdfs:label>
    <skos:definition xml:lang="es">Modulo os con utilidades para interactuar con el sistema operativo y los ficheros.</skos:definition>
    <skos:example>import os
os.getcwd()</skos:example>
    <skos:scopeNote xml:lang="es">Para rutas, os.path o, preferiblemente, pathlib; os.environ accede a las variables de entorno.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_modulos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/import_mod"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/lru_cache">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ModuloLibreria"/>
    <rdfs:label xml:lang="en">functools.lru_cache</rdfs:label>
    <rdfs:label xml:lang="es">functools.lru_cache</rdfs:label>
    <skos:definition xml:lang="es">Decorador que cachea los resultados de una funcion descartando los menos usados (LRU).</skos:definition>
    <skos:example>from functools import lru_cache
@lru_cache(maxsize=None)
def fib(n):
    return n if n &lt; 2 else fib(n-1) + fib(n-2)</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/memoizacion"/>
    <skos:scopeNote xml:lang="es">Acelera funciones puras y deterministas; los argumentos deben ser hashables.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_funcional"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/decorador"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/memoizacion"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/raw_string">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Raw strings</rdfs:label>
    <rdfs:label xml:lang="es">Cadenas en bruto (raw)</rdfs:label>
    <skos:definition xml:lang="es">Cadena con prefijo r en la que la barra invertida no se interpreta como secuencia de escape.</skos:definition>
    <skos:example>ruta = r'C:\nuevo\datos'
patron = r'\d+'</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/regex"/>
    <skos:scopeNote xml:lang="es">Imprescindible para patrones de expresiones regulares y rutas de Windows.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_strings"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/tipo_str"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/paquete">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ModuloLibreria"/>
    <rdfs:label xml:lang="en">Package</rdfs:label>
    <rdfs:label xml:lang="es">Paquete</rdfs:label>
    <skos:definition xml:lang="es">Directorio que agrupa modulos relacionados y se importa como una unidad.</skos:definition>
    <skos:example>from paquete.subpaquete import modulo</skos:example>
    <skos:scopeNote xml:lang="es">Tradicionalmente contiene __init__.py; permite organizar proyectos en jerarquias de espacios de nombres.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_modulos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/import_mod"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/async_generator">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeControl"/>
    <rdfs:label xml:lang="en">Async generator</rdfs:label>
    <rdfs:label xml:lang="es">Generador asincrono</rdfs:label>
    <skos:definition xml:lang="es">Funcion async def que produce valores con yield y se recorre con async for.</skos:definition>
    <skos:example>async def numeros():
    for i in range(3):
        await asyncio.sleep(0)
        yield i</skos:example>
    <skos:scopeNote xml:lang="es">Combina produccion perezosa y espera asincrona; util para flujos de datos de red por lotes.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:introducidoEnVersion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">3.6</cfkg:introducidoEnVersion>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_concurrencia"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/async_await"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/generador"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/ordenacion_rapida">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Quicksort</rdfs:label>
    <rdfs:label xml:lang="es">Ordenación rápida</rdfs:label>
    <skos:broader rdf:resource="https://w3id.org/codefeedback-kg/id/notacion_o"/>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Quicksort"/>
    <skos:definition xml:lang="es">Algoritmo de ordenacion por division y conquista que particiona en torno a un pivote.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q486598"/>
    <skos:example>def rapida(xs):
    if len(xs) &lt;= 1: return xs
    p = xs[0]
    return rapida([x for x in xs[1:] if x &lt; p]) + [p] + rapida([x for x in xs[1:] if x &gt;= p])</skos:example>
    <skos:scopeNote xml:lang="es">O(n log n) en promedio y O(n^2) en el peor caso; la eleccion del pivote es clave.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_algoritmos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/recursion"/>
    <cfkg:tieneComplejidadTemporal rdf:datatype="http://www.w3.org/2001/XMLSchema#string">O(n log n)</cfkg:tieneComplejidadTemporal>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/bytearray_tipo">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#TipoDeDato"/>
    <rdfs:label xml:lang="en">bytearray</rdfs:label>
    <rdfs:label xml:lang="es">bytearray</rdfs:label>
    <skos:definition xml:lang="es">Secuencia mutable de bytes que permite modificar su contenido en sitio.</skos:definition>
    <skos:example>ba = bytearray(b'abc')
ba[0] = 65  # b'Abc'</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/tipo_bytes"/>
    <skos:scopeNote xml:lang="es">Util para construir o transformar datos binarios sin crear copias; complementa al inmutable bytes.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_tipos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/tipo_bytes"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/tipo_complex">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#TipoDeDato"/>
    <rdfs:label xml:lang="en">Complex</rdfs:label>
    <rdfs:label xml:lang="es">Complejo (complex)</rdfs:label>
    <skos:definition xml:lang="es">Tipo numerico para numeros complejos con parte real e imaginaria (sufijo j).</skos:definition>
    <skos:example>z = 2 + 3j
z.real  # 2.0</skos:example>
    <skos:scopeNote xml:lang="es">Soporta aritmetica compleja nativa; accede a .real y .imag.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_tipos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/tipo_float"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/dfs">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Depth-first search</rdfs:label>
    <rdfs:label xml:lang="es">Recorrido en profundidad (DFS)</rdfs:label>
    <skos:broader rdf:resource="https://w3id.org/codefeedback-kg/id/grafo_estr"/>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Depth-first_search"/>
    <skos:definition xml:lang="es">Recorrido en profundidad de un grafo que explora un camino al maximo antes de retroceder.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q816319"/>
    <skos:example>def dfs(g, n, visto=None):
    visto = visto or set()
    visto.add(n)
    for v in g[n]:
        if v not in visto:
            dfs(g, v, visto)</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/bfs"/>
    <skos:scopeNote xml:lang="es">Se implementa con recursion o pila explicita; util para deteccion de ciclos y ordenacion topologica.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:contrastaCon rdf:resource="https://w3id.org/codefeedback-kg/id/bfs"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_algoritmos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/grafo_estr"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/recursion"/>
    <cfkg:tieneComplejidadTemporal rdf:datatype="http://www.w3.org/2001/XMLSchema#string">O(V + E)</cfkg:tieneComplejidadTemporal>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nd262beec0bf6424083a51343e94e0bcfb8">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://w3id.org/codefeedback-kg/schema#Estudiante"/>
    <owl:onProperty rdf:resource="https://w3id.org/codefeedback-kg/schema#porEstudiante"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#evaluaA">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">assesses activity</rdfs:label>
    <rdfs:label xml:lang="es">evalúa la actividad</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/codefeedback-kg/schema#EvaluacionActividad"/>
    <rdfs:range rdf:resource="https://w3id.org/codefeedback-kg/schema#Ejercicio"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/excepcion_personalizada">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Paradigma"/>
    <rdfs:label xml:lang="en">Custom exception</rdfs:label>
    <rdfs:label xml:lang="es">Excepción personalizada</rdfs:label>
    <skos:broader rdf:resource="https://w3id.org/codefeedback-kg/id/jerarquia_excepciones"/>
    <skos:definition xml:lang="es">Clase de excepcion propia que hereda de Exception para representar errores del dominio.</skos:definition>
    <skos:example>class SaldoInsuficienteError(Exception):
    pass</skos:example>
    <skos:scopeNote xml:lang="es">Permite capturar selectivamente y anadir contexto; nombra la clase terminando en Error por convencion.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_excepciones"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/excepcion"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/herencia"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/complejidad">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Time complexity</rdfs:label>
    <rdfs:label xml:lang="es">Complejidad temporal</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Time_complexity"/>
    <skos:definition xml:lang="es">Estimacion del crecimiento del tiempo o memoria de un algoritmo segun el tamano de la entrada.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q2393193"/>
    <skos:example># Recorrer una lista es O(n)
for x in xs:
    procesar(x)</skos:example>
    <skos:scopeNote xml:lang="es">Se expresa con notacion O grande; guia la eleccion de algoritmos y estructuras de datos.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_complejidad"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/abrir_fichero">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#FuncionIntegrada"/>
    <rdfs:label xml:lang="en">File open</rdfs:label>
    <rdfs:label xml:lang="es">Apertura de ficheros (open)</rdfs:label>
    <skos:definition xml:lang="es">Funcion open() que abre un fichero y devuelve un objeto de fichero para leer o escribir.</skos:definition>
    <skos:example>with open('datos.txt', 'r', encoding='utf-8') as f:
    contenido = f.read()</skos:example>
    <skos:scopeNote xml:lang="es">Usala siempre dentro de una sentencia with para garantizar el cierre del recurso y evitar fugas de descriptores.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_ficheros"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/with_context"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/lock_threading">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ConceptoDeConcurrencia"/>
    <rdfs:label xml:lang="en">Lock</rdfs:label>
    <rdfs:label xml:lang="es">Cerrojo (Lock)</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Lock_(computer_science)"/>
    <skos:definition xml:lang="es">Primitiva de sincronizacion que garantiza que solo un hilo accede a una seccion critica a la vez.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q1047554"/>
    <skos:example>import threading
cerrojo = threading.Lock()
with cerrojo:
    saldo += 1</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/hilos"/>
    <skos:scopeNote xml:lang="es">Protege estado compartido frente a condiciones de carrera; usalo como gestor de contexto con with.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_concurrencia"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/hilos"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/composicion">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Paradigma"/>
    <rdfs:label xml:lang="en">Composition</rdfs:label>
    <rdfs:label xml:lang="es">Composición</rdfs:label>
    <skos:definition xml:lang="es">Diseno en el que un objeto contiene instancias de otras clases para reutilizar su comportamiento.</skos:definition>
    <skos:example>class Motor: ...
class Coche:
    def __init__(self):
        self.motor = Motor()  # composicion</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/herencia"/>
    <skos:scopeNote xml:lang="es">Suele preferirse a la herencia ('composicion sobre herencia') por su menor acoplamiento.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:contrastaCon rdf:resource="https://w3id.org/codefeedback-kg/id/herencia"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_poo"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/objeto"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/envio_001">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EnvioEstudiante"/>
    <rdfs:label xml:lang="en">Submission 001</rdfs:label>
    <rdfs:label xml:lang="es">Envío 001</rdfs:label>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-05-12</dcterms:created>
    <cfkg:enviadoPor rdf:resource="https://w3id.org/codefeedback-kg/id/est_alicia"/>
    <cfkg:manifiestaError rdf:resource="https://w3id.org/codefeedback-kg/id/err_off_by_one"/>
    <cfkg:numeroDeLineas rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">18</cfkg:numeroDeLineas>
    <cfkg:resuelveEjercicio rdf:resource="https://w3id.org/codefeedback-kg/id/ej_busqueda"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#contrastaCon">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdfs:label xml:lang="en">contrasts with</rdfs:label>
    <rdfs:label xml:lang="es">contrasta con</rdfs:label>
    <rdfs:comment xml:lang="es">Conceptos frecuentemente confundidos que conviene explicar por oposición (p. ej. iteración / recursión). Simétrica.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
    <rdfs:range rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
    <rdfs:subPropertyOf rdf:resource="https://w3id.org/codefeedback-kg/schema#relacionadoConceptualmenteCon"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#cubiertoPorEjercicio">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">is covered by exercise</rdfs:label>
    <rdfs:label xml:lang="es">es cubierto por el ejercicio</rdfs:label>
    <rdfs:comment xml:lang="es">Inversa de cubreConcepto.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
    <rdfs:range rdf:resource="https://w3id.org/codefeedback-kg/schema#Ejercicio"/>
    <owl:inverseOf rdf:resource="https://w3id.org/codefeedback-kg/schema#cubreConcepto"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/evalact_07">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EvaluacionActividad"/>
    <rdfs:label xml:lang="en">Activity assessment 07</rdfs:label>
    <rdfs:label xml:lang="es">Evaluación de actividad 07</rdfs:label>
    <cfkg:enFecha rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-13</cfkg:enFecha>
    <cfkg:evaluaA rdf:resource="https://w3id.org/codefeedback-kg/id/ej_suma_lista"/>
    <cfkg:obtuvoNota rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">6.5</cfkg:obtuvoNota>
    <cfkg:porEstudiante rdf:resource="https://w3id.org/codefeedback-kg/id/est_alicia"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/leer_fichero">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#FuncionIntegrada"/>
    <rdfs:label xml:lang="en">File reading</rdfs:label>
    <rdfs:label xml:lang="es">Lectura de ficheros</rdfs:label>
    <skos:definition xml:lang="es">Lectura del contenido de un fichero con metodos como read(), readline() o iterando lineas.</skos:definition>
    <skos:example>with open('d.txt', encoding='utf-8') as f:
    for linea in f:
        print(linea.rstrip())</skos:example>
    <skos:scopeNote xml:lang="es">Iterar el objeto de fichero linea a linea es eficiente en memoria para ficheros grandes.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_ficheros"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/abrir_fichero"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/grafo_estr">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeDatos"/>
    <rdfs:label xml:lang="en">Graph</rdfs:label>
    <rdfs:label xml:lang="es">Grafo (estructura)</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Graph_(abstract_data_type)"/>
    <skos:definition xml:lang="es">Estructura de datos formada por nodos (vertices) y conexiones (aristas) entre ellos.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q2479726"/>
    <skos:example>g = {'a': ['b', 'c'], 'b': ['c'], 'c': []}</skos:example>
    <skos:narrower rdf:resource="https://w3id.org/codefeedback-kg/id/bfs"/>
    <skos:narrower rdf:resource="https://w3id.org/codefeedback-kg/id/dfs"/>
    <skos:scopeNote xml:lang="es">Se representa habitualmente con listas o diccionarios de adyacencia; base de BFS y DFS.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_algoritmos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/diccionario"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/diccionario">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeDatos"/>
    <rdfs:label xml:lang="en">Dictionary</rdfs:label>
    <rdfs:label xml:lang="es">Diccionario</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Associative_array"/>
    <skos:definition xml:lang="es">Coleccion de pares clave-valor con acceso por clave en tiempo medio O(1).</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q80585"/>
    <skos:example>d = {'a': 1, 'b': 2}
d['a']  # 1</skos:example>
    <skos:narrower rdf:resource="https://w3id.org/codefeedback-kg/id/counter"/>
    <skos:narrower rdf:resource="https://w3id.org/codefeedback-kg/id/defaultdict"/>
    <skos:narrower rdf:resource="https://w3id.org/codefeedback-kg/id/tabla_hash"/>
    <skos:scopeNote xml:lang="es">Las claves deben ser hashables; desde Python 3.7 conserva el orden de insercion.</skos:scopeNote>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_estructuras"/>
    <cfkg:tieneComplejidadTemporal rdf:datatype="http://www.w3.org/2001/XMLSchema#string">O(1)</cfkg:tieneComplejidadTemporal>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/retorno_multiple">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Multiple return</rdfs:label>
    <rdfs:label xml:lang="es">Retorno múltiple</rdfs:label>
    <skos:definition xml:lang="es">Devolucion de varios valores desde una funcion empaquetandolos en una tupla.</skos:definition>
    <skos:example>def divmod2(a, b):
    return a // b, a % b
c, r = divmod2(7, 2)</skos:example>
    <skos:scopeNote xml:lang="es">El receptor los desempaqueta en variables separadas; mejora la claridad frente a parametros de salida.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_funciones"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/funcion"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/tupla"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/self_param">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Paradigma"/>
    <rdfs:label xml:lang="en">self</rdfs:label>
    <rdfs:label xml:lang="es">Parámetro self</rdfs:label>
    <skos:definition xml:lang="es">Primer parametro de los metodos de instancia que referencia al propio objeto.</skos:definition>
    <skos:example>class C:
    def m(self):
        return self</skos:example>
    <skos:scopeNote xml:lang="es">Es explicito por convencion (no palabra clave); olvidarlo causa un TypeError frecuente en principiantes.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_poo"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/metodo"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/protocolo_typing">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ConceptoDeTipado"/>
    <rdfs:label xml:lang="en">Protocol (structural typing)</rdfs:label>
    <rdfs:label xml:lang="es">typing.Protocol</rdfs:label>
    <skos:definition xml:lang="es">Tipo que describe una interfaz por su estructura (metodos y atributos), no por herencia explicita.</skos:definition>
    <skos:example>from typing import Protocol
class Dibujable(Protocol):
    def dibujar(self) -&gt; None: ...</skos:example>
    <skos:scopeNote xml:lang="es">Formaliza el duck typing para los verificadores estaticos; una clase la satisface si tiene los miembros.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:introducidoEnVersion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">3.8</cfkg:introducidoEnVersion>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_tipos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/anotaciones_tipo"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/err_identidad_igualdad">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ErrorConceptual"/>
    <rdfs:label xml:lang="en">Equality vs identity confusion</rdfs:label>
    <rdfs:label xml:lang="es">Confusión == frente a is</rdfs:label>
    <cfkg:errorSobreConcepto rdf:resource="https://w3id.org/codefeedback-kg/id/tipo_bool"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/iterables">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Iterables</rdfs:label>
    <rdfs:label xml:lang="es">Iterables</rdfs:label>
    <skos:definition xml:lang="es">Objetos que pueden recorrerse en un bucle for porque producen un iterador (listas, cadenas, dicts).</skos:definition>
    <skos:example>for c in 'abc':
    print(c)</skos:example>
    <skos:scopeNote xml:lang="es">Implementan __iter__; distingue iterable (se puede recorrer) de iterador (mantiene la posicion).</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_estructuras"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/lista"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/sorted_f">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#FuncionIntegrada"/>
    <rdfs:label xml:lang="en">sorted/sort</rdfs:label>
    <rdfs:label xml:lang="es">sorted() y sort()</rdfs:label>
    <skos:definition xml:lang="es">Funcion sorted() que devuelve una lista ordenada y metodo list.sort() que ordena en sitio.</skos:definition>
    <skos:example>sorted([3, 1, 2])  # [1, 2, 3]
sorted(palabras, key=len)</skos:example>
    <skos:scopeNote xml:lang="es">Admiten key para criterio y reverse; el algoritmo Timsort es estable y O(n log n).</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_algoritmos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/lista"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/tipo_float">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#TipoDeDato"/>
    <rdfs:label xml:lang="en">Float</rdfs:label>
    <rdfs:label xml:lang="es">Flotante (float)</rdfs:label>
    <skos:definition xml:lang="es">Tipo numerico de coma flotante de doble precision (IEEE 754).</skos:definition>
    <skos:example>0.1 + 0.2  # 0.30000000000000004</skos:example>
    <skos:scopeNote xml:lang="es">Tiene precision limitada: evita comparar floats con == y usa math.isclose.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:contrastaCon rdf:resource="https://w3id.org/codefeedback-kg/id/tipo_int"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_tipos"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#manifiestaError">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">exhibits misconception</rdfs:label>
    <rdfs:label xml:lang="es">manifiesta el error</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/codefeedback-kg/schema#EnvioEstudiante"/>
    <rdfs:range rdf:resource="https://w3id.org/codefeedback-kg/schema#ErrorConceptual"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/est_borja">
    <rdf:type rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Estudiante"/>
    <rdfs:label xml:lang="en">Borja</rdfs:label>
    <rdfs:label xml:lang="es">Borja</rdfs:label>
    <foaf:name>Borja</foaf:name>
    <cfkg:dominaConcepto rdf:resource="https://w3id.org/codefeedback-kg/id/condicional"/>
    <cfkg:dominaConcepto rdf:resource="https://w3id.org/codefeedback-kg/id/variable"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/err_iteracion_recursion">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ErrorConceptual"/>
    <rdfs:label xml:lang="en">Iteration vs recursion confusion</rdfs:label>
    <rdfs:label xml:lang="es">Confusión iteración / recursión</rdfs:label>
    <cfkg:errorSobreConcepto rdf:resource="https://w3id.org/codefeedback-kg/id/recursion"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/herencia_multiple">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Paradigma"/>
    <rdfs:label xml:lang="en">Multiple inheritance</rdfs:label>
    <rdfs:label xml:lang="es">Herencia múltiple</rdfs:label>
    <skos:broader rdf:resource="https://w3id.org/codefeedback-kg/id/herencia"/>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Multiple_inheritance"/>
    <skos:definition xml:lang="es">Capacidad de una clase de heredar de varias clases base a la vez.</skos:definition>
    <skos:example>class A: ...
class B: ...
class C(A, B): ...</skos:example>
    <skos:scopeNote xml:lang="es">Util con mixins; el orden de resolucion de metodos (MRO) determina que implementacion se usa.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_poo"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/herencia"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/deque">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeDatos"/>
    <rdfs:label xml:lang="en">deque</rdfs:label>
    <rdfs:label xml:lang="es">collections.deque</rdfs:label>
    <skos:broader rdf:resource="https://w3id.org/codefeedback-kg/id/cola"/>
    <skos:definition xml:lang="es">Cola doblemente terminada (collections.deque) con insercion y extraccion O(1) por ambos extremos.</skos:definition>
    <skos:example>from collections import deque
d = deque([1, 2])
d.appendleft(0); d.pop()</skos:example>
    <skos:scopeNote xml:lang="es">Preferible a list para colas y pilas; permite limitar su tamano con maxlen.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_estructuras"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/lista"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/metodo_clase">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Paradigma"/>
    <rdfs:label xml:lang="en">Class method</rdfs:label>
    <rdfs:label xml:lang="es">Método de clase</rdfs:label>
    <skos:broader rdf:resource="https://w3id.org/codefeedback-kg/id/decorador"/>
    <skos:broader rdf:resource="https://w3id.org/codefeedback-kg/id/metodo"/>
    <skos:definition xml:lang="es">Metodo (@classmethod) que recibe la clase (cls) en lugar de la instancia.</skos:definition>
    <skos:example>class Fecha:
    @classmethod
    def hoy(cls):
        return cls()</skos:example>
    <skos:scopeNote xml:lang="es">Util para constructores alternativos (fabricas) que devuelven instancias configuradas.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_poo"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/decorador"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/metodo"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/propiedad">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Paradigma"/>
    <rdfs:label xml:lang="en">Property</rdfs:label>
    <rdfs:label xml:lang="es">Propiedad (@property)</rdfs:label>
    <skos:broader rdf:resource="https://w3id.org/codefeedback-kg/id/decorador"/>
    <skos:definition xml:lang="es">Atributo gestionado (@property) que ejecuta metodos al leer o escribir un valor.</skos:definition>
    <skos:example>class C:
    @property
    def area(self):
        return self.lado ** 2</skos:example>
    <skos:scopeNote xml:lang="es">Permite anadir validacion o calculo sin cambiar la interfaz publica del atributo.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_poo"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/decorador"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/encapsulacion"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#errorSobreConcepto">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">is a misconception about</rdfs:label>
    <rdfs:label xml:lang="es">es un error sobre el concepto</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/codefeedback-kg/schema#ErrorConceptual"/>
    <rdfs:range rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#porEstudiante">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">carried out by</rdfs:label>
    <rdfs:label xml:lang="es">realizada por</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/codefeedback-kg/schema#EvaluacionActividad"/>
    <rdfs:range rdf:resource="https://w3id.org/codefeedback-kg/schema#Estudiante"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <cc:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-06-18</dcterms:created>
    <dcterms:creator>Adrián Bueno Junquero</dcterms:creator>
    <dcterms:description xml:lang="es">Ontología y grafo de conocimiento del dominio de la programación en Python, diseñado para anclar la generación de retroalimentación formativa automática (arquitectura EKG + RAG + LLM). Modela conceptos, sus prerrequisitos y contrastes, temas, ejercicios, errores conceptuales (misconceptions), recursos y perfiles de estudiante.</dcterms:description>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-06-21</dcterms:issued>
    <dcterms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
    <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-06-21</dcterms:modified>
    <dcterms:title xml:lang="en">CodeFeedback-KG: A Semantic Knowledge Graph of Python Concepts for Pedagogical Code Feedback</dcterms:title>
    <dcterms:title xml:lang="es">Grafo de Conocimiento Educativo de Programación en Python (CodeFeedback-KG)</dcterms:title>
    <vann:preferredNamespacePrefix>cfkg</vann:preferredNamespacePrefix>
    <vann:preferredNamespaceUri>https://w3id.org/codefeedback-kg/schema#</vann:preferredNamespaceUri>
    <rdfs:seeAlso rdf:resource="https://w3id.org/codefeedback-kg/"/>
    <owl:versionIRI rdf:resource="https://w3id.org/codefeedback-kg/schema/2.0.0"/>
    <owl:versionInfo>2.0.0</owl:versionInfo>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/metaclase">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Paradigma"/>
    <rdfs:label xml:lang="en">Metaclass</rdfs:label>
    <rdfs:label xml:lang="es">Metaclase</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Metaclass"/>
    <skos:definition xml:lang="es">Clase cuyas instancias son a su vez clases, lo que permite personalizar como se crean.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q1924819"/>
    <skos:example>class Meta(type):
    def __new__(mcs, n, b, d):
        return super().__new__(mcs, n, b, d)</skos:example>
    <skos:scopeNote xml:lang="es">type es la metaclase por defecto; rara vez necesarias, pero potentes para frameworks (ORM, ABC).</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_poo"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/clase"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/envio_002">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EnvioEstudiante"/>
    <rdfs:label xml:lang="en">Submission 002</rdfs:label>
    <rdfs:label xml:lang="es">Envío 002</rdfs:label>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-05-14</dcterms:created>
    <cfkg:enviadoPor rdf:resource="https://w3id.org/codefeedback-kg/id/est_borja"/>
    <cfkg:manifiestaError rdf:resource="https://w3id.org/codefeedback-kg/id/err_iteracion_recursion"/>
    <cfkg:numeroDeLineas rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">11</cfkg:numeroDeLineas>
    <cfkg:resuelveEjercicio rdf:resource="https://w3id.org/codefeedback-kg/id/ej_factorial"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/duck_typing">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Paradigma"/>
    <rdfs:label xml:lang="en">Duck typing</rdfs:label>
    <rdfs:label xml:lang="es">Duck typing</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Duck_typing"/>
    <skos:definition xml:lang="es">Estilo en el que la idoneidad de un objeto depende de los metodos que ofrece, no de su tipo.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q374282"/>
    <skos:example>def total(coleccion):
    return sum(coleccion)  # vale cualquier iterable de numeros</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/polimorfismo"/>
    <skos:scopeNote xml:lang="es">'Si camina como un pato y grazna como un pato, es un pato'; favorece el polimorfismo flexible.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_poo"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/polimorfismo"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/singledispatch">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ModuloLibreria"/>
    <rdfs:label xml:lang="en">functools.singledispatch</rdfs:label>
    <rdfs:label xml:lang="es">functools.singledispatch</rdfs:label>
    <skos:definition xml:lang="es">Decorador que crea una funcion generica cuya implementacion se elige segun el tipo del primer argumento.</skos:definition>
    <skos:example>from functools import singledispatch
@singledispatch
def mostrar(x): print(x)
@mostrar.register
def _(x: list): print('lista', x)</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/polimorfismo"/>
    <skos:scopeNote xml:lang="es">Aporta despacho multiple basico al estilo funcional, sin recurrir a una jerarquia de clases.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_funcional"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/polimorfismo"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/break_continue">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeControl"/>
    <rdfs:label xml:lang="en">break and continue</rdfs:label>
    <rdfs:label xml:lang="es">break y continue</rdfs:label>
    <skos:definition xml:lang="es">Sentencias break (sale del bucle) y continue (salta a la siguiente iteracion).</skos:definition>
    <skos:example>for n in range(10):
    if n == 5:
        break
    if n % 2 == 0:
        continue
    print(n)</skos:example>
    <skos:scopeNote xml:lang="es">Afectan solo al bucle mas interno; un uso excesivo puede dificultar la lectura del codigo.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_control"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/bucle_for"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/truthiness">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Truthiness</rdfs:label>
    <rdfs:label xml:lang="es">Valores de verdad</rdfs:label>
    <skos:definition xml:lang="es">Evaluacion de un objeto como verdadero o falso en un contexto booleano.</skos:definition>
    <skos:example>if not lista:
    print('vacia')</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/any_all"/>
    <skos:scopeNote xml:lang="es">Colecciones vacias, 0, None y '' son falsy; el resto es truthy. Aprovechalo en condiciones idiomaticas.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_tipos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/tipo_bool"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/dunder">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Paradigma"/>
    <rdfs:label xml:lang="en">Dunder methods</rdfs:label>
    <rdfs:label xml:lang="es">Métodos especiales (dunder)</rdfs:label>
    <skos:definition xml:lang="es">Metodos especiales con doble guion bajo (__init__, __len__, __eq__) que integran objetos con el lenguaje.</skos:definition>
    <skos:example>class Vec:
    def __init__(self, n): self.n = n
    def __add__(self, o): return Vec(self.n + o.n)</skos:example>
    <skos:scopeNote xml:lang="es">Permiten personalizar operadores, iteracion o representacion; tambien llamados metodos magicos.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_poo"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/metodo"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/regex">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ModuloLibreria"/>
    <rdfs:label xml:lang="en">Regular expressions</rdfs:label>
    <rdfs:label xml:lang="es">Expresiones regulares (re)</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Regular_expression"/>
    <skos:definition xml:lang="es">Expresiones regulares (modulo re) para buscar y manipular texto segun patrones.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q185612"/>
    <skos:example>import re
re.findall(r'\d+', 'a12b3')  # ['12', '3']</skos:example>
    <skos:scopeNote xml:lang="es">Compila patrones con re.compile; usa cadenas raw (r'...') para las barras invertidas.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_strings"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/tipo_str"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</cfkg:tieneDificultad>
    <cfkg:tieneURLDocumentacion rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://docs.python.org/3/library/re.html</cfkg:tieneURLDocumentacion>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/bucle_for">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeControl"/>
    <rdfs:label xml:lang="en">For loop</rdfs:label>
    <rdfs:label xml:lang="es">Bucle for</rdfs:label>
    <skos:definition xml:lang="es">Bucle que itera sobre los elementos de un iterable ejecutando un bloque por cada uno.</skos:definition>
    <skos:example>for x in [1, 2, 3]:
    print(x)</skos:example>
    <skos:narrower rdf:resource="https://w3id.org/codefeedback-kg/id/comprension_listas"/>
    <skos:prefLabel xml:lang="es">Bucle for</skos:prefLabel>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/recursion"/>
    <skos:scopeNote xml:lang="es">Es el bucle idiomatico en Python; con range() permite repetir un numero fijo de veces.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:esPrerrequisitoDe rdf:resource="https://w3id.org/codefeedback-kg/id/comprension_listas"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_control"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</cfkg:tieneDificultad>
    <cfkg:tieneEjemploCodigo>for x in xs:
    print(x)</cfkg:tieneEjemploCodigo>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/any_all">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#FuncionIntegrada"/>
    <rdfs:label xml:lang="en">any and all</rdfs:label>
    <rdfs:label xml:lang="es">Funciones any y all</rdfs:label>
    <skos:definition xml:lang="es">any() devuelve True si algun elemento es verdadero; all() si todos lo son.</skos:definition>
    <skos:example>all(x &gt; 0 for x in [1, 2, 3])  # True
any(x &lt; 0 for x in [1, 2, 3])  # False</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/truthiness"/>
    <skos:scopeNote xml:lang="es">Operan de forma perezosa con cortocircuito; sobre un iterable vacio, all es True y any es False.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_control"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/iterables"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/itertools_mod">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ModuloLibreria"/>
    <rdfs:label xml:lang="en">itertools</rdfs:label>
    <rdfs:label xml:lang="es">itertools</rdfs:label>
    <skos:definition xml:lang="es">Modulo itertools con utilidades para construir iteradores eficientes y combinatorios.</skos:definition>
    <skos:example>import itertools
list(itertools.islice(itertools.count(), 3))  # [0, 1, 2]</skos:example>
    <skos:narrower rdf:resource="https://w3id.org/codefeedback-kg/id/itertools_chain"/>
    <skos:narrower rdf:resource="https://w3id.org/codefeedback-kg/id/itertools_product"/>
    <skos:scopeNote xml:lang="es">Incluye count, cycle, chain, product o combinations; opera de forma perezosa.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_funcional"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/iterables"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
    <cfkg:tieneURLDocumentacion rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://docs.python.org/3/library/itertools.html</cfkg:tieneURLDocumentacion>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#Paradigma">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Programming paradigm</rdfs:label>
    <rdfs:label xml:lang="es">Paradigma de programación</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
    <owl:disjointWith rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeDatos"/>
    <owl:disjointWith rdf:resource="https://w3id.org/codefeedback-kg/schema#TipoDeDato"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/format_method">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#FuncionIntegrada"/>
    <rdfs:label xml:lang="en">str.format</rdfs:label>
    <rdfs:label xml:lang="es">Metodo str.format</rdfs:label>
    <skos:definition xml:lang="es">Metodo que inserta valores en una cadena usando campos de reemplazo con llaves.</skos:definition>
    <skos:example>'{} tiene {} anos'.format('Ana', 30)</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/fstring"/>
    <skos:scopeNote xml:lang="es">Anterior a las f-strings; sigue siendo util para plantillas reutilizables separadas de los datos.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_strings"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/tipo_str"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/operador_pertenencia">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#OperadorDelLenguaje"/>
    <rdfs:label xml:lang="en">Membership operators</rdfs:label>
    <rdfs:label xml:lang="es">Operadores de pertenencia (in)</rdfs:label>
    <skos:definition xml:lang="es">Operadores in y not in que comprueban si un valor esta contenido en una coleccion.</skos:definition>
    <skos:example>3 in [1, 2, 3]   # True
'a' in 'casa'    # True</skos:example>
    <skos:scopeNote xml:lang="es">En sets y dicts es O(1); en listas es O(n). Tambien busca subcadenas en strings.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_estructuras"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/lista"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/memoizacion">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Memoization</rdfs:label>
    <rdfs:label xml:lang="es">Memoización (lru_cache)</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Memoization"/>
    <skos:definition xml:lang="es">Tecnica que almacena en cache los resultados de una funcion para reutilizarlos.</skos:definition>
    <skos:example>import functools
@functools.lru_cache
def fib(n):
    return n if n &lt; 2 else fib(n-1) + fib(n-2)</skos:example>
    <skos:scopeNote xml:lang="es">functools.lru_cache la implementa con un decorador; acelera funciones puras y recursivas.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_recursion"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/diccionario"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/recursion"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/slicing">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Slicing</rdfs:label>
    <rdfs:label xml:lang="es">Slicing (rebanado)</rdfs:label>
    <skos:broader rdf:resource="https://w3id.org/codefeedback-kg/id/indexacion"/>
    <skos:definition xml:lang="es">Extraccion de subsecuencias mediante la notacion [inicio:fin:paso].</skos:definition>
    <skos:example>xs = [0, 1, 2, 3, 4]
xs[1:4]  # [1, 2, 3]</skos:example>
    <skos:narrower rdf:resource="https://w3id.org/codefeedback-kg/id/slicing_str"/>
    <skos:scopeNote xml:lang="es">El fin se excluye; admite indices negativos y omitir extremos. xs[:] copia la secuencia.</skos:scopeNote>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_estructuras"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/indexacion"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#EvaluacionDeConcepto">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Concept assessment occurrence</rdfs:label>
    <rdfs:label xml:lang="es">Evaluación de concepto</rdfs:label>
    <rdfs:comment xml:lang="es">Nodo intermedio que reifica la relación N-aria (ejercicio, concepto, peso, nivel) sin perder información, según el patrón de relaciones N-arias del material docente.</rdfs:comment>
    <rdfs:subClassOf rdf:nodeID="nd262beec0bf6424083a51343e94e0bcfb1"/>
    <rdfs:subClassOf rdf:nodeID="nd262beec0bf6424083a51343e94e0bcfb2"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/codefeedback-kg/schema#EntidadEducativa"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/recursion_cola">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Tail recursion</rdfs:label>
    <rdfs:label xml:lang="es">Recursión de cola</rdfs:label>
    <skos:broader rdf:resource="https://w3id.org/codefeedback-kg/id/recursion"/>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Tail_call"/>
    <skos:definition xml:lang="es">Recursion en la que la llamada recursiva es la ultima operacion de la funcion.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q1340959"/>
    <skos:example>def suma(xs, acc=0):
    if not xs: return acc
    return suma(xs[1:], acc + xs[0])</skos:example>
    <skos:scopeNote xml:lang="es">Otros lenguajes la optimizan, pero CPython no elimina la recursion de cola: puede desbordar la pila.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_recursion"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/recursion"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/suppress_context">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeControl"/>
    <rdfs:label xml:lang="en">contextlib.suppress</rdfs:label>
    <rdfs:label xml:lang="es">contextlib.suppress</rdfs:label>
    <skos:definition xml:lang="es">Gestor de contexto que ignora silenciosamente las excepciones indicadas dentro del bloque.</skos:definition>
    <skos:example>from contextlib import suppress
with suppress(FileNotFoundError):
    open('quiza.txt')</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/try_except_else"/>
    <skos:scopeNote xml:lang="es">Alternativa concisa a un try/except con pass; usalo solo cuando ignorar el error sea intencionado.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_excepciones"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/try_except_else"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/dataclass_field">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Paradigma"/>
    <rdfs:label xml:lang="en">dataclasses.field</rdfs:label>
    <rdfs:label xml:lang="es">dataclasses.field</rdfs:label>
    <skos:broader rdf:resource="https://w3id.org/codefeedback-kg/id/dataclass"/>
    <skos:definition xml:lang="es">Funcion que personaliza un campo de una dataclass, por ejemplo con fabricas por defecto.</skos:definition>
    <skos:example>from dataclasses import dataclass, field
@dataclass
class C:
    items: list = field(default_factory=list)</skos:example>
    <skos:scopeNote xml:lang="es">Usa default_factory=list para valores mutables por defecto y evitar compartirlos entre instancias.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_tipos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/dataclass"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nd262beec0bf6424083a51343e94e0bcfb13">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AllDisjointClasses"/>
    <owl:members rdf:nodeID="nd262beec0bf6424083a51343e94e0bcfb14"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#especializa">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdfs:label xml:lang="en">specialises</rdfs:label>
    <rdfs:label xml:lang="es">especializa a</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
    <rdfs:range rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/decorador">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Paradigma"/>
    <rdfs:label xml:lang="en">Decorator</rdfs:label>
    <rdfs:label xml:lang="es">Decorador</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Python_syntax_and_semantics"/>
    <skos:definition xml:lang="es">Funcion que envuelve a otra para anadir comportamiento sin modificar su codigo, aplicada con @.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q110938941"/>
    <skos:example>def log(f):
    def envoltura(*a, **k):
        print('llamando', f.__name__)
        return f(*a, **k)
    return envoltura</skos:example>
    <skos:narrower rdf:resource="https://w3id.org/codefeedback-kg/id/metodo_clase"/>
    <skos:narrower rdf:resource="https://w3id.org/codefeedback-kg/id/propiedad"/>
    <skos:scopeNote xml:lang="es">Conserva metadatos con functools.wraps; util para logging, cache, control de acceso o tiempos.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_funcional"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/closure"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/funcion_orden_superior"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#EstructuraDeControl">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Control structure</rdfs:label>
    <rdfs:label xml:lang="es">Estructura de control</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
    <owl:disjointWith rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeDatos"/>
    <owl:disjointWith rdf:resource="https://w3id.org/codefeedback-kg/schema#ModuloLibreria"/>
    <owl:disjointWith rdf:resource="https://w3id.org/codefeedback-kg/schema#TipoDeDato"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/T_complejidad">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Tema"/>
    <rdfs:label xml:lang="en">Algorithmic complexity</rdfs:label>
    <rdfs:label xml:lang="es">Complejidad algorítmica</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/raise_excepcion">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeControl"/>
    <rdfs:label xml:lang="en">raise</rdfs:label>
    <rdfs:label xml:lang="es">raise</rdfs:label>
    <skos:definition xml:lang="es">Sentencia raise que lanza una excepcion de forma explicita.</skos:definition>
    <skos:example>if x &lt; 0:
    raise ValueError('x debe ser positivo')</skos:example>
    <skos:scopeNote xml:lang="es">Permite senalar errores del dominio; puede relanzar la actual con raise a secas dentro de un except.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_excepciones"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/excepcion"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/corrutina">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Coroutine</rdfs:label>
    <rdfs:label xml:lang="es">Corrutina</rdfs:label>
    <skos:broader rdf:resource="https://w3id.org/codefeedback-kg/id/async_await"/>
    <skos:definition xml:lang="es">Funcion que puede suspender y reanudar su ejecucion, cooperando con un planificador.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q1339231"/>
    <skos:example>async def contador():
    for i in range(3):
        await asyncio.sleep(0)
        yield i</skos:example>
    <skos:scopeNote xml:lang="es">En Python moderno se definen con async def; las clasicas usaban generadores con yield.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_concurrencia"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/async_await"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/generador"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/json_mod">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ModuloLibreria"/>
    <rdfs:label xml:lang="en">json module</rdfs:label>
    <rdfs:label xml:lang="es">Módulo json</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/JSON"/>
    <skos:definition xml:lang="es">Modulo json para serializar objetos Python a texto JSON y deserializarlos.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q2063"/>
    <skos:example>import json
json.dumps({'a': 1})  # '{"a": 1}'</skos:example>
    <skos:scopeNote xml:lang="es">dumps/loads trabajan con cadenas; dump/load con ficheros. No todos los tipos son serializables.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_ficheros"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/diccionario"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
    <cfkg:tieneURLDocumentacion rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://docs.python.org/3/library/json.html</cfkg:tieneURLDocumentacion>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/mutable_inmutable">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Mutable vs immutable</rdfs:label>
    <rdfs:label xml:lang="es">Mutable vs inmutable</rdfs:label>
    <skos:definition xml:lang="es">Distincion entre objetos modificables (mutables) y no modificables (inmutables).</skos:definition>
    <skos:example>t = (1, 2)   # inmutable
l = [1, 2]   # mutable</skos:example>
    <skos:scopeNote xml:lang="es">Los inmutables son hashables y seguros como claves; evita usar mutables como valores por defecto.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:contrastaCon rdf:resource="https://w3id.org/codefeedback-kg/id/tupla"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_tipos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/mutabilidad"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/excepcion">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeControl"/>
    <rdfs:label xml:lang="en">Exception</rdfs:label>
    <rdfs:label xml:lang="es">Excepción</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Exception_handling"/>
    <skos:definition xml:lang="es">Evento que interrumpe el flujo normal del programa para senalar un error o situacion especial.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q471748"/>
    <skos:example>try:
    1 / 0
except ZeroDivisionError:
    print('division por cero')</skos:example>
    <skos:scopeNote xml:lang="es">Se captura con try/except; en Python se prefiere pedir perdon (EAFP) a comprobar antes (LBYL).</skos:scopeNote>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_excepciones"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/condicional"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/T_funcional">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Tema"/>
    <rdfs:label xml:lang="en">Functional programming</rdfs:label>
    <rdfs:label xml:lang="es">Programación funcional</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/pila">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeDatos"/>
    <rdfs:label xml:lang="en">Stack</rdfs:label>
    <rdfs:label xml:lang="es">Pila (stack)</rdfs:label>
    <skos:broader rdf:resource="https://w3id.org/codefeedback-kg/id/lista"/>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Stack_(abstract_data_type)"/>
    <skos:definition xml:lang="es">Estructura LIFO (ultimo en entrar, primero en salir) que apila y desapila por un mismo extremo.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q177929"/>
    <skos:example>pila = []
pila.append(1)
pila.pop()  # 1</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/cola"/>
    <skos:scopeNote xml:lang="es">Una lista funciona como pila con append y pop; base de la recursion, el deshacer y la evaluacion de expresiones.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:contrastaCon rdf:resource="https://w3id.org/codefeedback-kg/id/cola"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_estructuras"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/lista"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/slicing_str">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">String slicing</rdfs:label>
    <rdfs:label xml:lang="es">Slicing de cadenas</rdfs:label>
    <skos:broader rdf:resource="https://w3id.org/codefeedback-kg/id/slicing"/>
    <skos:definition xml:lang="es">Aplicacion del slicing a cadenas para obtener subcadenas.</skos:definition>
    <skos:example>'Python'[0:3]  # 'Pyt'</skos:example>
    <skos:scopeNote xml:lang="es">Las cadenas son inmutables: el slicing devuelve una nueva cadena. xs[::-1] la invierte.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_strings"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/slicing"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/tipo_str"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/callable_func">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#FuncionIntegrada"/>
    <rdfs:label xml:lang="en">callable</rdfs:label>
    <rdfs:label xml:lang="es">Funcion callable</rdfs:label>
    <skos:definition xml:lang="es">Funcion que indica si un objeto puede invocarse como una funcion.</skos:definition>
    <skos:example>callable(len)   # True
callable(42)    # False</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/funcion_orden_superior"/>
    <skos:scopeNote xml:lang="es">Son invocables las funciones, clases y objetos con __call__; util al recibir callbacks.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_funcional"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/funcion"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#HerramientaDeDesarrollo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Development tool</rdfs:label>
    <rdfs:label xml:lang="es">Herramienta de desarrollo</rdfs:label>
    <rdfs:comment xml:lang="es">Herramienta de apoyo al desarrollo (empaquetado, entornos, pruebas).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/evalact_09">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EvaluacionActividad"/>
    <rdfs:label xml:lang="en">Activity assessment 09</rdfs:label>
    <rdfs:label xml:lang="es">Evaluación de actividad 09</rdfs:label>
    <cfkg:enFecha rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-27</cfkg:enFecha>
    <cfkg:evaluaA rdf:resource="https://w3id.org/codefeedback-kg/id/ej_busqueda"/>
    <cfkg:obtuvoNota rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">7.0</cfkg:obtuvoNota>
    <cfkg:porEstudiante rdf:resource="https://w3id.org/codefeedback-kg/id/est_alicia"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/args_kwargs">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">args and kwargs</rdfs:label>
    <rdfs:label xml:lang="es">*args y **kwargs</rdfs:label>
    <skos:definition xml:lang="es">Sintaxis *args y **kwargs para aceptar un numero variable de argumentos posicionales y por nombre.</skos:definition>
    <skos:example>def f(*args, **kwargs):
    print(args, kwargs)
f(1, 2, a=3)</skos:example>
    <skos:scopeNote xml:lang="es">*args agrupa posicionales en una tupla y **kwargs los nombrados en un diccionario.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_funciones"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/operador_estrella"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/parametros"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/variable_anotada">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ConceptoDeTipado"/>
    <rdfs:label xml:lang="en">Variable annotations</rdfs:label>
    <rdfs:label xml:lang="es">Anotaciones de variable</rdfs:label>
    <skos:definition xml:lang="es">Sintaxis (PEP 526) para anotar el tipo de una variable, con o sin asignacion.</skos:definition>
    <skos:example>conteo: int = 0
nombres: list[str]</skos:example>
    <skos:scopeNote xml:lang="es">Las anotaciones se guardan en __annotations__; documentan la intencion sin afectar a la ejecucion.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:introducidoEnVersion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">3.6</cfkg:introducidoEnVersion>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_tipos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/anotaciones_tipo"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/docstring">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Docstring</rdfs:label>
    <rdfs:label xml:lang="es">Docstring</rdfs:label>
    <skos:definition xml:lang="es">Cadena de documentacion situada al inicio de un modulo, clase o funcion.</skos:definition>
    <skos:example>def suma(a, b):
    """Devuelve la suma de a y b."""
    return a + b</skos:example>
    <skos:scopeNote xml:lang="es">Accesible mediante help() y __doc__; conviene seguir convenciones como PEP 257.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_testing"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/funcion"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/conversion_tipos">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Type casting</rdfs:label>
    <rdfs:label xml:lang="es">Conversión de tipos</rdfs:label>
    <skos:definition xml:lang="es">Cambio explicito del tipo de un valor mediante constructores como int(), str() o float().</skos:definition>
    <skos:example>edad = int('42')
texto = str(3.14)</skos:example>
    <skos:scopeNote xml:lang="es">Evita errores de TypeError al combinar tipos incompatibles; puede lanzar ValueError si el formato no es valido.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_tipos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/tipo_int"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/tipo_str"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/modulo_random">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ModuloLibreria"/>
    <rdfs:label xml:lang="en">random module</rdfs:label>
    <rdfs:label xml:lang="es">Módulo random</rdfs:label>
    <skos:definition xml:lang="es">Modulo random para generar numeros pseudoaleatorios y muestreos.</skos:definition>
    <skos:example>import random
random.randint(1, 6)</skos:example>
    <skos:scopeNote xml:lang="es">No es criptograficamente seguro; usa el modulo secrets para contrasenas o tokens.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_modulos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/import_mod"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/mutabilidad">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Mutability</rdfs:label>
    <rdfs:label xml:lang="es">Mutabilidad</rdfs:label>
    <rdfs:comment xml:lang="es">Propiedad de los objetos cuyo estado puede cambiar tras su creación.</rdfs:comment>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Immutable_object"/>
    <skos:definition xml:lang="es">Propiedad de los objetos cuyo estado puede modificarse tras su creacion.</skos:definition>
    <skos:example>xs = [1]
xs.append(2)  # mutado en sitio</skos:example>
    <skos:scopeNote xml:lang="es">Listas, dicts y sets son mutables; numeros, cadenas y tuplas son inmutables. Afecta a alias y copias.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:contrastaCon rdf:resource="https://w3id.org/codefeedback-kg/id/tupla"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_estructuras"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/bucle_while">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeControl"/>
    <rdfs:label xml:lang="en">While loop</rdfs:label>
    <rdfs:label xml:lang="es">Bucle while</rdfs:label>
    <skos:definition xml:lang="es">Bucle que repite un bloque mientras una condicion sea verdadera.</skos:definition>
    <skos:example>i = 0
while i &lt; 3:
    print(i)
    i += 1</skos:example>
    <skos:scopeNote xml:lang="es">Adecuado cuando no se conoce de antemano el numero de iteraciones; cuida la condicion de parada para evitar bucles infinitos.</skos:scopeNote>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_control"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/condicional"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/err_concatenar_tipos">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ErrorConceptual"/>
    <rdfs:label xml:lang="en">Concatenating str and int</rdfs:label>
    <rdfs:label xml:lang="es">Concatenar cadena y número (TypeError)</rdfs:label>
    <cfkg:errorSobreConcepto rdf:resource="https://w3id.org/codefeedback-kg/id/conversion_tipos"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/fstring">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">f-strings</rdfs:label>
    <rdfs:label xml:lang="es">f-strings</rdfs:label>
    <skos:definition xml:lang="es">Cadena literal con prefijo f que permite interpolar expresiones entre llaves.</skos:definition>
    <skos:example>nombre = 'Ana'
f'Hola {nombre}, {2+2=}'</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/formato_str"/>
    <skos:scopeNote xml:lang="es">Disponible desde Python 3.6; admite formato y, desde 3.8, la sintaxis de depuracion {x=}.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:introducidoEnVersion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">3.6</cfkg:introducidoEnVersion>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_strings"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/tipo_str"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/pip_mod">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">pip</rdfs:label>
    <rdfs:label xml:lang="es">Gestor de paquetes (pip)</rdfs:label>
    <skos:definition xml:lang="es">Gestor de paquetes pip para instalar bibliotecas desde el indice PyPI.</skos:definition>
    <skos:example>pip install requests
pip freeze &gt; requirements.txt</skos:example>
    <skos:scopeNote xml:lang="es">Trabaja con requirements.txt e idealmente dentro de un entorno virtual.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_modulos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/paquete"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/clase">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Paradigma"/>
    <rdfs:label xml:lang="en">Class</rdfs:label>
    <rdfs:label xml:lang="es">Clase</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Class_(computer_programming)"/>
    <skos:definition xml:lang="es">Plantilla que define atributos y metodos para crear objetos de un mismo tipo.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q4479242"/>
    <skos:example>class Coche:
    def __init__(self, marca):
        self.marca = marca</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/enum_tipo"/>
    <skos:scopeNote xml:lang="es">Convencion: el nombre va en CamelCase; instanciar la clase llama a __init__.</skos:scopeNote>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_poo"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/funcion"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/memoryview_tipo">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#TipoDeDato"/>
    <rdfs:label xml:lang="en">memoryview</rdfs:label>
    <rdfs:label xml:lang="es">memoryview</rdfs:label>
    <skos:definition xml:lang="es">Vista que expone el buffer de memoria de un objeto binario sin copiarlo.</skos:definition>
    <skos:example>mv = memoryview(bytearray(b'abcdef'))
bytes(mv[1:4])  # b'bcd'</skos:example>
    <skos:scopeNote xml:lang="es">Permite manipular grandes bloques de bytes de forma eficiente, por ejemplo al hacer slicing.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_tipos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/tipo_bytes"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/nonlocal_kw">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">nonlocal</rdfs:label>
    <rdfs:label xml:lang="es">Palabra clave nonlocal</rdfs:label>
    <skos:definition xml:lang="es">Declaracion que permite a una funcion anidada reasignar una variable del ambito envolvente.</skos:definition>
    <skos:example>def contador():
    n = 0
    def inc():
        nonlocal n
        n += 1
        return n
    return inc</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/ambito"/>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/closure"/>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/global_kw"/>
    <skos:scopeNote xml:lang="es">Sin ella, una asignacion crearia una variable local; clave en clausuras que mantienen estado.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_funciones"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/closure"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/formato_str">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">String formatting</rdfs:label>
    <rdfs:label xml:lang="es">Formateo de cadenas</rdfs:label>
    <skos:definition xml:lang="es">Conjunto de tecnicas para insertar valores en cadenas (f-strings, str.format, %).</skos:definition>
    <skos:example>n = 3
f'hay {n} elementos'</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/fstring"/>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/metodos_str"/>
    <skos:scopeNote xml:lang="es">Las f-strings son la opcion recomendada por su claridad y rendimiento desde Python 3.6.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_strings"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/tipo_str"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/contextlib_mod">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ModuloLibreria"/>
    <rdfs:label xml:lang="en">contextlib</rdfs:label>
    <rdfs:label xml:lang="es">Modulo contextlib</rdfs:label>
    <skos:definition xml:lang="es">Modulo con utilidades para crear gestores de contexto, como el decorador @contextmanager.</skos:definition>
    <skos:example>from contextlib import contextmanager
@contextmanager
def abierto(p):
    f = open(p)
    try:
        yield f
    finally:
        f.close()</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/context_manager"/>
    <skos:scopeNote xml:lang="es">@contextmanager convierte un generador con un unico yield en un gestor de contexto.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_control"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/context_manager"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#ErrorConceptual">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Misconception</rdfs:label>
    <rdfs:label xml:lang="es">Error conceptual (misconception)</rdfs:label>
    <rdfs:comment xml:lang="es">Malentendido recurrente documentado en la literatura de didáctica de la programación.</rdfs:comment>
    <rdfs:subClassOf rdf:nodeID="nd262beec0bf6424083a51343e94e0bcfb10"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/codefeedback-kg/schema#EntidadEducativa"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/operador_identidad">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#OperadorDelLenguaje"/>
    <rdfs:label xml:lang="en">Identity operators</rdfs:label>
    <rdfs:label xml:lang="es">Operadores de identidad (is)</rdfs:label>
    <skos:definition xml:lang="es">Operadores is e is not que comprueban si dos nombres referencian el mismo objeto.</skos:definition>
    <skos:example>x = None
x is None  # True</skos:example>
    <skos:scopeNote xml:lang="es">Reservalos para comparar con None; para igualdad de valor usa ==.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_tipos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/identidad_objetos"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#numeroDeLineas">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">number of lines</rdfs:label>
    <rdfs:label xml:lang="es">número de líneas</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/codefeedback-kg/schema#EnvioEstudiante"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/try_except_else">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeControl"/>
    <rdfs:label xml:lang="en">try/except/else/finally</rdfs:label>
    <rdfs:label xml:lang="es">try/except/else/finally</rdfs:label>
    <skos:definition xml:lang="es">Estructura try/except/else/finally para capturar y gestionar excepciones.</skos:definition>
    <skos:example>try:
    x = int(s)
except ValueError:
    x = 0
else:
    print('ok')
finally:
    print('fin')</skos:example>
    <skos:narrower rdf:resource="https://w3id.org/codefeedback-kg/id/finally_clause"/>
    <skos:scopeNote xml:lang="es">else se ejecuta si no hubo excepcion y finally siempre; mantenes el try lo mas pequeno posible.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_excepciones"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/excepcion"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/isinstance_func">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#FuncionIntegrada"/>
    <rdfs:label xml:lang="en">isinstance</rdfs:label>
    <rdfs:label xml:lang="es">Funcion isinstance</rdfs:label>
    <skos:definition xml:lang="es">Funcion que comprueba si un objeto es instancia de una clase o de alguna de varias clases.</skos:definition>
    <skos:example>isinstance(3, (int, float))  # True</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/herencia"/>
    <skos:scopeNote xml:lang="es">Respeta la herencia y es preferible a comparar type(x) directamente; acepta una tupla de tipos.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_poo"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/clase"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/namedtuple">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeDatos"/>
    <rdfs:label xml:lang="en">Named tuple</rdfs:label>
    <rdfs:label xml:lang="es">namedtuple</rdfs:label>
    <skos:broader rdf:resource="https://w3id.org/codefeedback-kg/id/tupla"/>
    <skos:definition xml:lang="es">Tupla con campos nombrados (collections.namedtuple) accesibles por atributo.</skos:definition>
    <skos:example>from collections import namedtuple
Punto = namedtuple('Punto', 'x y')
Punto(1, 2).x</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/dataclass"/>
    <skos:scopeNote xml:lang="es">Ligera e inmutable; mejora la legibilidad frente a tuplas posicionales. Para datos mutables usa dataclass.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_tipos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/tupla"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#esPrerrequisitoDe">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdfs:label xml:lang="en">is prerequisite of</rdfs:label>
    <rdfs:label xml:lang="es">es prerrequisito de</rdfs:label>
    <rdfs:comment xml:lang="es">A esPrerrequisitoDe B significa que dominar A es condición previa para aprender B. Transitiva: habilita el cálculo de prerrequisitos indirectos por inferencia.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
    <rdfs:range rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
    <rdfs:subPropertyOf rdf:resource="https://w3id.org/codefeedback-kg/schema#relacionadoConceptualmenteCon"/>
    <owl:inverseOf rdf:resource="https://w3id.org/codefeedback-kg/schema#requierePrerrequisito"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/escribir_fichero">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#FuncionIntegrada"/>
    <rdfs:label xml:lang="en">File writing</rdfs:label>
    <rdfs:label xml:lang="es">Escritura de ficheros</rdfs:label>
    <skos:definition xml:lang="es">Escritura de datos en un fichero mediante metodos como write() o writelines().</skos:definition>
    <skos:example>with open('s.txt', 'w', encoding='utf-8') as f:
    f.write('hola')</skos:example>
    <skos:scopeNote xml:lang="es">Abre en modo 'w' (sobrescribe) o 'a' (anade); usa with para cerrar y volcar el buffer.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_ficheros"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/abrir_fichero"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/typing_any">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ConceptoDeTipado"/>
    <rdfs:label xml:lang="en">typing.Any</rdfs:label>
    <rdfs:label xml:lang="es">typing.Any</rdfs:label>
    <skos:definition xml:lang="es">Tipo comodin compatible con cualquier otro, que desactiva la comprobacion estatica.</skos:definition>
    <skos:example>from typing import Any
def registrar(valor: Any) -&gt; None:
    print(valor)</skos:example>
    <skos:scopeNote xml:lang="es">Usalo con moderacion: cada Any es un agujero en el tipado; prefiere tipos concretos o genericos.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_tipos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/anotaciones_tipo"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/arbol_busqueda_binaria">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeDatos"/>
    <rdfs:label xml:lang="en">Binary search tree</rdfs:label>
    <rdfs:label xml:lang="es">Arbol de busqueda binaria</rdfs:label>
    <skos:broader rdf:resource="https://w3id.org/codefeedback-kg/id/arbol_binario"/>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Binary_search_tree"/>
    <skos:definition xml:lang="es">Arbol binario donde el subarbol izquierdo solo contiene valores menores y el derecho, mayores.</skos:definition>
    <skos:example>def buscar(nodo, x):
    if nodo is None or nodo.v == x:
        return nodo
    return buscar(nodo.izq if x &lt; nodo.v else nodo.der, x)</skos:example>
    <skos:scopeNote xml:lang="es">Permite busqueda, insercion y borrado en O(log n) si esta equilibrado; degenera a O(n) si no.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_algoritmos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/arbol_binario"/>
    <cfkg:tieneComplejidadTemporal rdf:datatype="http://www.w3.org/2001/XMLSchema#string">O(log n)</cfkg:tieneComplejidadTemporal>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#seAplicaA">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">applies to</rdfs:label>
    <rdfs:label xml:lang="es">se aplica a</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
    <rdfs:range rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
    <rdfs:subPropertyOf rdf:resource="https://w3id.org/codefeedback-kg/schema#relacionadoConceptualmenteCon"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/typing_final">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ConceptoDeTipado"/>
    <rdfs:label xml:lang="en">typing.Final</rdfs:label>
    <rdfs:label xml:lang="es">typing.Final</rdfs:label>
    <skos:definition xml:lang="es">Anotacion que marca un nombre como constante que no debe reasignarse ni redefinirse.</skos:definition>
    <skos:example>from typing import Final
MAX: Final = 100</skos:example>
    <skos:scopeNote xml:lang="es">El verificador estatico avisa si se intenta modificar; no impide el cambio en tiempo de ejecucion.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:introducidoEnVersion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">3.8</cfkg:introducidoEnVersion>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_tipos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/anotaciones_tipo"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/recoleccion_basura">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Garbage collection</rdfs:label>
    <rdfs:label xml:lang="es">Recoleccion de basura</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Garbage_collection_(computer_science)"/>
    <skos:definition xml:lang="es">Gestion automatica de la memoria que libera los objetos que ya no son alcanzables.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q322202"/>
    <skos:example>import gc
gc.collect()  # fuerza una recoleccion</skos:example>
    <skos:scopeNote xml:lang="es">CPython usa conteo de referencias mas un recolector ciclico (modulo gc) para los ciclos de referencias.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_fundamentos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/objeto"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/indexacion">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Indexing</rdfs:label>
    <rdfs:label xml:lang="es">Indexación</rdfs:label>
    <skos:definition xml:lang="es">Acceso a un elemento de una secuencia mediante su posicion entre corchetes.</skos:definition>
    <skos:example>xs = [10, 20, 30]
xs[0]  # 10</skos:example>
    <skos:narrower rdf:resource="https://w3id.org/codefeedback-kg/id/indexacion_negativa"/>
    <skos:narrower rdf:resource="https://w3id.org/codefeedback-kg/id/slicing"/>
    <skos:scopeNote xml:lang="es">Los indices empiezan en 0; acceder fuera de rango lanza IndexError.</skos:scopeNote>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_estructuras"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/lista"/>
    <cfkg:seAplicaA rdf:resource="https://w3id.org/codefeedback-kg/id/lista"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/ordered_dict">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeDatos"/>
    <rdfs:label xml:lang="en">OrderedDict</rdfs:label>
    <rdfs:label xml:lang="es">collections.OrderedDict</rdfs:label>
    <skos:definition xml:lang="es">Diccionario que recuerda el orden de insercion y ofrece operaciones de reordenacion.</skos:definition>
    <skos:example>from collections import OrderedDict
d = OrderedDict(a=1, b=2)
d.move_to_end('a')</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/diccionario"/>
    <skos:scopeNote xml:lang="es">Desde Python 3.7 dict ya conserva el orden, pero OrderedDict aporta move_to_end e igualdad sensible al orden.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_estructuras"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/diccionario"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/modulo_datetime">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ModuloLibreria"/>
    <rdfs:label xml:lang="en">datetime module</rdfs:label>
    <rdfs:label xml:lang="es">Módulo datetime</rdfs:label>
    <skos:definition xml:lang="es">Modulo datetime para representar y operar con fechas, horas y duraciones.</skos:definition>
    <skos:example>from datetime import date
date.today().isoformat()</skos:example>
    <skos:scopeNote xml:lang="es">Distingue objetos 'naive' y 'aware' (con zona horaria); usa timedelta para aritmetica.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_modulos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/import_mod"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
    <cfkg:tieneURLDocumentacion rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://docs.python.org/3/library/datetime.html</cfkg:tieneURLDocumentacion>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/global_kw">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">global</rdfs:label>
    <rdfs:label xml:lang="es">Palabra clave global</rdfs:label>
    <skos:definition xml:lang="es">Declaracion que permite a una funcion reasignar una variable del ambito global.</skos:definition>
    <skos:example>contador = 0
def inc():
    global contador
    contador += 1</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/ambito"/>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/nonlocal_kw"/>
    <skos:scopeNote xml:lang="es">Su uso suele indicar un diseno mejorable; prefiere devolver valores o encapsular el estado.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_funciones"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/ambito"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/typing_union">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Union</rdfs:label>
    <rdfs:label xml:lang="es">typing.Union</rdfs:label>
    <skos:definition xml:lang="es">Anotacion Union[A, B] que indica que un valor puede ser de varios tipos.</skos:definition>
    <skos:example>from typing import Union
def f(x: Union[int, str]) -&gt; str:
    return str(x)</skos:example>
    <skos:scopeNote xml:lang="es">Desde Python 3.10 se escribe A | B; usala con moderacion para no diluir el tipado.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:introducidoEnVersion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">3.5</cfkg:introducidoEnVersion>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_tipos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/anotaciones_tipo"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#esVarianteDe">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdfs:label xml:lang="en">is a variant of</rdfs:label>
    <rdfs:label xml:lang="es">es una variante de</rdfs:label>
    <rdfs:comment xml:lang="es">Relacion simetrica entre variantes sintacticas o conceptuales de una misma idea.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
    <rdfs:range rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
    <rdfs:subPropertyOf rdf:resource="https://w3id.org/codefeedback-kg/schema#relacionadoConceptualmenteCon"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/tipo_bytes">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#TipoDeDato"/>
    <rdfs:label xml:lang="en">Bytes</rdfs:label>
    <rdfs:label xml:lang="es">Bytes</rdfs:label>
    <skos:definition xml:lang="es">Secuencia inmutable de bytes (0-255) para datos binarios.</skos:definition>
    <skos:example>b'abc'
'cana'.encode('utf-8')</skos:example>
    <skos:scopeNote xml:lang="es">Se obtiene codificando texto; no confundas bytes con str. Para datos mutables usa bytearray.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_tipos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/tipo_str"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#ConceptoDeConcurrencia">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Concurrency concept</rdfs:label>
    <rdfs:label xml:lang="es">Concepto de concurrencia</rdfs:label>
    <rdfs:comment xml:lang="es">Concepto relacionado con la ejecucion concurrente o paralela.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/encoding">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Text encoding</rdfs:label>
    <rdfs:label xml:lang="es">Codificación de texto</rdfs:label>
    <skos:definition xml:lang="es">Esquema que asocia caracteres a secuencias de bytes (UTF-8, Latin-1) al codificar texto.</skos:definition>
    <skos:example>datos = 'cana'.encode('utf-8')
texto = datos.decode('utf-8')</skos:example>
    <skos:scopeNote xml:lang="es">Especifica siempre encoding al abrir ficheros de texto; errores de codificacion causan UnicodeDecodeError.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_strings"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/tipo_bytes"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/tipo_str"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/python">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Python</rdfs:label>
    <rdfs:label xml:lang="es">Python</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Python_(programming_language)"/>
    <skos:definition xml:lang="es">Lenguaje de programacion interpretado, de alto nivel y tipado dinamico, con enfasis en la legibilidad.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q28865"/>
    <skos:example>print('Hola, mundo')</skos:example>
    <skos:prefLabel xml:lang="es">Python</skos:prefLabel>
    <skos:scopeNote xml:lang="es">Multiparadigma (imperativo, orientado a objetos y funcional); su filosofia se resume en el Zen de Python.</skos:scopeNote>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_fundamentos"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/itertools_product">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ModuloLibreria"/>
    <rdfs:label xml:lang="en">itertools.product</rdfs:label>
    <rdfs:label xml:lang="es">itertools.product</rdfs:label>
    <skos:broader rdf:resource="https://w3id.org/codefeedback-kg/id/itertools_mod"/>
    <skos:definition xml:lang="es">Funcion que genera el producto cartesiano de varios iterables.</skos:definition>
    <skos:example>from itertools import product
list(product([0, 1], repeat=2))  # [(0,0),(0,1),(1,0),(1,1)]</skos:example>
    <skos:scopeNote xml:lang="es">Equivale a bucles for anidados; util para explorar combinaciones de parametros.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_funcional"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/itertools_mod"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/typing_optional">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Optional</rdfs:label>
    <rdfs:label xml:lang="es">typing.Optional</rdfs:label>
    <skos:definition xml:lang="es">Anotacion Optional[X] que indica un valor de tipo X o None.</skos:definition>
    <skos:example>from typing import Optional
def buscar(k) -&gt; Optional[int]:
    return None</skos:example>
    <skos:scopeNote xml:lang="es">Equivale a Union[X, None]; documenta funciones que pueden no devolver un valor.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:introducidoEnVersion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">3.5</cfkg:introducidoEnVersion>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_tipos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/anotaciones_tipo"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/tipo_none"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/err_gil_paralelismo">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ErrorConceptual"/>
    <rdfs:label xml:lang="en">Expecting threads to parallelize</rdfs:label>
    <rdfs:label xml:lang="es">Esperar paralelismo real con hilos (GIL)</rdfs:label>
    <cfkg:errorSobreConcepto rdf:resource="https://w3id.org/codefeedback-kg/id/gil"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/defaultdict">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeDatos"/>
    <rdfs:label xml:lang="en">defaultdict</rdfs:label>
    <rdfs:label xml:lang="es">collections.defaultdict</rdfs:label>
    <skos:broader rdf:resource="https://w3id.org/codefeedback-kg/id/diccionario"/>
    <skos:definition xml:lang="es">Diccionario (collections.defaultdict) que crea un valor por defecto al acceder a una clave inexistente.</skos:definition>
    <skos:example>from collections import defaultdict
d = defaultdict(list)
d['a'].append(1)</skos:example>
    <skos:scopeNote xml:lang="es">Evita comprobar la existencia de la clave; se inicializa con una fabrica (list, int, set).</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_estructuras"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/diccionario"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/conteo_referencias">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Reference counting</rdfs:label>
    <rdfs:label xml:lang="es">Conteo de referencias</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Reference_counting"/>
    <skos:definition xml:lang="es">Tecnica que libera un objeto cuando el numero de referencias que lo apuntan llega a cero.</skos:definition>
    <skos:example>import sys
x = []
sys.getrefcount(x)  # numero de referencias</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/recoleccion_basura"/>
    <skos:scopeNote xml:lang="es">Es inmediata pero no detecta ciclos; por eso CPython la combina con un recolector de ciclos.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_fundamentos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/recoleccion_basura"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/zip_f">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#FuncionIntegrada"/>
    <rdfs:label xml:lang="en">zip</rdfs:label>
    <rdfs:label xml:lang="es">zip()</rdfs:label>
    <skos:definition xml:lang="es">Funcion zip() que combina varios iterables en tuplas de elementos correspondientes.</skos:definition>
    <skos:example>list(zip([1, 2], ['a', 'b']))  # [(1, 'a'), (2, 'b')]</skos:example>
    <skos:scopeNote xml:lang="es">Se detiene en el iterable mas corto; zip(*m) permite transponer; para rellenar usa itertools.zip_longest.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_control"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/bucle_for"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/iterables"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/parametros">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Parameters</rdfs:label>
    <rdfs:label xml:lang="es">Parámetros y argumentos</rdfs:label>
    <skos:definition xml:lang="es">Variables declaradas en la definicion de una funcion que reciben los argumentos al llamarla.</skos:definition>
    <skos:example>def f(a, b=0):  # a y b son parametros
    return a + b</skos:example>
    <skos:scopeNote xml:lang="es">Distingue parametro (en la definicion) de argumento (en la llamada); admiten valores por defecto.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_funciones"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/funcion"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/copia_profunda">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Deep copy</rdfs:label>
    <rdfs:label xml:lang="es">Copia profunda</rdfs:label>
    <skos:definition xml:lang="es">Copia que duplica recursivamente un objeto y todos los objetos anidados que contiene.</skos:definition>
    <skos:example>import copy
b = copy.deepcopy(a)</skos:example>
    <skos:scopeNote xml:lang="es">Usa copy.deepcopy cuando modificar la copia no debe afectar al original anidado; es mas costosa que la superficial.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:contrastaCon rdf:resource="https://w3id.org/codefeedback-kg/id/copia_superficial"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_tipos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/copia_superficial"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/itertools_chain">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ModuloLibreria"/>
    <rdfs:label xml:lang="en">itertools.chain</rdfs:label>
    <rdfs:label xml:lang="es">itertools.chain</rdfs:label>
    <skos:broader rdf:resource="https://w3id.org/codefeedback-kg/id/itertools_mod"/>
    <skos:definition xml:lang="es">Funcion que encadena varios iterables y los recorre como una unica secuencia.</skos:definition>
    <skos:example>from itertools import chain
list(chain([1, 2], [3, 4]))  # [1, 2, 3, 4]</skos:example>
    <skos:scopeNote xml:lang="es">Evita crear listas intermedias al concatenar; chain.from_iterable aplana un iterable de iterables.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_funcional"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/itertools_mod"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/multilinea_str">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Triple-quoted strings</rdfs:label>
    <rdfs:label xml:lang="es">Cadenas multilinea</rdfs:label>
    <skos:definition xml:lang="es">Cadena delimitada por triples comillas que puede abarcar varias lineas.</skos:definition>
    <skos:example>texto = """linea 1
linea 2"""</skos:example>
    <skos:scopeNote xml:lang="es">Tambien se usan como docstrings; conservan los saltos de linea y la sangria literal.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_strings"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/tipo_str"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/condicional">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeControl"/>
    <rdfs:label xml:lang="en">Conditional (if)</rdfs:label>
    <rdfs:label xml:lang="es">Condicional (if)</rdfs:label>
    <skos:definition xml:lang="es">Sentencia if/elif/else que ejecuta bloques distintos segun condiciones booleanas.</skos:definition>
    <skos:example>if x &gt; 0:
    print('positivo')
elif x == 0:
    print('cero')
else:
    print('negativo')</skos:example>
    <skos:scopeNote xml:lang="es">La sangria delimita el bloque; las condiciones se evaluan en orden hasta la primera verdadera.</skos:scopeNote>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_control"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/tipo_bool"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nd262beec0bf6424083a51343e94e0bcfb12">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://w3id.org/codefeedback-kg/schema#Tema"/>
    <owl:onProperty rdf:resource="https://w3id.org/codefeedback-kg/schema#perteneceATema"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/operador_asignacion_aumentada">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#OperadorDelLenguaje"/>
    <rdfs:label xml:lang="en">Augmented assignment</rdfs:label>
    <rdfs:label xml:lang="es">Asignacion aumentada</rdfs:label>
    <skos:definition xml:lang="es">Operadores como +=, -= o *= que combinan una operacion con la asignacion.</skos:definition>
    <skos:example>total = 0
total += 5  # total == 5</skos:example>
    <skos:scopeNote xml:lang="es">En objetos mutables (listas) modifican en sitio; en inmutables crean un objeto nuevo.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_fundamentos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/asignacion"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#cubreConcepto">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">covers concept</rdfs:label>
    <rdfs:label xml:lang="es">cubre el concepto</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/codefeedback-kg/schema#Ejercicio"/>
    <rdfs:range rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/encadenar_excepciones">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeControl"/>
    <rdfs:label xml:lang="en">Exception chaining</rdfs:label>
    <rdfs:label xml:lang="es">Encadenar excepciones</rdfs:label>
    <skos:broader rdf:resource="https://w3id.org/codefeedback-kg/id/jerarquia_excepciones"/>
    <skos:definition xml:lang="es">Mecanismo (raise ... from ...) que vincula una excepcion con la causa original.</skos:definition>
    <skos:example>try:
    int('x')
except ValueError as e:
    raise RuntimeError('dato invalido') from e</skos:example>
    <skos:scopeNote xml:lang="es">Preserva la traza completa y aclara el origen del error; from None oculta la causa intencionadamente.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_excepciones"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/raise_excepcion"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#relacionadoConceptualmenteCon">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">conceptually related to</rdfs:label>
    <rdfs:label xml:lang="es">relacionado conceptualmente con</rdfs:label>
    <rdfs:comment xml:lang="es">Superpropiedad genérica de las relaciones entre conceptos; permite consultas amplias por subsunción de subpropiedades.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
    <rdfs:range rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/objeto">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Paradigma"/>
    <rdfs:label xml:lang="en">Object</rdfs:label>
    <rdfs:label xml:lang="es">Objeto / instancia</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Object_(computer_science)"/>
    <skos:definition xml:lang="es">Instancia concreta de una clase con su propio estado y comportamiento.</skos:definition>
    <skos:example>p = Punto(1, 2)  # p es un objeto</skos:example>
    <skos:scopeNote xml:lang="es">Todo en Python es un objeto; se crea llamando a la clase y vive mientras haya referencias a el.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_poo"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/clase"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/argparse_mod">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ModuloLibreria"/>
    <rdfs:label xml:lang="en">argparse</rdfs:label>
    <rdfs:label xml:lang="es">Modulo argparse</rdfs:label>
    <skos:definition xml:lang="es">Modulo estandar para definir y analizar argumentos de la linea de comandos.</skos:definition>
    <skos:example>import argparse
p = argparse.ArgumentParser()
p.add_argument('nombre')
p.parse_args()</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/modulo_sys"/>
    <skos:scopeNote xml:lang="es">Genera ayuda automatica y valida tipos; mas robusto que leer sys.argv manualmente.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_modulos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/modulo_sys"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/enumerate_f">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#FuncionIntegrada"/>
    <rdfs:label xml:lang="en">enumerate</rdfs:label>
    <rdfs:label xml:lang="es">enumerate()</rdfs:label>
    <skos:definition xml:lang="es">Funcion enumerate() que produce pares (indice, elemento) al iterar un iterable.</skos:definition>
    <skos:example>for i, v in enumerate(['a', 'b'], start=1):
    print(i, v)</skos:example>
    <skos:scopeNote xml:lang="es">Evita gestionar manualmente un contador; admite un indice inicial con start.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_control"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/bucle_for"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/indexacion"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/evalact_03">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EvaluacionActividad"/>
    <rdfs:label xml:lang="en">Activity assessment 03</rdfs:label>
    <rdfs:label xml:lang="es">Evaluación de actividad 03</rdfs:label>
    <cfkg:enFecha rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-03-16</cfkg:enFecha>
    <cfkg:evaluaA rdf:resource="https://w3id.org/codefeedback-kg/id/ej_busqueda"/>
    <cfkg:obtuvoNota rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">9.0</cfkg:obtuvoNota>
    <cfkg:porEstudiante rdf:resource="https://w3id.org/codefeedback-kg/id/est_alicia"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/closure">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Closure</rdfs:label>
    <rdfs:label xml:lang="es">Clausura (closure)</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Closure_(computer_programming)"/>
    <skos:definition xml:lang="es">Funcion interna que recuerda y captura variables del ambito envolvente donde fue creada.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q535335"/>
    <skos:example>def multiplicador(n):
    def f(x):
        return x * n
    return f
doble = multiplicador(2)</skos:example>
    <skos:scopeNote xml:lang="es">Permite fabricas de funciones; las variables capturadas se evaluan en el momento de la llamada (cuidado con el late binding).</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_funcional"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/ambito"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/funcion"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#Concepto">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Programming concept</rdfs:label>
    <rdfs:label xml:lang="es">Concepto de programación</rdfs:label>
    <rdfs:comment xml:lang="es">Unidad de conocimiento del dominio (p. ej. recursión, bucle for, mutabilidad). Al ser subclase de skos:Concept admite la red conceptual skos:broader/narrower/related.</rdfs:comment>
    <rdfs:subClassOf rdf:nodeID="nd262beec0bf6424083a51343e94e0bcfb11"/>
    <rdfs:subClassOf rdf:nodeID="nd262beec0bf6424083a51343e94e0bcfb12"/>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/codefeedback-kg/schema#EntidadEducativa"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/descriptor">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Paradigma"/>
    <rdfs:label xml:lang="en">Descriptor</rdfs:label>
    <rdfs:label xml:lang="es">Descriptor</rdfs:label>
    <skos:definition xml:lang="es">Objeto que define __get__, __set__ o __delete__ para controlar el acceso a un atributo.</skos:definition>
    <skos:example>class SoloLectura:
    def __get__(self, obj, tipo=None):
        return 42</skos:example>
    <skos:scopeNote xml:lang="es">Es el mecanismo subyacente de property, los metodos y classmethod; protocolo avanzado de POO.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_poo"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/propiedad"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/est_alicia">
    <rdf:type rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Estudiante"/>
    <rdfs:label xml:lang="en">Alice</rdfs:label>
    <rdfs:label xml:lang="es">Alicia</rdfs:label>
    <foaf:name>Alicia</foaf:name>
    <cfkg:dominaConcepto rdf:resource="https://w3id.org/codefeedback-kg/id/bucle_for"/>
    <cfkg:dominaConcepto rdf:resource="https://w3id.org/codefeedback-kg/id/funcion"/>
    <cfkg:dominaConcepto rdf:resource="https://w3id.org/codefeedback-kg/id/variable"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/cached_property_mod">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ModuloLibreria"/>
    <rdfs:label xml:lang="en">functools.cached_property</rdfs:label>
    <rdfs:label xml:lang="es">functools.cached_property</rdfs:label>
    <skos:definition xml:lang="es">Decorador que convierte un metodo en una propiedad cuyo valor se calcula una vez y se cachea.</skos:definition>
    <skos:example>from functools import cached_property
class D:
    @cached_property
    def media(self):
        return sum(self.xs) / len(self.xs)</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/propiedad"/>
    <skos:scopeNote xml:lang="es">Ideal para calculos costosos que no cambian; el resultado se guarda en el __dict__ de la instancia.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:introducidoEnVersion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">3.8</cfkg:introducidoEnVersion>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_poo"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/propiedad"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/T_strings">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Tema"/>
    <rdfs:label xml:lang="en">Strings</rdfs:label>
    <rdfs:label xml:lang="es">Cadenas de texto</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/abstract_class">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Paradigma"/>
    <rdfs:label xml:lang="en">Abstract base class</rdfs:label>
    <rdfs:label xml:lang="es">Clase abstracta (ABC)</rdfs:label>
    <skos:definition xml:lang="es">Clase base abstracta (ABC) que define una interfaz comun y no puede instanciarse directamente.</skos:definition>
    <skos:example>from abc import ABC, abstractmethod
class Figura(ABC):
    @abstractmethod
    def area(self): ...</skos:example>
    <skos:scopeNote xml:lang="es">Se declara heredando de abc.ABC y marcando metodos con @abstractmethod; obliga a las subclases a implementarlos.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_poo"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/herencia"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#Algoritmo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Algorithm</rdfs:label>
    <rdfs:label xml:lang="es">Algoritmo</rdfs:label>
    <rdfs:comment xml:lang="es">Procedimiento paso a paso bien definido para resolver un problema.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/basico">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#NivelDominio"/>
    <rdfs:label xml:lang="en">basic</rdfs:label>
    <rdfs:label xml:lang="es">básico</rdfs:label>
    <skos:notation>1</skos:notation>
    <skos:prefLabel xml:lang="en">basic</skos:prefLabel>
    <skos:prefLabel xml:lang="es">básico</skos:prefLabel>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/copia_superficial">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Shallow copy</rdfs:label>
    <rdfs:label xml:lang="es">Copia superficial</rdfs:label>
    <skos:definition xml:lang="es">Copia que duplica el contenedor externo pero comparte las referencias a los objetos internos.</skos:definition>
    <skos:example>import copy
b = copy.copy(a)  # superficial</skos:example>
    <skos:scopeNote xml:lang="es">list(x), x[:] o copy.copy crean copias superficiales; modificar elementos anidados afecta a ambas copias.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_tipos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/lista"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/mutabilidad"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/assert_stmt">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeControl"/>
    <rdfs:label xml:lang="en">assert</rdfs:label>
    <rdfs:label xml:lang="es">assert</rdfs:label>
    <skos:definition xml:lang="es">Sentencia assert que verifica una condicion y lanza AssertionError si es falsa.</skos:definition>
    <skos:example>def media(xs):
    assert len(xs) &gt; 0, 'lista vacia'
    return sum(xs) / len(xs)</skos:example>
    <skos:scopeNote xml:lang="es">Util para comprobaciones internas y pruebas; se desactiva al ejecutar Python con la opcion -O.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_testing"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/condicional"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nd262beec0bf6424083a51343e94e0bcfb4">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://w3id.org/codefeedback-kg/schema#ErrorConceptual"/>
    <owl:onProperty rdf:resource="https://w3id.org/codefeedback-kg/schema#manifiestaError"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/yield_from">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeControl"/>
    <rdfs:label xml:lang="en">yield from</rdfs:label>
    <rdfs:label xml:lang="es">yield from</rdfs:label>
    <skos:definition xml:lang="es">Expresion yield from que delega la produccion de valores a otro generador o iterable.</skos:definition>
    <skos:example>def aplanar(listas):
    for l in listas:
        yield from l</skos:example>
    <skos:scopeNote xml:lang="es">Simplifica la composicion de generadores y transmite valores enviados y excepciones.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:introducidoEnVersion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">3.3</cfkg:introducidoEnVersion>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_funcional"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/generador"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/min_max">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#FuncionIntegrada"/>
    <rdfs:label xml:lang="en">min and max</rdfs:label>
    <rdfs:label xml:lang="es">Funciones min y max</rdfs:label>
    <skos:definition xml:lang="es">Funciones que devuelven el menor o mayor elemento de un iterable o de varios argumentos.</skos:definition>
    <skos:example>max([3, 1, 2])             # 3
max(palabras, key=len)</skos:example>
    <skos:scopeNote xml:lang="es">Aceptan key para definir el criterio y default para iterables vacios.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_algoritmos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/iterables"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/with_context">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeControl"/>
    <rdfs:label xml:lang="en">with statement</rdfs:label>
    <rdfs:label xml:lang="es">Sentencia with</rdfs:label>
    <skos:definition xml:lang="es">Sentencia with que delega en un gestor de contexto la apertura y cierre de un recurso.</skos:definition>
    <skos:example>with open('f.txt') as f:
    datos = f.read()</skos:example>
    <skos:scopeNote xml:lang="es">Garantiza la liberacion del recurso aunque ocurra una excepcion; reduce el codigo repetitivo de try/finally.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_control"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/excepcion"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/logging_mod">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ModuloLibreria"/>
    <rdfs:label xml:lang="en">logging</rdfs:label>
    <rdfs:label xml:lang="es">Modulo logging</rdfs:label>
    <skos:definition xml:lang="es">Modulo estandar para registrar mensajes con distintos niveles de severidad.</skos:definition>
    <skos:example>import logging
logging.basicConfig(level=logging.INFO)
logging.info('iniciado')</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/pep8"/>
    <skos:scopeNote xml:lang="es">Preferible a print en programas reales: permite niveles, formato y destinos configurables.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_testing"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/import_mod"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/notacion_o">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Big-O notation</rdfs:label>
    <rdfs:label xml:lang="es">Notación O grande</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Big_O_notation"/>
    <skos:definition xml:lang="es">Notacion O grande que describe el crecimiento asintotico del coste de un algoritmo.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q269878"/>
    <skos:example># Busqueda binaria: O(log n)
# Ordenacion por mezcla: O(n log n)</skos:example>
    <skos:narrower rdf:resource="https://w3id.org/codefeedback-kg/id/ordenacion_burbuja"/>
    <skos:narrower rdf:resource="https://w3id.org/codefeedback-kg/id/ordenacion_mezcla"/>
    <skos:narrower rdf:resource="https://w3id.org/codefeedback-kg/id/ordenacion_rapida"/>
    <skos:scopeNote xml:lang="es">Ignora constantes y terminos menores; O(1) &lt; O(log n) &lt; O(n) &lt; O(n log n) &lt; O(n^2).</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_algoritmos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/complejidad"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#tieneURLDocumentacion">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">has documentation URL</rdfs:label>
    <rdfs:label xml:lang="es">tiene URL de documentacion</rdfs:label>
    <rdfs:comment xml:lang="es">Enlace a la documentacion oficial del concepto.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/valor_por_defecto">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Default arguments</rdfs:label>
    <rdfs:label xml:lang="es">Argumentos por defecto</rdfs:label>
    <skos:definition xml:lang="es">Valor asignado a un parametro cuando la llamada no proporciona ese argumento.</skos:definition>
    <skos:example>def f(xs=None):
    if xs is None:
        xs = []</skos:example>
    <skos:scopeNote xml:lang="es">Nunca uses objetos mutables como valor por defecto: se comparten entre llamadas. Usa None y crealo dentro.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_funciones"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/parametros"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/patron_captura">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeControl"/>
    <rdfs:label xml:lang="en">Capture patterns</rdfs:label>
    <rdfs:label xml:lang="es">Patrones de captura</rdfs:label>
    <skos:broader rdf:resource="https://w3id.org/codefeedback-kg/id/match_case"/>
    <skos:definition xml:lang="es">Patrones de match que extraen partes de una estructura y las vinculan a variables.</skos:definition>
    <skos:example>match punto:
    case (x, y) if x == y:
        print('diagonal')
    case (x, y):
        print(x, y)</skos:example>
    <skos:scopeNote xml:lang="es">Permiten desestructurar secuencias y objetos; combinados con guardas (if) afinan la coincidencia.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:introducidoEnVersion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">3.10</cfkg:introducidoEnVersion>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_control"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/match_case"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/T_testing">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Tema"/>
    <rdfs:label xml:lang="en">Testing and style</rdfs:label>
    <rdfs:label xml:lang="es">Pruebas y estilo</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/condicion_carrera">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ConceptoDeConcurrencia"/>
    <rdfs:label xml:lang="en">Race condition</rdfs:label>
    <rdfs:label xml:lang="es">Condicion de carrera</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Race_condition"/>
    <skos:definition xml:lang="es">Defecto en el que el resultado depende del orden imprevisible en que se intercalan los hilos.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q616554"/>
    <skos:example># saldo += 1 no es atomico: dos hilos pueden
# leer el mismo valor y perder una actualizacion</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/lock_threading"/>
    <skos:scopeNote xml:lang="es">Se evita sincronizando el acceso al estado compartido con cerrojos u otras primitivas.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_concurrencia"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/hilos"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/err_except_generico">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ErrorConceptual"/>
    <rdfs:label xml:lang="en">Overly broad except</rdfs:label>
    <rdfs:label xml:lang="es">Capturar Exception de forma demasiado amplia</rdfs:label>
    <cfkg:errorSobreConcepto rdf:resource="https://w3id.org/codefeedback-kg/id/jerarquia_excepciones"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#perteneceATema">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">belongs to topic</rdfs:label>
    <rdfs:label xml:lang="es">pertenece al tema</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
    <rdfs:range rdf:resource="https://w3id.org/codefeedback-kg/schema#Tema"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/err_late_binding">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ErrorConceptual"/>
    <rdfs:label xml:lang="en">Loop closure late binding</rdfs:label>
    <rdfs:label xml:lang="es">Late binding en clausuras de bucle</rdfs:label>
    <cfkg:errorSobreConcepto rdf:resource="https://w3id.org/codefeedback-kg/id/closure"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#tieneComplejidadTemporal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">has time complexity</rdfs:label>
    <rdfs:label xml:lang="es">tiene complejidad temporal</rdfs:label>
    <rdfs:comment xml:lang="es">Complejidad temporal en notacion O grande (p. ej. 'O(log n)').</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/tipo_bool">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#TipoDeDato"/>
    <rdfs:label xml:lang="en">Boolean (bool)</rdfs:label>
    <rdfs:label xml:lang="es">Booleano (bool)</rdfs:label>
    <skos:definition xml:lang="es">Tipo booleano con los valores True y False, subtipo de int.</skos:definition>
    <skos:example>es_mayor = 5 &gt; 3  # True</skos:example>
    <skos:scopeNote xml:lang="es">Resulta de comparaciones; True equivale a 1 y False a 0 en contextos numericos.</skos:scopeNote>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_fundamentos"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/init_method">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Paradigma"/>
    <rdfs:label xml:lang="en">Constructor</rdfs:label>
    <rdfs:label xml:lang="es">Constructor __init__</rdfs:label>
    <skos:broader rdf:resource="https://w3id.org/codefeedback-kg/id/metodo"/>
    <skos:definition xml:lang="es">Metodo especial __init__ que inicializa el estado de una instancia recien creada.</skos:definition>
    <skos:example>class Punto:
    def __init__(self, x, y):
        self.x, self.y = x, y</skos:example>
    <skos:scopeNote xml:lang="es">Recibe self y los argumentos del constructor; no devuelve valor (debe retornar None).</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_poo"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/metodo"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/evalact_05">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EvaluacionActividad"/>
    <rdfs:label xml:lang="en">Activity assessment 05</rdfs:label>
    <rdfs:label xml:lang="es">Evaluación de actividad 05</rdfs:label>
    <cfkg:enFecha rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-03-30</cfkg:enFecha>
    <cfkg:evaluaA rdf:resource="https://w3id.org/codefeedback-kg/id/ej_factorial"/>
    <cfkg:obtuvoNota rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">5.5</cfkg:obtuvoNota>
    <cfkg:porEstudiante rdf:resource="https://w3id.org/codefeedback-kg/id/est_alicia"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/busqueda_binaria">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Binary search</rdfs:label>
    <rdfs:label xml:lang="es">Búsqueda binaria</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Binary_search_algorithm"/>
    <skos:definition xml:lang="es">Algoritmo que localiza un elemento en una lista ordenada dividiendo a la mitad el espacio de busqueda.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q243754"/>
    <skos:example>def binaria(xs, x):
    lo, hi = 0, len(xs) - 1
    while lo &lt;= hi:
        m = (lo + hi) // 2
        if xs[m] == x: return m
        if xs[m] &lt; x: lo = m + 1
        else: hi = m - 1
    return -1</skos:example>
    <skos:prefLabel xml:lang="es">Búsqueda binaria</skos:prefLabel>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/busqueda_lineal"/>
    <skos:scopeNote xml:lang="es">Requiere que la secuencia este ordenada; su coste es O(log n) frente a O(n) de la busqueda lineal.</skos:scopeNote>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_complejidad"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/bucle_while"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/indexacion"/>
    <cfkg:seAplicaA rdf:resource="https://w3id.org/codefeedback-kg/id/lista"/>
    <cfkg:tieneComplejidadTemporal rdf:datatype="http://www.w3.org/2001/XMLSchema#string">O(log n)</cfkg:tieneComplejidadTemporal>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/context_manager">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Paradigma"/>
    <rdfs:label xml:lang="en">Context manager</rdfs:label>
    <rdfs:label xml:lang="es">Gestor de contexto</rdfs:label>
    <skos:definition xml:lang="es">Objeto que define la entrada (__enter__) y salida (__exit__) de un bloque with para gestionar recursos.</skos:definition>
    <skos:example>class Recurso:
    def __enter__(self): return self
    def __exit__(self, *a): print('cerrado')</skos:example>
    <skos:scopeNote xml:lang="es">Garantiza la liberacion del recurso incluso si ocurre una excepcion; contextlib facilita crearlos.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_control"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/clase"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/with_context"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/recursion">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Recursion</rdfs:label>
    <rdfs:label xml:lang="es">Recursión</rdfs:label>
    <rdfs:comment xml:lang="es">Definición de una función en términos de sí misma.</rdfs:comment>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Recursion_(computer_science)"/>
    <skos:definition xml:lang="es">Tecnica en la que una funcion se define en terminos de si misma sobre un problema menor.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q264164"/>
    <skos:example>def fact(n):
    return 1 if n == 0 else n * fact(n - 1)</skos:example>
    <skos:narrower rdf:resource="https://w3id.org/codefeedback-kg/id/recursion_cola"/>
    <skos:prefLabel xml:lang="es">Recursión</skos:prefLabel>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/bucle_for"/>
    <skos:scopeNote xml:lang="es">Necesita un caso base que detenga la recursion; cuidado con el limite de profundidad de la pila.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:contrastaCon rdf:resource="https://w3id.org/codefeedback-kg/id/bucle_for"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_recursion"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/funcion"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/event_loop">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ConceptoDeConcurrencia"/>
    <rdfs:label xml:lang="en">Event loop</rdfs:label>
    <rdfs:label xml:lang="es">Bucle de eventos</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Event_loop"/>
    <skos:definition xml:lang="es">Planificador que ejecuta y reanuda corrutinas a medida que sus operaciones de E/S se completan.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q1349935"/>
    <skos:example>import asyncio
asyncio.run(main())  # arranca el bucle de eventos</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/asyncio_mod"/>
    <skos:scopeNote xml:lang="es">Es el nucleo de asyncio; asyncio.run() crea y gestiona el bucle por ti.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_concurrencia"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/asyncio_mod"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#EstructuraDeDatos">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Data structure</rdfs:label>
    <rdfs:label xml:lang="es">Estructura de datos</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
    <owl:disjointWith rdf:resource="https://w3id.org/codefeedback-kg/schema#ModuloLibreria"/>
    <owl:disjointWith rdf:resource="https://w3id.org/codefeedback-kg/schema#TipoDeDato"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#enEjercicio">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">in exercise</rdfs:label>
    <rdfs:label xml:lang="es">en el ejercicio</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/codefeedback-kg/schema#EvaluacionDeConcepto"/>
    <rdfs:range rdf:resource="https://w3id.org/codefeedback-kg/schema#Ejercicio"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/lista_enlazada">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeDatos"/>
    <rdfs:label xml:lang="en">Linked list</rdfs:label>
    <rdfs:label xml:lang="es">Lista enlazada</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Linked_list"/>
    <skos:definition xml:lang="es">Estructura lineal de nodos donde cada nodo guarda un valor y una referencia al siguiente.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q7003418"/>
    <skos:example>class Nodo:
    def __init__(self, valor, sig=None):
        self.valor = valor
        self.sig = sig</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/lista"/>
    <skos:scopeNote xml:lang="es">Insertar al principio es O(1), pero el acceso por posicion es O(n); en Python suele bastar con list o deque.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_estructuras"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/clase"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/objeto"/>
    <cfkg:tieneComplejidadTemporal rdf:datatype="http://www.w3.org/2001/XMLSchema#string">O(n)</cfkg:tieneComplejidadTemporal>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/err_off_by_one">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ErrorConceptual"/>
    <rdfs:label xml:lang="en">Off-by-one error</rdfs:label>
    <rdfs:label xml:lang="es">Error de índice por uno (off-by-one)</rdfs:label>
    <rdfs:comment xml:lang="es">Confusión en la condición de parada de un bucle o en los límites de un rango/índice.</rdfs:comment>
    <cfkg:errorSobreConcepto rdf:resource="https://w3id.org/codefeedback-kg/id/indexacion"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/frozenset_tipo">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeDatos"/>
    <rdfs:label xml:lang="en">frozenset</rdfs:label>
    <rdfs:label xml:lang="es">Conjunto inmutable (frozenset)</rdfs:label>
    <skos:definition xml:lang="es">Version inmutable y hashable del conjunto, que no admite anadir ni quitar elementos.</skos:definition>
    <skos:example>fs = frozenset({1, 2, 3})
{fs: 'valor'}  # valido como clave</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/conjunto"/>
    <skos:scopeNote xml:lang="es">Al ser hashable puede usarse como clave de diccionario o elemento de otro conjunto.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_estructuras"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/conjunto"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#Recurso">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Learning resource</rdfs:label>
    <rdfs:label xml:lang="es">Recurso de aprendizaje</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="nd262beec0bf6424083a51343e94e0bcfb3"/>
    <rdfs:subClassOf rdf:resource="http://schema.org/LearningResource"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/codefeedback-kg/schema#EntidadEducativa"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/collections_mod">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ModuloLibreria"/>
    <rdfs:label xml:lang="en">collections</rdfs:label>
    <rdfs:label xml:lang="es">collections</rdfs:label>
    <skos:definition xml:lang="es">Modulo collections con tipos de contenedor especializados (deque, Counter, defaultdict, namedtuple).</skos:definition>
    <skos:example>from collections import Counter
Counter('aabbbc')  # Counter({'b': 3, 'a': 2, 'c': 1})</skos:example>
    <skos:scopeNote xml:lang="es">Ofrece alternativas mas eficientes o expresivas que las estructuras integradas para casos concretos.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_modulos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/import_mod"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
    <cfkg:tieneURLDocumentacion rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://docs.python.org/3/library/collections.html</cfkg:tieneURLDocumentacion>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/err_decorador_wraps">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ErrorConceptual"/>
    <rdfs:label xml:lang="en">Decorator without wraps</rdfs:label>
    <rdfs:label xml:lang="es">Decorador sin functools.wraps</rdfs:label>
    <cfkg:errorSobreConcepto rdf:resource="https://w3id.org/codefeedback-kg/id/decorador"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/gil">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Global Interpreter Lock</rdfs:label>
    <rdfs:label xml:lang="es">GIL</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Global_interpreter_lock"/>
    <skos:definition xml:lang="es">Bloqueo global del interprete (GIL) de CPython que permite ejecutar un solo hilo de bytecode a la vez.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q5570451"/>
    <skos:example># Los hilos no aceleran calculo puro de CPU por el GIL
import threading</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/hilos"/>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/multiproceso"/>
    <skos:scopeNote xml:lang="es">Limita el paralelismo real con hilos en tareas de CPU; usa multiprocessing para calculo intensivo.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_concurrencia"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/evalact_04">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EvaluacionActividad"/>
    <rdfs:label xml:lang="en">Activity assessment 04</rdfs:label>
    <rdfs:label xml:lang="es">Evaluación de actividad 04</rdfs:label>
    <cfkg:enFecha rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-03-23</cfkg:enFecha>
    <cfkg:evaluaA rdf:resource="https://w3id.org/codefeedback-kg/id/ej_suma_lista"/>
    <cfkg:obtuvoNota rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">7.5</cfkg:obtuvoNota>
    <cfkg:porEstudiante rdf:resource="https://w3id.org/codefeedback-kg/id/est_borja"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/interbloqueo">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ConceptoDeConcurrencia"/>
    <rdfs:label xml:lang="en">Deadlock</rdfs:label>
    <rdfs:label xml:lang="es">Interbloqueo</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Deadlock"/>
    <skos:definition xml:lang="es">Situacion en la que dos o mas hilos se bloquean mutuamente esperando recursos que el otro retiene.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q623276"/>
    <skos:example># Hilo 1: lock_a luego lock_b
# Hilo 2: lock_b luego lock_a  -&gt; interbloqueo</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/lock_threading"/>
    <skos:scopeNote xml:lang="es">Se previene adquiriendo los cerrojos siempre en el mismo orden o con tiempos de espera.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_concurrencia"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/lock_threading"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/prog_dinamica">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Dynamic programming</rdfs:label>
    <rdfs:label xml:lang="es">Programación dinámica</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Dynamic_programming"/>
    <skos:definition xml:lang="es">Tecnica que resuelve un problema combinando soluciones de subproblemas solapados, guardandolas.</skos:definition>
    <skos:example>def fib(n, memo={}):
    if n &lt; 2: return n
    if n not in memo:
        memo[n] = fib(n-1) + fib(n-2)
    return memo[n]</skos:example>
    <skos:scopeNote xml:lang="es">Combina recursion con memoizacion o tablas; evita recalcular (p. ej. Fibonacci, mochila).</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_algoritmos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/memoizacion"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/recursion"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/comprension_sets">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeControl"/>
    <rdfs:label xml:lang="en">Set comprehension</rdfs:label>
    <rdfs:label xml:lang="es">Comprensión de conjuntos</rdfs:label>
    <skos:broader rdf:resource="https://w3id.org/codefeedback-kg/id/comprension_listas"/>
    <skos:definition xml:lang="es">Sintaxis concisa para construir conjuntos eliminando duplicados a partir de un iterable.</skos:definition>
    <skos:example>iniciales = {p[0] for p in ['ana', 'alba', 'bea']}</skos:example>
    <skos:scopeNote xml:lang="es">Sigue el patron {expr for ...}; util para obtener elementos unicos transformados.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_estructuras"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/comprension_listas"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/conjunto"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/typing_literal">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ConceptoDeTipado"/>
    <rdfs:label xml:lang="en">typing.Literal</rdfs:label>
    <rdfs:label xml:lang="es">typing.Literal</rdfs:label>
    <skos:definition xml:lang="es">Anotacion que restringe un valor a un conjunto concreto de constantes literales.</skos:definition>
    <skos:example>from typing import Literal
def mover(d: Literal['n', 's', 'e', 'o']) -&gt; None: ...</skos:example>
    <skos:scopeNote xml:lang="es">Documenta parametros que solo admiten ciertos valores; el verificador rechaza los demas.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:introducidoEnVersion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">3.8</cfkg:introducidoEnVersion>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_tipos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/anotaciones_tipo"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#evaluaCompetencia">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">assesses competency</rdfs:label>
    <rdfs:label xml:lang="es">evalúa la competencia</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/codefeedback-kg/schema#Ejercicio"/>
    <rdfs:range rdf:resource="https://w3id.org/codefeedback-kg/schema#Competencia"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/eval_busqueda_bb">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EvaluacionDeConcepto"/>
    <rdfs:label xml:lang="en">Binary-search assessment in ej_busqueda</rdfs:label>
    <rdfs:label xml:lang="es">Evaluación de búsqueda binaria en ej_busqueda</rdfs:label>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:conPeso rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0.6</cfkg:conPeso>
    <cfkg:enEjercicio rdf:resource="https://w3id.org/codefeedback-kg/id/ej_busqueda"/>
    <cfkg:sobreConcepto rdf:resource="https://w3id.org/codefeedback-kg/id/busqueda_binaria"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/lista">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeDatos"/>
    <rdfs:label xml:lang="en">List</rdfs:label>
    <rdfs:label xml:lang="es">Lista</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/List_(abstract_data_type)"/>
    <skos:definition xml:lang="es">Secuencia mutable y ordenada que admite elementos de cualquier tipo.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q27948"/>
    <skos:example>xs = [1, 'a', True]
xs.append(2)</skos:example>
    <skos:narrower rdf:resource="https://w3id.org/codefeedback-kg/id/cola"/>
    <skos:narrower rdf:resource="https://w3id.org/codefeedback-kg/id/pila"/>
    <skos:prefLabel xml:lang="es">Lista</skos:prefLabel>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/conjunto"/>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/tupla"/>
    <skos:scopeNote xml:lang="es">Crece dinamicamente; el acceso por indice es O(1) y la insercion al final amortizada O(1).</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_estructuras"/>
    <cfkg:tieneComplejidadTemporal rdf:datatype="http://www.w3.org/2001/XMLSchema#string">O(n)</cfkg:tieneComplejidadTemporal>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</cfkg:tieneDificultad>
    <cfkg:tieneEjemploCodigo>xs = [1, 2, 3]</cfkg:tieneEjemploCodigo>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/getattr_setattr">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#FuncionIntegrada"/>
    <rdfs:label xml:lang="en">getattr and setattr</rdfs:label>
    <rdfs:label xml:lang="es">getattr y setattr</rdfs:label>
    <skos:definition xml:lang="es">Funciones que leen y escriben atributos de un objeto a partir de su nombre como cadena.</skos:definition>
    <skos:example>getattr(obj, 'x', 0)
setattr(obj, 'x', 10)</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/atributo"/>
    <skos:scopeNote xml:lang="es">Permiten acceso dinamico a atributos; getattr admite un valor por defecto para evitar AttributeError.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_poo"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/atributo"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/metodos_str">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#FuncionIntegrada"/>
    <rdfs:label xml:lang="en">String methods</rdfs:label>
    <rdfs:label xml:lang="es">Métodos de cadena</rdfs:label>
    <skos:definition xml:lang="es">Conjunto de metodos del tipo str para manipular texto (upper, strip, replace, find).</skos:definition>
    <skos:example>'  Hola  '.strip().lower()  # 'hola'</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/formato_str"/>
    <skos:scopeNote xml:lang="es">Las cadenas son inmutables: estos metodos devuelven una cadena nueva, no modifican la original.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_strings"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/tipo_str"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/frozen_dataclass">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Paradigma"/>
    <rdfs:label xml:lang="en">Frozen dataclass</rdfs:label>
    <rdfs:label xml:lang="es">Dataclass inmutable</rdfs:label>
    <skos:broader rdf:resource="https://w3id.org/codefeedback-kg/id/dataclass"/>
    <skos:definition xml:lang="es">Dataclass declarada con frozen=True cuyas instancias son inmutables y hashables.</skos:definition>
    <skos:example>from dataclasses import dataclass
@dataclass(frozen=True)
class Punto:
    x: int
    y: int</skos:example>
    <skos:scopeNote xml:lang="es">Intentar modificar un campo lanza FrozenInstanceError; util para objetos de valor.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_tipos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/dataclass"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/concatenacion_str">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">String concatenation</rdfs:label>
    <rdfs:label xml:lang="es">Concatenacion de cadenas</rdfs:label>
    <skos:definition xml:lang="es">Union de varias cadenas en una sola mediante el operador + o por yuxtaposicion.</skos:definition>
    <skos:example>'Hola' + ' ' + 'mundo'
''.join(['a', 'b', 'c'])</skos:example>
    <skos:scopeNote xml:lang="es">Para unir muchas cadenas en un bucle, str.join es mas eficiente que la concatenacion repetida.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_strings"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/tipo_str"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/sum_func">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#FuncionIntegrada"/>
    <rdfs:label xml:lang="en">sum</rdfs:label>
    <rdfs:label xml:lang="es">Funcion sum</rdfs:label>
    <skos:definition xml:lang="es">Funcion que suma los elementos de un iterable numerico, con un valor inicial opcional.</skos:definition>
    <skos:example>sum([1, 2, 3])      # 6
sum([1, 2], 10)     # 13</skos:example>
    <skos:scopeNote xml:lang="es">No la uses para concatenar cadenas (usa join); admite un segundo argumento como punto de partida.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_control"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/iterables"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/bfs">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Breadth-first search</rdfs:label>
    <rdfs:label xml:lang="es">Recorrido en anchura (BFS)</rdfs:label>
    <skos:broader rdf:resource="https://w3id.org/codefeedback-kg/id/grafo_estr"/>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Breadth-first_search"/>
    <skos:definition xml:lang="es">Recorrido en anchura de un grafo que visita los nodos por niveles desde el origen usando una cola.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q325904"/>
    <skos:example>from collections import deque
def bfs(g, inicio):
    visto, cola = {inicio}, deque([inicio])
    while cola:
        n = cola.popleft()
        for v in g[n]:
            if v not in visto:
                visto.add(v); cola.append(v)</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/dfs"/>
    <skos:scopeNote xml:lang="es">Encuentra el camino mas corto en grafos no ponderados; contrasta con DFS que usa pila/recursion.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:contrastaCon rdf:resource="https://w3id.org/codefeedback-kg/id/dfs"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_algoritmos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/cola"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/grafo_estr"/>
    <cfkg:tieneComplejidadTemporal rdf:datatype="http://www.w3.org/2001/XMLSchema#string">O(V + E)</cfkg:tieneComplejidadTemporal>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/ambito">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Variable scope</rdfs:label>
    <rdfs:label xml:lang="es">Ámbito de variables (scope)</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Scope_(computer_science)"/>
    <skos:definition xml:lang="es">Region del programa donde un nombre de variable es visible y accesible (regla LEGB).</skos:definition>
    <skos:example>x = 1
def f():
    x = 2  # variable local, no afecta a la global
    return x</skos:example>
    <skos:scopeNote xml:lang="es">Distingue ambito local, envolvente, global e incorporado; una asignacion crea una variable local salvo global/nonlocal.</skos:scopeNote>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_funciones"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/funcion"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/T_fundamentos">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Tema"/>
    <rdfs:label xml:lang="en">Fundamentals</rdfs:label>
    <rdfs:label xml:lang="es">Fundamentos</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/cola_prioridad">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeDatos"/>
    <rdfs:label xml:lang="en">Priority queue</rdfs:label>
    <rdfs:label xml:lang="es">Cola de prioridad</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Priority_queue"/>
    <skos:definition xml:lang="es">Cola en la que cada elemento tiene una prioridad y se extrae siempre el de mayor prioridad.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q629283"/>
    <skos:example>import heapq
pq = []
heapq.heappush(pq, (2, 'tarea B'))
heapq.heappush(pq, (1, 'tarea A'))
heapq.heappop(pq)  # (1, 'tarea A')</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/cola"/>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/heap"/>
    <skos:scopeNote xml:lang="es">Se implementa eficientemente con un monticulo (heapq); base de algoritmos como Dijkstra.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_estructuras"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/heap"/>
    <cfkg:tieneComplejidadTemporal rdf:datatype="http://www.w3.org/2001/XMLSchema#string">O(log n)</cfkg:tieneComplejidadTemporal>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/encapsulacion">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Paradigma"/>
    <rdfs:label xml:lang="en">Encapsulation</rdfs:label>
    <rdfs:label xml:lang="es">Encapsulación</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Encapsulation_(computer_programming)"/>
    <skos:definition xml:lang="es">Principio de ocultar el estado interno de un objeto exponiendo solo una interfaz controlada.</skos:definition>
    <skos:example>class Cuenta:
    def __init__(self):
        self.__saldo = 0  # 'privado'</skos:example>
    <skos:scopeNote xml:lang="es">Python usa convenciones (_protegido, __privado con name mangling) en lugar de modificadores estrictos.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_poo"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/atributo"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/typing_typeddict">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ConceptoDeTipado"/>
    <rdfs:label xml:lang="en">TypedDict</rdfs:label>
    <rdfs:label xml:lang="es">typing.TypedDict</rdfs:label>
    <skos:definition xml:lang="es">Tipo que especifica las claves esperadas de un diccionario y el tipo de cada valor.</skos:definition>
    <skos:example>from typing import TypedDict
class Usuario(TypedDict):
    nombre: str
    edad: int</skos:example>
    <skos:scopeNote xml:lang="es">Aporta seguridad de tipos a los diccionarios tipo registro sin crear una clase.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:introducidoEnVersion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">3.8</cfkg:introducidoEnVersion>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_tipos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/anotaciones_tipo"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/diccionario"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/T_excepciones">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Tema"/>
    <rdfs:label xml:lang="en">Exceptions</rdfs:label>
    <rdfs:label xml:lang="es">Excepciones</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/identidad_objetos">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Object identity</rdfs:label>
    <rdfs:label xml:lang="es">Identidad de objetos (is)</rdfs:label>
    <skos:definition xml:lang="es">Comprobacion (is) de si dos nombres referencian exactamente el mismo objeto en memoria.</skos:definition>
    <skos:example>a = [1]
b = a
a is b  # True
a is [1]  # False</skos:example>
    <skos:scopeNote xml:lang="es">is compara identidad y == compara valor; reserva is para None y centinelas.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_tipos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/mutable_inmutable"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/partial">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ModuloLibreria"/>
    <rdfs:label xml:lang="en">partial</rdfs:label>
    <rdfs:label xml:lang="es">functools.partial</rdfs:label>
    <skos:definition xml:lang="es">Funcion functools.partial que fija algunos argumentos de otra y devuelve una nueva.</skos:definition>
    <skos:example>from functools import partial
cubo = partial(pow, exp=3)</skos:example>
    <skos:scopeNote xml:lang="es">Util para especializar funciones genericas y pasarlas como callbacks.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_funcional"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/funcion_orden_superior"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/T_funciones">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Tema"/>
    <rdfs:label xml:lang="en">Functions</rdfs:label>
    <rdfs:label xml:lang="es">Funciones</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/modulo_sys">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ModuloLibreria"/>
    <rdfs:label xml:lang="en">sys module</rdfs:label>
    <rdfs:label xml:lang="es">Módulo sys</rdfs:label>
    <skos:definition xml:lang="es">Modulo sys con acceso a parametros y funciones del interprete (argv, path, exit).</skos:definition>
    <skos:example>import sys
print(sys.argv)</skos:example>
    <skos:scopeNote xml:lang="es">sys.argv recibe los argumentos de linea de comandos; sys.exit termina el programa.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_modulos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/import_mod"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/desempaquetado">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Unpacking</rdfs:label>
    <rdfs:label xml:lang="es">Desempaquetado</rdfs:label>
    <skos:definition xml:lang="es">Asignacion simultanea de los elementos de un iterable a varias variables.</skos:definition>
    <skos:example>a, b, *resto = [1, 2, 3, 4]</skos:example>
    <skos:scopeNote xml:lang="es">Admite el comodin * para capturar el resto; util para intercambios y retorno multiple.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_estructuras"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/lista"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/tupla"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/iterador">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Iterator</rdfs:label>
    <rdfs:label xml:lang="es">Iterador (iter, next)</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Iterator"/>
    <skos:definition xml:lang="es">Objeto que produce los elementos de un iterable de uno en uno mediante next().</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q1326388"/>
    <skos:example>it = iter([1, 2])
next(it)  # 1</skos:example>
    <skos:scopeNote xml:lang="es">Implementa __iter__ y __next__; lanza StopIteration al agotarse.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_funcional"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/iterables"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/err_float_igualdad">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ErrorConceptual"/>
    <rdfs:label xml:lang="en">Float equality comparison</rdfs:label>
    <rdfs:label xml:lang="es">Comparar flotantes con ==</rdfs:label>
    <cfkg:errorSobreConcepto rdf:resource="https://w3id.org/codefeedback-kg/id/tipo_float"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/typing_generics">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Paradigma"/>
    <rdfs:label xml:lang="en">Generics</rdfs:label>
    <rdfs:label xml:lang="es">Genéricos (TypeVar)</rdfs:label>
    <skos:definition xml:lang="es">Tipos genericos parametrizados (TypeVar, Generic) que abstraen el tipo de los elementos.</skos:definition>
    <skos:example>from typing import TypeVar
T = TypeVar('T')
def primero(xs: list[T]) -&gt; T:
    return xs[0]</skos:example>
    <skos:scopeNote xml:lang="es">Permiten contenedores con seguridad de tipos reutilizables; el chequeo lo hace el verificador estatico.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:introducidoEnVersion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">3.5</cfkg:introducidoEnVersion>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_tipos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/anotaciones_tipo"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/clase"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/enum_tipo">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Paradigma"/>
    <rdfs:label xml:lang="en">Enum</rdfs:label>
    <rdfs:label xml:lang="es">Enumeración (Enum)</rdfs:label>
    <skos:definition xml:lang="es">Tipo enumerado (enum.Enum) que define un conjunto de constantes simbolicas con nombre.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q760170"/>
    <skos:example>from enum import Enum
class Color(Enum):
    ROJO = 1
    VERDE = 2</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/clase"/>
    <skos:scopeNote xml:lang="es">Mejora la legibilidad frente a constantes sueltas; los miembros son unicos y comparables por identidad.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_tipos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/clase"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/ej_suma_lista">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Ejercicio"/>
    <rdfs:label xml:lang="en">Sum the elements of a list</rdfs:label>
    <rdfs:label xml:lang="es">Suma de los elementos de una lista</rdfs:label>
    <cfkg:cubreConcepto rdf:resource="https://w3id.org/codefeedback-kg/id/bucle_for"/>
    <cfkg:cubreConcepto rdf:resource="https://w3id.org/codefeedback-kg/id/funcion"/>
    <cfkg:cubreConcepto rdf:resource="https://w3id.org/codefeedback-kg/id/lista"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</cfkg:tieneDificultad>
    <cfkg:tieneEnunciado xml:lang="es">Escribe una función que reciba una lista de enteros y devuelva su suma usando un bucle.</cfkg:tieneEnunciado>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/T_tipos">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Tema"/>
    <rdfs:label xml:lang="en">Type system</rdfs:label>
    <rdfs:label xml:lang="es">Sistema de tipos</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/tipo_int">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#TipoDeDato"/>
    <rdfs:label xml:lang="en">Integer (int)</rdfs:label>
    <rdfs:label xml:lang="es">Entero (int)</rdfs:label>
    <skos:definition xml:lang="es">Tipo numerico entero de precision arbitraria en Python.</skos:definition>
    <skos:example>10 ** 100  # entero enorme sin desbordamiento</skos:example>
    <skos:scopeNote xml:lang="es">No desborda como en otros lenguajes; admite bases y separadores de miles con guion bajo.</skos:scopeNote>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_fundamentos"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/T_poo">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Tema"/>
    <rdfs:label xml:lang="en">Object-oriented programming</rdfs:label>
    <rdfs:label xml:lang="es">Programación orientada a objetos</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/pytest_mod">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ModuloLibreria"/>
    <rdfs:label xml:lang="en">pytest</rdfs:label>
    <rdfs:label xml:lang="es">pytest</rdfs:label>
    <skos:definition xml:lang="es">Marco de pruebas pytest que descubre y ejecuta tests con asserts simples.</skos:definition>
    <skos:example>def test_suma():
    assert 1 + 1 == 2</skos:example>
    <skos:scopeNote xml:lang="es">Ofrece fixtures, parametrizacion y mensajes de fallo detallados; estandar de facto en Python.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_testing"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/funcion"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/busqueda_lineal">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Linear search</rdfs:label>
    <rdfs:label xml:lang="es">Búsqueda lineal</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Linear_search"/>
    <skos:definition xml:lang="es">Algoritmo que recorre una secuencia elemento a elemento hasta encontrar el buscado.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q787903"/>
    <skos:example>def lineal(xs, x):
    for i, v in enumerate(xs):
        if v == x:
            return i
    return -1</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/busqueda_binaria"/>
    <skos:scopeNote xml:lang="es">Simple y sin requisitos de orden, pero ineficiente (O(n)) para colecciones grandes.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:contrastaCon rdf:resource="https://w3id.org/codefeedback-kg/id/busqueda_binaria"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_algoritmos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/bucle_for"/>
    <cfkg:tieneComplejidadTemporal rdf:datatype="http://www.w3.org/2001/XMLSchema#string">O(n)</cfkg:tieneComplejidadTemporal>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/indexacion_negativa">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Negative indexing</rdfs:label>
    <rdfs:label xml:lang="es">Indexación negativa</rdfs:label>
    <skos:broader rdf:resource="https://w3id.org/codefeedback-kg/id/indexacion"/>
    <skos:definition xml:lang="es">Acceso a elementos contando desde el final con indices negativos (-1 es el ultimo).</skos:definition>
    <skos:example>xs = [1, 2, 3]
xs[-1]  # 3</skos:example>
    <skos:scopeNote xml:lang="es">Evita calcular len(x)-1; tambien aplica al slicing.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_estructuras"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/indexacion"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/super_call">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Paradigma"/>
    <rdfs:label xml:lang="en">super</rdfs:label>
    <rdfs:label xml:lang="es">super()</rdfs:label>
    <skos:definition xml:lang="es">Funcion super() que invoca metodos de la clase base segun el MRO.</skos:definition>
    <skos:example>class B(A):
    def __init__(self):
        super().__init__()</skos:example>
    <skos:scopeNote xml:lang="es">Esencial para encadenar __init__ en herencia y cooperar correctamente con herencia multiple.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_poo"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/herencia"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/funcion_lambda">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Lambda</rdfs:label>
    <rdfs:label xml:lang="es">Función lambda</rdfs:label>
    <skos:broader rdf:resource="https://w3id.org/codefeedback-kg/id/funcion"/>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Anonymous_function"/>
    <skos:definition xml:lang="es">Funcion anonima de una sola expresion definida con la palabra clave lambda.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q567612"/>
    <skos:example>ordenar = sorted(pares, key=lambda p: p[1])</skos:example>
    <skos:scopeNote xml:lang="es">Util como argumento breve (key de sorted); si crece, mejor una funcion con def.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_funcional"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/funcion"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/evalact_06">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EvaluacionActividad"/>
    <rdfs:label xml:lang="en">Activity assessment 06</rdfs:label>
    <rdfs:label xml:lang="es">Evaluación de actividad 06</rdfs:label>
    <cfkg:enFecha rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-06</cfkg:enFecha>
    <cfkg:evaluaA rdf:resource="https://w3id.org/codefeedback-kg/id/ej_busqueda"/>
    <cfkg:obtuvoNota rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">10.0</cfkg:obtuvoNota>
    <cfkg:porEstudiante rdf:resource="https://w3id.org/codefeedback-kg/id/est_borja"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/type_checking">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Type checking</rdfs:label>
    <rdfs:label xml:lang="es">Comprobación de tipos (mypy)</rdfs:label>
    <skos:definition xml:lang="es">Comprobacion estatica de tipos a partir de las anotaciones, sin ejecutar el programa.</skos:definition>
    <skos:example># def f(x: int) -&gt; int: return x + 1
# mypy avisa si se llama f('a')</skos:example>
    <skos:scopeNote xml:lang="es">Herramientas como mypy detectan incoherencias antes de la ejecucion; no afecta al rendimiento.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_testing"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/anotaciones_tipo"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#introducidoEnVersion">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label xml:lang="en">introduced in version</rdfs:label>
    <rdfs:label xml:lang="es">introducido en la version</rdfs:label>
    <rdfs:comment xml:lang="es">Version de Python que introdujo la caracteristica (p. ej. '3.10').</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#ilustradoEnRecurso">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">is illustrated in resource</rdfs:label>
    <rdfs:label xml:lang="es">se ilustra en el recurso</rdfs:label>
    <rdfs:comment xml:lang="es">Inversa de ilustraConcepto.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
    <rdfs:range rdf:resource="https://w3id.org/codefeedback-kg/schema#Recurso"/>
    <owl:inverseOf rdf:resource="https://w3id.org/codefeedback-kg/schema#ilustraConcepto"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/generador">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeControl"/>
    <rdfs:label xml:lang="en">Generator</rdfs:label>
    <rdfs:label xml:lang="es">Generador (yield)</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Generator_(computer_programming)"/>
    <skos:definition xml:lang="es">Funcion que produce una secuencia de valores de forma perezosa usando yield.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q2565187"/>
    <skos:example>def cuenta(n):
    i = 0
    while i &lt; n:
        yield i
        i += 1</skos:example>
    <skos:scopeNote xml:lang="es">Mantiene su estado entre llamadas y ahorra memoria; se agota tras recorrerse una vez.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_funcional"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/funcion"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/iterador"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/atributo">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Paradigma"/>
    <rdfs:label xml:lang="en">Attribute</rdfs:label>
    <rdfs:label xml:lang="es">Atributo de instancia</rdfs:label>
    <skos:definition xml:lang="es">Variable asociada a una instancia que almacena parte de su estado.</skos:definition>
    <skos:example>class Punto:
    def __init__(self, x):
        self.x = x  # atributo de instancia</skos:example>
    <skos:scopeNote xml:lang="es">Se define normalmente en __init__ usando self; no confundir con atributos de clase compartidos.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_poo"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/objeto"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#conPeso">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">with weight</rdfs:label>
    <rdfs:label xml:lang="es">con peso</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/codefeedback-kg/schema#EvaluacionDeConcepto"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#dominaConcepto">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">has mastered concept</rdfs:label>
    <rdfs:label xml:lang="es">domina el concepto</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/codefeedback-kg/schema#Estudiante"/>
    <rdfs:range rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/str_repr">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Paradigma"/>
    <rdfs:label xml:lang="en">str and repr</rdfs:label>
    <rdfs:label xml:lang="es">__str__ y __repr__</rdfs:label>
    <skos:definition xml:lang="es">Metodos __str__ (representacion legible) y __repr__ (representacion no ambigua) de un objeto.</skos:definition>
    <skos:example>class P:
    def __repr__(self):
        return f'P({self.x!r})'</skos:example>
    <skos:scopeNote xml:lang="es">__str__ se usa en print y __repr__ en la consola/depuracion; define __repr__ al menos.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_poo"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/dunder"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/evalact_08">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EvaluacionActividad"/>
    <rdfs:label xml:lang="en">Activity assessment 08</rdfs:label>
    <rdfs:label xml:lang="es">Evaluación de actividad 08</rdfs:label>
    <cfkg:enFecha rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-20</cfkg:enFecha>
    <cfkg:evaluaA rdf:resource="https://w3id.org/codefeedback-kg/id/ej_factorial"/>
    <cfkg:obtuvoNota rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">8.0</cfkg:obtuvoNota>
    <cfkg:porEstudiante rdf:resource="https://w3id.org/codefeedback-kg/id/est_borja"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nd262beec0bf6424083a51343e94e0bcfb23">
    <rdf:first rdf:resource="https://w3id.org/codefeedback-kg/schema#EvaluacionDeConcepto"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#sobreConcepto">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">about concept</rdfs:label>
    <rdfs:label xml:lang="es">sobre el concepto</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/codefeedback-kg/schema#EvaluacionDeConcepto"/>
    <rdfs:range rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/evalact_10">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EvaluacionActividad"/>
    <rdfs:label xml:lang="en">Activity assessment 10</rdfs:label>
    <rdfs:label xml:lang="es">Evaluación de actividad 10</rdfs:label>
    <cfkg:enFecha rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-05-04</cfkg:enFecha>
    <cfkg:evaluaA rdf:resource="https://w3id.org/codefeedback-kg/id/ej_suma_lista"/>
    <cfkg:obtuvoNota rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">9.5</cfkg:obtuvoNota>
    <cfkg:porEstudiante rdf:resource="https://w3id.org/codefeedback-kg/id/est_borja"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/arbol_estr">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeDatos"/>
    <rdfs:label xml:lang="en">Tree</rdfs:label>
    <rdfs:label xml:lang="es">Árbol</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Tree_(data_structure)"/>
    <skos:definition xml:lang="es">Estructura de datos jerarquica formada por nodos con un nodo raiz y subarboles hijos.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q223655"/>
    <skos:example>nodo = {'valor': 1, 'hijos': [{'valor': 2, 'hijos': []}]}</skos:example>
    <skos:narrower rdf:resource="https://w3id.org/codefeedback-kg/id/arbol_binario"/>
    <skos:scopeNote xml:lang="es">Es la base de arboles binarios, de busqueda y montículos; se recorre habitualmente de forma recursiva.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_algoritmos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/recursion"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/cola">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeDatos"/>
    <rdfs:label xml:lang="en">Queue</rdfs:label>
    <rdfs:label xml:lang="es">Cola (queue)</rdfs:label>
    <skos:broader rdf:resource="https://w3id.org/codefeedback-kg/id/lista"/>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Queue_(abstract_data_type)"/>
    <skos:definition xml:lang="es">Estructura FIFO (primero en entrar, primero en salir) que anade por un extremo y extrae por el otro.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q220543"/>
    <skos:example>from collections import deque
q = deque()
q.append(1); q.popleft()</skos:example>
    <skos:narrower rdf:resource="https://w3id.org/codefeedback-kg/id/deque"/>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/pila"/>
    <skos:scopeNote xml:lang="es">Usa collections.deque para operaciones O(1) en ambos extremos en lugar de list.pop(0).</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:contrastaCon rdf:resource="https://w3id.org/codefeedback-kg/id/pila"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_estructuras"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/lista"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/variable">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Variable</rdfs:label>
    <rdfs:label xml:lang="es">Variable</rdfs:label>
    <rdfs:comment xml:lang="es">Nombre asociado a un valor en memoria.</rdfs:comment>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Variable_(computer_science)"/>
    <skos:definition xml:lang="es">Nombre que referencia un valor almacenado en memoria.</skos:definition>
    <skos:example>x = 42
x = 'ahora texto'</skos:example>
    <skos:scopeNote xml:lang="es">En Python no se declara el tipo: el nombre se vincula al objeto en la asignacion y puede reasignarse.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_fundamentos"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</cfkg:tieneDificultad>
    <cfkg:tieneEjemploCodigo>x = 42</cfkg:tieneEjemploCodigo>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#ModuloLibreria">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Module or library</rdfs:label>
    <rdfs:label xml:lang="es">Módulo o librería</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#TipoDeDato">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Data type</rdfs:label>
    <rdfs:label xml:lang="es">Tipo de dato</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
    <owl:disjointWith rdf:resource="https://w3id.org/codefeedback-kg/schema#ModuloLibreria"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/from_import">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">from import</rdfs:label>
    <rdfs:label xml:lang="es">from ... import</rdfs:label>
    <skos:definition xml:lang="es">Variante del import que trae nombres concretos de un modulo al espacio de nombres actual.</skos:definition>
    <skos:example>from math import sqrt
sqrt(16)</skos:example>
    <skos:scopeNote xml:lang="es">Evita el prefijo del modulo pero puede provocar colisiones; no abuses de from modulo import *.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_modulos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/import_mod"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/modulo_math">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ModuloLibreria"/>
    <rdfs:label xml:lang="en">math module</rdfs:label>
    <rdfs:label xml:lang="es">Módulo math</rdfs:label>
    <skos:definition xml:lang="es">Modulo math con funciones y constantes matematicas para numeros reales.</skos:definition>
    <skos:example>import math
math.sqrt(2)</skos:example>
    <skos:scopeNote xml:lang="es">Incluye sqrt, sin, factorial, pi y e; para vectores grandes considera numpy.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_modulos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/import_mod"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</cfkg:tieneDificultad>
    <cfkg:tieneURLDocumentacion rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://docs.python.org/3/library/math.html</cfkg:tieneURLDocumentacion>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/funcion">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Function</rdfs:label>
    <rdfs:label xml:lang="es">Función</rdfs:label>
    <skos:definition xml:lang="es">Bloque de codigo reutilizable con nombre que recibe parametros y puede devolver un valor.</skos:definition>
    <skos:example>def cuadrado(x):
    return x * x</skos:example>
    <skos:narrower rdf:resource="https://w3id.org/codefeedback-kg/id/funcion_lambda"/>
    <skos:prefLabel xml:lang="es">Función</skos:prefLabel>
    <skos:scopeNote xml:lang="es">Se define con def; favorece la modularidad y evita la repeticion de codigo.</skos:scopeNote>
    <cfkg:esPrerrequisitoDe rdf:resource="https://w3id.org/codefeedback-kg/id/recursion"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_funciones"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</cfkg:tieneDificultad>
    <cfkg:tieneEjemploCodigo>def f(x):
    return x + 1</cfkg:tieneEjemploCodigo>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#tieneDificultad">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label xml:lang="en">has difficulty</rdfs:label>
    <rdfs:label xml:lang="es">tiene dificultad</rdfs:label>
    <rdfs:comment xml:lang="es">Dificultad estimada en una escala entera 1–5.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/codefeedback-kg/schema#EntidadEducativa"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nd262beec0bf6424083a51343e94e0bcfb10">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
    <owl:onProperty rdf:resource="https://w3id.org/codefeedback-kg/schema#errorSobreConcepto"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/arbol_binario">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeDatos"/>
    <rdfs:label xml:lang="en">Binary tree</rdfs:label>
    <rdfs:label xml:lang="es">Arbol binario</rdfs:label>
    <skos:broader rdf:resource="https://w3id.org/codefeedback-kg/id/arbol_estr"/>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Binary_tree"/>
    <skos:definition xml:lang="es">Arbol en el que cada nodo tiene como maximo dos hijos, izquierdo y derecho.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q380172"/>
    <skos:example>class NodoB:
    def __init__(self, v):
        self.v = v
        self.izq = self.der = None</skos:example>
    <skos:narrower rdf:resource="https://w3id.org/codefeedback-kg/id/arbol_busqueda_binaria"/>
    <skos:scopeNote xml:lang="es">Base de los arboles de busqueda y los montículos; se recorre en preorden, inorden o postorden.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_algoritmos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/arbol_estr"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/ordenacion_burbuja">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Bubble sort</rdfs:label>
    <rdfs:label xml:lang="es">Ordenación de burbuja</rdfs:label>
    <skos:broader rdf:resource="https://w3id.org/codefeedback-kg/id/notacion_o"/>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Bubble_sort"/>
    <skos:definition xml:lang="es">Algoritmo de ordenacion que intercambia repetidamente elementos adyacentes desordenados.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q60864"/>
    <skos:example>def burbuja(xs):
    for i in range(len(xs)):
        for j in range(len(xs)-1-i):
            if xs[j] &gt; xs[j+1]:
                xs[j], xs[j+1] = xs[j+1], xs[j]</skos:example>
    <skos:scopeNote xml:lang="es">Didactico pero ineficiente (O(n^2)); en la practica usa sorted() (Timsort).</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_algoritmos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/bucle_for"/>
    <cfkg:tieneComplejidadTemporal rdf:datatype="http://www.w3.org/2001/XMLSchema#string">O(n^2)</cfkg:tieneComplejidadTemporal>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#requierePrerrequisito">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdfs:label xml:lang="en">requires prerequisite</rdfs:label>
    <rdfs:label xml:lang="es">requiere como prerrequisito</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
    <rdfs:range rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/fstring_format_spec">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Format specification</rdfs:label>
    <rdfs:label xml:lang="es">Mini-lenguaje de formato</rdfs:label>
    <skos:definition xml:lang="es">Sintaxis tras los dos puntos en un campo de formato para controlar ancho, precision y alineacion.</skos:definition>
    <skos:example>import math
f'{math.pi:.2f}'  # '3.14'
f'{42:05d}'        # '00042'</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/fstring"/>
    <skos:scopeNote xml:lang="es">Permite formatear numeros (:.2f), porcentajes (:.0%) o rellenar con ceros (:03d).</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_strings"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/fstring"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/match_case">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeControl"/>
    <rdfs:label xml:lang="en">Structural pattern matching</rdfs:label>
    <rdfs:label xml:lang="es">match-case</rdfs:label>
    <skos:definition xml:lang="es">Coincidencia estructural de patrones (match/case) que compara un valor con varias formas.</skos:definition>
    <skos:example>match punto:
    case (0, 0):
        print('origen')
    case (x, y):
        print(x, y)</skos:example>
    <skos:narrower rdf:resource="https://w3id.org/codefeedback-kg/id/patron_captura"/>
    <skos:scopeNote xml:lang="es">Disponible desde Python 3.10; permite desestructurar y usar guardas, mas potente que una cadena de if.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:introducidoEnVersion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">3.10</cfkg:introducidoEnVersion>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_control"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/condicional"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/ternario">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeControl"/>
    <rdfs:label xml:lang="en">Ternary operator</rdfs:label>
    <rdfs:label xml:lang="es">Operador ternario</rdfs:label>
    <skos:definition xml:lang="es">Expresion condicional en una linea: valor_si_verdadero if condicion else valor_si_falso.</skos:definition>
    <skos:example>signo = 'par' if n % 2 == 0 else 'impar'</skos:example>
    <skos:scopeNote xml:lang="es">Util para asignaciones breves; si la logica crece, un if/else completo es mas claro.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_control"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/condicional"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#dependeDe">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdfs:label xml:lang="en">depends on</rdfs:label>
    <rdfs:label xml:lang="es">depende de</rdfs:label>
    <rdfs:comment xml:lang="es">Dependencia conceptual generica y transitiva entre conceptos.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
    <rdfs:range rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
    <rdfs:subPropertyOf rdf:resource="https://w3id.org/codefeedback-kg/schema#relacionadoConceptualmenteCon"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/operador_estrella">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Star operator</rdfs:label>
    <rdfs:label xml:lang="es">Operador * y **</rdfs:label>
    <skos:definition xml:lang="es">Operadores * y ** para empaquetar y desempaquetar argumentos e iterables.</skos:definition>
    <skos:example>def f(a, b, c): ...
args = [1, 2, 3]
f(*args)</skos:example>
    <skos:scopeNote xml:lang="es">* expande secuencias y ** diccionarios; permiten reenviar argumentos entre funciones.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_estructuras"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/desempaquetado"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/reduce_func">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#FuncionIntegrada"/>
    <rdfs:label xml:lang="en">reduce</rdfs:label>
    <rdfs:label xml:lang="es">functools.reduce()</rdfs:label>
    <skos:definition xml:lang="es">Funcion functools.reduce que combina los elementos de un iterable en un unico valor.</skos:definition>
    <skos:example>from functools import reduce
reduce(lambda a, b: a*b, [1, 2, 3, 4])  # 24</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/filter_func"/>
    <skos:scopeNote xml:lang="es">Aplica una funcion binaria acumulando; para sumas o productos hay alternativas mas claras (sum, math.prod).</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_funcional"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/funcion_orden_superior"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/dataclass">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Paradigma"/>
    <rdfs:label xml:lang="en">Dataclass</rdfs:label>
    <rdfs:label xml:lang="es">Dataclass</rdfs:label>
    <skos:definition xml:lang="es">Decorador @dataclass que genera automaticamente __init__, __repr__ y __eq__ a partir de anotaciones.</skos:definition>
    <skos:example>from dataclasses import dataclass
@dataclass
class Punto:
    x: int
    y: int = 0</skos:example>
    <skos:narrower rdf:resource="https://w3id.org/codefeedback-kg/id/dataclass_field"/>
    <skos:narrower rdf:resource="https://w3id.org/codefeedback-kg/id/frozen_dataclass"/>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/namedtuple"/>
    <skos:scopeNote xml:lang="es">Reduce el codigo repetitivo de las clases que solo almacenan datos; admite valores por defecto y campos.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:introducidoEnVersion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">3.7</cfkg:introducidoEnVersion>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_tipos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/anotaciones_tipo"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/clase"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/backtracking">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Backtracking</rdfs:label>
    <rdfs:label xml:lang="es">Backtracking</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Backtracking"/>
    <skos:definition xml:lang="es">Tecnica algoritmica que construye soluciones de forma incremental y retrocede al detectar un callejon sin salida.</skos:definition>
    <skos:example>def resolver(estado):
    if completo(estado):
        return estado
    for mov in movimientos(estado):
        if valido(mov):
            r = resolver(aplicar(estado, mov))
            if r:
                return r
    return None</skos:example>
    <skos:scopeNote xml:lang="es">Tipica en problemas de combinatoria (N reinas, sudoku); se implementa con recursion y poda.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_algoritmos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/recursion"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#ConceptoDeTipado">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Typing concept</rdfs:label>
    <rdfs:label xml:lang="es">Concepto de tipado</rdfs:label>
    <rdfs:comment xml:lang="es">Concepto relativo al sistema de tipos y a las anotaciones de tipo.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/csv_mod">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ModuloLibreria"/>
    <rdfs:label xml:lang="en">csv module</rdfs:label>
    <rdfs:label xml:lang="es">Módulo csv</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Comma-separated_values"/>
    <skos:definition xml:lang="es">Modulo estandar csv para leer y escribir ficheros de valores separados por comas.</skos:definition>
    <skos:example>import csv
with open('d.csv', newline='') as f:
    for fila in csv.reader(f):
        print(fila)</skos:example>
    <skos:scopeNote xml:lang="es">Maneja correctamente comillas y delimitadores; usa newline='' al abrir el fichero.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_ficheros"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/lista"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
    <cfkg:tieneURLDocumentacion rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://docs.python.org/3/library/csv.html</cfkg:tieneURLDocumentacion>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nd262beec0bf6424083a51343e94e0bcfb7">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
    <owl:onProperty rdf:resource="https://w3id.org/codefeedback-kg/schema#cubreConcepto"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/ej_busqueda">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Ejercicio"/>
    <rdfs:label xml:lang="en">Binary search on a sorted list</rdfs:label>
    <rdfs:label xml:lang="es">Búsqueda binaria sobre lista ordenada</rdfs:label>
    <cfkg:cubreConcepto rdf:resource="https://w3id.org/codefeedback-kg/id/bucle_while"/>
    <cfkg:cubreConcepto rdf:resource="https://w3id.org/codefeedback-kg/id/busqueda_binaria"/>
    <cfkg:cubreConcepto rdf:resource="https://w3id.org/codefeedback-kg/id/indexacion"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
    <cfkg:tieneEnunciado xml:lang="es">Implementa la búsqueda binaria sobre una lista ordenada y devuelve el índice del elemento.</cfkg:tieneEnunciado>
  </rdf:Description>
