  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#generaliza">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdfs:label xml:lang="en">generalises</rdfs:label>
    <rdfs:label xml:lang="es">generaliza a</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
    <rdfs:range rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
    <rdfs:subPropertyOf rdf:resource="https://w3id.org/codefeedback-kg/schema#relacionadoConceptualmenteCon"/>
    <owl:inverseOf rdf:resource="https://w3id.org/codefeedback-kg/schema#especializa"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/chainmap">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeDatos"/>
    <rdfs:label xml:lang="en">ChainMap</rdfs:label>
    <rdfs:label xml:lang="es">collections.ChainMap</rdfs:label>
    <skos:definition xml:lang="es">Vista que agrupa varios diccionarios y los consulta como si fueran uno solo.</skos:definition>
    <skos:example>from collections import ChainMap
cfg = ChainMap({'a': 1}, {'a': 0, 'b': 2})
cfg['a']  # 1</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/diccionario"/>
    <skos:scopeNote xml:lang="es">Util para gestionar capas de configuracion (por defecto, usuario, entorno) sin copiarlas.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_estructuras"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/diccionario"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/async_await">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeControl"/>
    <rdfs:label xml:lang="en">async/await</rdfs:label>
    <rdfs:label xml:lang="es">async/await</rdfs:label>
    <skos:definition xml:lang="es">Sintaxis async/await para definir y suspender corrutinas en programacion asincrona.</skos:definition>
    <skos:example>import asyncio
async def main():
    await asyncio.sleep(1)
    print('listo')</skos:example>
    <skos:narrower rdf:resource="https://w3id.org/codefeedback-kg/id/corrutina"/>
    <skos:scopeNote xml:lang="es">await solo puede usarse dentro de una funcion async def; cede el control al bucle de eventos sin bloquear el hilo.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:introducidoEnVersion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">3.5</cfkg:introducidoEnVersion>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_concurrencia"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/funcion"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/asignacion">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Assignment</rdfs:label>
    <rdfs:label xml:lang="es">Asignación</rdfs:label>
    <skos:definition xml:lang="es">Operacion que vincula un nombre a un objeto en memoria mediante el operador =.</skos:definition>
    <skos:example>x = [1, 2, 3]
y = x  # y referencia la misma lista</skos:example>
    <skos:scopeNote xml:lang="es">En Python la asignacion no copia el objeto: asocia una referencia; varios nombres pueden apuntar al mismo objeto.</skos:scopeNote>
    <cfkg:esPrerrequisitoDe rdf:resource="https://w3id.org/codefeedback-kg/id/bucle_for"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_fundamentos"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/tipo_str">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#TipoDeDato"/>
    <rdfs:label xml:lang="en">String (str)</rdfs:label>
    <rdfs:label xml:lang="es">Cadena (str)</rdfs:label>
    <skos:definition xml:lang="es">Secuencia inmutable de caracteres Unicode para representar texto.</skos:definition>
    <skos:example>s = 'Python'
s[0]  # 'P'</skos:example>
    <skos:scopeNote xml:lang="es">Admite indexacion, slicing y muchos metodos; al ser inmutable, cada operacion crea una cadena nueva.</skos:scopeNote>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_fundamentos"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#EnvioEstudiante">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Student submission</rdfs:label>
    <rdfs:label xml:lang="es">Envío de estudiante</rdfs:label>
    <rdfs:comment xml:lang="es">Entrega de código de un estudiante en respuesta a un ejercicio.</rdfs:comment>
    <rdfs:subClassOf rdf:nodeID="nd262beec0bf6424083a51343e94e0bcfb4"/>
    <rdfs:subClassOf rdf:nodeID="nd262beec0bf6424083a51343e94e0bcfb5"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/codefeedback-kg/schema#EntidadEducativa"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#Competencia">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Competency</rdfs:label>
    <rdfs:label xml:lang="es">Competencia</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/codefeedback-kg/schema#EntidadEducativa"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/evalact_02">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EvaluacionActividad"/>
    <rdfs:label xml:lang="en">Activity assessment 02</rdfs:label>
    <rdfs:label xml:lang="es">Evaluación de actividad 02</rdfs:label>
    <cfkg:enFecha rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-03-09</cfkg:enFecha>
    <cfkg:evaluaA rdf:resource="https://w3id.org/codefeedback-kg/id/ej_factorial"/>
    <cfkg:obtuvoNota rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">6.0</cfkg:obtuvoNota>
    <cfkg:porEstudiante rdf:resource="https://w3id.org/codefeedback-kg/id/est_borja"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nd262beec0bf6424083a51343e94e0bcfb2">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
    <owl:onClass rdf:resource="https://w3id.org/codefeedback-kg/schema#Ejercicio"/>
    <owl:onProperty rdf:resource="https://w3id.org/codefeedback-kg/schema#enEjercicio"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#Tema">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Curricular topic</rdfs:label>
    <rdfs:label xml:lang="es">Tema curricular</rdfs:label>
    <rdfs:comment xml:lang="es">Agrupación curricular de conceptos (unidad didáctica).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/codefeedback-kg/schema#EntidadEducativa"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/err_mod_durante_iteracion">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ErrorConceptual"/>
    <rdfs:label xml:lang="en">Mutating list while iterating</rdfs:label>
    <rdfs:label xml:lang="es">Modificar una lista mientras se itera</rdfs:label>
    <cfkg:errorSobreConcepto rdf:resource="https://w3id.org/codefeedback-kg/id/bucle_for"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#tieneEjemploCodigo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">has code example</rdfs:label>
    <rdfs:label xml:lang="es">tiene ejemplo de código</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/ej_factorial">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Ejercicio"/>
    <rdfs:label xml:lang="en">Recursive factorial</rdfs:label>
    <rdfs:label xml:lang="es">Factorial recursivo</rdfs:label>
    <cfkg:cubreConcepto rdf:resource="https://w3id.org/codefeedback-kg/id/funcion"/>
    <cfkg:cubreConcepto rdf:resource="https://w3id.org/codefeedback-kg/id/recursion"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
    <cfkg:tieneEnunciado xml:lang="es">Implementa el factorial de n de forma recursiva.</cfkg:tieneEnunciado>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/with_multiple">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeControl"/>
    <rdfs:label xml:lang="en">Multiple context managers</rdfs:label>
    <rdfs:label xml:lang="es">with multiple</rdfs:label>
    <skos:definition xml:lang="es">Sintaxis que gestiona varios recursos en una sola sentencia with separados por comas.</skos:definition>
    <skos:example>with open('a') as a, open('b') as b:
    b.write(a.read())</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/with_context"/>
    <skos:scopeNote xml:lang="es">Desde Python 3.10 admite parentesis para repartirlos en varias lineas de forma legible.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_control"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/with_context"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/intermedio">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#NivelDominio"/>
    <rdfs:label xml:lang="en">intermediate</rdfs:label>
    <rdfs:label xml:lang="es">intermedio</rdfs:label>
    <skos:notation>2</skos:notation>
    <skos:prefLabel xml:lang="en">intermediate</skos:prefLabel>
    <skos:prefLabel xml:lang="es">intermedio</skos:prefLabel>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/counter">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeDatos"/>
    <rdfs:label xml:lang="en">Counter</rdfs:label>
    <rdfs:label xml:lang="es">collections.Counter</rdfs:label>
    <skos:broader rdf:resource="https://w3id.org/codefeedback-kg/id/diccionario"/>
    <skos:definition xml:lang="es">Subclase de diccionario (collections.Counter) que cuenta apariciones de elementos hashables.</skos:definition>
    <skos:example>from collections import Counter
c = Counter('banana')
c.most_common(1)  # [('a', 3)]</skos:example>
    <skos:scopeNote xml:lang="es">Ofrece most_common() y aritmetica de multiconjuntos; ideal para frecuencias.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_estructuras"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/diccionario"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/anotaciones_tipo">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Type hints</rdfs:label>
    <rdfs:label xml:lang="es">Anotaciones de tipo</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Type_signature"/>
    <skos:definition xml:lang="es">Indicaciones opcionales del tipo esperado de variables, parametros y valores de retorno (type hints).</skos:definition>
    <skos:example>def saluda(nombre: str) -&gt; str:
    return f'Hola {nombre}'</skos:example>
    <skos:scopeNote xml:lang="es">No las comprueba el interprete en tiempo de ejecucion; las usan herramientas como mypy y los editores.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:introducidoEnVersion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">3.5</cfkg:introducidoEnVersion>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_tipos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/funcion"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/polimorfismo">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Paradigma"/>
    <rdfs:label xml:lang="en">Polymorphism</rdfs:label>
    <rdfs:label xml:lang="es">Polimorfismo</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Polymorphism_(computer_science)"/>
    <skos:definition xml:lang="es">Capacidad de tratar de forma uniforme objetos de distintas clases que comparten interfaz.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q3240252"/>
    <skos:example>for a in animales:
    print(a.hablar())  # cada clase implementa hablar</skos:example>
    <skos:scopeNote xml:lang="es">Python lo logra por duck typing: importa el comportamiento, no el tipo exacto.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_poo"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/herencia"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#ilustraConcepto">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">illustrates concept</rdfs:label>
    <rdfs:label xml:lang="es">ilustra el concepto</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/codefeedback-kg/schema#Recurso"/>
    <rdfs:range rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/heap">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeDatos"/>
    <rdfs:label xml:lang="en">Heap</rdfs:label>
    <rdfs:label xml:lang="es">Montículo (heapq)</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Heap_(data_structure)"/>
    <skos:definition xml:lang="es">Arbol binario parcialmente ordenado que da acceso O(1) al minimo o maximo (modulo heapq).</skos:definition>
    <skos:example>import heapq
h = [3, 1, 2]
heapq.heapify(h)
heapq.heappop(h)  # 1</skos:example>
    <skos:scopeNote xml:lang="es">heapq implementa un min-heap sobre una lista; util para colas de prioridad y los k mayores.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_estructuras"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/complejidad"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/lista"/>
    <cfkg:tieneComplejidadTemporal rdf:datatype="http://www.w3.org/2001/XMLSchema#string">O(log n)</cfkg:tieneComplejidadTemporal>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/tupla">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeDatos"/>
    <rdfs:label xml:lang="en">Tuple</rdfs:label>
    <rdfs:label xml:lang="es">Tupla</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Tuple"/>
    <skos:definition xml:lang="es">Secuencia ordenada e inmutable de elementos, posiblemente de distintos tipos.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q2879072"/>
    <skos:example>punto = (3, 4)
x, y = punto</skos:example>
    <skos:narrower rdf:resource="https://w3id.org/codefeedback-kg/id/namedtuple"/>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/lista"/>
    <skos:scopeNote xml:lang="es">Util para datos heterogeneos fijos y como claves de diccionario; es hashable si sus elementos lo son.</skos:scopeNote>
    <cfkg:contrastaCon rdf:resource="https://w3id.org/codefeedback-kg/id/lista"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_estructuras"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/rec_doc_listas">
    <rdf:type rdf:resource="http://schema.org/LearningResource"/>
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Recurso"/>
    <rdfs:label xml:lang="en">Official documentation: data structures</rdfs:label>
    <rdfs:label xml:lang="es">Documentación oficial: estructuras de datos</rdfs:label>
    <dcterms:creator>Python Software Foundation</dcterms:creator>
    <dcterms:title xml:lang="en">Data Structures — The Python Tutorial</dcterms:title>
    <schema1:url>https://docs.python.org/3/tutorial/datastructures.html</schema1:url>
    <cfkg:ilustraConcepto rdf:resource="https://w3id.org/codefeedback-kg/id/diccionario"/>
    <cfkg:ilustraConcepto rdf:resource="https://w3id.org/codefeedback-kg/id/lista"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/err_shallow_copy">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ErrorConceptual"/>
    <rdfs:label xml:lang="en">Shallow when deep needed</rdfs:label>
    <rdfs:label xml:lang="es">Copia superficial cuando se necesita profunda</rdfs:label>
    <cfkg:errorSobreConcepto rdf:resource="https://w3id.org/codefeedback-kg/id/copia_superficial"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nd262beec0bf6424083a51343e94e0bcfb22">
    <rdf:first rdf:resource="https://w3id.org/codefeedback-kg/schema#RutaAprendizaje"/>
    <rdf:rest rdf:nodeID="nd262beec0bf6424083a51343e94e0bcfb23"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nd262beec0bf6424083a51343e94e0bcfb15">
    <rdf:first rdf:resource="https://w3id.org/codefeedback-kg/schema#Tema"/>
    <rdf:rest rdf:nodeID="nd262beec0bf6424083a51343e94e0bcfb16"/>
