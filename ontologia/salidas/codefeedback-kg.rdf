  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/mro">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Paradigma"/>
    <rdfs:label xml:lang="en">Method resolution order</rdfs:label>
    <rdfs:label xml:lang="es">Orden de resolución (MRO)</rdfs:label>
    <skos:definition xml:lang="es">Orden de resolucion de metodos (MRO) que determina como Python busca atributos en herencia multiple.</skos:definition>
    <skos:example>class C(A, B): ...
C.mro()</skos:example>
    <skos:scopeNote xml:lang="es">Se calcula con el algoritmo C3 y es consultable con NombreClase.mro().</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_poo"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/herencia_multiple"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/future_annotations">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ConceptoDeTipado"/>
    <rdfs:label xml:lang="en">Postponed annotations</rdfs:label>
    <rdfs:label xml:lang="es">from __future__ import annotations</rdfs:label>
    <skos:definition xml:lang="es">Directiva que evalua las anotaciones como cadenas, posponiendo su resolucion.</skos:definition>
    <skos:example>from __future__ import annotations
class Nodo:
    sig: Nodo | None = None</skos:example>
    <skos:scopeNote xml:lang="es">Evita referencias adelantadas y costes de importacion; conviene conocerla al usar tipos recursivos.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:introducidoEnVersion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">3.7</cfkg:introducidoEnVersion>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_tipos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/anotaciones_tipo"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/operador_comparacion">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#OperadorDelLenguaje"/>
    <rdfs:label xml:lang="en">Comparison operators</rdfs:label>
    <rdfs:label xml:lang="es">Operadores de comparacion</rdfs:label>
    <skos:definition xml:lang="es">Operadores que comparan valores y devuelven un booleano: ==, !=, &lt;, &lt;=, &gt;, &gt;=.</skos:definition>
    <skos:example>1 &lt; 2 &lt;= 2  # True</skos:example>
    <skos:scopeNote xml:lang="es">Pueden encadenarse (1 &lt; x &lt; 10); == compara valor mientras que is compara identidad.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_fundamentos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/variable"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/operador_bitwise">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#OperadorDelLenguaje"/>
    <rdfs:label xml:lang="en">Bitwise operators</rdfs:label>
    <rdfs:label xml:lang="es">Operadores a nivel de bits</rdfs:label>
    <skos:definition xml:lang="es">Operadores que manipulan los bits individuales de los enteros: &amp;, |, ^, ~, &lt;&lt; y &gt;&gt;.</skos:definition>
    <skos:example>0b1100 &amp; 0b1010  # 0b1000 (8)
1 &lt;&lt; 4           # 16</skos:example>
    <skos:scopeNote xml:lang="es">Utiles para mascaras, banderas y optimizaciones; no confundir &amp; con and.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_fundamentos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/tipo_int"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#EntidadEducativa">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Educational entity</rdfs:label>
    <rdfs:label xml:lang="es">Entidad educativa</rdfs:label>
    <rdfs:comment xml:lang="es">Superclase abstracta de todas las entidades del grafo educativo.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nd262beec0bf6424083a51343e94e0bcfb11">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
    <owl:onProperty rdf:resource="https://w3id.org/codefeedback-kg/schema#requierePrerrequisito"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/range_f">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#FuncionIntegrada"/>
    <rdfs:label xml:lang="en">range</rdfs:label>
    <rdfs:label xml:lang="es">range()</rdfs:label>
    <skos:definition xml:lang="es">Funcion range() que genera una secuencia perezosa de enteros equiespaciados.</skos:definition>
    <skos:example>list(range(2, 10, 2))  # [2, 4, 6, 8]</skos:example>
    <skos:scopeNote xml:lang="es">Define inicio, fin (excluido) y paso; no crea una lista, ahorra memoria.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_control"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/bucle_for"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/functools_wraps">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ModuloLibreria"/>
    <rdfs:label xml:lang="en">functools.wraps</rdfs:label>
    <rdfs:label xml:lang="es">functools.wraps</rdfs:label>
    <skos:definition xml:lang="es">Decorador functools.wraps que copia los metadatos de la funcion original a la envoltura.</skos:definition>
    <skos:example>import functools
def d(f):
    @functools.wraps(f)
    def w(*a, **k): return f(*a, **k)
    return w</skos:example>
    <skos:scopeNote xml:lang="es">Conserva __name__ y __doc__ al crear decoradores; sin el se pierde la introspeccion.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_funcional"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/decorador"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/import_mod">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">import</rdfs:label>
    <rdfs:label xml:lang="es">import</rdfs:label>
    <skos:definition xml:lang="es">Sentencia import que carga un modulo y lo pone a disposicion del programa.</skos:definition>
    <skos:example>import math
math.pi</skos:example>
    <skos:scopeNote xml:lang="es">El interprete cachea los modulos importados; situa los imports al inicio del fichero (PEP 8).</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_modulos"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/atributo_clase">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Paradigma"/>
    <rdfs:label xml:lang="en">Class attribute</rdfs:label>
    <rdfs:label xml:lang="es">Atributo de clase</rdfs:label>
    <skos:definition xml:lang="es">Atributo definido en la clase y compartido por todas sus instancias.</skos:definition>
    <skos:example>class Contador:
    total = 0  # atributo de clase compartido</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/atributo"/>
    <skos:scopeNote xml:lang="es">Cuidado al usar valores mutables: se comparten entre instancias; las asignaciones via self crean copias locales.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_poo"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/atributo"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nd262beec0bf6424083a51343e94e0bcfb14">
    <rdf:first rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
    <rdf:rest rdf:nodeID="nd262beec0bf6424083a51343e94e0bcfb15"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Cross-cutting principle</rdfs:label>
    <rdfs:label xml:lang="es">Principio transversal</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/operador_logico">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#OperadorDelLenguaje"/>
    <rdfs:label xml:lang="en">Logical operators</rdfs:label>
    <rdfs:label xml:lang="es">Operadores logicos</rdfs:label>
    <skos:definition xml:lang="es">Operadores and, or y not que combinan o niegan expresiones booleanas.</skos:definition>
    <skos:example>(x &gt; 0) and (x &lt; 10)
nombre or 'anonimo'</skos:example>
    <skos:scopeNote xml:lang="es">and/or evaluan de forma perezosa (cortocircuito) y devuelven uno de los operandos, no solo True/False.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_fundamentos"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/tipo_bool"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/funcion_orden_superior">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">Higher-order functions</rdfs:label>
    <rdfs:label xml:lang="es">Funciones de orden superior</rdfs:label>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Higher-order_function"/>
    <skos:definition xml:lang="es">Funcion que recibe otras funciones como argumento o devuelve una funcion.</skos:definition>
    <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q1474542"/>
    <skos:example>def aplica(f, x):
    return f(x)
aplica(abs, -5)</skos:example>
    <skos:scopeNote xml:lang="es">Base de map, filter y los decoradores; aprovecha que las funciones son objetos de primera clase.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_funcional"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/funcion"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#enviadoPor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">submitted by</rdfs:label>
    <rdfs:label xml:lang="es">enviado por</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/codefeedback-kg/schema#EnvioEstudiante"/>
    <rdfs:range rdf:resource="https://w3id.org/codefeedback-kg/schema#Estudiante"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/ref_keuning2019">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Recurso"/>
    <rdfs:label xml:lang="en">Keuning, Jeuring &amp; Heeren (2019), A systematic literature review of automated feedback generation for programming exercises</rdfs:label>
    <rdfs:label xml:lang="es">Keuning et al. (2019): revisión sistemática de generación automática de feedback</rdfs:label>
    <dcterms:creator>Bastiaan Heeren</dcterms:creator>
    <dcterms:creator>Hieke Keuning</dcterms:creator>
    <dcterms:creator>Johan Jeuring</dcterms:creator>
    <dcterms:date rdf:datatype="http://www.w3.org/2001/XMLSchema#gYear">2019</dcterms:date>
    <dcterms:identifier>10.1145/3231711</dcterms:identifier>
    <dcterms:title xml:lang="en">A systematic literature review of automated feedback generation for programming exercises</dcterms:title>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/pep8">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#PrincipioTransversal"/>
    <rdfs:label xml:lang="en">PEP 8</rdfs:label>
    <rdfs:label xml:lang="es">PEP 8 (estilo)</rdfs:label>
    <skos:definition xml:lang="es">Guia de estilo oficial PEP 8 con convenciones de formato del codigo Python.</skos:definition>
    <skos:example># correcto
def calcular_total(precio, cantidad):
    return precio * cantidad</skos:example>
    <skos:scopeNote xml:lang="es">Recomienda sangria de 4 espacios, snake_case y lineas de hasta 79 caracteres; herramientas como flake8 la verifican.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_testing"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/T_estructuras">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#Tema"/>
    <rdfs:label xml:lang="en">Data structures</rdfs:label>
    <rdfs:label xml:lang="es">Estructuras de datos</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#introduceConcepto">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">introduces concept</rdfs:label>
    <rdfs:label xml:lang="es">introduce el concepto</rdfs:label>
    <rdfs:comment xml:lang="es">Un tema curricular introduce (presenta por primera vez) un concepto.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/codefeedback-kg/schema#Tema"/>
    <rdfs:range rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/tipo_none">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#TipoDeDato"/>
    <rdfs:label xml:lang="en">NoneType</rdfs:label>
    <rdfs:label xml:lang="es">NoneType (None)</rdfs:label>
    <skos:definition xml:lang="es">Tipo con un unico valor, None, que representa la ausencia de valor.</skos:definition>
    <skos:example>def f():
    pass
f() is None  # True</skos:example>
    <skos:scopeNote xml:lang="es">Es el retorno por defecto de las funciones; comparalo con is None, no con ==.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/basico"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_tipos"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/expresion_generadora">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeControl"/>
    <rdfs:label xml:lang="en">Generator expression</rdfs:label>
    <rdfs:label xml:lang="es">Expresión generadora</rdfs:label>
    <skos:broader rdf:resource="https://w3id.org/codefeedback-kg/id/comprension_listas"/>
    <skos:definition xml:lang="es">Expresion perezosa, similar a una comprension, que produce valores bajo demanda con parentesis.</skos:definition>
    <skos:example>suma = sum(x*x for x in range(1000))</skos:example>
    <skos:scopeNote xml:lang="es">Ahorra memoria frente a una lista cuando solo se itera una vez; no se puede indexar.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/avanzado"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_funcional"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/comprension_listas"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/generador"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#FuncionIntegrada">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Built-in function</rdfs:label>
    <rdfs:label xml:lang="es">Función integrada</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/codefeedback-kg/schema#Concepto"/>
    <owl:disjointWith rdf:resource="https://w3id.org/codefeedback-kg/schema#EstructuraDeControl"/>
    <owl:disjointWith rdf:resource="https://w3id.org/codefeedback-kg/schema#TipoDeDato"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#Estudiante">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Student</rdfs:label>
    <rdfs:label xml:lang="es">Estudiante</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="nd262beec0bf6424083a51343e94e0bcfb6"/>
    <rdfs:subClassOf rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/codefeedback-kg/schema#EntidadEducativa"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#Ejercicio">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Exercise or assignment</rdfs:label>
    <rdfs:label xml:lang="es">Ejercicio o enunciado</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="nd262beec0bf6424083a51343e94e0bcfb7"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/codefeedback-kg/schema#EntidadEducativa"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/map_func">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#FuncionIntegrada"/>
    <rdfs:label xml:lang="en">map</rdfs:label>
    <rdfs:label xml:lang="es">map()</rdfs:label>
    <skos:definition xml:lang="es">Funcion map() que aplica una funcion a cada elemento de uno o varios iterables.</skos:definition>
    <skos:example>dobles = list(map(lambda x: x*2, [1, 2, 3]))</skos:example>
    <skos:related rdf:resource="https://w3id.org/codefeedback-kg/id/filter_func"/>
    <skos:scopeNote xml:lang="es">Devuelve un iterador perezoso; una comprension suele ser mas legible.</skos:scopeNote>
    <cfkg:aNivelDominio rdf:resource="https://w3id.org/codefeedback-kg/id/intermedio"/>
    <cfkg:perteneceATema rdf:resource="https://w3id.org/codefeedback-kg/id/T_funcional"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/funcion_orden_superior"/>
    <cfkg:requierePrerrequisito rdf:resource="https://w3id.org/codefeedback-kg/id/iterables"/>
    <cfkg:tieneDificultad rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</cfkg:tieneDificultad>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/err_self_olvidado">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ErrorConceptual"/>
    <rdfs:label xml:lang="en">Missing self parameter</rdfs:label>
    <rdfs:label xml:lang="es">Olvidar self en un método</rdfs:label>
    <cfkg:errorSobreConcepto rdf:resource="https://w3id.org/codefeedback-kg/id/metodo"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/id/err_global_local">
    <rdf:type rdf:resource="https://w3id.org/codefeedback-kg/schema#ErrorConceptual"/>
    <rdfs:label xml:lang="en">Global vs local confusion</rdfs:label>
    <rdfs:label xml:lang="es">Confundir variable global y local</rdfs:label>
    <cfkg:errorSobreConcepto rdf:resource="https://w3id.org/codefeedback-kg/id/ambito"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#obtuvoNota">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">obtained grade</rdfs:label>
    <rdfs:label xml:lang="es">obtuvo nota</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/codefeedback-kg/schema#EvaluacionActividad"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/codefeedback-kg/schema#enFecha">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
