    cfkg:tieneDificultad 3 .

cfr:decorador a cfkg:Paradigma ;
    rdfs:label "Decorator"@en,
        "Decorador"@es ;
    skos:exactMatch wd:Q110938941 ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:perteneceATema cfr:T_funcional ;
    cfkg:requierePrerrequisito cfr:closure,
        cfr:funcion_orden_superior ;
    cfkg:tieneDificultad 5 .

cfr:ej_busqueda a cfkg:Ejercicio ;
    rdfs:label "Binary search on a sorted list"@en,
        "Búsqueda binaria sobre lista ordenada"@es ;
    cfkg:cubreConcepto cfr:bucle_while,
        cfr:busqueda_binaria,
        cfr:indexacion ;
    cfkg:tieneDificultad 4 ;
    cfkg:tieneEnunciado "Implementa la búsqueda binaria sobre una lista ordenada y devuelve el índice del elemento."@es .

cfr:excepcion a cfkg:EstructuraDeControl ;
    rdfs:label "Exception"@en,
        "Excepción"@es ;
    skos:exactMatch wd:Q471748 ;
    cfkg:perteneceATema cfr:T_excepciones ;
    cfkg:requierePrerrequisito cfr:condicional ;
    cfkg:tieneDificultad 3 .

cfr:funcion_orden_superior a cfkg:PrincipioTransversal ;
    rdfs:label "Higher-order functions"@en,
        "Funciones de orden superior"@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:perteneceATema cfr:T_funcional ;
    cfkg:requierePrerrequisito cfr:funcion ;
    cfkg:tieneDificultad 4 .

cfr:iterables a cfkg:PrincipioTransversal ;
    rdfs:label "Iterables"@en,
        "Iterables"@es ;
    cfkg:aNivelDominio cfr:basico ;
    cfkg:perteneceATema cfr:T_estructuras ;
    cfkg:requierePrerrequisito cfr:lista ;
    cfkg:tieneDificultad 2 .

cfkg:EvaluacionDeConcepto a owl:Class ;
    rdfs:label "Concept assessment occurrence"@en,
        "Evaluación de concepto"@es ;
    rdfs:comment "Nodo intermedio que reifica la relación N-aria (ejercicio, concepto, peso, nivel) sin perder información, según el patrón de relaciones N-arias del material docente."@es ;
    rdfs:subClassOf cfkg:EntidadEducativa .

cfr:T_concurrencia a cfkg:Tema ;
    rdfs:label "Concurrency"@en,
        "Concurrencia"@es .

cfr:T_excepciones a cfkg:Tema ;
    rdfs:label "Exceptions"@en,
        "Excepciones"@es .

cfr:T_ficheros a cfkg:Tema ;
    rdfs:label "Files and I/O"@en,
        "Ficheros y E/S"@es .

cfr:T_fundamentos a cfkg:Tema ;
    rdfs:label "Fundamentals"@en,
        "Fundamentos"@es .

cfr:T_strings a cfkg:Tema ;
    rdfs:label "Strings"@en,
        "Cadenas de texto"@es .

cfr:T_testing a cfkg:Tema ;
    rdfs:label "Testing and style"@en,
        "Pruebas y estilo"@es .

cfr:est_alicia a foaf:Person,
        cfkg:Estudiante ;
    rdfs:label "Alice"@en,
        "Alicia"@es ;
    foaf:name "Alicia" ;
    cfkg:dominaConcepto cfr:bucle_for,
        cfr:funcion,
        cfr:variable .

cfr:est_borja a foaf:Person,
        cfkg:Estudiante ;
    rdfs:label "Borja"@en,
        "Borja"@es ;
    foaf:name "Borja" ;
    cfkg:dominaConcepto cfr:condicional,
        cfr:variable .

cfr:tupla a cfkg:EstructuraDeDatos ;
    rdfs:label "Tuple"@en,
        "Tupla"@es ;
    skos:exactMatch wd:Q2879072 ;
    skos:related cfr:lista ;
    cfkg:contrastaCon cfr:lista ;
    cfkg:perteneceATema cfr:T_estructuras ;
    cfkg:tieneDificultad 2 .

cfkg:Estudiante a owl:Class ;
    rdfs:label "Student"@en,
        "Estudiante"@es ;
    rdfs:subClassOf cfkg:EntidadEducativa .

cfr:T_funciones a cfkg:Tema ;
    rdfs:label "Functions"@en,
        "Funciones"@es .

cfr:condicional a cfkg:EstructuraDeControl ;
    rdfs:label "Conditional (if)"@en,
        "Condicional (if)"@es ;
    cfkg:perteneceATema cfr:T_control ;
    cfkg:requierePrerrequisito cfr:tipo_bool ;
    cfkg:tieneDificultad 1 .

cfkg:EnvioEstudiante a owl:Class ;
    rdfs:label "Student submission"@en,
        "Envío de estudiante"@es ;
    rdfs:comment "Entrega de código de un estudiante en respuesta a un ejercicio."@es ;
    rdfs:subClassOf cfkg:EntidadEducativa .

cfkg:TipoDeDato a owl:Class ;
    rdfs:label "Data type"@en,
        "Tipo de dato"@es ;
    rdfs:subClassOf cfkg:Concepto .

cfr:clase a cfkg:Paradigma ;
    rdfs:label "Class"@en,
        "Clase"@es ;
    skos:exactMatch wd:Q4479242 ;
    cfkg:perteneceATema cfr:T_poo ;
    cfkg:requierePrerrequisito cfr:funcion ;
    cfkg:tieneDificultad 3 .

cfr:comprension_listas a cfkg:EstructuraDeControl ;
    rdfs:label "List comprehension"@en,
        "Comprensión de listas"@es ;
    skos:broader cfr:bucle_for ;
    skos:exactMatch wd:Q795065 ;
    skos:narrower cfr:comprension_dicts,
        cfr:comprension_sets,
        cfr:expresion_generadora ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:perteneceATema cfr:T_control ;
    cfkg:requierePrerrequisito cfr:lista ;
    cfkg:tieneDificultad 4 ;
    cfkg:tieneEjemploCodigo "ys = [x*x for x in xs if x > 0]" .

cfr:diccionario a cfkg:EstructuraDeDatos ;
    rdfs:label "Dictionary"@en,
        "Diccionario"@es ;
    skos:exactMatch wd:Q80585 ;
    cfkg:perteneceATema cfr:T_estructuras ;
    cfkg:tieneDificultad 2 .

cfr:import_mod a cfkg:PrincipioTransversal ;
    rdfs:label "import"@en,
        "import"@es ;
    cfkg:aNivelDominio cfr:basico ;
    cfkg:perteneceATema cfr:T_modulos ;
    cfkg:tieneDificultad 2 .

cfr:tipo_str a cfkg:TipoDeDato ;
    rdfs:label "String (str)"@en,
        "Cadena (str)"@es ;
    cfkg:perteneceATema cfr:T_fundamentos ;
    cfkg:tieneDificultad 1 .

cfr:indexacion a cfkg:PrincipioTransversal ;
    rdfs:label "Indexing"@en,
        "Indexación"@es ;
    skos:narrower cfr:indexacion_negativa,
        cfr:slicing ;
    cfkg:perteneceATema cfr:T_estructuras ;
    cfkg:requierePrerrequisito cfr:lista ;
    cfkg:seAplicaA cfr:lista ;
    cfkg:tieneDificultad 2 .

cfr:metodo a cfkg:Paradigma ;
    rdfs:label "Method"@en,
        "Método"@es ;
    skos:narrower cfr:init_method,
        cfr:metodo_clase,
        cfr:metodo_estatico ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:perteneceATema cfr:T_poo ;
    cfkg:requierePrerrequisito cfr:clase,
        cfr:funcion ;
    cfkg:tieneDificultad 3 .

cfr:herencia a cfkg:Paradigma ;
    rdfs:label "Inheritance"@en,
        "Herencia"@es ;
    skos:exactMatch wd:Q212542 ;
    skos:narrower cfr:herencia_multiple ;
    skos:related cfr:composicion ;
    cfkg:perteneceATema cfr:T_poo ;
    cfkg:requierePrerrequisito cfr:clase ;
    cfkg:tieneDificultad 4 .

cfkg:Ejercicio a owl:Class ;
    rdfs:label "Exercise or assignment"@en,
        "Ejercicio o enunciado"@es ;
    rdfs:subClassOf cfkg:EntidadEducativa .

cfr:T_modulos a cfkg:Tema ;
    rdfs:label "Modules and packages"@en,
        "Módulos y paquetes"@es .

cfkg:FuncionIntegrada a owl:Class ;
    rdfs:label "Built-in function"@en,
        "Función integrada"@es ;
    rdfs:subClassOf cfkg:Concepto .

cfkg:EntidadEducativa a owl:Class ;
    rdfs:label "Educational entity"@en,
        "Entidad educativa"@es ;
    rdfs:comment "Superclase abstracta de todas las entidades del grafo educativo."@es .

cfr:T_algoritmos a cfkg:Tema ;
    rdfs:label "Algorithms"@en,
        "Algoritmos"@es .

cfr:recursion a cfkg:PrincipioTransversal ;
    rdfs:label "Recursion"@en,
        "Recursión"@es ;
    rdfs:comment "Definición de una función en términos de sí misma."@es ;
    skos:exactMatch wd:Q264164 ;
    skos:narrower cfr:recursion_cola ;
    skos:prefLabel "Recursión"@es ;
    skos:related cfr:bucle_for ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:contrastaCon cfr:bucle_for ;
    cfkg:perteneceATema cfr:T_recursion ;
    cfkg:requierePrerrequisito cfr:funcion ;
    cfkg:tieneDificultad 4 .

cfr:T_control a cfkg:Tema ;
    rdfs:label "Control flow"@en,
        "Control de flujo"@es .

cfr:T_funcional a cfkg:Tema ;
    rdfs:label "Functional programming"@en,
        "Programación funcional"@es .

cfr:bucle_for a cfkg:EstructuraDeControl ;
    rdfs:label "For loop"@en,
        "Bucle for"@es ;
    skos:narrower cfr:comprension_listas ;
    skos:prefLabel "Bucle for"@es ;
    skos:related cfr:recursion ;
    cfkg:aNivelDominio cfr:basico ;
    cfkg:esPrerrequisitoDe cfr:comprension_listas ;
    cfkg:perteneceATema cfr:T_control ;
    cfkg:tieneDificultad 2 ;
    cfkg:tieneEjemploCodigo """for x in xs:
    print(x)""" .

cfkg:EstructuraDeDatos a owl:Class ;
    rdfs:label "Data structure"@en,
        "Estructura de datos"@es ;
    rdfs:subClassOf cfkg:Concepto .

cfkg:EvaluacionActividad a owl:Class ;
    rdfs:label "Activity assessment"@en,
        "Evaluación de actividad"@es ;
    rdfs:subClassOf cfkg:EntidadEducativa .

cfr:T_tipos a cfkg:Tema ;
    rdfs:label "Type system"@en,
        "Sistema de tipos"@es .

cfkg:ModuloLibreria a owl:Class ;
    rdfs:label "Module or library"@en,
        "Módulo o librería"@es ;
    rdfs:subClassOf cfkg:Concepto .

cfr:funcion a cfkg:PrincipioTransversal ;
    rdfs:label "Function"@en,
        "Función"@es ;
    skos:prefLabel "Función"@es ;
    cfkg:esPrerrequisitoDe cfr:recursion ;
    cfkg:perteneceATema cfr:T_funciones ;
    cfkg:tieneDificultad 2 ;
    cfkg:tieneEjemploCodigo """def f(x):
    return x + 1""" .

cfkg:Tema a owl:Class ;
    rdfs:label "Curricular topic"@en,
        "Tema curricular"@es ;
    rdfs:comment "Agrupación curricular de conceptos (unidad didáctica)."@es ;
    rdfs:subClassOf cfkg:EntidadEducativa .

cfr:T_estructuras a cfkg:Tema ;
    rdfs:label "Data structures"@en,
        "Estructuras de datos"@es .

cfkg:ErrorConceptual a owl:Class ;
    rdfs:label "Misconception"@en,
        "Error conceptual (misconception)"@es ;
    rdfs:comment "Malentendido recurrente documentado en la literatura de didáctica de la programación."@es ;
    rdfs:subClassOf cfkg:EntidadEducativa .

cfr:lista a cfkg:EstructuraDeDatos ;
    rdfs:label "List"@en,
        "Lista"@es ;
    skos:exactMatch wd:Q27948 ;
    skos:narrower cfr:cola,
        cfr:pila ;
    skos:prefLabel "Lista"@es ;
    skos:related cfr:conjunto,
        cfr:tupla ;
    cfkg:aNivelDominio cfr:basico ;
    cfkg:perteneceATema cfr:T_estructuras ;
    cfkg:tieneDificultad 2 ;
    cfkg:tieneEjemploCodigo "xs = [1, 2, 3]" .

cfr:T_poo a cfkg:Tema ;
    rdfs:label "Object-oriented programming"@en,
        "Programación orientada a objetos"@es .

cfkg:EstructuraDeControl a owl:Class ;
    rdfs:label "Control structure"@en,
        "Estructura de control"@es ;
    rdfs:subClassOf cfkg:Concepto .

cfkg:Concepto a owl:Class ;
    rdfs:label "Programming concept"@en,
        "Concepto de programación"@es ;
    rdfs:comment "Unidad de conocimiento del dominio (p. ej. recursión, bucle for, mutabilidad). Al ser subclase de skos:Concept admite la red conceptual skos:broader/narrower/related."@es ;
    rdfs:subClassOf skos:Concept,
        cfkg:EntidadEducativa .

cfkg:Paradigma a owl:Class ;
    rdfs:label "Programming paradigm"@en,
        "Paradigma de programación"@es ;
    rdfs:subClassOf cfkg:Concepto .

cfr:basico a cfkg:NivelDominio ;
    rdfs:label "basic"@en,
        "básico"@es ;
    skos:notation "1" ;
    skos:prefLabel "basic"@en,
        "básico"@es .

cfr:intermedio a cfkg:NivelDominio ;
    rdfs:label "intermediate"@en,
        "intermedio"@es ;
    skos:notation "2" ;
    skos:prefLabel "intermediate"@en,
        "intermedio"@es .

cfkg:PrincipioTransversal a owl:Class ;
    rdfs:label "Cross-cutting principle"@en,
        "Principio transversal"@es ;
    rdfs:subClassOf cfkg:Concepto .

cfr:avanzado a cfkg:NivelDominio ;
    rdfs:label "advanced"@en,
        "avanzado"@es ;
    skos:notation "3" ;
    skos:prefLabel "advanced"@en,
        "avanzado"@es .

[] a owl:AllDisjointClasses ;
    owl:members ( cfkg:Concepto cfkg:Tema cfkg:Competencia cfkg:Ejercicio cfkg:EnvioEstudiante cfkg:ErrorConceptual cfkg:Recurso cfkg:Estudiante cfkg:RutaAprendizaje cfkg:EvaluacionDeConcepto ) .

