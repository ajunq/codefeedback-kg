cfkg: a owl:Ontology ;
    dcterms:created "2026-06-18"^^xsd:date ;
    dcterms:creator "Adrián Bueno Junquero" ;
    dcterms:description "Ontología y grafo de conocimiento del dominio de la programación en Python, diseñado para anclar la generación de retroalimentación formativa automática (arquitectura EKG + RAG + LLM). Modela conceptos, sus prerrequisitos y contrastes, temas, ejercicios, errores conceptuales (misconceptions), recursos y perfiles de estudiante."@es ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:title "Educational Knowledge Graph for Python Programming (CodeFeedback-KG)"@en,
        "Grafo de Conocimiento Educativo de Programación en Python (CodeFeedback-KG)"@es ;
    owl:versionInfo "0.1.0" .

cfkg:aNivelDominio a owl:ObjectProperty ;
    rdfs:label "at mastery level"@en,
        "a nivel de dominio"@es ;
    rdfs:range cfkg:NivelDominio .

cfkg:conPeso a owl:DatatypeProperty ;
    rdfs:label "with weight"@en,
        "con peso"@es ;
    rdfs:domain cfkg:EvaluacionDeConcepto ;
    rdfs:range xsd:decimal .

cfkg:contrastaCon a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "contrasts with"@en,
        "contrasta con"@es ;
    rdfs:comment "Conceptos frecuentemente confundidos que conviene explicar por oposición (p. ej. iteración / recursión). Simétrica."@es ;
    rdfs:domain cfkg:Concepto ;
    rdfs:range cfkg:Concepto ;
    rdfs:subPropertyOf cfkg:relacionadoConceptualmenteCon .

cfkg:cubreConcepto a owl:ObjectProperty ;
    rdfs:label "covers concept"@en,
        "cubre el concepto"@es ;
    rdfs:domain cfkg:Ejercicio ;
    rdfs:range cfkg:Concepto .

cfkg:dominaConcepto a owl:ObjectProperty ;
    rdfs:label "has mastered concept"@en,
        "domina el concepto"@es ;
    rdfs:domain cfkg:Estudiante ;
    rdfs:range cfkg:Concepto .

cfkg:enEjercicio a owl:ObjectProperty ;
    rdfs:label "in exercise"@en,
        "en el ejercicio"@es ;
    rdfs:domain cfkg:EvaluacionDeConcepto ;
    rdfs:range cfkg:Ejercicio .

cfkg:enFecha a owl:DatatypeProperty ;
    rdfs:label "on date"@en,
        "en la fecha"@es ;
    rdfs:domain cfkg:EvaluacionActividad ;
    rdfs:range xsd:date .

cfkg:enviadoPor a owl:ObjectProperty ;
    rdfs:label "submitted by"@en,
        "enviado por"@es ;
    rdfs:domain cfkg:EnvioEstudiante ;
    rdfs:range cfkg:Estudiante .

cfkg:esPrerrequisitoDe a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "is prerequisite of"@en,
        "es prerrequisito de"@es ;
    rdfs:comment "A esPrerrequisitoDe B significa que dominar A es condición previa para aprender B. Transitiva: habilita el cálculo de prerrequisitos indirectos por inferencia."@es ;
    rdfs:domain cfkg:Concepto ;
    rdfs:range cfkg:Concepto ;
    rdfs:subPropertyOf cfkg:relacionadoConceptualmenteCon ;
    owl:inverseOf cfkg:requierePrerrequisito .

cfkg:evaluaA a owl:ObjectProperty ;
    rdfs:label "assesses activity"@en,
        "evalúa la actividad"@es ;
    rdfs:domain cfkg:EvaluacionActividad ;
    rdfs:range cfkg:Ejercicio .

cfkg:evaluaCompetencia a owl:ObjectProperty ;
    rdfs:label "assesses competency"@en,
        "evalúa la competencia"@es ;
    rdfs:domain cfkg:Ejercicio ;
    rdfs:range cfkg:Competencia .

cfkg:generaliza a owl:ObjectProperty ;
    rdfs:label "generalises"@en,
        "generaliza a"@es ;
    rdfs:domain cfkg:Concepto ;
    rdfs:range cfkg:Concepto ;
    rdfs:subPropertyOf cfkg:relacionadoConceptualmenteCon ;
    owl:inverseOf cfkg:especializa .

cfkg:ilustraConcepto a owl:ObjectProperty ;
    rdfs:label "illustrates concept"@en,
        "ilustra el concepto"@es ;
    rdfs:domain cfkg:Recurso ;
    rdfs:range cfkg:Concepto .

cfkg:manifiestaError a owl:ObjectProperty ;
    rdfs:label "exhibits misconception"@en,
        "manifiesta el error"@es ;
    rdfs:domain cfkg:EnvioEstudiante ;
    rdfs:range cfkg:ErrorConceptual .

cfkg:numeroDeLineas a owl:DatatypeProperty ;
    rdfs:label "number of lines"@en,
        "número de líneas"@es ;
    rdfs:domain cfkg:EnvioEstudiante ;
    rdfs:range xsd:integer .

cfkg:obtuvoNota a owl:DatatypeProperty ;
    rdfs:label "obtained grade"@en,
        "obtuvo nota"@es ;
    rdfs:domain cfkg:EvaluacionActividad ;
    rdfs:range xsd:decimal .

cfkg:perteneceATema a owl:ObjectProperty ;
    rdfs:label "belongs to topic"@en,
        "pertenece al tema"@es ;
    rdfs:domain cfkg:Concepto ;
    rdfs:range cfkg:Tema .

cfkg:porEstudiante a owl:ObjectProperty ;
    rdfs:label "carried out by"@en,
        "realizada por"@es ;
    rdfs:domain cfkg:EvaluacionActividad ;
    rdfs:range cfkg:Estudiante .

cfkg:resuelveEjercicio a owl:ObjectProperty ;
    rdfs:label "solves exercise"@en,
        "resuelve el ejercicio"@es ;
    rdfs:domain cfkg:EnvioEstudiante ;
    rdfs:range cfkg:Ejercicio .

cfkg:seAplicaA a owl:ObjectProperty ;
    rdfs:label "applies to"@en,
        "se aplica a"@es ;
    rdfs:domain cfkg:Concepto ;
    rdfs:range cfkg:Concepto ;
    rdfs:subPropertyOf cfkg:relacionadoConceptualmenteCon .

cfkg:sobreConcepto a owl:ObjectProperty ;
    rdfs:label "about concept"@en,
        "sobre el concepto"@es ;
    rdfs:domain cfkg:EvaluacionDeConcepto ;
    rdfs:range cfkg:Concepto .

cfkg:tieneDificultad a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "has difficulty"@en,
        "tiene dificultad"@es ;
    rdfs:comment "Dificultad estimada en una escala entera 1–5."@es ;
    rdfs:domain cfkg:EntidadEducativa ;
    rdfs:range xsd:integer .

cfkg:tieneEjemploCodigo a owl:DatatypeProperty ;
    rdfs:label "has code example"@en,
        "tiene ejemplo de código"@es ;
    rdfs:range xsd:string .

cfkg:tieneEnunciado a owl:DatatypeProperty ;
    rdfs:label "has statement"@en,
        "tiene enunciado"@es ;
    rdfs:domain cfkg:Ejercicio ;
    rdfs:range rdf:langString .

cfr:atributo a cfkg:Paradigma ;
    rdfs:label "Attribute"@en,
        "Atributo de instancia"@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:perteneceATema cfr:T_poo ;
    cfkg:requierePrerrequisito cfr:objeto ;
    cfkg:tieneDificultad 3 .

cfr:busqueda_lineal a cfkg:PrincipioTransversal ;
    rdfs:label "Linear search"@en,
        "Búsqueda lineal"@es ;
    skos:exactMatch wd:Q787903 ;
    skos:related cfr:busqueda_binaria ;
    cfkg:aNivelDominio cfr:basico ;
    cfkg:contrastaCon cfr:busqueda_binaria ;
    cfkg:perteneceATema cfr:T_algoritmos ;
    cfkg:requierePrerrequisito cfr:bucle_for ;
    cfkg:tieneDificultad 2 .

cfr:composicion a cfkg:Paradigma ;
    rdfs:label "Composition"@en,
        "Composición"@es ;
    skos:related cfr:herencia ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:contrastaCon cfr:herencia ;
    cfkg:perteneceATema cfr:T_poo ;
    cfkg:requierePrerrequisito cfr:objeto ;
    cfkg:tieneDificultad 4 .

cfr:comprension_dicts a cfkg:EstructuraDeControl ;
    rdfs:label "Dict comprehension"@en,
        "Comprensión de diccionarios"@es ;
    skos:broader cfr:comprension_listas ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:perteneceATema cfr:T_estructuras ;
    cfkg:requierePrerrequisito cfr:comprension_listas,
        cfr:diccionario ;
    cfkg:tieneDificultad 4 .

cfr:comprension_sets a cfkg:EstructuraDeControl ;
    rdfs:label "Set comprehension"@en,
        "Comprensión de conjuntos"@es ;
    skos:broader cfr:comprension_listas ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:perteneceATema cfr:T_estructuras ;
    cfkg:requierePrerrequisito cfr:comprension_listas,
        cfr:conjunto ;
    cfkg:tieneDificultad 4 .

cfr:conversion_tipos a cfkg:PrincipioTransversal ;
    rdfs:label "Type casting"@en,
        "Conversión de tipos"@es ;
    cfkg:aNivelDominio cfr:basico ;
    cfkg:perteneceATema cfr:T_tipos ;
    cfkg:requierePrerrequisito cfr:tipo_int,
        cfr:tipo_str ;
    cfkg:tieneDificultad 2 .

cfr:desempaquetado a cfkg:PrincipioTransversal ;
    rdfs:label "Unpacking"@en,
        "Desempaquetado"@es ;
    cfkg:aNivelDominio cfr:basico ;
    cfkg:perteneceATema cfr:T_estructuras ;
