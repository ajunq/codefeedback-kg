@prefix cc: <http://creativecommons.org/ns#> .
@prefix cfkg: <https://w3id.org/codefeedback-kg/schema#> .
@prefix cfr: <https://w3id.org/codefeedback-kg/id/> .
@prefix dbr: <http://dbpedia.org/resource/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix wd: <http://www.wikidata.org/entity/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

skos:broader rdfs:subPropertyOf skos:broaderTransitive .

cfr:abstract_class a cfkg:Paradigma ;
    rdfs:label "Abstract base class"@en,
        "Clase abstracta (ABC)"@es ;
    skos:definition "Clase base abstracta (ABC) que define una interfaz comun y no puede instanciarse directamente."@es ;
    skos:example """from abc import ABC, abstractmethod
class Figura(ABC):
    @abstractmethod
    def area(self): ...""" ;
    skos:scopeNote "Se declara heredando de abc.ABC y marcando metodos con @abstractmethod; obliga a las subclases a implementarlos."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:perteneceATema cfr:T_poo ;
    cfkg:requierePrerrequisito cfr:herencia ;
    cfkg:tieneDificultad 5 .

cfr:argparse_mod a cfkg:ModuloLibreria ;
    rdfs:label "argparse"@en,
        "Modulo argparse"@es ;
    skos:definition "Modulo estandar para definir y analizar argumentos de la linea de comandos."@es ;
    skos:example """import argparse
p = argparse.ArgumentParser()
p.add_argument('nombre')
p.parse_args()""" ;
    skos:related cfr:modulo_sys ;
    skos:scopeNote "Genera ayuda automatica y valida tipos; mas robusto que leer sys.argv manualmente."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:perteneceATema cfr:T_modulos ;
    cfkg:requierePrerrequisito cfr:modulo_sys ;
    cfkg:tieneDificultad 3 .

cfr:args_kwargs a cfkg:PrincipioTransversal ;
    rdfs:label "args and kwargs"@en,
        "*args y **kwargs"@es ;
    skos:definition "Sintaxis *args y **kwargs para aceptar un numero variable de argumentos posicionales y por nombre."@es ;
    skos:example """def f(*args, **kwargs):
    print(args, kwargs)
f(1, 2, a=3)""" ;
    skos:scopeNote "*args agrupa posicionales en una tupla y **kwargs los nombrados en un diccionario."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:perteneceATema cfr:T_funciones ;
    cfkg:requierePrerrequisito cfr:operador_estrella,
        cfr:parametros ;
    cfkg:tieneDificultad 3 .

cfr:argumentos_nombrados a cfkg:PrincipioTransversal ;
    rdfs:label "Keyword arguments"@en,
        "Argumentos por nombre"@es ;
    skos:definition "Argumentos que se pasan a una funcion indicando el nombre del parametro (clave=valor)."@es ;
    skos:example """def conecta(host, puerto=80):
    ...
conecta('localhost', puerto=8080)""" ;
    skos:scopeNote "Mejoran la legibilidad y permiten omitir el orden; deben ir despues de los posicionales."@es ;
    cfkg:aNivelDominio cfr:basico ;
    cfkg:perteneceATema cfr:T_funciones ;
    cfkg:requierePrerrequisito cfr:parametros ;
    cfkg:tieneDificultad 2 .

cfr:assert_stmt a cfkg:EstructuraDeControl ;
    rdfs:label "assert"@en,
        "assert"@es ;
    skos:definition "Sentencia assert que verifica una condicion y lanza AssertionError si es falsa."@es ;
    skos:example """def media(xs):
    assert len(xs) > 0, 'lista vacia'
    return sum(xs) / len(xs)""" ;
    skos:scopeNote "Util para comprobaciones internas y pruebas; se desactiva al ejecutar Python con la opcion -O."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:perteneceATema cfr:T_testing ;
    cfkg:requierePrerrequisito cfr:condicional ;
    cfkg:tieneDificultad 3 .

cfr:async_generator a cfkg:EstructuraDeControl ;
    rdfs:label "Async generator"@en,
        "Generador asincrono"@es ;
    skos:definition "Funcion async def que produce valores con yield y se recorre con async for."@es ;
    skos:example """async def numeros():
    for i in range(3):
        await asyncio.sleep(0)
        yield i""" ;
    skos:scopeNote "Combina produccion perezosa y espera asincrona; util para flujos de datos de red por lotes."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:introducidoEnVersion "3.6"^^xsd:string ;
    cfkg:perteneceATema cfr:T_concurrencia ;
    cfkg:requierePrerrequisito cfr:async_await,
        cfr:generador ;
    cfkg:tieneDificultad 5 .

cfr:atributo_clase a cfkg:Paradigma ;
    rdfs:label "Class attribute"@en,
        "Atributo de clase"@es ;
    skos:definition "Atributo definido en la clase y compartido por todas sus instancias."@es ;
    skos:example """class Contador:
    total = 0  # atributo de clase compartido""" ;
    skos:related cfr:atributo ;
    skos:scopeNote "Cuidado al usar valores mutables: se comparten entre instancias; las asignaciones via self crean copias locales."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:perteneceATema cfr:T_poo ;
    cfkg:requierePrerrequisito cfr:atributo ;
    cfkg:tieneDificultad 3 .

cfr:backtracking a cfkg:PrincipioTransversal ;
    rdfs:label "Backtracking"@en,
        "Backtracking"@es ;
    skos:closeMatch dbr:Backtracking ;
    skos:definition "Tecnica algoritmica que construye soluciones de forma incremental y retrocede al detectar un callejon sin salida."@es ;
    skos:example """def resolver(estado):
    if completo(estado):
        return estado
    for mov in movimientos(estado):
        if valido(mov):
            r = resolver(aplicar(estado, mov))
            if r:
                return r
    return None""" ;
    skos:scopeNote "Tipica en problemas de combinatoria (N reinas, sudoku); se implementa con recursion y poda."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:perteneceATema cfr:T_algoritmos ;
    cfkg:requierePrerrequisito cfr:recursion ;
    cfkg:tieneDificultad 5 .

cfr:break_continue a cfkg:EstructuraDeControl ;
    rdfs:label "break and continue"@en,
        "break y continue"@es ;
    skos:definition "Sentencias break (sale del bucle) y continue (salta a la siguiente iteracion)."@es ;
    skos:example """for n in range(10):
    if n == 5:
        break
    if n % 2 == 0:
        continue
    print(n)""" ;
    skos:scopeNote "Afectan solo al bucle mas interno; un uso excesivo puede dificultar la lectura del codigo."@es ;
    cfkg:aNivelDominio cfr:basico ;
    cfkg:perteneceATema cfr:T_control ;
    cfkg:requierePrerrequisito cfr:bucle_for ;
    cfkg:tieneDificultad 2 .

cfr:bytearray_tipo a cfkg:TipoDeDato ;
    rdfs:label "bytearray"@en,
        "bytearray"@es ;
    skos:definition "Secuencia mutable de bytes que permite modificar su contenido en sitio."@es ;
    skos:example """ba = bytearray(b'abc')
ba[0] = 65  # b'Abc'""" ;
    skos:related cfr:tipo_bytes ;
    skos:scopeNote "Util para construir o transformar datos binarios sin crear copias; complementa al inmutable bytes."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:perteneceATema cfr:T_tipos ;
    cfkg:requierePrerrequisito cfr:tipo_bytes ;
    cfkg:tieneDificultad 3 .

cfr:cached_property_mod a cfkg:ModuloLibreria ;
    rdfs:label "functools.cached_property"@en,
        "functools.cached_property"@es ;
    skos:definition "Decorador que convierte un metodo en una propiedad cuyo valor se calcula una vez y se cachea."@es ;
    skos:example """from functools import cached_property
class D:
    @cached_property
    def media(self):
        return sum(self.xs) / len(self.xs)""" ;
    skos:related cfr:propiedad ;
    skos:scopeNote "Ideal para calculos costosos que no cambian; el resultado se guarda en el __dict__ de la instancia."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:introducidoEnVersion "3.8"^^xsd:string ;
    cfkg:perteneceATema cfr:T_poo ;
    cfkg:requierePrerrequisito cfr:propiedad ;
    cfkg:tieneDificultad 4 .

cfr:callable_func a cfkg:FuncionIntegrada ;
    rdfs:label "callable"@en,
        "Funcion callable"@es ;
    skos:definition "Funcion que indica si un objeto puede invocarse como una funcion."@es ;
    skos:example """callable(len)   # True
callable(42)    # False""" ;
    skos:related cfr:funcion_orden_superior ;
    skos:scopeNote "Son invocables las funciones, clases y objetos con __call__; util al recibir callbacks."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:perteneceATema cfr:T_funcional ;
    cfkg:requierePrerrequisito cfr:funcion ;
    cfkg:tieneDificultad 3 .

cfr:chainmap a cfkg:EstructuraDeDatos ;
    rdfs:label "ChainMap"@en,
        "collections.ChainMap"@es ;
    skos:definition "Vista que agrupa varios diccionarios y los consulta como si fueran uno solo."@es ;
    skos:example """from collections import ChainMap
cfg = ChainMap({'a': 1}, {'a': 0, 'b': 2})
cfg['a']  # 1""" ;
    skos:related cfr:diccionario ;
    skos:scopeNote "Util para gestionar capas de configuracion (por defecto, usuario, entorno) sin copiarlas."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:perteneceATema cfr:T_estructuras ;
    cfkg:requierePrerrequisito cfr:diccionario ;
    cfkg:tieneDificultad 3 .

cfr:cola_prioridad a cfkg:EstructuraDeDatos ;
    rdfs:label "Priority queue"@en,
        "Cola de prioridad"@es ;
    skos:closeMatch dbr:Priority_queue ;
    skos:definition "Cola en la que cada elemento tiene una prioridad y se extrae siempre el de mayor prioridad."@es ;
    skos:exactMatch wd:Q629283 ;
    skos:example """import heapq
pq = []
heapq.heappush(pq, (2, 'tarea B'))
heapq.heappush(pq, (1, 'tarea A'))
heapq.heappop(pq)  # (1, 'tarea A')""" ;
    skos:related cfr:cola,
        cfr:heap ;
    skos:scopeNote "Se implementa eficientemente con un monticulo (heapq); base de algoritmos como Dijkstra."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:perteneceATema cfr:T_estructuras ;
    cfkg:requierePrerrequisito cfr:heap ;
    cfkg:tieneComplejidadTemporal "O(log n)"^^xsd:string ;
    cfkg:tieneDificultad 4 .

cfr:collections_mod a cfkg:ModuloLibreria ;
    rdfs:label "collections"@en,
        "collections"@es ;
    skos:definition "Modulo collections con tipos de contenedor especializados (deque, Counter, defaultdict, namedtuple)."@es ;
    skos:example """from collections import Counter
Counter('aabbbc')  # Counter({'b': 3, 'a': 2, 'c': 1})""" ;
    skos:scopeNote "Ofrece alternativas mas eficientes o expresivas que las estructuras integradas para casos concretos."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:perteneceATema cfr:T_modulos ;
    cfkg:requierePrerrequisito cfr:import_mod ;
    cfkg:tieneDificultad 3 ;
    cfkg:tieneURLDocumentacion "https://docs.python.org/3/library/collections.html"^^xsd:anyURI .

cfr:concatenacion_str a cfkg:PrincipioTransversal ;
    rdfs:label "String concatenation"@en,
        "Concatenacion de cadenas"@es ;
    skos:definition "Union de varias cadenas en una sola mediante el operador + o por yuxtaposicion."@es ;
    skos:example """'Hola' + ' ' + 'mundo'
''.join(['a', 'b', 'c'])""" ;
    skos:scopeNote "Para unir muchas cadenas en un bucle, str.join es mas eficiente que la concatenacion repetida."@es ;
    cfkg:aNivelDominio cfr:basico ;
    cfkg:perteneceATema cfr:T_strings ;
    cfkg:requierePrerrequisito cfr:tipo_str ;
    cfkg:tieneDificultad 1 .

cfr:concurrent_futures a cfkg:ConceptoDeConcurrencia ;
    rdfs:label "concurrent.futures"@en,
        "concurrent.futures"@es ;
    skos:definition "Interfaz de alto nivel para ejecutar tareas en grupos de hilos o procesos mediante Executors."@es ;
    skos:example """from concurrent.futures import ThreadPoolExecutor
with ThreadPoolExecutor() as ex:
    list(ex.map(str, range(3)))""" ;
    skos:related cfr:hilos,
        cfr:multiproceso ;
    skos:scopeNote "ThreadPoolExecutor para E/S y ProcessPoolExecutor para CPU; map() y submit() devuelven futuros."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:perteneceATema cfr:T_concurrencia ;
    cfkg:requierePrerrequisito cfr:hilos ;
    cfkg:tieneDificultad 4 .

cfr:condicion_carrera a cfkg:ConceptoDeConcurrencia ;
    rdfs:label "Race condition"@en,
        "Condicion de carrera"@es ;
    skos:closeMatch dbr:Race_condition ;
    skos:definition "Defecto en el que el resultado depende del orden imprevisible en que se intercalan los hilos."@es ;
    skos:exactMatch wd:Q616554 ;
    skos:example """# saldo += 1 no es atomico: dos hilos pueden
# leer el mismo valor y perder una actualizacion""" ;
    skos:related cfr:lock_threading ;
    skos:scopeNote "Se evita sincronizando el acceso al estado compartido con cerrojos u otras primitivas."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:perteneceATema cfr:T_concurrencia ;
    cfkg:requierePrerrequisito cfr:hilos ;
    cfkg:tieneDificultad 5 .

cfr:conteo_referencias a cfkg:PrincipioTransversal ;
    rdfs:label "Reference counting"@en,
        "Conteo de referencias"@es ;
    skos:closeMatch dbr:Reference_counting ;
    skos:definition "Tecnica que libera un objeto cuando el numero de referencias que lo apuntan llega a cero."@es ;
    skos:example """import sys
x = []
sys.getrefcount(x)  # numero de referencias""" ;
    skos:related cfr:recoleccion_basura ;
    skos:scopeNote "Es inmediata pero no detecta ciclos; por eso CPython la combina con un recolector de ciclos."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:perteneceATema cfr:T_fundamentos ;
    cfkg:requierePrerrequisito cfr:recoleccion_basura ;
    cfkg:tieneDificultad 4 .

cfr:contextlib_mod a cfkg:ModuloLibreria ;
    rdfs:label "contextlib"@en,
        "Modulo contextlib"@es ;
    skos:definition "Modulo con utilidades para crear gestores de contexto, como el decorador @contextmanager."@es ;
    skos:example """from contextlib import contextmanager
@contextmanager
def abierto(p):
    f = open(p)
    try:
        yield f
    finally:
        f.close()""" ;
    skos:related cfr:context_manager ;
    skos:scopeNote "@contextmanager convierte un generador con un unico yield en un gestor de contexto."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:perteneceATema cfr:T_control ;
    cfkg:requierePrerrequisito cfr:context_manager ;
    cfkg:tieneDificultad 4 .

cfr:copia_profunda a cfkg:PrincipioTransversal ;
    rdfs:label "Deep copy"@en,
        "Copia profunda"@es ;
    skos:definition "Copia que duplica recursivamente un objeto y todos los objetos anidados que contiene."@es ;
    skos:example """import copy
b = copy.deepcopy(a)""" ;
    skos:scopeNote "Usa copy.deepcopy cuando modificar la copia no debe afectar al original anidado; es mas costosa que la superficial."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:contrastaCon cfr:copia_superficial ;
    cfkg:perteneceATema cfr:T_tipos ;
    cfkg:requierePrerrequisito cfr:copia_superficial ;
    cfkg:tieneDificultad 4 .

cfr:csv_mod a cfkg:ModuloLibreria ;
    rdfs:label "csv module"@en,
        "Módulo csv"@es ;
    skos:closeMatch dbr:Comma-separated_values ;
    skos:definition "Modulo estandar csv para leer y escribir ficheros de valores separados por comas."@es ;
    skos:example """import csv
with open('d.csv', newline='') as f:
    for fila in csv.reader(f):
        print(fila)""" ;
    skos:scopeNote "Maneja correctamente comillas y delimitadores; usa newline='' al abrir el fichero."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:perteneceATema cfr:T_ficheros ;
    cfkg:requierePrerrequisito cfr:lista ;
    cfkg:tieneDificultad 3 ;
    cfkg:tieneURLDocumentacion "https://docs.python.org/3/library/csv.html"^^xsd:anyURI .

cfr:descriptor a cfkg:Paradigma ;
    rdfs:label "Descriptor"@en,
        "Descriptor"@es ;
    skos:definition "Objeto que define __get__, __set__ o __delete__ para controlar el acceso a un atributo."@es ;
    skos:example """class SoloLectura:
    def __get__(self, obj, tipo=None):
        return 42""" ;
    skos:scopeNote "Es el mecanismo subyacente de property, los metodos y classmethod; protocolo avanzado de POO."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:perteneceATema cfr:T_poo ;
    cfkg:requierePrerrequisito cfr:propiedad ;
    cfkg:tieneDificultad 5 .

cfr:docstring a cfkg:PrincipioTransversal ;
    rdfs:label "Docstring"@en,
        "Docstring"@es ;
    skos:definition "Cadena de documentacion situada al inicio de un modulo, clase o funcion."@es ;
    skos:example """def suma(a, b):
    \"\"\"Devuelve la suma de a y b.\"\"\"
    return a + b""" ;
    skos:scopeNote "Accesible mediante help() y __doc__; conviene seguir convenciones como PEP 257."@es ;
    cfkg:aNivelDominio cfr:basico ;
    cfkg:perteneceATema cfr:T_testing ;
    cfkg:requierePrerrequisito cfr:funcion ;
    cfkg:tieneDificultad 2 .

cfr:duck_typing a cfkg:Paradigma ;
    rdfs:label "Duck typing"@en,
        "Duck typing"@es ;
    skos:closeMatch dbr:Duck_typing ;
    skos:definition "Estilo en el que la idoneidad de un objeto depende de los metodos que ofrece, no de su tipo."@es ;
    skos:exactMatch wd:Q374282 ;
    skos:example """def total(coleccion):
    return sum(coleccion)  # vale cualquier iterable de numeros""" ;
    skos:related cfr:polimorfismo ;
    skos:scopeNote "'Si camina como un pato y grazna como un pato, es un pato'; favorece el polimorfismo flexible."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:perteneceATema cfr:T_poo ;
    cfkg:requierePrerrequisito cfr:polimorfismo ;
    cfkg:tieneDificultad 3 .

cfr:else_bucle a cfkg:EstructuraDeControl ;
    rdfs:label "loop else"@en,
        "else en bucles"@es ;
    skos:definition "Clausula else de un bucle que se ejecuta solo si el bucle termina sin break."@es ;
    skos:example """for x in xs:
    if x == objetivo:
        break
else:
    print('no encontrado')""" ;
    skos:scopeNote "Util para detectar si una busqueda no encontro el elemento; suele confundir a los principiantes."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:perteneceATema cfr:T_control ;
    cfkg:requierePrerrequisito cfr:bucle_for ;
    cfkg:tieneDificultad 3 .

cfr:encoding a cfkg:PrincipioTransversal ;
    rdfs:label "Text encoding"@en,
        "Codificación de texto"@es ;
    skos:definition "Esquema que asocia caracteres a secuencias de bytes (UTF-8, Latin-1) al codificar texto."@es ;
    skos:example """datos = 'cana'.encode('utf-8')
texto = datos.decode('utf-8')""" ;
    skos:scopeNote "Especifica siempre encoding al abrir ficheros de texto; errores de codificacion causan UnicodeDecodeError."@es ;
    cfkg:aNivelDominio cfr:avanzado ;
    cfkg:perteneceATema cfr:T_strings ;
    cfkg:requierePrerrequisito cfr:tipo_bytes,
        cfr:tipo_str ;
    cfkg:tieneDificultad 4 .

cfr:entorno_virtual a cfkg:PrincipioTransversal ;
    rdfs:label "Virtual environments"@en,
        "Entornos virtuales (venv)"@es ;
    skos:definition "Entorno aislado (venv) con su propio interprete y dependencias para un proyecto."@es ;
    skos:example """python -m venv .venv
source .venv/bin/activate""" ;
    skos:scopeNote "Evita conflictos de versiones entre proyectos; se activa antes de instalar paquetes con pip."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:perteneceATema cfr:T_modulos ;
    cfkg:requierePrerrequisito cfr:paquete ;
    cfkg:tieneDificultad 3 .

cfr:enumerate_f a cfkg:FuncionIntegrada ;
    rdfs:label "enumerate"@en,
        "enumerate()"@es ;
    skos:definition "Funcion enumerate() que produce pares (indice, elemento) al iterar un iterable."@es ;
    skos:example """for i, v in enumerate(['a', 'b'], start=1):
    print(i, v)""" ;
    skos:scopeNote "Evita gestionar manualmente un contador; admite un indice inicial con start."@es ;
    cfkg:aNivelDominio cfr:basico ;
    cfkg:perteneceATema cfr:T_control ;
    cfkg:requierePrerrequisito cfr:bucle_for,
        cfr:indexacion ;
    cfkg:tieneDificultad 2 .

cfr:envio_001 a cfkg:EnvioEstudiante ;
    rdfs:label "Submission 001"@en,
        "Envío 001"@es ;
    dcterms:created "2026-05-12"^^xsd:date ;
    cfkg:enviadoPor cfr:est_alicia ;
    cfkg:manifiestaError cfr:err_off_by_one ;
    cfkg:numeroDeLineas 18 ;
    cfkg:resuelveEjercicio cfr:ej_busqueda .

cfr:envio_002 a cfkg:EnvioEstudiante ;
    rdfs:label "Submission 002"@en,
        "Envío 002"@es ;
    dcterms:created "2026-05-14"^^xsd:date ;
    cfkg:enviadoPor cfr:est_borja ;
    cfkg:manifiestaError cfr:err_iteracion_recursion ;
    cfkg:numeroDeLineas 11 ;
    cfkg:resuelveEjercicio cfr:ej_factorial .

cfr:err_concatenar_tipos a cfkg:ErrorConceptual ;
    rdfs:label "Concatenating str and int"@en,
        "Concatenar cadena y número (TypeError)"@es ;
    cfkg:errorSobreConcepto cfr:conversion_tipos .

cfr:err_decorador_wraps a cfkg:ErrorConceptual ;
    rdfs:label "Decorator without wraps"@en,
        "Decorador sin functools.wraps"@es ;
    cfkg:errorSobreConcepto cfr:decorador .

cfr:err_except_generico a cfkg:ErrorConceptual ;
    rdfs:label "Overly broad except"@en,
        "Capturar Exception de forma demasiado amplia"@es ;
    cfkg:errorSobreConcepto cfr:jerarquia_excepciones .

cfr:err_float_igualdad a cfkg:ErrorConceptual ;
    rdfs:label "Float equality comparison"@en,
        "Comparar flotantes con =="@es ;
    cfkg:errorSobreConcepto cfr:tipo_float .

cfr:err_generador_agotado a cfkg:ErrorConceptual ;
    rdfs:label "Exhausted generator reuse"@en,
        "Reutilizar un generador agotado"@es ;
    cfkg:errorSobreConcepto cfr:generador .

cfr:err_gil_paralelismo a cfkg:ErrorConceptual ;
    rdfs:label "Expecting threads to parallelize"@en,
        "Esperar paralelismo real con hilos (GIL)"@es ;
    cfkg:errorSobreConcepto cfr:gil .

cfr:err_global_local a cfkg:ErrorConceptual ;
    rdfs:label "Global vs local confusion"@en,
        "Confundir variable global y local"@es ;
    cfkg:errorSobreConcepto cfr:ambito .

cfr:err_identidad_igualdad a cfkg:ErrorConceptual ;
    rdfs:label "Equality vs identity confusion"@en,
        "Confusión == frente a is"@es ;
    cfkg:errorSobreConcepto cfr:tipo_bool .

cfr:err_late_binding a cfkg:ErrorConceptual ;
    rdfs:label "Loop closure late binding"@en,
        "Late binding en clausuras de bucle"@es ;
    cfkg:errorSobreConcepto cfr:closure .

cfr:err_mod_durante_iteracion a cfkg:ErrorConceptual ;
    rdfs:label "Mutating list while iterating"@en,
        "Modificar una lista mientras se itera"@es ;
    cfkg:errorSobreConcepto cfr:bucle_for .

cfr:err_paso_referencia a cfkg:ErrorConceptual ;
    rdfs:label "Value vs reference confusion"@en,
        "Confusión paso por valor / por referencia"@es ;
    cfkg:errorSobreConcepto cfr:mutabilidad .

cfr:err_self_olvidado a cfkg:ErrorConceptual ;
    rdfs:label "Missing self parameter"@en,
        "Olvidar self en un método"@es ;
    cfkg:errorSobreConcepto cfr:metodo .

cfr:err_shallow_copy a cfkg:ErrorConceptual ;
    rdfs:label "Shallow when deep needed"@en,
        "Copia superficial cuando se necesita profunda"@es ;
    cfkg:errorSobreConcepto cfr:copia_superficial .

cfr:err_super_olvidado a cfkg:ErrorConceptual ;
    rdfs:label "Missing super() call"@en,
        "No llamar a super() en la subclase"@es ;
    cfkg:errorSobreConcepto cfr:herencia .

cfr:escribir_fichero a cfkg:FuncionIntegrada ;
    rdfs:label "File writing"@en,
        "Escritura de ficheros"@es ;
    skos:definition "Escritura de datos en un fichero mediante metodos como write() o writelines()."@es ;
    skos:example """with open('s.txt', 'w', encoding='utf-8') as f:
    f.write('hola')""" ;
    skos:scopeNote "Abre en modo 'w' (sobrescribe) o 'a' (anade); usa with para cerrar y volcar el buffer."@es ;
    cfkg:aNivelDominio cfr:intermedio ;
    cfkg:perteneceATema cfr:T_ficheros ;
    cfkg:requierePrerrequisito cfr:abrir_fichero ;
    cfkg:tieneDificultad 3 .

