    given-names: "Adrián"
    orcid: "https://orcid.org/0000-0002-5897-185X"
    affiliation: "Universitat Oberta de Catalunya (UOC)"
version: "2.0.0"
date-released: "2026-06-22"
license: Apache-2.0
url: "https://github.com/ajunq/codefeedback-kg"
repository-code: "https://github.com/ajunq/codefeedback-kg"
keywords:
  - knowledge graph
  - GraphRAG
  - large language models
  - criterion validity
  - inter-annotator agreement
  - programming education
